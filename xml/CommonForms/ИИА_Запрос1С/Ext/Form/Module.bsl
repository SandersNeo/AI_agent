&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Статус = "Готово";
	ТекстЗапроса = "";
	ПараметрыЗапросаJSON = "";
	ЗаполнитьТабличныйРеквизитПараметров(СоздатьТаблицуПараметровЗапроса());
	РезультатЗапроса = "";
	ЕстьРезультатЗапроса = Ложь;

	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		СсылкаДиалога = ИИА_ВызовСервера.НайтиПоследнийДиалогПользователяПоТипу(ИИА_Сервер.ИмяТекущегоПользователя(), Перечисления.ИИА_ТипДиалога.Запрос1С);
		Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
			СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог(ИИА_Сервер.ИмяТекущегоПользователя(), Перечисления.ИИА_ТипДиалога.Запрос1С);
		КонецЕсли;
	КонецЕсли;

	НастроитьВыборТиповПараметра();
	ЗагрузитьСостояниеЗапроса1С();

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	Если ЕстьРезультатЗапроса Тогда
		ОткрытьТабличныйДокументРезультата(Ложь);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСостояниеЗапроса1С()

	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Статус = "Диалог не передан.";
		Возврат;
	КонецЕсли;

	СостояниеЗапроса = ИИА_ВызовСервера.ПолучитьСостояниеЗапроса1С(СсылкаДиалога);
	Если СостояниеЗапроса = Неопределено Тогда
		Статус = "Данные запроса пока не сформированы.";
		Возврат;
	КонецЕсли;

	ТекстЗапроса = Строка(СостояниеЗапроса.ТекстЗапроса);
	ПараметрыЗапросаJSON = Строка(СостояниеЗапроса.ПараметрыJSON);
	ЗаполнитьТабличныйРеквизитПараметров(ЗаполнитьТаблицуПараметровЗапроса(СостояниеЗапроса.Параметры, ПараметрыЗапросаJSON));
	РезультатЗапроса = Строка(СостояниеЗапроса.РезультатТекст);
	ЕстьРезультатЗапроса = СостояниеЗапроса.КоличествоСтрок > 0;

	Если ПустаяСтрока(ТекстЗапроса) Тогда
		Статус = "Агент еще не подготовил запрос.";
	ИначеЕсли ПустаяСтрока(РезультатЗапроса) Тогда
		Статус = "Запрос загружен. Можно выполнить.";
	Иначе
		Статус = "Загружен последний результат. Строк: " + Формат(СостояниеЗапроса.КоличествоСтрок, "ЧН=0");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьКоманду(Команда)

	Если ПустаяСтрока(СокрЛП(ТекстЗапроса)) Тогда
		Сообщить("Текст запроса не заполнен.");
		Возврат;
	КонецЕсли;

	Статус = "Выполняю запрос...";

	Попытка
		ВыполнитьЗапросНаСервере();
		ОткрытьТабличныйДокументРезультата(Истина);
	Исключение
		Статус = "Ошибка выполнения";
		Сообщить(ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ТекстЗапросаПриИзменении(Элемент)
	СохранитьЧерновикНаСервере();
	РезультатЗапроса = "";
	ЕстьРезультатЗапроса = Ложь;
	Статус = "Текст запроса изменен. Агент будет использовать эту версию.";
КонецПроцедуры

&НаКлиенте
Процедура ПараметрЗапросаПриИзменении(Элемент)
	СохранитьЧерновикНаСервере();
	РезультатЗапроса = "";
	ЕстьРезультатЗапроса = Ложь;
	Статус = "Параметры изменены. Агент будет использовать эту версию.";
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьТекстЗапросаДляТеста(НовыйТекст) Экспорт
	ТекстЗапроса = НовыйТекст;
	ТекстЗапросаПриИзменении(Неопределено);
КонецПроцедуры

&НаСервере
Процедура СохранитьЧерновикНаСервере()

	ПараметрыЗапросаJSON = СформироватьJSONПараметровЗапроса();
	ИИА_ВызовСервера.СохранитьЧерновикЗапроса1С(СсылкаДиалога, ТекстЗапроса, ПараметрыЗапросаJSON);

КонецПроцедуры

&НаСервере
Процедура ПроверитьАктуальныйКонтекстДляТеста(ОжидаемыйТекст = "") Экспорт

	Контекст = ИИА_Сервер.ПолучитьКонтекстАктуальногоЗапроса1СДляАгента(СсылкаДиалога);
	Если СтрНайти(Контекст, ОжидаемыйТекст) = 0 Тогда
		ВызватьИсключение "Актуальная версия запроса не попала в контекст агента: " + Контекст;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ВыполнитьЗапросНаСервере()

	ПараметрыЗапросаJSON = СформироватьJSONПараметровЗапроса();
	СостояниеЗапроса = ИИА_ВызовСервера.ВыполнитьЗапрос1СИзФормы(СсылкаДиалога, ТекстЗапроса, ПараметрыЗапросаJSON);

	ТекстЗапроса = Строка(СостояниеЗапроса.ТекстЗапроса);
	ПараметрыЗапросаJSON = Строка(СостояниеЗапроса.ПараметрыJSON);
	ЗаполнитьТабличныйРеквизитПараметров(ЗаполнитьТаблицуПараметровЗапроса(СостояниеЗапроса.Параметры, ПараметрыЗапросаJSON));
	РезультатЗапроса = Строка(СостояниеЗапроса.РезультатТекст);
	ЕстьРезультатЗапроса = СостояниеЗапроса.КоличествоСтрок > 0;
	Статус = "Запрос выполнен. Строк: " + Формат(СостояниеЗапроса.КоличествоСтрок, "ЧН=0");

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьТабличныйДокументРезультата(ПоказыватьСообщение = Истина)

	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Если ПоказыватьСообщение Тогда
			Сообщить("Диалог запроса не задан.");
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Попытка
		ДанныеДляТаблицы = ИИА_ВызовСервера.ПолучитьПоследниеДанныеЗапроса(СсылкаДиалога);
		Если ДанныеДляТаблицы = Неопределено
			ИЛИ ТипЗнч(ДанныеДляТаблицы) <> Тип("Массив")
			ИЛИ ДанныеДляТаблицы.Количество() = 0 Тогда
			Если ПоказыватьСообщение Тогда
				Сообщить("Табличный результат пуст или еще не сформирован.");
			КонецЕсли;
			Возврат;
		КонецЕсли;

		ТабличныйДокумент = ИИА_ВызовСервера.СоздатьТабличныйДокументИзДанных(ДанныеДляТаблицы);
		Если ТабличныйДокумент = Неопределено Тогда
			Если ПоказыватьСообщение Тогда
				Сообщить("Не удалось сформировать табличный документ результата.");
			КонецЕсли;
			Возврат;
		КонецЕсли;

		ТабличныйДокумент.Показать("Результат запроса 1С");
		ИИА_ВызовСервера.УстановитьФлагТаблицыВХранилище(СсылкаДиалога, Истина);
	Исключение
		Если ПоказыватьСообщение Тогда
			Сообщить("Не удалось открыть табличный документ результата: " + ОписаниеОшибки());
		КонецЕсли;
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьТабличныйДокументРезультатаКоманда(Команда)
	ОткрытьТабличныйДокументРезультата(Истина);
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФорму(Команда)
	Закрыть();
КонецПроцедуры

&НаСервере
Функция СоздатьТаблицуПараметровЗапроса()

	ТаблицаПараметров = Новый ТаблицаЗначений;
	ТаблицаПараметров.Колонки.Добавить("ИмяПараметра", Новый ОписаниеТипов("Строка"));
	ТаблицаПараметров.Колонки.Добавить("ТипПараметра", Новый ОписаниеТипов("Строка"));
	ТаблицаПараметров.Колонки.Добавить("ЗначениеПараметра", Новый ОписаниеТипов("Строка"));

	Возврат ТаблицаПараметров;

КонецФункции

&НаСервере
Процедура НастроитьВыборТиповПараметра()

	СписокТипов = Новый СписокЗначений;
	СписокТипов.Добавить("Строка", "Строка");
	СписокТипов.Добавить("Число", "Число");
	СписокТипов.Добавить("Булево", "Булево");
	СписокТипов.Добавить("Дата", "Дата");
	СписокТипов.Добавить("JSON", "JSON");

	СписокВыбора = Элементы.ПараметрыЗапросаТаблицаТипПараметра.СписокВыбора;
	СписокВыбора.Очистить();
	Для Каждого ТипПараметра Из СписокТипов Цикл
		СписокВыбора.Добавить(ТипПараметра.Значение, ТипПараметра.Представление);
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ЗаполнитьТаблицуПараметровЗапроса(ПараметрыЗапроса, ПараметрыJSON)

	ТаблицаПараметров = СоздатьТаблицуПараметровЗапроса();
	ИсточникПараметров = ПараметрыЗапроса;

	Если ИсточникПараметров = Неопределено И НЕ ПустаяСтрока(СокрЛП(ПараметрыJSON)) Тогда
		Попытка
			ИсточникПараметров = ИИА_Сервер.ПрочитатьПараметрыЗапроса1СИзJSON(ПараметрыJSON);
		Исключение
			ИсточникПараметров = Неопределено;
		КонецПопытки;
	КонецЕсли;

	Если ИсточникПараметров = Неопределено Тогда
		Возврат ТаблицаПараметров;
	КонецЕсли;

	Если ТипЗнч(ИсточникПараметров) = Тип("Структура") Тогда
		Для Каждого Параметр Из ИсточникПараметров Цикл
			ДобавитьСтрокуПараметраВТаблицу(ТаблицаПараметров, Параметр.Ключ, Параметр.Значение);
		КонецЦикла;
	ИначеЕсли ТипЗнч(ИсточникПараметров) = Тип("Соответствие") Тогда
		Для Каждого Параметр Из ИсточникПараметров Цикл
			ДобавитьСтрокуПараметраВТаблицу(ТаблицаПараметров, Строка(Параметр.Ключ), Параметр.Значение);
		КонецЦикла;
	КонецЕсли;

	Возврат ТаблицаПараметров;

КонецФункции

&НаСервере
Процедура ЗаполнитьТабличныйРеквизитПараметров(ТаблицаПараметров)

	ПараметрыЗапросаТаблица.Очистить();

	Для Каждого СтрокаПараметра Из ТаблицаПараметров Цикл
		НоваяСтрока = ПараметрыЗапросаТаблица.Добавить();
		НоваяСтрока.ИмяПараметра = СтрокаПараметра.ИмяПараметра;
		НоваяСтрока.ТипПараметра = СтрокаПараметра.ТипПараметра;
		НоваяСтрока.ЗначениеПараметра = СтрокаПараметра.ЗначениеПараметра;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокуПараметраВТаблицу(ТаблицаПараметров, ИмяПараметра, ЗначениеПараметра)

	НоваяСтрока = ТаблицаПараметров.Добавить();
	НоваяСтрока.ИмяПараметра = Строка(ИмяПараметра);
	НоваяСтрока.ТипПараметра = ОпределитьТипПараметраДляТаблицы(ЗначениеПараметра);
	НоваяСтрока.ЗначениеПараметра = ПредставлениеЗначенияПараметраДляТаблицы(ЗначениеПараметра, НоваяСтрока.ТипПараметра);

КонецПроцедуры

&НаСервере
Функция ОпределитьТипПараметраДляТаблицы(ЗначениеПараметра)

	Если ЗначениеПараметра = Неопределено Тогда
		Возврат "Строка";
	КонецЕсли;

	ТипЗначения = ТипЗнч(ЗначениеПараметра);
	Если ТипЗначения = Тип("Строка") Тогда
		Возврат "Строка";
	ИначеЕсли ТипЗначения = Тип("Число") Тогда
		Возврат "Число";
	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		Возврат "Булево";
	ИначеЕсли ТипЗначения = Тип("Дата") Тогда
		Возврат "Дата";
	КонецЕсли;

	Возврат "JSON";

КонецФункции

&НаСервере
Функция ПредставлениеЗначенияПараметраДляТаблицы(ЗначениеПараметра, ТипПараметра)

	Если ЗначениеПараметра = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Если ТипПараметра = "Дата" Тогда
		Возврат Формат(ЗначениеПараметра, "ДФ=yyyy-MM-dd HH:mm:ss");
	ИначеЕсли ТипПараметра = "Булево" Тогда
		Если ЗначениеПараметра Тогда
			Возврат "true";
		Иначе
			Возврат "false";
		КонецЕсли;
	ИначеЕсли ТипПараметра = "JSON" Тогда
		Возврат ИИА_Сервер.ЗаписатьЗначениеВJSONСтроку(ЗначениеПараметра);
	КонецЕсли;

	Возврат Строка(ЗначениеПараметра);

КонецФункции

&НаСервере
Функция СформироватьJSONПараметровЗапроса()

	СтруктураПараметров = Новый Структура;

	Для Каждого СтрокаПараметра Из ПараметрыЗапросаТаблица Цикл
		ИмяПараметра = СокрЛП(СтрокаПараметра.ИмяПараметра);
		Если ПустаяСтрока(ИмяПараметра) Тогда
			Продолжить;
		КонецЕсли;

		ТипПараметра = НормализоватьТипПараметра(СтрокаПараметра.ТипПараметра);
		ЗначениеПараметра = ПреобразоватьСтроковоеЗначениеПараметра(ТипПараметра, СтрокаПараметра.ЗначениеПараметра, ИмяПараметра);
		СтруктураПараметров.Вставить(ИмяПараметра, ЗначениеПараметра);
	КонецЦикла;

	Если СтруктураПараметров.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;

	Возврат ИИА_Сервер.ЗаписатьЗначениеВJSONСтроку(СтруктураПараметров);

КонецФункции

&НаСервере
Функция НормализоватьТипПараметра(ТипПараметра)

	ТипПараметра = СокрЛП(Строка(ТипПараметра));
	Если ПустаяСтрока(ТипПараметра) Тогда
		Возврат "Строка";
	КонецЕсли;

	Если ТипПараметра = "Строка"
		ИЛИ ТипПараметра = "Число"
		ИЛИ ТипПараметра = "Булево"
		ИЛИ ТипПараметра = "Дата"
		ИЛИ ТипПараметра = "JSON" Тогда
		Возврат ТипПараметра;
	КонецЕсли;

	Возврат "Строка";

КонецФункции

&НаСервере
Функция ПреобразоватьСтроковоеЗначениеПараметра(ТипПараметра, СтроковоеЗначение, ИмяПараметра)

	СтроковоеЗначение = Строка(СтроковоеЗначение);

	Если ТипПараметра = "Строка" Тогда
		Возврат СтроковоеЗначение;
	ИначеЕсли ТипПараметра = "JSON" Тогда
		Если ПустаяСтрока(СокрЛП(СтроковоеЗначение)) Тогда
			Возврат Неопределено;
		КонецЕсли;

		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(СтроковоеЗначение);
			ЗначениеПараметра = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
			Возврат ЗначениеПараметра;
		Исключение
			ВызватьИсключение "Параметр """ + ИмяПараметра + """ содержит некорректный JSON: " + ОписаниеОшибки();
		КонецПопытки;
	ИначеЕсли ТипПараметра = "Булево" Тогда
		НормализованноеЗначение = НРег(СокрЛП(СтроковоеЗначение));
		Если НормализованноеЗначение = "true" ИЛИ НормализованноеЗначение = "истина" ИЛИ НормализованноеЗначение = "1" Тогда
			Возврат Истина;
		ИначеЕсли НормализованноеЗначение = "false" ИЛИ НормализованноеЗначение = "ложь" ИЛИ НормализованноеЗначение = "0" ИЛИ НормализованноеЗначение = "" Тогда
			Возврат Ложь;
		Иначе
			ВызватьИсключение "Параметр """ + ИмяПараметра + """ типа Булево должен быть true/false.";
		КонецЕсли;
	КонецЕсли;

	Попытка
		Если ТипПараметра = "Число" Тогда
			Возврат XMLЗначение(Тип("Число"), СтроковоеЗначение);
		ИначеЕсли ТипПараметра = "Дата" Тогда
			Возврат XMLЗначение(Тип("Дата"), СтроковоеЗначение);
		КонецЕсли;
	Исключение
		ВызватьИсключение "Не удалось преобразовать параметр """ + ИмяПараметра + """ к типу " + ТипПараметра + ": " + ОписаниеОшибки();
	КонецПопытки;

	Возврат СтроковоеЗначение;

КонецФункции
