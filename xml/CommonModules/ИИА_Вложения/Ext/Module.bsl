#Область ПрограммныйИнтерфейс

Функция ПолучитьВложенияДиалога(СсылкаДиалога) Экспорт
	СырыеВложения = ПолучитьСырыеВложенияДиалога(СсылкаДиалога);
	Результат = Новый Массив;
	Для Каждого Вложение Из СырыеВложения Цикл
		Результат.Добавить(ПодготовитьВложениеДляВозвратаКлиенту(Вложение));
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ПолучитьНативныеВложенияДляМодели(СсылкаДиалога) Экспорт
	СырыеВложения = ПолучитьСырыеВложенияДиалога(СсылкаДиалога);
	Результат = Новый Массив;
	Для Каждого Вложение Из СырыеВложения Цикл
		Если НЕ Вложение.Свойство("native_binary") Тогда
			Продолжить;
		КонецЕсли;
		Если ТипЗнч(Вложение.native_binary) <> Тип("ХранилищеЗначения") Тогда
			Продолжить;
		КонецЕсли;
		ДвоичныеДанныеФайла = Вложение.native_binary.Получить();
		Если ДвоичныеДанныеФайла = Неопределено ИЛИ ТипЗнч(ДвоичныеДанныеФайла) <> Тип("ДвоичныеДанные") Тогда
			Продолжить;
		КонецЕсли;
		НативноеВложение = Новый Структура;
		НативноеВложение.Вставить("id", ?(Вложение.Свойство("id"), Строка(Вложение.id), ""));
		НативноеВложение.Вставить("file_name", ?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), ""));
		НативноеВложение.Вставить("kind", ?(Вложение.Свойство("kind"), Строка(Вложение.kind), ""));
		НативноеВложение.Вставить("mime_type", ?(Вложение.Свойство("mime_type"), Строка(Вложение.mime_type), "application/octet-stream"));
		НативноеВложение.Вставить("native_transport", ?(Вложение.Свойство("native_transport"), Строка(Вложение.native_transport), ""));
		НативноеВложение.Вставить("data_url", ПодготовитьНативныйDataUrl(ДвоичныеДанныеФайла, НативноеВложение.mime_type));
		Результат.Добавить(НативноеВложение);
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ДобавитьВложениеИзДвоичныхДанных(СсылкаДиалога, ИмяФайла, ДвоичныеДанныеФайла) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		ВызватьИсключение "Не выбран диалог для добавления вложения.";
	КонецЕсли;
	ИмяФайла = СокрЛП(ИмяФайла);
	Если ПустаяСтрока(ИмяФайла) Тогда
		ВызватьИсключение "Имя файла не указано.";
	КонецЕсли;
	Если ДвоичныеДанныеФайла = Неопределено Тогда
		ВызватьИсключение "Двоичные данные файла не переданы.";
	КонецЕсли;
	ВременныйФайл = СохранитьДвоичныеДанныеВоВременныйФайл(ДвоичныеДанныеФайла, ИмяФайла);
	Возврат ДобавитьВложениеИзФайла(СсылкаДиалога, ВременныйФайл, ИмяФайла);
КонецФункции

Функция ДобавитьВложениеИзВременногоХранилища(СсылкаДиалога, ИмяФайла, АдресВременногоХранилища) Экспорт
	Если ПустаяСтрока(СокрЛП(Строка(АдресВременногоХранилища))) Тогда
		ВызватьИсключение "Адрес временного хранилища не указан.";
	КонецЕсли;
	ДанныеИзХранилища = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
	Если ДанныеИзХранилища = Неопределено Тогда
		ВызватьИсключение "Не удалось получить файл из временного хранилища.";
	КонецЕсли;
	Если ТипЗнч(ДанныеИзХранилища) = Тип("ДвоичныеДанные") Тогда
		Возврат ДобавитьВложениеИзДвоичныхДанных(СсылкаДиалога, ИмяФайла, ДанныеИзХранилища);
	КонецЕсли;
	Если ТипЗнч(ДанныеИзХранилища) = Тип("ХранилищеЗначения") Тогда
		ДвоичныеДанныеФайла = ДанныеИзХранилища.Получить();
		Если ТипЗнч(ДвоичныеДанныеФайла) = Тип("ДвоичныеДанные") Тогда
			Возврат ДобавитьВложениеИзДвоичныхДанных(СсылкаДиалога, ИмяФайла, ДвоичныеДанныеФайла);
		КонецЕсли;
	КонецЕсли;
	ВызватьИсключение "Во временном хранилище не найдено значение типа ДвоичныеДанные.";
КонецФункции

Функция ДобавитьВложениеИзФайла(СсылкаДиалога, ПутьКФайлу, ОтображаемоеИмяФайла = "") Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		ВызватьИсключение "Не выбран диалог для добавления вложения.";
	КонецЕсли;
	ПутьКФайлу = СокрЛП(ПутьКФайлу);
	Если ПустаяСтрока(ПутьКФайлу) Тогда
		ВызватьИсключение "Путь к файлу не указан.";
	КонецЕсли;
	ФайлВложения = Новый Файл(ПутьКФайлу);
	Если НЕ ФайлВложения.Существует() Тогда
		ВызватьИсключение "Файл не найден: " + ПутьКФайлу;
	КонецЕсли;
	Расширение = ПолучитьРасширениеФайлаВНижнемРегистре(ПутьКФайлу);
	ВидВложения = ОпределитьВидВложенияПоРасширению(Расширение);
	MimeТип = ОпределитьMimeТипВложения(Расширение);
	ИзвлеченныйТекст = "";
	КраткаяСводка = "";
	НативныйБинарник = Неопределено;
	ФайлПустой = Ложь;
	Попытка
		ФайлПустой = ФайлВложения.Размер() = 0;
	Исключение
		ФайлПустой = Ложь;
	КонецПопытки;
	Если ВидВложения = "text" Тогда
		Если Расширение = "doc" ИЛИ Расширение = "docx" Тогда
			ИзвлеченныйТекст = ИзвлечьТекстИзТабличногоДокументаДляВложения(ПутьКФайлу);
			Если ПустаяСтрока(ИзвлеченныйТекст) Тогда
				ИзвлеченныйТекст = ОчиститьТекстДляXDTO(ПрочитатьТекстФайлаДляВложения(ПутьКФайлу));
			КонецЕсли;
		Иначе
			ИзвлеченныйТекст = ОчиститьТекстДляXDTO(ПрочитатьТекстФайлаДляВложения(ПутьКФайлу));
		КонецЕсли;
		Если ФайлПустой ИЛИ ТекстВложенияПустойПоСодержимому(ИзвлеченныйТекст) Тогда
			КраткаяСводка = "Файл пуст.";
		Иначе
			КраткаяСводка = ?(ПустаяСтрока(ИзвлеченныйТекст), "Текст не удалось прочитать.", "Извлечен текст из файла.");
		КонецЕсли;
	ИначеЕсли ВидВложения = "table" Тогда
		Если Расширение = "mxl" ИЛИ Расширение = "xls" ИЛИ Расширение = "xlsx" Тогда
			ИзвлеченныйТекст = ИзвлечьТекстИзТабличногоДокументаДляВложения(ПутьКФайлу);
		Иначе
			ИзвлеченныйТекст = ОчиститьТекстДляXDTO(ПрочитатьТекстФайлаДляВложения(ПутьКФайлу));
		КонецЕсли;
		КраткаяСводка = ОчиститьТекстДляXDTO(ПостроитьСводкуТаблицыИзТекста(ИзвлеченныйТекст));
		Если ПустаяСтрока(КраткаяСводка) Тогда
			Если Расширение = "xls" ИЛИ Расширение = "xlsx" Тогда
				КраткаяСводка = "Excel-файл прочитан через ТабличныйДокумент. Табличный preview построить не удалось.";
			Иначе
				КраткаяСводка = "Табличный preview построить не удалось.";
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ВидВложения = "image" Тогда
		КраткаяСводка = "Изображение зарегистрировано. Для совместимых моделей передается нативно.";
	ИначеЕсли ВидВложения = "pdf" Тогда
		КраткаяСводка = "PDF зарегистрирован. Для совместимых моделей передается нативно.";
	Иначе
		КраткаяСводка = "Файл зарегистрирован как неизвестный тип. Автоизвлечение содержимого не выполнено.";
	КонецЕсли;
	Если ЭтоНативноеВложениеДляМодели(ВидВложения, Расширение) Тогда
		НативныйБинарник = ПрочитатьДвоичныеДанныеФайла(ПутьКФайлу);
	КонецЕсли;
	Вложение = Новый Структура;
	Вложение.Вставить("id", Строка(Новый УникальныйИдентификатор()));
	Вложение.Вставить("added_at", ТекущаяДата());
	Если ПустаяСтрока(ОтображаемоеИмяФайла) Тогда
		ОтображаемоеИмяФайла = ФайлВложения.Имя;
	КонецЕсли;
	Вложение.Вставить("file_name", ОтображаемоеИмяФайла);
	Вложение.Вставить("file_path", ПутьКФайлу);
	Вложение.Вставить("extension", Расширение);
	Вложение.Вставить("kind", ВидВложения);
	Вложение.Вставить("mime_type", MimeТип);
	Вложение.Вставить("native_transport", ?(ВидВложения = "image", "image_url", ?(ВидВложения = "pdf", "file", "")));
	РазмерФайла = 0;
	Попытка
		РазмерФайла = ФайлВложения.Размер();
	Исключение
		РазмерФайла = 0;
	КонецПопытки;
	Вложение.Вставить("size_bytes", РазмерФайла);
	Вложение.Вставить("extracted_text", ОчиститьТекстДляXDTO(ИзвлеченныйТекст));
	Вложение.Вставить("summary", ОчиститьТекстДляXDTO(КраткаяСводка));
	Если НативныйБинарник <> Неопределено Тогда
		Вложение.Вставить("native_binary", Новый ХранилищеЗначения(НативныйБинарник));
	КонецЕсли;
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	Вложения = Новый Массив;
	Если СтруктураДанных.Свойство("Вложения") И ТипЗнч(СтруктураДанных.Вложения) = Тип("Массив") Тогда
		Вложения = СтруктураДанных.Вложения;
	КонецЕсли;
	Вложения.Добавить(Вложение);
	СтруктураДанных.Вставить("Вложения", Вложения);
	ИИА_DialogStorage.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	ИИА_Сервер.ДобавитьСообщениеВДиалог(
		СсылкаДиалога,
		Перечисления.ИИА_АвторСообщения.Пользователь,
		Перечисления.ИИА_ТипСообщения.Текст,
		СформироватьТекстСообщенияОВложении(Вложение)
	);
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[ATTACHMENT] Добавлено вложение: " + ФайлВложения.Имя + ", kind=" + ВидВложения);
	Возврат Вложение;
КонецФункции

Функция НайтиВложениеДиалога(СсылкаДиалога, ИдентификаторИлиИмя = "") Экспорт
	Вложения = ПолучитьВложенияДиалога(СсылкаДиалога);
	Если Вложения = Неопределено ИЛИ Вложения.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	КлючПоиска = СокрЛП(Строка(ИдентификаторИлиИмя));
	Если ПустаяСтрока(КлючПоиска) Тогда
		Возврат Вложения[Вложения.Количество() - 1];
	КонецЕсли;
	Индекс = Вложения.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Вложение = Вложения[Индекс];
		Если (Вложение.Свойство("id") И Строка(Вложение.id) = КлючПоиска)
			ИЛИ (Вложение.Свойство("file_name") И Строка(Вложение.file_name) = КлючПоиска) Тогда
			Возврат Вложение;
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	КлючПоискаВРег = ВРег(КлючПоиска);
	Индекс = Вложения.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Вложение = Вложения[Индекс];
		Если Вложение.Свойство("file_name") И СтрНайти(ВРег(Строка(Вложение.file_name)), КлючПоискаВРег) > 0 Тогда
			Возврат Вложение;
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция ПолучитьПолныйТекстВложения(СсылкаДиалога, ИдентификаторИлиИмя = "") Экспорт
	Вложение = НайтиВложениеДиалога(СсылкаДиалога, ИдентификаторИлиИмя);
	Если Вложение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Если Вложение.Свойство("extracted_text") Тогда
		Возврат ОчиститьТекстДляXDTO(Строка(Вложение.extracted_text));
	КонецЕсли;
	Возврат "";
КонецФункции

Функция НайтиВоВложениях(СсылкаДиалога, ИскомыйТекст, Лимит = 20, ИдентификаторИлиИмя = "") Экспорт
	Результаты = Новый Массив;
	Шаблон = СокрЛП(Строка(ИскомыйТекст));
	Если ПустаяСтрока(Шаблон) Тогда
		Возврат Результаты;
	КонецЕсли;
	Вложения = ПолучитьВложенияДиалога(СсылкаДиалога);
	Если Вложения = Неопределено ИЛИ Вложения.Количество() = 0 Тогда
		Возврат Результаты;
	КонецЕсли;
	Если Лимит <= 0 Тогда
		Лимит = 20;
	КонецЕсли;
	ФильтрВложения = Неопределено;
	Если НЕ ПустаяСтрока(СокрЛП(Строка(ИдентификаторИлиИмя))) Тогда
		ФильтрВложения = НайтиВложениеДиалога(СсылкаДиалога, ИдентификаторИлиИмя);
		Если ФильтрВложения = Неопределено Тогда
			Возврат Результаты;
		КонецЕсли;
	КонецЕсли;
	ШаблонВРег = ВРег(Шаблон);
	Для Каждого Вложение Из Вложения Цикл
		Если ФильтрВложения <> Неопределено И Строка(Вложение.id) <> Строка(ФильтрВложения.id) Тогда
			Продолжить;
		КонецЕсли;
		ТекстВложения = ?(Вложение.Свойство("extracted_text"), Строка(Вложение.extracted_text), "");
		Если ПустаяСтрока(ТекстВложения) Тогда
			Продолжить;
		КонецЕсли;
		Строки = СтрРазделить(СтрЗаменить(ТекстВложения, Символы.ВК, ""), Символы.ПС);
		НомерСтроки = 0;
		Для Каждого СтрокаВложения Из Строки Цикл
			НомерСтроки = НомерСтроки + 1;
			Если СтрНайти(ВРег(СтрокаВложения), ШаблонВРег) > 0 Тогда
				Совпадение = Новый Структура;
				Совпадение.Вставить("attachment_id", ?(Вложение.Свойство("id"), Строка(Вложение.id), ""));
				Совпадение.Вставить("file_name", ?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), ""));
				Совпадение.Вставить("line_no", НомерСтроки);
				Совпадение.Вставить("line_text", ОграничитьТекстДляПромптаВложения(СтрокаВложения, 500));
				Результаты.Добавить(Совпадение);
				Если Результаты.Количество() >= Лимит Тогда
					Возврат Результаты;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Результаты;
КонецФункции

Функция ПолучитьСводкуВложенийДляПромпта(СсылкаДиалога, Лимит = 3) Экспорт
	Вложения = ПолучитьВложенияДиалога(СсылкаДиалога);
	Если Вложения = Неопределено ИЛИ Вложения.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	Начало = Макс(0, Вложения.Количество() - Лимит);
	Результат = "КОНТЕКСТ ВЛОЖЕНИЙ:" + Символы.ПС;
	Для Индекс = Начало По Вложения.Количество() - 1 Цикл
		Вложение = Вложения[Индекс];
		Результат = Результат + "- Файл: " + ОчиститьТекстДляXDTO(?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), "файл"));
		Результат = Результат + "; тип=" + ОчиститьТекстДляXDTO(?(Вложение.Свойство("kind"), Строка(Вложение.kind), "unknown"));
		Если Вложение.Свойство("summary") И НЕ ПустаяСтрока(Строка(Вложение.summary)) Тогда
			Результат = Результат + Символы.ПС + "  summary: " + ОграничитьТекстДляПромптаВложения(Строка(Вложение.summary), 1200);
		КонецЕсли;
		Если Вложение.Свойство("extracted_text") И НЕ ПустаяСтрока(Строка(Вложение.extracted_text)) Тогда
			Результат = Результат + Символы.ПС + "  content: " + ОграничитьТекстДляПромптаВложения(Строка(Вложение.extracted_text), 2000);
		КонецЕсли;
		Результат = Результат + Символы.ПС;
	КонецЦикла;
	Возврат ОчиститьТекстДляXDTO(ОграничитьТекстДляВложения(Результат, 12000));
КонецФункции

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьСырыеВложенияДиалога(СсылкаДиалога)
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Вложения") И ТипЗнч(СтруктураДанных.Вложения) = Тип("Массив") Тогда
		Возврат СтруктураДанных.Вложения;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПодготовитьВложениеДляВозвратаКлиенту(Вложение)
	Если Вложение = Неопределено ИЛИ ТипЗнч(Вложение) <> Тип("Структура") Тогда
		Возврат Новый Структура;
	КонецЕсли;
	КлючиДляКлиента = Новый Массив;
	КлючиДляКлиента.Добавить("id");
	КлючиДляКлиента.Добавить("added_at");
	КлючиДляКлиента.Добавить("file_name");
	КлючиДляКлиента.Добавить("file_path");
	КлючиДляКлиента.Добавить("extension");
	КлючиДляКлиента.Добавить("kind");
	КлючиДляКлиента.Добавить("size_bytes");
	КлючиДляКлиента.Добавить("extracted_text");
	КлючиДляКлиента.Добавить("summary");
	КлючиДляКлиента.Добавить("mime_type");
	КлючиДляКлиента.Добавить("native_transport");
	Результат = Новый Структура;
	Для Каждого Ключ Из КлючиДляКлиента Цикл
		ЗначениеПоля = Неопределено;
		Если Вложение.Свойство(Ключ, ЗначениеПоля) Тогда
			Результат.Вставить(Ключ, ЗначениеПоля);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция СохранитьДвоичныеДанныеВоВременныйФайл(ДвоичныеДанныеФайла, ИмяФайла)
	Расширение = ПолучитьРасширениеФайлаВНижнемРегистре(ИмяФайла);
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла(?(ПустаяСтрока(Расширение), "", Расширение));
	ДвоичныеДанныеФайла.Записать(ИмяВременногоФайла);
	Возврат ИмяВременногоФайла;
КонецФункции

Функция ПолучитьРасширениеФайлаВНижнемРегистре(ПутьКФайлу)
	ФайлПоПути = Новый Файл(ПутьКФайлу);
	ИмяФайла = ФайлПоПути.Имя;
	ПозицияТочки = СтрНайти(ИмяФайла, ".");
	Если ПозицияТочки <= 0 Тогда
		Возврат "";
	КонецЕсли;
	Пока ПозицияТочки > 0 Цикл
		СледующаяТочка = СтрНайти(Сред(ИмяФайла, ПозицияТочки + 1), ".");
		Если СледующаяТочка <= 0 Тогда
			Прервать;
		КонецЕсли;
		ПозицияТочки = ПозицияТочки + СледующаяТочка;
	КонецЦикла;
	Возврат НРег(Сред(ИмяФайла, ПозицияТочки + 1));
КонецФункции

Функция ОпределитьВидВложенияПоРасширению(Расширение)
	Если Расширение = "csv" ИЛИ Расширение = "tsv" ИЛИ Расширение = "mxl" ИЛИ Расширение = "xls" ИЛИ Расширение = "xlsx" Тогда
		Возврат "table";
	КонецЕсли;
	Если Расширение = "txt" ИЛИ Расширение = "md" ИЛИ Расширение = "json" ИЛИ Расширение = "xml" ИЛИ Расширение = "log" ИЛИ Расширение = "bsl" ИЛИ Расширение = "doc" ИЛИ Расширение = "docx" Тогда
		Возврат "text";
	КонецЕсли;
	Если Расширение = "png" ИЛИ Расширение = "jpg" ИЛИ Расширение = "jpeg" ИЛИ Расширение = "bmp" ИЛИ Расширение = "gif" ИЛИ Расширение = "webp" Тогда
		Возврат "image";
	КонецЕсли;
	Если Расширение = "pdf" Тогда
		Возврат "pdf";
	КонецЕсли;
	Возврат "unknown";
КонецФункции

Функция ОпределитьMimeТипВложения(Расширение)
	Если Расширение = "png" Тогда
		Возврат "image/png";
	ИначеЕсли Расширение = "jpg" ИЛИ Расширение = "jpeg" Тогда
		Возврат "image/jpeg";
	ИначеЕсли Расширение = "gif" Тогда
		Возврат "image/gif";
	ИначеЕсли Расширение = "webp" Тогда
		Возврат "image/webp";
	ИначеЕсли Расширение = "bmp" Тогда
		Возврат "image/bmp";
	ИначеЕсли Расширение = "pdf" Тогда
		Возврат "application/pdf";
	ИначеЕсли Расширение = "docx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
	ИначеЕсли Расширение = "doc" Тогда
		Возврат "application/msword";
	ИначеЕсли Расширение = "xlsx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
	ИначеЕсли Расширение = "xls" Тогда
		Возврат "application/vnd.ms-excel";
	ИначеЕсли Расширение = "csv" Тогда
		Возврат "text/csv";
	ИначеЕсли Расширение = "tsv" Тогда
		Возврат "text/tsv";
	ИначеЕсли Расширение = "txt" Тогда
		Возврат "text/plain";
	КонецЕсли;
	Возврат "application/octet-stream";
КонецФункции

Функция ЭтоНативноеВложениеДляМодели(ВидВложения, Расширение)
	Возврат ВидВложения = "image" ИЛИ Расширение = "pdf";
КонецФункции

Функция ОграничитьТекстДляВложения(Текст, Максимум = 6000)
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	Результат = СокрЛП(Текст);
	Если СтрДлина(Результат) > Максимум Тогда
		Результат = Лев(Результат, Максимум) + Символы.ПС + "...(truncated)";
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ОграничитьТекстДляПромптаВложения(Текст, Максимум = 2000)
	Возврат ОграничитьТекстДляВложения(ОчиститьТекстДляXDTO(Текст), Максимум);
КонецФункции

Функция ПрочитатьТекстФайлаДляВложения(ПутьКФайлу)
	Кодировки = Новый Массив;
	Кодировки.Добавить(КодировкаТекста.UTF8);
	Кодировки.Добавить(КодировкаТекста.UTF16);
	Попытка
		Кодировки.Добавить(КодировкаТекста.ANSI);
	Исключение
	КонецПопытки;
	Попытка
		Кодировки.Добавить(КодировкаТекста.OEM);
	Исключение
	КонецПопытки;
	Для Каждого Кодировка Из Кодировки Цикл
		Попытка
			ТекстовыйДокумент = Новый ТекстовыйДокумент;
			ТекстовыйДокумент.Прочитать(ПутьКФайлу, Кодировка);
			Возврат ТекстовыйДокумент.ПолучитьТекст();
		Исключение
		КонецПопытки;
	КонецЦикла;
	Попытка
		ТекстовыйДокумент = Новый ТекстовыйДокумент;
		ТекстовыйДокумент.Прочитать(ПутьКФайлу);
		Возврат ТекстовыйДокумент.ПолучитьТекст();
	Исключение
		Возврат "";
	КонецПопытки;
КонецФункции

Функция ОчиститьТекстДляXDTO(Текст)
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	Результат = "";
	Для Позиция = 1 По СтрДлина(Текст) Цикл
		Символ = Сред(Текст, Позиция, 1);
		Код = КодСимвола(Символ);
		Если Код = 9 ИЛИ Код = 10 ИЛИ Код = 13 ИЛИ Код >= 32 Тогда
			Результат = Результат + Символ;
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ТекстВложенияПустойПоСодержимому(Текст)
	Если НЕ ЗначениеЗаполнено(Текст) Тогда
		Возврат Истина;
	КонецЕсли;
	НормализованныйТекст = Строка(Текст);
	НормализованныйТекст = СтрЗаменить(НормализованныйТекст, Символы.ВК, "");
	НормализованныйТекст = СтрЗаменить(НормализованныйТекст, Символы.ПС, "");
	НормализованныйТекст = СтрЗаменить(НормализованныйТекст, Символы.Таб, "");
	НормализованныйТекст = СокрЛП(НормализованныйТекст);
	Возврат ПустаяСтрока(НормализованныйТекст);
КонецФункции

Функция ОпределитьРазделительТаблицы(ПерваяСтрока)
	Кандидаты = Новый Массив;
	Кандидаты.Добавить(";");
	Кандидаты.Добавить(",");
	Кандидаты.Добавить(Символы.ВТаб);
	ЛучшийРазделитель = ";";
	ЛучшееКоличество = -1;
	Для Каждого Кандидат Из Кандидаты Цикл
		Количество = СтрЧислоВхождений(ПерваяСтрока, Кандидат);
		Если Количество > ЛучшееКоличество Тогда
			ЛучшееКоличество = Количество;
			ЛучшийРазделитель = Кандидат;
		КонецЕсли;
	КонецЦикла;
	Возврат ЛучшийРазделитель;
КонецФункции

Функция ПостроитьСводкуТаблицыИзТекста(ТекстТаблицы)
	Если ПустаяСтрока(ТекстТаблицы) Тогда
		Возврат "";
	КонецЕсли;
	Строки = СтрРазделить(СтрЗаменить(ТекстТаблицы, Символы.ВК, ""), Символы.ПС);
	Если Строки.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	ПерваяНепустаяСтрока = "";
	Для Каждого СтрокаТаблицы Из Строки Цикл
		Если НЕ ПустаяСтрока(СокрЛП(СтрокаТаблицы)) Тогда
			ПерваяНепустаяСтрока = СтрокаТаблицы;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если ПустаяСтрока(ПерваяНепустаяСтрока) Тогда
		Возврат "";
	КонецЕсли;
	Разделитель = ОпределитьРазделительТаблицы(ПерваяНепустаяСтрока);
	Результат = "ТАБЛИЦА (preview):" + Символы.ПС;
	НомерСтроки = 0;
	Для Каждого СтрокаТаблицы Из Строки Цикл
		Если ПустаяСтрока(СокрЛП(СтрокаТаблицы)) Тогда
			Продолжить;
		КонецЕсли;
		Колонки = СтрРазделить(СтрокаТаблицы, Разделитель);
		СтрокаPreview = "";
		ПределКолонок = Мин(Колонки.Количество(), 8);
		Для ИндексКолонки = 0 По ПределКолонок - 1 Цикл
			Если НЕ ПустаяСтрока(СтрокаPreview) Тогда
				СтрокаPreview = СтрокаPreview + " | ";
			КонецЕсли;
			СтрокаPreview = СтрокаPreview + СокрЛП(Колонки[ИндексКолонки]);
		КонецЦикла;
		Результат = Результат + СтрокаPreview + Символы.ПС;
		НомерСтроки = НомерСтроки + 1;
		Если НомерСтроки >= 10 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Возврат ОграничитьТекстДляВложения(Результат, 4000);
КонецФункции

Функция ИзвлечьТекстИзТабличногоДокументаДляВложения(ПутьКФайлу)
	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
		ТекстТабДок = ТабДок.Текст;
		Если НЕ ПустаяСтрока(СокрЛП(ТекстТабДок)) Тогда
			Возврат ОчиститьТекстДляXDTO(ТекстТабДок);
		КонецЕсли;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	Возврат "";
КонецФункции

Функция ПрочитатьДвоичныеДанныеФайла(ПутьКФайлу)
	Попытка
		Возврат Новый ДвоичныеДанные(ПутьКФайлу);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция ПодготовитьНативныйDataUrl(ДвоичныеДанныеФайла, MimeТип)
	Возврат "data:" + MimeТип + ";base64," + Base64Строка(ДвоичныеДанныеФайла);
КонецФункции

Функция СформироватьТекстСообщенияОВложении(Вложение)
	ИмяФайла = ?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), "файл");
	ВидВложения = ?(Вложение.Свойство("kind"), Строка(Вложение.kind), "unknown");
	Текст = "[Вложение] " + ИмяФайла + " (" + ВидВложения + ")";
	Если Вложение.Свойство("summary") И НЕ ПустаяСтрока(Строка(Вложение.summary)) Тогда
		Текст = Текст + Символы.ПС + Строка(Вложение.summary);
	КонецЕсли;
	Возврат ОчиститьТекстДляXDTO(Текст);
КонецФункции

