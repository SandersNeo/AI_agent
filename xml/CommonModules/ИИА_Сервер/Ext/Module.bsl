Процедура ДобавитьЗаписьВСайдЭффектЛог(СсылкаДиалога, ЗаписьЛога) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	Если ЗаписьЛога = Неопределено ИЛИ ТипЗнч(ЗаписьЛога) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	
	Лог = Новый Массив;
	Если СтруктураДанных.Свойство("SideEffect_Log") И ТипЗнч(СтруктураДанных.SideEffect_Log) = Тип("Массив") Тогда
		Лог = СтруктураДанных.SideEffect_Log;
	КонецЕсли;
	
	Если НЕ ЗаписьЛога.Свойство("timestamp") Тогда
		ЗаписьЛога.Вставить("timestamp", ТекущаяДатаСеанса());
	КонецЕсли;
	Если НЕ ЗаписьЛога.Свойство("replay_safety") Тогда
		Если ЗаписьЛога.Свойство("operation_id") И НЕ ПустаяСтрока(Строка(ЗаписьЛога.operation_id)) Тогда
			ЗаписьЛога.Вставить("replay_safety", "resume_only");
		Иначе
			ЗаписьЛога.Вставить("replay_safety", "no_replay");
		КонецЕсли;
	КонецЕсли;
	
	Лог.Добавить(ЗаписьЛога);
	Пока Лог.Количество() > 300 Цикл
		Лог.Удалить(0);
	КонецЦикла;
	
	СтруктураДанных.Вставить("SideEffect_Log", Лог);
	ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
КонецПроцедуры

