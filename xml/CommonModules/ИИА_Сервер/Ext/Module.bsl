#Область ПрограммныйИнтерфейс

// Извлекает названия сущностей из запроса пользователя через ИИ
//
// Параметры:
//  ТекстЗапроса - Строка - исходный запрос
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - (опционально) ссылка на диалог для логирования
//
// Возвращаемое значение:
//  Строка - извлеченные сущности или пустая строка
Функция ИзвлечьСущностиДляRAG(Знач ТекстЗапроса, Знач СсылкаДиалога = Неопределено) Экспорт
	
	// Не передавать JSON (DSL) в экстрактор — только текст запроса пользователя
	ТекстОбрезанный = СокрЛП(ТекстЗапроса);
	Если СтрДлина(ТекстОбрезанный) > 0 И (Лев(ТекстОбрезанный, 1) = "{" ИЛИ Лев(ТекстОбрезанный, 1) = "[") Тогда
		Возврат "";
	КонецЕсли;
	
	Промпт = ИИА_Промты.ПолучитьПромптЭкстрактораСущностей(ТекстЗапроса);
	
	// Получаем текущие параметры провайдера
	ПараметрыИИ = ПолучитьНастройкиПользователя(ИмяТекущегоПользователя());
	
	Если ПараметрыИИ = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	// Передаем ссылку на диалог для логирования RAG
	ПараметрыИИ.Вставить("СсылкаДиалога", СсылкаДиалога);
	// Запрещаем рекурсивный вызов RAG внутри экстрактора
	ПараметрыИИ.Вставить("ИспользоватьRAG", Ложь);
	
	ПараметрыИИ.Вставить("ExpectedResponseFormat", "text");
	
	// Вызываем ИИ через стандартный интерфейс провайдера
	ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[ENTITY_EXTRACTOR] Запрос к ИИ для извлечения сущностей...");
	ОтветИИ = ИИА_Провайдеры.ВызватьИИ("Чат", Промпт, Неопределено, ПараметрыИИ, "", 0.0);
	
	// В ответе ИИ может быть поле Успех или Ошибки. Проверим наличие текста.
	Если НЕ ПустаяСтрока(ОтветИИ.Текст) Тогда
		Результат = СокрЛП(ОтветИИ.Текст);
		ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[ENTITY_EXTRACTOR] Результат: " + Результат);
		Если ВРег(Результат) = "НЕТ" Тогда
			Возврат "";
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция РежимОтладкиJSON(Знач Пользователь = "") Экспорт
	// В этом общем модуле нельзя использовать Перем на уровне модуля,
	// поэтому режим отладки читаем из настроек пользователя.
	ПараметрыПользователя = ПолучитьНастройкиПользователя(Пользователь);
	Если ПараметрыПользователя <> Неопределено И ПараметрыПользователя.Свойство("РежимОтладки") Тогда
		Возврат ПараметрыПользователя.РежимОтладки;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

// Возвращает имя текущего пользователя ИБ или "Администратор" по умолчанию
Функция ИмяТекущегоПользователя() Экспорт
	
	Пользователь = "";
	Попытка
		Пользователь = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Если ПустаяСтрока(Пользователь) Тогда
		Пользователь = "Администратор";
	КонецЕсли;
	
	Возврат Пользователь;
	
КонецФункции

Функция ОпределитьRAGДляСообщения(ТекстПользователя, ТипДиалога) Экспорт
	
	Результат = Новый Структура("ИспользоватьRAG,Причина", Ложь, "");
	
	Если ТипДиалога = Перечисления.ИИА_ТипДиалога.Запрос1С Тогда
		Результат.ИспользоватьRAG = Истина;
		Результат.Причина = "Тип диалога Запрос1С";
		Возврат Результат;
	КонецЕсли;
	
	Если ПустаяСтрока(ТекстПользователя) Тогда
		Результат.Причина = "Пустой текст запроса";
		Возврат Результат;
	КонецЕсли;
	
	ТекстВРег = ВРег(ТекстПользователя);
	
	Ключевые = Новый Массив;
	Ключевые.Добавить("ДОКУМЕНТ");
	Ключевые.Добавить("СПРАВОЧНИК");
	Ключевые.Добавить("РЕГИСТР");
	Ключевые.Добавить("ПЕРЕЧИСЛЕНИ");
	Ключевые.Добавить("НАКЛАДН");
	Ключевые.Добавить("РЕАЛИЗАЦ");
	Ключевые.Добавить("ОТГРУЗК");
	Ключевые.Добавить("ПОСТУПЛЕН");
	Ключевые.Добавить("ПЕРЕМЕЩЕН");
	Ключевые.Добавить("СЧЕТ");
	Ключевые.Добавить("АКТ");
	Ключевые.Добавить("ПЛАТЕЖ");
	Ключевые.Добавить("КАСС");
	Ключевые.Добавить("СКЛАД");
	Ключевые.Добавить("ТОВАР");
	Ключевые.Добавить("УСЛУГ");
	
	Для Каждого Ключ Из Ключевые Цикл
		Если СтрНайти(ТекстВРег, Ключ) > 0 Тогда
			Результат.ИспользоватьRAG = Истина;
			Результат.Причина = "Найдены ключевые слова метаданных";
			Возврат Результат;
		КонецЕсли;
	КонецЦикла;
	
	Результат.Причина = "Ключевые слова метаданных не найдены";
	Возврат Результат;
	
КонецФункции

// Получает настройки пользователя из регистра сведений
//
// Параметры:
//  Пользователь - Строка - имя пользователя, для которого получить настройки
	//
	// Возвращаемое значение:
	//  Структура - структура с настройками:
	//   * Provider_BaseURL - Строка
	//   * Provider_ApiKey - Строка
	//   * ЛимитТокеновНаЗапуск - Число
	//   * Модель - Строка
	//   * email - Строка
	//
	Функция ПолучитьНастройкиПользователя(Знач Пользователь = "") Экспорт 
		
		Если ПустаяСтрока(Пользователь) Тогда
			Пользователь = ИмяТекущегоПользователя();
		КонецЕсли;
		
		Результат = Новый Структура;
		Результат.Вставить("Provider_BaseUrl", "");
		Результат.Вставить("Provider_ApiKey", "");
		Результат.Вставить("ЛимитТокеновНаЗапуск", 0);
		Результат.Вставить("Модель", "");
		Результат.Вставить("email", "");
	Результат.Вставить("РежимОтладки", Ложь);
	// По умолчанию запись разрешена (чтобы не ломать существующее поведение)
	Результат.Вставить("ДоступнаЗапись", Истина);
	Результат.Вставить("ПутьКЛогуОтладки", "");
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиПользователя.Provider_BaseUrl,
		|	НастройкиПользователя.Provider_ApiKey,
		|	НастройкиПользователя.ЛимитТокеновНаЗапуск,
		|	НастройкиПользователя.Модель,
	|	НастройкиПользователя.email,
	|	НастройкиПользователя.РежимОтладки,
	|	НастройкиПользователя.ДоступнаЗапись,
	|	НастройкиПользователя.ПутьКЛогуОтладки
		|ИЗ
		|	РегистрСведений.ИИА_НастройкиПользователей КАК НастройкиПользователя
		|ГДЕ
		|	НастройкиПользователя.Пользователь = &Пользователь";
		
		Запрос.УстановитьПараметр("Пользователь", Пользователь);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			Возврат Результат;
		КонецЕсли;
		
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		
		Результат.Provider_BaseUrl = Выборка.Provider_BaseUrl;
		Результат.Provider_ApiKey = Выборка.Provider_ApiKey;
		Результат.ЛимитТокеновНаЗапуск = Выборка.ЛимитТокеновНаЗапуск;
		Результат.Модель = Выборка.Модель;
		Результат.email = Выборка.email;
		
		// Выборка результата запроса не поддерживает метод Свойство().
		// Читаем новые поля через Попытка/Исключение для совместимости со старыми версиями регистра.
		Попытка
			Результат.РежимОтладки = Выборка.РежимОтладки;
		Исключение
			Результат.РежимОтладки = Ложь;
		КонецПопытки;
		
		Попытка
			Результат.ДоступнаЗапись = Выборка.ДоступнаЗапись;
		Исключение
			Результат.ДоступнаЗапись = Истина;
		КонецПопытки;
		
		Попытка
			Результат.ПутьКЛогуОтладки = Выборка.ПутьКЛогуОтладки;
		Исключение
			Результат.ПутьКЛогуОтладки = "";
		КонецПопытки;
		
		Возврат Результат;
		
	КонецФункции

// Функции для работы с Гигачат перенесены в модуль ИИА_Гигачат

// Находит активный диалог пользователя или создает новый
//
// Параметры:
//  Пользователь - СправочникСсылка.Пользователи - пользователь
//
// Возвращаемое значение:
//  СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
Функция НайтиИлиСоздатьДиалогПользователя(Пользователь) Экспорт
	
	// Ищем последний диалог пользователя (по дате создания)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Диалоги.Ссылка
	|ИЗ
	|	Справочник.ИИА_Диалоги КАК Диалоги
	|ГДЕ
	|	Диалоги.Пользователь = &Пользователь
	|УПОРЯДОЧИТЬ ПО
	|	Диалоги.ДатаСоздания УБЫВ";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	// Создаем новый диалог
	НовыйДиалог = Справочники.ИИА_Диалоги.СоздатьЭлемент();
	НовыйДиалог.Пользователь = Пользователь;
	НаименованиеДиалога = "Диалог ИИ от " + Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy HH:mm:ss");
	НовыйДиалог.Наименование = НаименованиеДиалога;
	НовыйДиалог.ДатаСоздания = ТекущаяДата();
	НовыйДиалог.ТипДиалога = Перечисления.ИИА_ТипДиалога.Агент;
	НовыйДиалог.Записать();
	
	Возврат НовыйДиалог.Ссылка;
	
КонецФункции

// Создает новый диалог для текущего пользователя
//
// Возвращаемое значение:
//  СправочникСсылка.ИИА_Диалоги - ссылка на новый диалог
//
Функция СоздатьНовыйДиалог(Пользователь, ТипДиалога = Неопределено) Экспорт
	
	// Создаем новый диалог
	НовыйДиалог = Справочники.ИИА_Диалоги.СоздатьЭлемент();
	НовыйДиалог.Пользователь = Пользователь;
	НаименованиеДиалога = "Диалог ИИ от " + Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy HH:mm:ss");
	НовыйДиалог.Наименование = НаименованиеДиалога;
	НовыйДиалог.ДатаСоздания = ТекущаяДата();
	
	// Устанавливаем тип диалога
	Если ТипДиалога <> Неопределено Тогда
		НовыйДиалог.ТипДиалога = ТипДиалога;
	Иначе
		// По умолчанию - Агент
		НовыйДиалог.ТипДиалога = Перечисления.ИИА_ТипДиалога.Агент;
	КонецЕсли;
	
	НовыйДиалог.Записать();
	
	Возврат НовыйДиалог.Ссылка;
	
КонецФункции

// Получает сообщения диалога
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//  Количество - Число - количество последних сообщений (0 - все сообщения)
//
// Возвращаемое значение:
//  Массив - массив структур с сообщениями
//
Функция ПолучитьСообщенияДиалога(СсылкаДиалога, Количество = 0) Экспорт
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	ОбеспечитьКорректныеИдентификаторыСообщений(Диалог);
	
	МассивСообщений = Новый Массив;
	
	ИндексНачала = 0;
	Если Количество > 0 Тогда
		ИндексНачала = Макс(0, Диалог.Сообщения.Количество() - Количество);
	КонецЕсли;
	
	Для Индекс = ИндексНачала По Диалог.Сообщения.Количество() - 1 Цикл
		
		Строка = Диалог.Сообщения[Индекс];
		
		СтруктураСообщения = Новый Структура;
		СтруктураСообщения.Вставить("Время", Строка.Время);
		СтруктураСообщения.Вставить("Автор", Строка.Автор);
		СтруктураСообщения.Вставить("ТипСообщения", Строка.ТипСообщения);
		СтруктураСообщения.Вставить("Текст", ОчиститьТекстДляXDTO(Строка.Текст));
		СтруктураСообщения.Вставить("ТекстКода", ОчиститьТекстДляXDTO(Строка.ТекстКода));
		СтруктураСообщения.Вставить("Статус", Строка.Статус);
		СтруктураСообщения.Вставить("UsageTokens", Строка.UsageTokens);
		СтруктураСообщения.Вставить("СтатусDSL", Строка.СтатусDSL);
		СтруктураСообщения.Вставить("УИД", Строка.УИД);
		СтруктураСообщения.Вставить("СкрытоеСлужебное", Строка.СкрытоеСлужебное);
		
		МассивСообщений.Добавить(СтруктураСообщения);
		
	КонецЦикла;
	
	Возврат МассивСообщений;
	
КонецФункции

Процедура ОбеспечитьКорректныеИдентификаторыСообщений(Диалог)
	Если Диалог = Неопределено Тогда
		ВызватьИсключение "Ошибка синхронизации сообщений: объект диалога не определен.";
	КонецЕсли;
	
	БылиИзменения = Ложь;
	ВстреченныеУИД = Новый Соответствие;
	
	Для Каждого СтрокаСообщения Из Диалог.Сообщения Цикл
		УИДСтроки = "";
		Если ЗначениеЗаполнено(СтрокаСообщения.УИД) Тогда
			УИДСтроки = СокрЛП(Строка(СтрокаСообщения.УИД));
		КонецЕсли;
		
		Если ПустаяСтрока(УИДСтроки) Тогда
			УИДСтроки = Строка(Новый УникальныйИдентификатор());
			СтрокаСообщения.УИД = Лев(УИДСтроки, 36);
			БылиИзменения = Истина;
		Иначе
			УИДСтроки = Лев(УИДСтроки, 36);
			Если УИДСтроки <> СтрокаСообщения.УИД Тогда
				СтрокаСообщения.УИД = УИДСтроки;
				БылиИзменения = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если ВстреченныеУИД.Получить(УИДСтроки) <> Неопределено Тогда
			ВызватьИсключение "Ошибка синхронизации сообщений: обнаружен дублирующийся УИД '" + УИДСтроки + "'.";
		КонецЕсли;
		ВстреченныеУИД.Вставить(УИДСтроки, Истина);
		
		НовоеСкрытоеСлужебное = ЭтоСкрытоеСлужебноеСообщение(
			СтрокаСообщения.Автор,
			СтрокаСообщения.ТипСообщения,
			СтрокаСообщения.Текст,
			СтрокаСообщения.ТекстКода
		);
		
		Если СтрокаСообщения.СкрытоеСлужебное = Неопределено 
			ИЛИ СтрокаСообщения.СкрытоеСлужебное <> НовоеСкрытоеСлужебное Тогда
			СтрокаСообщения.СкрытоеСлужебное = НовоеСкрытоеСлужебное;
			БылиИзменения = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если БылиИзменения Тогда
		Попытка
			Диалог.Записать();
		Исключение
			ВызватьИсключение "Ошибка записи УИД сообщений в диалог: " + ОписаниеОшибки();
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры

// Получает первое сообщение пользователя из диалога (исходную задачу)
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
// Возвращаемое значение:
//  Структура - структура с информацией о первом сообщении пользователя:
//   * Найдено - Булево - найдено ли сообщение
//   * Текст - Строка - текст сообщения
//
Функция ПолучитьПервоеСообщениеПользователя(СсылкаДиалога) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Найдено", Ложь);
	Результат.Вставить("Текст", "");
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	
	Если Диалог.Сообщения.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	// Ищем первое сообщение пользователя (исходную задачу)
	Для Индекс = 0 По Диалог.Сообщения.Количество() - 1 Цикл
		
		СтрокаСообщения = Диалог.Сообщения[Индекс];
		
		Если СтрокаСообщения.Автор = Перечисления.ИИА_АвторСообщения.Пользователь Тогда
			Результат.Найдено = Истина;
			Результат.Текст = СтрокаСообщения.Текст;
			Возврат Результат;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Получает последнее сообщение пользователя из диалога
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
// Возвращаемое значение:
//  Структура - структура с информацией о последнем сообщении пользователя:
//   * Найдено - Булево - найдено ли сообщение
//   * Текст - Строка - текст сообщения
//
Функция ПолучитьПоследнееСообщениеПользователя(СсылкаДиалога) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Найдено", Ложь);
	Результат.Вставить("Текст", "");
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	
	Если Диалог.Сообщения.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	// Ищем последнее сообщение пользователя
	Индекс = Диалог.Сообщения.Количество() - 1;
	Пока Индекс >= 0 Цикл
		
		СтрокаСообщения = Диалог.Сообщения[Индекс];
		
		Если СтрокаСообщения.Автор = Перечисления.ИИА_АвторСообщения.Пользователь Тогда
			Результат.Найдено = Истина;
			Результат.Текст = СтрокаСообщения.Текст;
			Возврат Результат;
		КонецЕсли;
		
		Индекс = Индекс - 1;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Инициализирует план выполнения задачи в диалоге
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
// Возвращаемое значение:
//  Булево - Истина, если план успешно создан
//
// Функции планирования и оркестрации перенесены в модуль ИИА_Оркестратор

// Получает последнее DSL сообщение и его статус
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
// Возвращаемое значение:
//  Структура - структура с информацией о последнем DSL сообщении:
//   * Найдено - Булево - найдено ли сообщение
//   * СтатусDSL - ПеречислениеСсылка.ИИА_СтатусDSL - статус DSL
//   * ТекстКода - Строка - текст DSL
//
Функция ПолучитьПоследнееDSLСообщение(СсылкаДиалога) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Найдено", Ложь);
	Результат.Вставить("СтатусDSL", Неопределено);
	Результат.Вставить("ТекстКода", "");
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	
	Если Диалог.Сообщения.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	// Ищем последнее сообщение с DSL (тип Код)
	Индекс = Диалог.Сообщения.Количество() - 1;
	Пока Индекс >= 0 Цикл
		
		СтрокаСообщения = Диалог.Сообщения[Индекс];
		
		Если СтрокаСообщения.ТипСообщения = Перечисления.ИИА_ТипСообщения.Код 
			И НЕ ПустаяСтрока(СтрокаСообщения.ТекстКода) Тогда
			Результат.Найдено = Истина;
			Результат.СтатусDSL = СтрокаСообщения.СтатусDSL;
			Результат.ТекстКода = СтрокаСообщения.ТекстКода;
			Возврат Результат;
		КонецЕсли;
		
		Индекс = Индекс - 1;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Получает общее количество использованных токенов в диалоге
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
// Возвращаемое значение:
//  Число - общее количество использованных токенов
//
Функция ПолучитьОбщееКоличествоТокенов(СсылкаДиалога) Экспорт
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	
	ОбщееКоличествоТокенов = 0;
	
	Для Каждого СтрокаСообщения Из Диалог.Сообщения Цикл
		Если ЗначениеЗаполнено(СтрокаСообщения.UsageTokens) Тогда
			ОбщееКоличествоТокенов = ОбщееКоличествоТокенов + СтрокаСообщения.UsageTokens;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ОбщееКоличествоТокенов;
	
КонецФункции

// Возвращает структуру данных диалога из регистра ИИА_ДанныеДиалогов (или Неопределено/пустую структуру).
//
Функция ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Неопределено;
	КонецЕсли;
	МенеджерЗаписи = РегистрыСведений.ИИА_ДанныеДиалогов.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Диалог = СсылкаДиалога;
	МенеджерЗаписи.Прочитать();
	Если НЕ МенеджерЗаписи.Выбран() Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(МенеджерЗаписи.ХранилищеЗначения) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Данные = МенеджерЗаписи.ХранилищеЗначения.Получить();
		Если ТипЗнч(Данные) = Тип("Структура") Тогда
			Возврат Данные;
		КонецЕсли;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

// Записывает структуру данных диалога в регистр ИИА_ДанныеДиалогов.
// Сохраняет ОркестраторВключен, чтобы не сбрасывать флаг оркестратора.
//
Процедура ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) ИЛИ СсылкаДиалога.Пустая() Тогда
		Возврат;
	КонецЕсли;
	Если ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	МенеджерЗаписи = РегистрыСведений.ИИА_ДанныеДиалогов.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Диалог = СсылкаДиалога;
	МенеджерЗаписи.Прочитать();
	Если НЕ МенеджерЗаписи.Выбран() Тогда
		МенеджерЗаписи.Диалог = СсылкаДиалога;
		МенеджерЗаписи.ОркестраторВключен = Ложь;
		МенеджерЗаписи.ХранилищеЗначения = Новый ХранилищеЗначения(СтруктураДанных);
	Иначе
		СохранитьОркестратор = МенеджерЗаписи.ОркестраторВключен = Истина;
		МенеджерЗаписи.ХранилищеЗначения = Новый ХранилищеЗначения(СтруктураДанных);
		МенеджерЗаписи.ОркестраторВключен = СохранитьОркестратор;
	КонецЕсли;
	МенеджерЗаписи.Записать();
КонецПроцедуры

Процедура ДобавитьСобытиеОркестратораВИсториюВДанных(СтруктураДанных, ВидСобытия, Стадия = "", Переход = "", ПопыткаНомер = 0, Детали = Неопределено)
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	НормВидСобытия = НормализоватьТипEventHistory(ВидСобытия);
	Если ПустаяСтрока(НормВидСобытия) Тогда
		Возврат;
	КонецЕсли;
	НормПереход = НормализоватьTransitionEventHistory(Переход);
	
	История = Новый Массив;
	Если СтруктураДанных.Свойство("Оркестратор_ИсторияСобытий")
		И ТипЗнч(СтруктураДанных.Оркестратор_ИсторияСобытий) = Тип("Массив") Тогда
		История = СтруктураДанных.Оркестратор_ИсторияСобытий;
	КонецЕсли;
	
	Событие = Новый Структура;
	Событие.Вставить("timestamp", ТекущаяДатаСеанса());
	Событие.Вставить("event_type", НормВидСобытия);
	Событие.Вставить("stage", Стадия);
	Событие.Вставить("transition", НормПереход);
	Событие.Вставить("attempt", ПопыткаНомер);
	Если Детали <> Неопределено Тогда
		Событие.Вставить("details", Детали);
	КонецЕсли;
	
	История.Добавить(Событие);
	Пока История.Количество() > 200 Цикл
		История.Удалить(0);
	КонецЦикла;
	
	СтруктураДанных.Вставить("Оркестратор_ИсторияСобытий", История);
КонецПроцедуры

Процедура ОбновитьЧекпоинтОркестратораВДанных(СтруктураДанных, ВидЧекпоинта, Стадия = "", Переход = "", ПопыткаНомер = 0, Детали = Неопределено)
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	НормВидЧекпоинта = НормализоватьТипCheckpointTrace(ВидЧекпоинта);
	Если ПустаяСтрока(НормВидЧекпоинта) Тогда
		Возврат;
	КонецЕсли;
	
	Чекпоинт = Новый Структура;
	Чекпоинт.Вставить("timestamp", ТекущаяДатаСеанса());
	Чекпоинт.Вставить("checkpoint_type", НормВидЧекпоинта);
	Чекпоинт.Вставить("stage", Стадия);
	Чекпоинт.Вставить("transition", Переход);
	Чекпоинт.Вставить("attempt", ПопыткаНомер);
	Если Детали <> Неопределено Тогда
		Чекпоинт.Вставить("details", Детали);
	КонецЕсли;
	
	ИсторияЧекпоинтов = Новый Массив;
	Если СтруктураДанных.Свойство("Оркестратор_ИсторияЧекпоинтов")
		И ТипЗнч(СтруктураДанных.Оркестратор_ИсторияЧекпоинтов) = Тип("Массив") Тогда
		ИсторияЧекпоинтов = СтруктураДанных.Оркестратор_ИсторияЧекпоинтов;
	КонецЕсли;
	
	ИсторияЧекпоинтов.Добавить(Чекпоинт);
	Пока ИсторияЧекпоинтов.Количество() > 50 Цикл
		ИсторияЧекпоинтов.Удалить(0);
	КонецЦикла;
	
	СтруктураДанных.Вставить("Оркестратор_ПоследнийЧекпоинт", Чекпоинт);
	СтруктураДанных.Вставить("Оркестратор_ИсторияЧекпоинтов", ИсторияЧекпоинтов);
КонецПроцедуры

Функция ПолучитьСырыеВложенияДиалога(СсылкаДиалога)
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Вложения") И ТипЗнч(СтруктураДанных.Вложения) = Тип("Массив") Тогда
		Возврат СтруктураДанных.Вложения;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПодготовитьВложениеДляВозвратаКлиенту(Вложение)
	Если Вложение = Неопределено ИЛИ ТипЗнч(Вложение) <> Тип("Структура") Тогда
		Возврат Новый Структура;
	КонецЕсли;
	КлючиДляКлиента = Новый Массив;
	КлючиДляКлиента.Добавить("id");
	КлючиДляКлиента.Добавить("added_at");
	КлючиДляКлиента.Добавить("file_name");
	КлючиДляКлиента.Добавить("file_path");
	КлючиДляКлиента.Добавить("extension");
	КлючиДляКлиента.Добавить("kind");
	КлючиДляКлиента.Добавить("size_bytes");
	КлючиДляКлиента.Добавить("extracted_text");
	КлючиДляКлиента.Добавить("summary");
	КлючиДляКлиента.Добавить("mime_type");
	КлючиДляКлиента.Добавить("native_transport");
	Результат = Новый Структура;
	Для Каждого Ключ Из КлючиДляКлиента Цикл
		ЗначениеПоля = Неопределено;
		Если Вложение.Свойство(Ключ, ЗначениеПоля) Тогда
			Результат.Вставить(Ключ, ЗначениеПоля);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ПолучитьВложенияДиалога(СсылкаДиалога) Экспорт
	СырыеВложения = ПолучитьСырыеВложенияДиалога(СсылкаДиалога);
	Результат = Новый Массив;
	Для Каждого Вложение Из СырыеВложения Цикл
		Результат.Добавить(ПодготовитьВложениеДляВозвратаКлиенту(Вложение));
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция СохранитьДвоичныеДанныеВоВременныйФайл(ДвоичныеДанныеФайла, ИмяФайла)
	Расширение = ПолучитьРасширениеФайлаВНижнемРегистре(ИмяФайла);
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла(?(ПустаяСтрока(Расширение), "", Расширение));
	ДвоичныеДанныеФайла.Записать(ИмяВременногоФайла);
	Возврат ИмяВременногоФайла;
КонецФункции

Функция ПолучитьРасширениеФайлаВНижнемРегистре(ПутьКФайлу)
	ФайлПоПути = Новый Файл(ПутьКФайлу);
	ИмяФайла = ФайлПоПути.Имя;
	ПозицияТочки = СтрНайти(ИмяФайла, ".");
	Если ПозицияТочки <= 0 Тогда
		Возврат "";
	КонецЕсли;
	Пока ПозицияТочки > 0 Цикл
		СледующаяТочка = СтрНайти(Сред(ИмяФайла, ПозицияТочки + 1), ".");
		Если СледующаяТочка <= 0 Тогда
			Прервать;
		КонецЕсли;
		ПозицияТочки = ПозицияТочки + СледующаяТочка;
	КонецЦикла;
	Возврат НРег(Сред(ИмяФайла, ПозицияТочки + 1));
КонецФункции

Функция ОпределитьВидВложенияПоРасширению(Расширение)
	Если Расширение = "csv" ИЛИ Расширение = "tsv" ИЛИ Расширение = "mxl" ИЛИ Расширение = "xls" ИЛИ Расширение = "xlsx" Тогда
		Возврат "table";
	КонецЕсли;
	Если Расширение = "txt" ИЛИ Расширение = "md" ИЛИ Расширение = "json" ИЛИ Расширение = "xml" ИЛИ Расширение = "log" ИЛИ Расширение = "bsl" ИЛИ Расширение = "doc" ИЛИ Расширение = "docx" Тогда
		Возврат "text";
	КонецЕсли;
	Если Расширение = "png" ИЛИ Расширение = "jpg" ИЛИ Расширение = "jpeg" ИЛИ Расширение = "bmp" ИЛИ Расширение = "gif" ИЛИ Расширение = "webp" Тогда
		Возврат "image";
	КонецЕсли;
	Если Расширение = "pdf" Тогда
		Возврат "pdf";
	КонецЕсли;
	Возврат "unknown";
КонецФункции

Функция ОпределитьMimeТипВложения(Расширение)
	Если Расширение = "png" Тогда
		Возврат "image/png";
	ИначеЕсли Расширение = "jpg" ИЛИ Расширение = "jpeg" Тогда
		Возврат "image/jpeg";
	ИначеЕсли Расширение = "gif" Тогда
		Возврат "image/gif";
	ИначеЕсли Расширение = "webp" Тогда
		Возврат "image/webp";
	ИначеЕсли Расширение = "bmp" Тогда
		Возврат "image/bmp";
	ИначеЕсли Расширение = "pdf" Тогда
		Возврат "application/pdf";
	ИначеЕсли Расширение = "docx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
	ИначеЕсли Расширение = "doc" Тогда
		Возврат "application/msword";
	ИначеЕсли Расширение = "xlsx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
	ИначеЕсли Расширение = "xls" Тогда
		Возврат "application/vnd.ms-excel";
	ИначеЕсли Расширение = "csv" Тогда
		Возврат "text/csv";
	ИначеЕсли Расширение = "tsv" Тогда
		Возврат "text/tsv";
	ИначеЕсли Расширение = "txt" Тогда
		Возврат "text/plain";
	КонецЕсли;
	Возврат "application/octet-stream";
КонецФункции

Функция ЭтоНативноеВложениеДляМодели(ВидВложения, Расширение)
	Возврат ВидВложения = "image" ИЛИ Расширение = "pdf";
КонецФункции

Функция ОграничитьТекстДляВложения(Текст, Максимум = 6000)
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	Результат = СокрЛП(Текст);
	Если СтрДлина(Результат) > Максимум Тогда
		Результат = Лев(Результат, Максимум) + Символы.ПС + "...(truncated)";
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ОграничитьТекстДляПромптаВложения(Текст, Максимум = 2000)
	Возврат ОграничитьТекстДляВложения(ОчиститьТекстДляXDTO(Текст), Максимум);
КонецФункции

Функция ОчиститьТекстДляXDTO(Текст)
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	Результат = "";
	Для Позиция = 1 По СтрДлина(Текст) Цикл
		Символ = Сред(Текст, Позиция, 1);
		Код = КодСимвола(Символ);
		Если Код = 9 ИЛИ Код = 10 ИЛИ Код = 13 ИЛИ Код >= 32 Тогда
			Результат = Результат + Символ;
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ПрочитатьТекстФайлаДляВложения(ПутьКФайлу)
	Кодировки = Новый Массив;
	Кодировки.Добавить(КодировкаТекста.UTF8);
	Кодировки.Добавить(КодировкаТекста.UTF16);
	Попытка
		Кодировки.Добавить(КодировкаТекста.ANSI);
	Исключение
	КонецПопытки;
	Попытка
		Кодировки.Добавить(КодировкаТекста.OEM);
	Исключение
	КонецПопытки;
	
	Для Каждого Кодировка Из Кодировки Цикл
		Попытка
			ТекстовыйДокумент = Новый ТекстовыйДокумент;
			ТекстовыйДокумент.Прочитать(ПутьКФайлу, Кодировка);
			Возврат ТекстовыйДокумент.ПолучитьТекст();
		Исключение
		КонецПопытки;
	КонецЦикла;
	
	Попытка
		ТекстовыйДокумент = Новый ТекстовыйДокумент;
		ТекстовыйДокумент.Прочитать(ПутьКФайлу);
		Возврат ТекстовыйДокумент.ПолучитьТекст();
	Исключение
		Возврат "";
	КонецПопытки;
КонецФункции

Функция ТекстВложенияПустойПоСодержимому(Текст)
	Если НЕ ЗначениеЗаполнено(Текст) Тогда
		Возврат Истина;
	КонецЕсли;
	НормализованныйТекст = Строка(Текст);
	НормализованныйТекст = СтрЗаменить(НормализованныйТекст, Символы.ВК, "");
	НормализованныйТекст = СтрЗаменить(НормализованныйТекст, Символы.ПС, "");
	НормализованныйТекст = СтрЗаменить(НормализованныйТекст, Символы.Таб, "");
	НормализованныйТекст = СокрЛП(НормализованныйТекст);
	Возврат ПустаяСтрока(НормализованныйТекст);
КонецФункции

Функция ОпределитьРазделительТаблицы(ПерваяСтрока)
	Кандидаты = Новый Массив;
	Кандидаты.Добавить(";");
	Кандидаты.Добавить(",");
	Кандидаты.Добавить(Символы.ВТаб);
	ЛучшийРазделитель = ";";
	ЛучшееКоличество = -1;
	Для Каждого Кандидат Из Кандидаты Цикл
		Количество = СтрЧислоВхождений(ПерваяСтрока, Кандидат);
		Если Количество > ЛучшееКоличество Тогда
			ЛучшееКоличество = Количество;
			ЛучшийРазделитель = Кандидат;
		КонецЕсли;
	КонецЦикла;
	Возврат ЛучшийРазделитель;
КонецФункции

Функция ПостроитьСводкуТаблицыИзТекста(ТекстТаблицы)
	Если ПустаяСтрока(ТекстТаблицы) Тогда
		Возврат "";
	КонецЕсли;
	Строки = СтрРазделить(СтрЗаменить(ТекстТаблицы, Символы.ВК, ""), Символы.ПС);
	Если Строки.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	ПерваяНепустаяСтрока = "";
	Для Каждого СтрокаТаблицы Из Строки Цикл
		Если НЕ ПустаяСтрока(СокрЛП(СтрокаТаблицы)) Тогда
			ПерваяНепустаяСтрока = СтрокаТаблицы;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если ПустаяСтрока(ПерваяНепустаяСтрока) Тогда
		Возврат "";
	КонецЕсли;
	Разделитель = ОпределитьРазделительТаблицы(ПерваяНепустаяСтрока);
	Результат = "ТАБЛИЦА (preview):" + Символы.ПС;
	НомерСтроки = 0;
	Для Каждого СтрокаТаблицы Из Строки Цикл
		Если ПустаяСтрока(СокрЛП(СтрокаТаблицы)) Тогда
			Продолжить;
		КонецЕсли;
		Колонки = СтрРазделить(СтрокаТаблицы, Разделитель);
		СтрокаPreview = "";
		ПределКолонок = Мин(Колонки.Количество(), 8);
		Для ИндексКолонки = 0 По ПределКолонок - 1 Цикл
			Если НЕ ПустаяСтрока(СтрокаPreview) Тогда
				СтрокаPreview = СтрокаPreview + " | ";
			КонецЕсли;
			СтрокаPreview = СтрокаPreview + СокрЛП(Колонки[ИндексКолонки]);
		КонецЦикла;
		Результат = Результат + СтрокаPreview + Символы.ПС;
		НомерСтроки = НомерСтроки + 1;
		Если НомерСтроки >= 10 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Возврат ОграничитьТекстДляВложения(Результат, 4000);
КонецФункции

Функция ИзвлечьТекстИзТабличногоДокументаДляВложения(ПутьКФайлу)
	Попытка
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ПутьКФайлу);
		ТекстТабДок = ТабДок.Текст;
		Если НЕ ПустаяСтрока(СокрЛП(ТекстТабДок)) Тогда
			Возврат ОчиститьТекстДляXDTO(ТекстТабДок);
		КонецЕсли;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	Возврат "";
КонецФункции

Функция ПрочитатьДвоичныеДанныеФайла(ПутьКФайлу)
	Попытка
		Возврат Новый ДвоичныеДанные(ПутьКФайлу);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция ПодготовитьНативныйDataUrl(ДвоичныеДанныеФайла, MimeТип)
	Возврат "data:" + MimeТип + ";base64," + Base64Строка(ДвоичныеДанныеФайла);
КонецФункции

Функция ПолучитьНативныеВложенияДляМодели(СсылкаДиалога) Экспорт
	СырыеВложения = ПолучитьСырыеВложенияДиалога(СсылкаДиалога);
	Результат = Новый Массив;
	Для Каждого Вложение Из СырыеВложения Цикл
		Если НЕ Вложение.Свойство("native_binary") Тогда
			Продолжить;
		КонецЕсли;
		Если ТипЗнч(Вложение.native_binary) <> Тип("ХранилищеЗначения") Тогда
			Продолжить;
		КонецЕсли;
		ДвоичныеДанныеФайла = Вложение.native_binary.Получить();
		Если ДвоичныеДанныеФайла = Неопределено ИЛИ ТипЗнч(ДвоичныеДанныеФайла) <> Тип("ДвоичныеДанные") Тогда
			Продолжить;
		КонецЕсли;
		НативноеВложение = Новый Структура;
		НативноеВложение.Вставить("id", ?(Вложение.Свойство("id"), Строка(Вложение.id), ""));
		НативноеВложение.Вставить("file_name", ?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), ""));
		НативноеВложение.Вставить("kind", ?(Вложение.Свойство("kind"), Строка(Вложение.kind), ""));
		НативноеВложение.Вставить("mime_type", ?(Вложение.Свойство("mime_type"), Строка(Вложение.mime_type), "application/octet-stream"));
		НативноеВложение.Вставить("native_transport", ?(Вложение.Свойство("native_transport"), Строка(Вложение.native_transport), ""));
		НативноеВложение.Вставить("data_url", ПодготовитьНативныйDataUrl(ДвоичныеДанныеФайла, НативноеВложение.mime_type));
		Результат.Добавить(НативноеВложение);
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция СформироватьТекстСообщенияОВложении(Вложение)
	ИмяФайла = ?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), "файл");
	ВидВложения = ?(Вложение.Свойство("kind"), Строка(Вложение.kind), "unknown");
	Текст = "[Вложение] " + ИмяФайла + " (" + ВидВложения + ")";
	Если Вложение.Свойство("summary") И НЕ ПустаяСтрока(Строка(Вложение.summary)) Тогда
		Текст = Текст + Символы.ПС + Строка(Вложение.summary);
	КонецЕсли;
	Возврат ОчиститьТекстДляXDTO(Текст);
КонецФункции

Функция ДобавитьВложениеИзДвоичныхДанных(СсылкаДиалога, ИмяФайла, ДвоичныеДанныеФайла) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		ВызватьИсключение "Не выбран диалог для добавления вложения.";
	КонецЕсли;
	ИмяФайла = СокрЛП(ИмяФайла);
	Если ПустаяСтрока(ИмяФайла) Тогда
		ВызватьИсключение "Имя файла не указано.";
	КонецЕсли;
	Если ДвоичныеДанныеФайла = Неопределено Тогда
		ВызватьИсключение "Двоичные данные файла не переданы.";
	КонецЕсли;

	ВременныйФайл = СохранитьДвоичныеДанныеВоВременныйФайл(ДвоичныеДанныеФайла, ИмяФайла);
	Возврат ДобавитьВложениеИзФайла(СсылкаДиалога, ВременныйФайл, ИмяФайла);
КонецФункции

Функция ДобавитьВложениеИзВременногоХранилища(СсылкаДиалога, ИмяФайла, АдресВременногоХранилища) Экспорт
	Если ПустаяСтрока(СокрЛП(Строка(АдресВременногоХранилища))) Тогда
		ВызватьИсключение "Адрес временного хранилища не указан.";
	КонецЕсли;
	ДанныеИзХранилища = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
	Если ДанныеИзХранилища = Неопределено Тогда
		ВызватьИсключение "Не удалось получить файл из временного хранилища.";
	КонецЕсли;
	Если ТипЗнч(ДанныеИзХранилища) = Тип("ДвоичныеДанные") Тогда
		Возврат ДобавитьВложениеИзДвоичныхДанных(СсылкаДиалога, ИмяФайла, ДанныеИзХранилища);
	КонецЕсли;
	Если ТипЗнч(ДанныеИзХранилища) = Тип("ХранилищеЗначения") Тогда
		ДвоичныеДанныеФайла = ДанныеИзХранилища.Получить();
		Если ТипЗнч(ДвоичныеДанныеФайла) = Тип("ДвоичныеДанные") Тогда
			Возврат ДобавитьВложениеИзДвоичныхДанных(СсылкаДиалога, ИмяФайла, ДвоичныеДанныеФайла);
		КонецЕсли;
	КонецЕсли;
	ВызватьИсключение "Во временном хранилище не найдено значение типа ДвоичныеДанные.";
КонецФункции

Функция ДобавитьВложениеИзФайла(СсылкаДиалога, ПутьКФайлу, ОтображаемоеИмяФайла = "") Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		ВызватьИсключение "Не выбран диалог для добавления вложения.";
	КонецЕсли;
	ПутьКФайлу = СокрЛП(ПутьКФайлу);
	Если ПустаяСтрока(ПутьКФайлу) Тогда
		ВызватьИсключение "Путь к файлу не указан.";
	КонецЕсли;

	ФайлВложения = Новый Файл(ПутьКФайлу);
	Если НЕ ФайлВложения.Существует() Тогда
		ВызватьИсключение "Файл не найден: " + ПутьКФайлу;
	КонецЕсли;

	Расширение = ПолучитьРасширениеФайлаВНижнемРегистре(ПутьКФайлу);
	ВидВложения = ОпределитьВидВложенияПоРасширению(Расширение);
	MimeТип = ОпределитьMimeТипВложения(Расширение);
	ИзвлеченныйТекст = "";
	КраткаяСводка = "";
	НативныйБинарник = Неопределено;
	ФайлПустой = Ложь;
	Попытка
		ФайлПустой = ФайлВложения.Размер() = 0;
	Исключение
		ФайлПустой = Ложь;
	КонецПопытки;

	Если ВидВложения = "text" Тогда
		Если Расширение = "doc" ИЛИ Расширение = "docx" Тогда
			ИзвлеченныйТекст = ИзвлечьТекстИзТабличногоДокументаДляВложения(ПутьКФайлу);
			Если ПустаяСтрока(ИзвлеченныйТекст) Тогда
				ИзвлеченныйТекст = ОчиститьТекстДляXDTO(ПрочитатьТекстФайлаДляВложения(ПутьКФайлу));
			КонецЕсли;
		Иначе
			ИзвлеченныйТекст = ОчиститьТекстДляXDTO(ПрочитатьТекстФайлаДляВложения(ПутьКФайлу));
		КонецЕсли;
		Если ФайлПустой ИЛИ ТекстВложенияПустойПоСодержимому(ИзвлеченныйТекст) Тогда
			КраткаяСводка = "Файл пуст.";
		Иначе
			КраткаяСводка = ?(ПустаяСтрока(ИзвлеченныйТекст), "Текст не удалось прочитать.", "Извлечен текст из файла.");
		КонецЕсли;
	ИначеЕсли ВидВложения = "table" Тогда
		Если Расширение = "mxl" ИЛИ Расширение = "xls" ИЛИ Расширение = "xlsx" Тогда
			ИзвлеченныйТекст = ИзвлечьТекстИзТабличногоДокументаДляВложения(ПутьКФайлу);
		Иначе
			ИзвлеченныйТекст = ОчиститьТекстДляXDTO(ПрочитатьТекстФайлаДляВложения(ПутьКФайлу));
		КонецЕсли;
		КраткаяСводка = ОчиститьТекстДляXDTO(ПостроитьСводкуТаблицыИзТекста(ИзвлеченныйТекст));
		Если ПустаяСтрока(КраткаяСводка) Тогда
			Если Расширение = "xls" ИЛИ Расширение = "xlsx" Тогда
				КраткаяСводка = "Excel-файл прочитан через ТабличныйДокумент. Табличный preview построить не удалось.";
			Иначе
				КраткаяСводка = "Табличный preview построить не удалось.";
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ВидВложения = "image" Тогда
		КраткаяСводка = "Изображение зарегистрировано. Для совместимых моделей передается нативно.";
	ИначеЕсли ВидВложения = "pdf" Тогда
		КраткаяСводка = "PDF зарегистрирован. Для совместимых моделей передается нативно.";
	Иначе
		КраткаяСводка = "Файл зарегистрирован как неизвестный тип. Автоизвлечение содержимого не выполнено.";
	КонецЕсли;
	
	Если ЭтоНативноеВложениеДляМодели(ВидВложения, Расширение) Тогда
		НативныйБинарник = ПрочитатьДвоичныеДанныеФайла(ПутьКФайлу);
	КонецЕсли;

	Вложение = Новый Структура;
	Вложение.Вставить("id", Строка(Новый УникальныйИдентификатор()));
	Вложение.Вставить("added_at", ТекущаяДата());
	Если ПустаяСтрока(ОтображаемоеИмяФайла) Тогда
		ОтображаемоеИмяФайла = ФайлВложения.Имя;
	КонецЕсли;
	Вложение.Вставить("file_name", ОтображаемоеИмяФайла);
	Вложение.Вставить("file_path", ПутьКФайлу);
	Вложение.Вставить("extension", Расширение);
	Вложение.Вставить("kind", ВидВложения);
	Вложение.Вставить("mime_type", MimeТип);
	Вложение.Вставить("native_transport", ?(ВидВложения = "image", "image_url", ?(ВидВложения = "pdf", "file", "")));
	РазмерФайла = 0;
	Попытка
		РазмерФайла = ФайлВложения.Размер();
	Исключение
		РазмерФайла = 0;
	КонецПопытки;
	Вложение.Вставить("size_bytes", РазмерФайла);
	Вложение.Вставить("extracted_text", ОчиститьТекстДляXDTO(ИзвлеченныйТекст));
	Вложение.Вставить("summary", ОчиститьТекстДляXDTO(КраткаяСводка));
	Если НативныйБинарник <> Неопределено Тогда
		Вложение.Вставить("native_binary", Новый ХранилищеЗначения(НативныйБинарник));
	КонецЕсли;

	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	Вложения = Новый Массив;
	Если СтруктураДанных.Свойство("Вложения") И ТипЗнч(СтруктураДанных.Вложения) = Тип("Массив") Тогда
		Вложения = СтруктураДанных.Вложения;
	КонецЕсли;
	Вложения.Добавить(Вложение);
	СтруктураДанных.Вставить("Вложения", Вложения);
	ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);

	ДобавитьСообщениеВДиалог(
		СсылкаДиалога,
		Перечисления.ИИА_АвторСообщения.Пользователь,
		Перечисления.ИИА_ТипСообщения.Текст,
		СформироватьТекстСообщенияОВложении(Вложение)
	);
	ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[ATTACHMENT] Добавлено вложение: " + ФайлВложения.Имя + ", kind=" + ВидВложения);

	Возврат Вложение;
КонецФункции

Функция НайтиВложениеДиалога(СсылкаДиалога, ИдентификаторИлиИмя = "") Экспорт
	Вложения = ПолучитьВложенияДиалога(СсылкаДиалога);
	Если Вложения = Неопределено ИЛИ Вложения.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	КлючПоиска = СокрЛП(Строка(ИдентификаторИлиИмя));
	Если ПустаяСтрока(КлючПоиска) Тогда
		Возврат Вложения[Вложения.Количество() - 1];
	КонецЕсли;
	Индекс = Вложения.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Вложение = Вложения[Индекс];
		Если (Вложение.Свойство("id") И Строка(Вложение.id) = КлючПоиска)
			ИЛИ (Вложение.Свойство("file_name") И Строка(Вложение.file_name) = КлючПоиска) Тогда
			Возврат Вложение;
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	КлючПоискаВРег = ВРег(КлючПоиска);
	Индекс = Вложения.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Вложение = Вложения[Индекс];
		Если Вложение.Свойство("file_name") И СтрНайти(ВРег(Строка(Вложение.file_name)), КлючПоискаВРег) > 0 Тогда
			Возврат Вложение;
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция ПолучитьПолныйТекстВложения(СсылкаДиалога, ИдентификаторИлиИмя = "") Экспорт
	Вложение = НайтиВложениеДиалога(СсылкаДиалога, ИдентификаторИлиИмя);
	Если Вложение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Если Вложение.Свойство("extracted_text") Тогда
		Возврат ОчиститьТекстДляXDTO(Строка(Вложение.extracted_text));
	КонецЕсли;
	Возврат "";
КонецФункции

Функция НайтиВоВложениях(СсылкаДиалога, ИскомыйТекст, Лимит = 20, ИдентификаторИлиИмя = "") Экспорт
	Результаты = Новый Массив;
	Шаблон = СокрЛП(Строка(ИскомыйТекст));
	Если ПустаяСтрока(Шаблон) Тогда
		Возврат Результаты;
	КонецЕсли;
	Вложения = ПолучитьВложенияДиалога(СсылкаДиалога);
	Если Вложения = Неопределено ИЛИ Вложения.Количество() = 0 Тогда
		Возврат Результаты;
	КонецЕсли;
	Если Лимит <= 0 Тогда
		Лимит = 20;
	КонецЕсли;
	ФильтрВложения = Неопределено;
	Если НЕ ПустаяСтрока(СокрЛП(Строка(ИдентификаторИлиИмя))) Тогда
		ФильтрВложения = НайтиВложениеДиалога(СсылкаДиалога, ИдентификаторИлиИмя);
		Если ФильтрВложения = Неопределено Тогда
			Возврат Результаты;
		КонецЕсли;
	КонецЕсли;
	ШаблонВРег = ВРег(Шаблон);
	Для Каждого Вложение Из Вложения Цикл
		Если ФильтрВложения <> Неопределено И Строка(Вложение.id) <> Строка(ФильтрВложения.id) Тогда
			Продолжить;
		КонецЕсли;
		ТекстВложения = ?(Вложение.Свойство("extracted_text"), Строка(Вложение.extracted_text), "");
		Если ПустаяСтрока(ТекстВложения) Тогда
			Продолжить;
		КонецЕсли;
		Строки = СтрРазделить(СтрЗаменить(ТекстВложения, Символы.ВК, ""), Символы.ПС);
		НомерСтроки = 0;
		Для Каждого СтрокаВложения Из Строки Цикл
			НомерСтроки = НомерСтроки + 1;
			Если СтрНайти(ВРег(СтрокаВложения), ШаблонВРег) > 0 Тогда
				Совпадение = Новый Структура;
				Совпадение.Вставить("attachment_id", ?(Вложение.Свойство("id"), Строка(Вложение.id), ""));
				Совпадение.Вставить("file_name", ?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), ""));
				Совпадение.Вставить("line_no", НомерСтроки);
				Совпадение.Вставить("line_text", ОграничитьТекстДляПромптаВложения(СтрокаВложения, 500));
				Результаты.Добавить(Совпадение);
				Если Результаты.Количество() >= Лимит Тогда
					Возврат Результаты;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Результаты;
КонецФункции

Функция ПолучитьСводкуВложенийДляПромпта(СсылкаДиалога, Лимит = 3) Экспорт
	Вложения = ПолучитьВложенияДиалога(СсылкаДиалога);
	Если Вложения = Неопределено ИЛИ Вложения.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	Начало = Макс(0, Вложения.Количество() - Лимит);
	Результат = "КОНТЕКСТ ВЛОЖЕНИЙ:" + Символы.ПС;
	Для Индекс = Начало По Вложения.Количество() - 1 Цикл
		Вложение = Вложения[Индекс];
		Результат = Результат + "- Файл: " + ОчиститьТекстДляXDTO(?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), "файл"));
		Результат = Результат + "; тип=" + ОчиститьТекстДляXDTO(?(Вложение.Свойство("kind"), Строка(Вложение.kind), "unknown"));
		Если Вложение.Свойство("summary") И НЕ ПустаяСтрока(Строка(Вложение.summary)) Тогда
			Результат = Результат + Символы.ПС + "  summary: " + ОграничитьТекстДляПромптаВложения(Строка(Вложение.summary), 1200);
		КонецЕсли;
		Если Вложение.Свойство("extracted_text") И НЕ ПустаяСтрока(Строка(Вложение.extracted_text)) Тогда
			Результат = Результат + Символы.ПС + "  content: " + ОграничитьТекстДляПромптаВложения(Строка(Вложение.extracted_text), 2000);
		КонецЕсли;
		Результат = Результат + Символы.ПС;
	КонецЦикла;
	Возврат ОчиститьТекстДляXDTO(ОграничитьТекстДляВложения(Результат, 12000));
КонецФункции

// Очищает сохранённый контекст DSL для диалога (вызывать при завершении плана)
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
Процедура ОчиститьКонтекстDSLДиалога(СсылкаДиалога) Экспорт
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) ИЛИ СсылкаДиалога.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	КлючиDSL = Новый Массив;
	КлючиDSL.Добавить("DSL_СсылкаОбъекта");
	КлючиDSL.Добавить("DSL_ТипОбъекта");
	КлючиDSL.Добавить("DSL_ИмяОбъекта");
	
	ЕстьИзменения = Ложь;
	Для Каждого Ключ Из КлючиDSL Цикл
		Если СтруктураДанных.Свойство(Ключ) Тогда
			СтруктураДанных.Удалить(Ключ);
			ЕстьИзменения = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьИзменения Тогда
		ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает очередь mock-ответов для режима холостого хода (тесты без вызова ИИ).
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//  МассивMockОтветов - Массив - массив структур или строк (каждый элемент — mock для очередного вызова ИИ)
//
Процедура УстановитьОчередьMockОтветов(СсылкаДиалога, МассивMockОтветов) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) ИЛИ СсылкаДиалога.Пустая() Тогда
		Возврат;
	КонецЕсли;
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	СтруктураДанных.Вставить("MockОтветыОчередь", МассивMockОтветов);
	ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
КонецПроцедуры

// Очищает очередь mock-ответов для диалога.
//
Процедура ОчиститьОчередьMockОтветов(СсылкаДиалога) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) ИЛИ СсылкаДиалога.Пустая() Тогда
		Возврат;
	КонецЕсли;
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	Если СтруктураДанных.Свойство("MockОтветыОчередь") Тогда
		СтруктураДанных.Удалить("MockОтветыОчередь");
		ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	КонецЕсли;
КонецПроцедуры

// Получает список ключей из хранилища значений диалога (регистр ИИА_ДанныеДиалогов)
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
// Возвращаемое значение:
//  Массив - массив строк с ключами хранилища
//
Функция ПолучитьКлючиХранилища(СсылкаДиалога) Экспорт
	
	Результат = Новый Массив;
	
	Попытка
		СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
		Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
			Возврат Результат;
		КонецЕсли;
		
		Для Каждого КлючЗначение Из СтруктураДанных Цикл
			Результат.Добавить(КлючЗначение.Ключ);
		КонецЦикла;
		
	Исключение
		// В случае ошибки возвращаем пустой массив
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Инициализирует архитектурный контекст исполнения диалога:
// trace_id, prompt_version, режим выполнения DSL, capability-модель.
Процедура ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога, PromptVersion = "", DSLРежим = "commit") Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	
	Если ПустаяСтрока(PromptVersion) Тогда
		PromptVersion = ИИА_Промты.ПолучитьВерсиюПромптов();
		Если ПустаяСтрока(PromptVersion) Тогда
			ВызватьИсключение "Не удалось определить Prompt-Version для архитектурного контекста.";
		КонецЕсли;
	КонецЕсли;
	
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	
	Если НЕ СтруктураДанных.Свойство("trace_id") ИЛИ ПустаяСтрока(Строка(СтруктураДанных.trace_id)) Тогда
		СтруктураДанных.Вставить("trace_id", Строка(Новый УникальныйИдентификатор()));
	КонецЕсли;
	
	СтруктураДанных.Вставить("prompt_version", PromptVersion);
	СтруктураДанных.Вставить("DSL_РежимВыполнения", DSLРежим);
	
	Если НЕ СтруктураДанных.Свойство("DSL_Capabilities") ИЛИ ТипЗнч(СтруктураДанных.DSL_Capabilities) <> Тип("Массив") Тогда
		Capabilities = Новый Массив;
		Capabilities.Добавить("metadata.read");
		Capabilities.Добавить("data.read");
		Capabilities.Добавить("data.write.reference");
		Capabilities.Добавить("data.write.document");
		Capabilities.Добавить("admin.settings");
		СтруктураДанных.Вставить("DSL_Capabilities", Capabilities);
	КонецЕсли;
	
	ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
КонецПроцедуры

Функция ПолучитьКонтекстАрхитектуры(СсылкаДиалога) Экспорт
	Результат = Новый Структура("trace_id,prompt_version,DSL_РежимВыполнения,DSL_Capabilities", "", "", "commit", Новый Массив);
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("trace_id") Тогда
		Результат.trace_id = Строка(СтруктураДанных.trace_id);
	КонецЕсли;
	Если СтруктураДанных.Свойство("prompt_version") Тогда
		Результат.prompt_version = Строка(СтруктураДанных.prompt_version);
	КонецЕсли;
	Если СтруктураДанных.Свойство("DSL_РежимВыполнения") Тогда
		Результат.DSL_РежимВыполнения = Строка(СтруктураДанных.DSL_РежимВыполнения);
	КонецЕсли;
	Если СтруктураДанных.Свойство("DSL_Capabilities") Тогда
		Результат.DSL_Capabilities = СтруктураДанных.DSL_Capabilities;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьСостояниеОркестратора(СсылкаДиалога) Экспорт
	Результат = Новый Структура("ТекущаяСтадия,ПоследнийПереход,НомерПопытки,execution_policy,active_subgraph,subgraph_history,decision_log,active_step_id,thread_id", "Intent", "", 0, "", "", Новый Массив, Новый Массив, "", "");
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Оркестратор_Стадия") Тогда
		Результат.ТекущаяСтадия = Строка(СтруктураДанных.Оркестратор_Стадия);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Оркестратор_Переход") Тогда
		Результат.ПоследнийПереход = Строка(СтруктураДанных.Оркестратор_Переход);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Оркестратор_Попытка") Тогда
		Результат.НомерПопытки = СтруктураДанных.Оркестратор_Попытка;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Execution_Policy") Тогда
		Результат.execution_policy = Строка(СтруктураДанных.Execution_Policy);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Active_Subgraph") Тогда
		Результат.active_subgraph = Строка(СтруктураДанных.Active_Subgraph);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Subgraph_History") И ТипЗнч(СтруктураДанных.Subgraph_History) = Тип("Массив") Тогда
		Результат.subgraph_history = СтруктураДанных.Subgraph_History;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Decision_Log") И ТипЗнч(СтруктураДанных.Decision_Log) = Тип("Массив") Тогда
		Результат.decision_log = СтруктураДанных.Decision_Log;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Active_Step_Id") Тогда
		Результат.active_step_id = Строка(СтруктураДанных.Active_Step_Id);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Thread_Id") Тогда
		Результат.thread_id = Строка(СтруктураДанных.Thread_Id);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьDecisionTimeline(СсылкаДиалога, Лимит = 20) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат "";
	КонецЕсли;
	
	Состояние = ПолучитьСостояниеОркестратора(СсылкаДиалога);
	Если Состояние = Неопределено
		ИЛИ НЕ Состояние.Свойство("decision_log")
		ИЛИ ТипЗнч(Состояние.decision_log) <> Тип("Массив")
		ИЛИ Состояние.decision_log.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Если Лимит <= 0 Тогда
		Лимит = 20;
	КонецЕсли;
	
	НачальныйИндекс = Макс(0, Состояние.decision_log.Количество() - Лимит);
	СтрокиТаймлайна = Новый Массив;
	Для Индекс = НачальныйИндекс По Состояние.decision_log.Количество() - 1 Цикл
		ЗаписьРешения = Состояние.decision_log[Индекс];
		Если ТипЗнч(ЗаписьРешения) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		СтрокаРешения = "";
		Если ЗаписьРешения.Свойство("timestamp") И ЗаписьРешения.timestamp <> Неопределено Тогда
			СтрокаРешения = Формат(ЗаписьРешения.timestamp, "ДФ=dd.MM HH:mm:ss") + " | ";
		КонецЕсли;
		СтрокаРешения = СтрокаРешения + ?(ЗаписьРешения.Свойство("kind"), Строка(ЗаписьРешения.kind), "");
		СтрокаРешения = СтрокаРешения + " -> " + ?(ЗаписьРешения.Свойство("decision"), Строка(ЗаписьРешения.decision), "");
		Если ЗаписьРешения.Свойство("source") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.source)) Тогда
			СтрокаРешения = СтрокаРешения + " | source=" + Строка(ЗаписьРешения.source);
		КонецЕсли;
		Если ЗаписьРешения.Свойство("step_id") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.step_id)) Тогда
			СтрокаРешения = СтрокаРешения + " | step=" + Строка(ЗаписьРешения.step_id);
		КонецЕсли;
		Если ЗаписьРешения.Свойство("policy") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.policy)) Тогда
			СтрокаРешения = СтрокаРешения + " | policy=" + Строка(ЗаписьРешения.policy);
		КонецЕсли;
		Если ЗаписьРешения.Свойство("reason") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.reason)) Тогда
			СтрокаРешения = СтрокаРешения + " | reason=" + Строка(ЗаписьРешения.reason);
		КонецЕсли;
		СтрокиТаймлайна.Добавить(СтрокаРешения);
	КонецЦикла;
	
	Возврат СтрСоединить(СтрокиТаймлайна, Символы.ПС);
КонецФункции

Функция СоздатьСобытиеRuntimeTrace(TraceType, Timestamp = Неопределено) Экспорт
	Событие = Новый Структура;
	Событие.Вставить("timestamp", Timestamp);
	Событие.Вставить("trace_type", TraceType);
	Событие.Вставить("kind", "");
	Событие.Вставить("decision", "");
	Событие.Вставить("source", "");
	Событие.Вставить("step_id", "");
	Событие.Вставить("policy", "");
	Событие.Вставить("reason", "");
	Событие.Вставить("subgraph", "");
	Событие.Вставить("stage", "");
	Событие.Вставить("transition", "");
	Событие.Вставить("attempt", 0);
	Событие.Вставить("trace_id", "");
	Событие.Вставить("thread_id", "");
	Событие.Вставить("details", Неопределено);
	Возврат Событие;
КонецФункции

Процедура ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Details)
	Если Событие = Неопределено
		ИЛИ ТипЗнч(Событие) <> Тип("Структура")
		ИЛИ Details = Неопределено
		ИЛИ ТипЗнч(Details) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	Если Details.Свойство("source") И НЕ ПустаяСтрока(Строка(Details.source)) Тогда
		Событие.source = Строка(Details.source);
	КонецЕсли;
	Если Details.Свойство("step_id") И НЕ ПустаяСтрока(Строка(Details.step_id)) Тогда
		Событие.step_id = Строка(Details.step_id);
	ИначеЕсли Details.Свойство("active_step_id") И НЕ ПустаяСтрока(Строка(Details.active_step_id)) Тогда
		Событие.step_id = Строка(Details.active_step_id);
	КонецЕсли;
	Если Details.Свойство("policy") И НЕ ПустаяСтрока(Строка(Details.policy)) Тогда
		Событие.policy = Строка(Details.policy);
	ИначеЕсли Details.Свойство("policy_id") И НЕ ПустаяСтрока(Строка(Details.policy_id)) Тогда
		Событие.policy = Строка(Details.policy_id);
	КонецЕсли;
	Если Details.Свойство("reason") И НЕ ПустаяСтрока(Строка(Details.reason)) Тогда
		Событие.reason = Строка(Details.reason);
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьRuntimeTrace(СсылкаДиалога, Лимит = 100) Экспорт
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	Если Лимит <= 0 Тогда
		Лимит = 100;
	КонецЕсли;
	
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	TraceId = ?(СтруктураДанных.Свойство("trace_id"), Строка(СтруктураДанных.trace_id), "");
	ThreadId = ?(СтруктураДанных.Свойство("Thread_Id"), Строка(СтруктураДанных.Thread_Id), "");
	
	Если СтруктураДанных.Свойство("Оркестратор_ИсторияСобытий")
		И ТипЗнч(СтруктураДанных.Оркестратор_ИсторияСобытий) = Тип("Массив") Тогда
		Для Каждого ИстСобытие Из СтруктураДанных.Оркестратор_ИсторияСобытий Цикл
			Если ТипЗнч(ИстСобытие) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Событие = СоздатьСобытиеRuntimeTrace("event_history", ?(ИстСобытие.Свойство("timestamp"), ИстСобытие.timestamp, Неопределено));
			Событие.kind = ?(ИстСобытие.Свойство("event_type"), Строка(ИстСобытие.event_type), "");
			Событие.stage = ?(ИстСобытие.Свойство("stage"), Строка(ИстСобытие.stage), "");
			Событие.transition = ?(ИстСобытие.Свойство("transition"), Строка(ИстСобытие.transition), "");
			Событие.attempt = ?(ИстСобытие.Свойство("attempt"), ИстСобытие.attempt, 0);
			Событие.source = "orchestrator";
			Событие.trace_id = TraceId;
			Событие.thread_id = ThreadId;
			Событие.details = ?(ИстСобытие.Свойство("details"), ИстСобытие.details, Неопределено);
			ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Событие.details);
			Результат.Добавить(Событие);
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Оркестратор_ИсторияЧекпоинтов")
		И ТипЗнч(СтруктураДанных.Оркестратор_ИсторияЧекпоинтов) = Тип("Массив") Тогда
		Для Каждого ИстЧекпоинт Из СтруктураДанных.Оркестратор_ИсторияЧекпоинтов Цикл
			Если ТипЗнч(ИстЧекпоинт) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Событие = СоздатьСобытиеRuntimeTrace("checkpoint", ?(ИстЧекпоинт.Свойство("timestamp"), ИстЧекпоинт.timestamp, Неопределено));
			Событие.kind = ?(ИстЧекпоинт.Свойство("checkpoint_type"), Строка(ИстЧекпоинт.checkpoint_type), "");
			Событие.stage = ?(ИстЧекпоинт.Свойство("stage"), Строка(ИстЧекпоинт.stage), "");
			Событие.transition = ?(ИстЧекпоинт.Свойство("transition"), Строка(ИстЧекпоинт.transition), "");
			Событие.attempt = ?(ИстЧекпоинт.Свойство("attempt"), ИстЧекпоинт.attempt, 0);
			Событие.source = "checkpoint";
			Событие.trace_id = TraceId;
			Событие.thread_id = ThreadId;
			Событие.details = ?(ИстЧекпоинт.Свойство("details"), ИстЧекпоинт.details, Неопределено);
			ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Событие.details);
			Результат.Добавить(Событие);
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Subgraph_History")
		И ТипЗнч(СтруктураДанных.Subgraph_History) = Тип("Массив") Тогда
		Для Каждого ИстПодграф Из СтруктураДанных.Subgraph_History Цикл
			Если ТипЗнч(ИстПодграф) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Событие = СоздатьСобытиеRuntimeTrace("subgraph_history", ?(ИстПодграф.Свойство("timestamp"), ИстПодграф.timestamp, Неопределено));
			Событие.subgraph = ?(ИстПодграф.Свойство("subgraph"), Строка(ИстПодграф.subgraph), "");
			Событие.decision = ?(ИстПодграф.Свойство("decision"), Строка(ИстПодграф.decision), "");
			Событие.source = "subgraph";
			Событие.trace_id = TraceId;
			Событие.thread_id = ThreadId;
			Событие.details = ?(ИстПодграф.Свойство("details"), ИстПодграф.details, Неопределено);
			ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Событие.details);
			Результат.Добавить(Событие);
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Decision_Log")
		И ТипЗнч(СтруктураДанных.Decision_Log) = Тип("Массив") Тогда
		Для Каждого ЗаписьРешения Из СтруктураДанных.Decision_Log Цикл
			Если ТипЗнч(ЗаписьРешения) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Событие = СоздатьСобытиеRuntimeTrace("decision_log", ?(ЗаписьРешения.Свойство("timestamp"), ЗаписьРешения.timestamp, Неопределено));
			Событие.kind = ?(ЗаписьРешения.Свойство("kind"), Строка(ЗаписьРешения.kind), "");
			Событие.decision = ?(ЗаписьРешения.Свойство("decision"), Строка(ЗаписьРешения.decision), "");
			Событие.source = ?(ЗаписьРешения.Свойство("source"), Строка(ЗаписьРешения.source), "");
			Событие.step_id = ?(ЗаписьРешения.Свойство("step_id"), Строка(ЗаписьРешения.step_id), "");
			Событие.policy = ?(ЗаписьРешения.Свойство("policy"), Строка(ЗаписьРешения.policy), "");
			Событие.reason = ?(ЗаписьРешения.Свойство("reason"), Строка(ЗаписьРешения.reason), "");
			Событие.subgraph = ?(ЗаписьРешения.Свойство("subgraph"), Строка(ЗаписьРешения.subgraph), "");
			Событие.trace_id = TraceId;
			Событие.thread_id = ThreadId;
			Событие.details = ?(ЗаписьРешения.Свойство("details"), ЗаписьРешения.details, Неопределено);
			ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Событие.details);
			Результат.Добавить(Событие);
		КонецЦикла;
	КонецЕсли;
	
	Если Результат.Количество() <= Лимит Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИндексНачала = Результат.Количество() - Лимит;
	ОграниченныйРезультат = Новый Массив;
	Для Индекс = ИндексНачала По Результат.Количество() - 1 Цикл
		ОграниченныйРезультат.Добавить(Результат[Индекс]);
	КонецЦикла;
	Возврат ОграниченныйРезультат;
КонецФункции

Процедура УстановитьСостояниеОркестратора(СсылкаДиалога, Стадия, Переход = "", УвеличитьПопытку = Ложь) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	
	ПопыткаНомер = 0;
	Если СтруктураДанных.Свойство("Оркестратор_Попытка") Тогда
		ПопыткаНомер = СтруктураДанных.Оркестратор_Попытка;
	КонецЕсли;
	Если УвеличитьПопытку Тогда
		ПопыткаНомер = ПопыткаНомер + 1;
	ИначеЕсли Переход = "reset_attempt" Тогда
		ПопыткаНомер = 0;
	КонецЕсли;
	Переход = НормализоватьTransitionEventHistory(Переход);
	
	СтруктураДанных.Вставить("Оркестратор_Стадия", Стадия);
	СтруктураДанных.Вставить("Оркестратор_Переход", Переход);
	СтруктураДанных.Вставить("Оркестратор_Попытка", ПопыткаНомер);
	ДобавитьСобытиеОркестратораВИсториюВДанных(СтруктураДанных, "stage_transition", Стадия, Переход, ПопыткаНомер);
	ОбновитьЧекпоинтОркестратораВДанных(СтруктураДанных, "stage_transition", Стадия, Переход, ПопыткаНомер);
	ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
КонецПроцедуры

