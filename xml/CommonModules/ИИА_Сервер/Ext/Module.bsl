Процедура УвеличитьСчетчикМетрики(Счетчики, Ключ)
	Если Счетчики = Неопределено Или ТипЗнч(Счетчики) <> Тип("Соответствие") Или ПустаяСтрока(СокрЛП(Строка(Ключ))) Тогда
		Возврат;
	КонецЕсли;
	ТекущееЗначение = Счетчики.Получить(Ключ);
	Если ТекущееЗначение = Неопределено Тогда
		ТекущееЗначение = 0;
	КонецЕсли;
	Счетчики.Вставить(Ключ, ТекущееЗначение + 1);
КонецПроцедуры

Функция СчетчикиВСортированныйМассив(Счетчики)
	Результат = Новый Массив;
	Если Счетчики = Неопределено Или ТипЗнч(Счетчики) <> Тип("Соответствие") Тогда
		Возврат Результат;
	КонецЕсли;
	Для Каждого Пара Из Счетчики Цикл
		Результат.Добавить(Новый Структура("key,count", Строка(Пара.Ключ), Пара.Значение));
	КонецЦикла;
	Для Левый = 0 По Результат.Количество() - 2 Цикл
		Для Правый = Левый + 1 По Результат.Количество() - 1 Цикл
			Если Результат[Правый].count > Результат[Левый].count Тогда
				ВременноеЗначение = Результат[Левый];
				Результат[Левый] = Результат[Правый];
				Результат[Правый] = ВременноеЗначение;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ЭтоПохожеНаПричинуСбоя(Причина)
	ТекстПричины = НРег(СокрЛП(Строка(Причина)));
	Если ПустаяСтрока(ТекстПричины) Тогда
		Возврат Ложь;
	КонецЕсли;
	Возврат СтрНайти(ТекстПричины, "fail") > 0
		Или СтрНайти(ТекстПричины, "error") > 0
		Или СтрНайти(ТекстПричины, "abort") > 0
		Или СтрНайти(ТекстПричины, "rejected") > 0
		Или СтрНайти(ТекстПричины, "missing") > 0
		Или СтрНайти(ТекстПричины, "unsafe") > 0;
КонецФункции

