Функция СформироватьМетрикиПоСтадиям(СчетчикиУспехаСтадий, СчетчикиОшибокСтадий)
	Результат = Новый Массив;
	ИменаСтадий = Новый Массив;
	Для Каждого Пара Из СчетчикиУспехаСтадий Цикл
		Если НЕ ЭтоЗначениеВСпискеDecisionLog(ИменаСтадий, Строка(Пара.Ключ)) Тогда
			ИменаСтадий.Добавить(Строка(Пара.Ключ));
		КонецЕсли;
	КонецЦикла;
	Для Каждого Пара Из СчетчикиОшибокСтадий Цикл
		Если НЕ ЭтоЗначениеВСпискеDecisionLog(ИменаСтадий, Строка(Пара.Ключ)) Тогда
			ИменаСтадий.Добавить(Строка(Пара.Ключ));
		КонецЕсли;
	КонецЦикла;
	Для Каждого ИмяСтадии Из ИменаСтадий Цикл
		SuccessCount = ?(СчетчикиУспехаСтадий.Получить(ИмяСтадии) = Неопределено, 0, СчетчикиУспехаСтадий.Получить(ИмяСтадии));
		FailureCount = ?(СчетчикиОшибокСтадий.Получить(ИмяСтадии) = Неопределено, 0, СчетчикиОшибокСтадий.Получить(ИмяСтадии));
		Результат.Добавить(Новый Структура("stage,success_count,failure_count", ИмяСтадии, SuccessCount, FailureCount));
	КонецЦикла;
	Возврат Результат;
КонецФункции

