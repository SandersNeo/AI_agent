Процедура ЗафиксироватьАктивныйПодграф(СсылкаДиалога, SubgraphName, Decision = "", Details = Неопределено) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	
	История = Новый Массив;
	Если СтруктураДанных.Свойство("Subgraph_History") И ТипЗнч(СтруктураДанных.Subgraph_History) = Тип("Массив") Тогда
		История = СтруктураДанных.Subgraph_History;
	КонецЕсли;
	
	ЗаписьИстории = Новый Структура;
	ЗаписьИстории.Вставить("timestamp", ТекущаяДатаСеанса());
	ЗаписьИстории.Вставить("subgraph", SubgraphName);
	НормDecisionПодграфа = НормализоватьDecisionSubgraphTrace(Decision);
	Если НЕ ПустаяСтрока(НормDecisionПодграфа) Тогда
		ЗаписьИстории.Вставить("decision", НормDecisionПодграфа);
	КонецЕсли;
	Если Details <> Неопределено Тогда
		ЗаписьИстории.Вставить("details", Details);
	КонецЕсли;
	История.Добавить(ЗаписьИстории);
	Пока История.Количество() > 100 Цикл
		История.Удалить(0);
	КонецЦикла;
	
	СтруктураДанных.Вставить("Active_Subgraph", SubgraphName);
	СтруктураДанных.Вставить("Subgraph_History", История);
	ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
КонецПроцедуры

Процедура ДобавитьРешениеВDecisionLog(СсылкаДиалога, DecisionKind, DecisionValue, SubgraphName = "", Details = Неопределено) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	НормKind = НормализоватьKindDecisionLog(DecisionKind);
	НормDecision = НормализоватьValueDecisionLog(НормKind, DecisionValue);
	Если ПустаяСтрока(НормKind) Или ПустаяСтрока(НормDecision) Тогда
		Возврат;
	КонецЕсли;
	СтруктураДанных = ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	DecisionLog = Новый Массив;
	Если СтруктураДанных.Свойство("Decision_Log") И ТипЗнч(СтруктураДанных.Decision_Log) = Тип("Массив") Тогда
		DecisionLog = СтруктураДанных.Decision_Log;
	КонецЕсли;
	ЗаписьРешения = Новый Структура;
	ЗаписьРешения.Вставить("timestamp", ТекущаяДатаСеанса());
	ЗаписьРешения.Вставить("kind", НормKind);
	ЗаписьРешения.Вставить("decision", НормDecision);
	ЗаписьРешения.Вставить("source", "");
	ЗаписьРешения.Вставить("step_id", "");
	ЗаписьРешения.Вставить("policy", "");
	ЗаписьРешения.Вставить("reason", "");
	Если НЕ ПустаяСтрока(SubgraphName) Тогда
		ЗаписьРешения.Вставить("subgraph", SubgraphName);
		ЗаписьРешения.source = SubgraphName;
	КонецЕсли;
	Если Details <> Неопределено И ТипЗнч(Details) = Тип("Структура") Тогда
		Если Details.Свойство("source") И НЕ ПустаяСтрока(Строка(Details.source)) Тогда
			ЗаписьРешения.source = Строка(Details.source);
		КонецЕсли;
		Если Details.Свойство("step_id") И НЕ ПустаяСтрока(Строка(Details.step_id)) Тогда
			ЗаписьРешения.step_id = Строка(Details.step_id);
		ИначеЕсли Details.Свойство("active_step_id") И НЕ ПустаяСтрока(Строка(Details.active_step_id)) Тогда
			ЗаписьРешения.step_id = Строка(Details.active_step_id);
		КонецЕсли;
		Если Details.Свойство("policy") И НЕ ПустаяСтрока(Строка(Details.policy)) Тогда
			ЗаписьРешения.policy = Строка(Details.policy);
		ИначеЕсли Details.Свойство("policy_id") И НЕ ПустаяСтрока(Строка(Details.policy_id)) Тогда
			ЗаписьРешения.policy = Строка(Details.policy_id);
		КонецЕсли;
		Если Details.Свойство("reason") И НЕ ПустаяСтрока(Строка(Details.reason)) Тогда
			ЗаписьРешения.reason = Строка(Details.reason);
		КонецЕсли;
	КонецЕсли;
	Если Details <> Неопределено Тогда
		ЗаписьРешения.Вставить("details", Details);
	КонецЕсли;
	DecisionLog.Добавить(ЗаписьРешения);
	Пока DecisionLog.Количество() > 100 Цикл
		DecisionLog.Удалить(0);
	КонецЦикла;
	СтруктураДанных.Вставить("Decision_Log", DecisionLog);
	ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
КонецПроцедуры

Функция ПолучитьРеестрDecisionLogPolicy() Экспорт
	Реестр = Новый Соответствие;
	Реестр.Вставить("discovery_rag", Новый Структура("validation_mode,allowed_values", "fixed", Новый Массив));
	Реестр.Получить("discovery_rag").allowed_values.Добавить("rag_on");
	Реестр.Получить("discovery_rag").allowed_values.Добавить("rag_off");
	Реестр.Вставить("execution_policy", Новый Структура("validation_mode,allowed_values", "transition_policy", Новый Массив));
	Реестр.Вставить("next_step_selected", Новый Структура("validation_mode,allowed_values", "freeform", Новый Массив));
	Реестр.Вставить("approval", Новый Структура("validation_mode,allowed_values", "fixed", Новый Массив));
	Реестр.Получить("approval").allowed_values.Добавить("requested");
	Реестр.Получить("approval").allowed_values.Добавить("approved");
	Реестр.Получить("approval").allowed_values.Добавить("rejected");
	Реестр.Вставить("recovery_policy", Новый Структура("validation_mode,allowed_values", "transition_reason", Новый Массив));
	Реестр.Вставить("checkpoint_resume", Новый Структура("validation_mode,allowed_values", "fixed", Новый Массив));
	Реестр.Получить("checkpoint_resume").allowed_values.Добавить("requested");
	Возврат Реестр;
КонецФункции

