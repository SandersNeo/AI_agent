Функция ОбработатьApprovalПередExecuteSubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана = Неопределено, ИмяПодграфа = "")
	ОценкаРиска = ОценитьРискDSLДляПодтверждения(DSLДляИсполнения);
	Если ИИА_Сервер.ЭтоРежимБезПодтверждения(СсылкаДиалога) Тогда
		ОценкаРиска.requires_approval = Ложь;
		ОценкаРиска.reason = ОценкаРиска.reason + ?(ПустаяСтрока(ОценкаРиска.reason), "", " ") + "Для текущего диалога включен режим выполнения без подтверждения.";
	КонецЕсли;
	СостояниеПодтверждения = ИИА_Сервер.ПолучитьСостояниеПодтверждения(СсылкаДиалога);
	Если СостояниеПодтверждения <> Неопределено
		И СостояниеПодтверждения.Свойство("status")
		И ВРег(Строка(СостояниеПодтверждения.status)) = "APPROVED"
		И СостояниеПодтверждения.Свойство("planned_dsl")
		И СокрЛП(Строка(СостояниеПодтверждения.planned_dsl)) = СокрЛП(DSLДляИсполнения) Тогда
		СостояниеПодтверждения.status = "consumed";
		ИИА_Сервер.СохранитьСостояниеПодтверждения(СсылкаДиалога, СостояниеПодтверждения);
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "approval_consumed", "Execute", СостояниеПодтверждения, "approval_consumed");
		Возврат Ложь;
	КонецЕсли;
	Если ТребуетсяПодтверждениеПередИсполнением(ОценкаРиска) Тогда
		ЗапроситьПодтверждениеПользователя(СсылкаДиалога, DSLДляИсполнения, ОценкаРиска, АртефактПлана, ИмяПодграфа);
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

Функция ОпределитьИсполнительныйПодграф(DSLСценарий) Экспорт
	Результат = Новый Структура("SubgraphName,HasWriteActions,HasRunQuery", "GenericExecuteSubgraph", Ложь, Ложь);
	Если ПустаяСтрока(DSLСценарий) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		ТекстJSON = ИИА_DSL.НормализоватьJSONТекст(DSLСценарий);
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		Возврат Результат;
	КонецПопытки;
	
	Шаги = Новый Массив;
	Если ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") Тогда
		Шаги = Сценарий.steps;
	ИначеЕсли ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("action") Тогда
		Шаги.Добавить(Сценарий);
	Иначе
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Шаг Из Шаги Цикл
		Если ТипЗнч(Шаг) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ Шаг.Свойство("action") Тогда
			Продолжить;
		КонецЕсли;
		Действие = СокрЛП(Строка(Шаг.action));
		Если ЭтоWriteДействиеДляOperationId(Действие) Тогда
			Результат.HasWriteActions = Истина;
		КонецЕсли;
		Если ВРег(Действие) = "RUNQUERY" Тогда
			Результат.HasRunQuery = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если Результат.HasWriteActions Тогда
		Результат.SubgraphName = "WriteActionSubgraph";
	ИначеЕсли Результат.HasRunQuery Тогда
		Результат.SubgraphName = "ReadQuerySubgraph";
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ЭтоWriteДействиеДляOperationId(Действие)
	ДействиеВРег = ВРег(СокрЛП(Действие));
	Возврат ДействиеВРег = "CREATEDOCUMENT"
		ИЛИ ДействиеВРег = "CREATEREFERENCE"
		ИЛИ ДействиеВРег = "SETFIELD"
		ИЛИ ДействиеВРег = "WRITE";
КонецФункции

Функция ПолучитьРеестрReplaySafetyPolicy() Экспорт
	Реестр = Новый Массив;
	Реестр.Добавить("safe_replay");
	Реестр.Добавить("resume_only");
	Реестр.Добавить("no_replay");
	Возврат Реестр;
КонецФункции

Функция ПолучитьРеестрReplayStagePolicy() Экспорт
	Реестр = Новый Соответствие;
	Реестр.Вставить("Execute", Новый Структура("classification,policy,reason", "resume_only", "stage_execute_resume_only", "stage_policy_resume_only"));
	Реестр.Вставить("Validate", Новый Структура("classification,policy,reason", "safe_replay", "stage_validate_safe_replay", "stage_policy_safe_replay"));
	Реестр.Вставить("Recover", Новый Структура("classification,policy,reason", "resume_only", "stage_recover_resume_only", "stage_policy_resume_only"));
	Реестр.Вставить("Summarize", Новый Структура("classification,policy,reason", "safe_replay", "stage_summarize_safe_replay", "stage_policy_safe_replay"));
	Возврат Реестр;
КонецФункции

Функция ИзвлечьReplayАналитикуИзDSL(DSLСценарий)
	Результат = Новый Структура("actions,has_write_actions,has_unsafe_retry_actions,operation_id", Новый Массив, Ложь, Ложь, "");
	Если ПустаяСтрока(DSLСценарий) Тогда
		Возврат Результат;
	КонецЕсли;
	Попытка
		ТекстJSON = ИИА_DSL.НормализоватьJSONТекст(DSLСценарий);
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		Результат.has_unsafe_retry_actions = Истина;
		Возврат Результат;
	КонецПопытки;
	Шаги = Новый Массив;
	Если ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") Тогда
		Шаги = Сценарий.steps;
	ИначеЕсли ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("action") Тогда
		Шаги.Добавить(Сценарий);
	КонецЕсли;
	РеестрКонтрактов = ИИА_DSL.ПолучитьРеестрКонтрактовDSL();
	Для Каждого Шаг Из Шаги Цикл
		Если ТипЗнч(Шаг) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ Шаг.Свойство("action") Тогда
			Продолжить;
		КонецЕсли;
		Действие = СокрЛП(Строка(Шаг.action));
		Результат.actions.Добавить(Действие);
		Контракт = РеестрКонтрактов.Получить(Действие);
		Если Контракт <> Неопределено
			И Контракт.Свойство("requires_write")
			И Контракт.requires_write Тогда
			Результат.has_write_actions = Истина;
		КонецЕсли;
		Если Контракт = Неопределено
			Или НЕ Контракт.Свойство("supports_safe_retries")
			Или НЕ Контракт.supports_safe_retries Тогда
			Результат.has_unsafe_retry_actions = Истина;
		КонецЕсли;
		Если ПустаяСтрока(Результат.operation_id)
			И Шаг.Свойство("operation_id")
			И НЕ ПустаяСтрока(СокрЛП(Строка(Шаг.operation_id))) Тогда
			Результат.operation_id = СокрЛП(Строка(Шаг.operation_id));
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция КлассифицироватьReplaySafety(СсылкаДиалога, ИндексЧекпоинта = -1) Экспорт
	Результат = Новый Структура("classification,reason,stage,operation_id,checkpoint_index", "safe_replay", "default_safe_replay", "", "", ИндексЧекпоинта);
	ИсторияЧекпоинтов = ИИА_Сервер.ПолучитьИсториюЧекпоинтовОркестратора(СсылкаДиалога, 100);
	Если ТипЗнч(ИсторияЧекпоинтов) <> Тип("Массив") Или ИсторияЧекпоинтов.Количество() = 0 Тогда
		Результат.classification = "no_replay";
		Результат.reason = "checkpoint_history_missing";
		Возврат Результат;
	КонецЕсли;
	Если ИндексЧекпоинта < 0 Тогда
		ИндексЧекпоинта = ИсторияЧекпоинтов.Количество() - 1;
	КонецЕсли;
	Если ИндексЧекпоинта < 0 Или ИндексЧекпоинта >= ИсторияЧекпоинтов.Количество() Тогда
		Результат.classification = "no_replay";
		Результат.reason = "checkpoint_index_invalid";
		Возврат Результат;
	КонецЕсли;
	Чекпоинт = ИсторияЧекпоинтов[ИндексЧекпоинта];
	Результат.checkpoint_index = ИндексЧекпоинта;
	Результат.stage = ?(Чекпоинт.Свойство("stage"), Строка(Чекпоинт.stage), "");
	РеестрStagePolicy = ПолучитьРеестрReplayStagePolicy();
	ДеталиЧекпоинта = ?(Чекпоинт.Свойство("details"), Чекпоинт.details, Неопределено);
	Если ДеталиЧекпоинта <> Неопределено И ТипЗнч(ДеталиЧекпоинта) = Тип("Структура") Тогда
		Если ДеталиЧекпоинта.Свойство("replay_safety") И НЕ ПустаяСтрока(Строка(ДеталиЧекпоинта.replay_safety)) Тогда
			Результат.classification = Строка(ДеталиЧекпоинта.replay_safety);
			Результат.reason = "checkpoint_replay_safety";
			Если ДеталиЧекпоинта.Свойство("operation_id") Тогда
				Результат.operation_id = Строка(ДеталиЧекпоинта.operation_id);
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	Если Результат.stage <> "Execute" Тогда
		StagePolicy = РеестрStagePolicy.Получить(Результат.stage);
		Если StagePolicy <> Неопределено Тогда
			Результат.classification = ?(StagePolicy.Свойство("classification"), StagePolicy.classification, "safe_replay");
			Результат.reason = ?(StagePolicy.Свойство("reason"), StagePolicy.reason, "non_execute_checkpoint");
		Иначе
			Результат.classification = "safe_replay";
			Результат.reason = "non_execute_checkpoint";
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
	DSLИсходный = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL"), АртефактПлана.PlannedDSL, "");
	Если ПустаяСтрока(DSLИсходный) Тогда
		Результат.classification = "no_replay";
		Результат.reason = "planned_dsl_missing";
		Возврат Результат;
	КонецЕсли;
	АналитикаDSL = ИзвлечьReplayАналитикуИзDSL(DSLИсходный);
	Результат.operation_id = АналитикаDSL.operation_id;
	Если НЕ ПустаяСтрока(АналитикаDSL.operation_id) Тогда
		ПоследнийЭффект = НайтиПоследнийSideEffectПоOperationId(СсылкаДиалога, АналитикаDSL.operation_id);
		Если ПоследнийЭффект <> Неопределено
			И ТипЗнч(ПоследнийЭффект) = Тип("Структура")
			И ПоследнийЭффект.Свойство("replay_safety")
			И НЕ ПустаяСтрока(Строка(ПоследнийЭффект.replay_safety)) Тогда
			Результат.classification = Строка(ПоследнийЭффект.replay_safety);
			Результат.reason = "side_effect_replay_safety";
			Если ЭтоКоммитящийSideEffect(ПоследнийЭффект) И Результат.classification <> "no_replay" Тогда
				Результат.classification = "resume_only";
				Результат.reason = "committed_side_effect_resume_only";
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	Если НЕ АналитикаDSL.has_write_actions И НЕ АналитикаDSL.has_unsafe_retry_actions Тогда
		Результат.classification = "safe_replay";
		Результат.reason = "read_only_dsl";
		Возврат Результат;
	КонецЕсли;
	Если АналитикаDSL.has_write_actions Тогда
		Если ПустаяСтрока(АналитикаDSL.operation_id) Тогда
			Результат.classification = "no_replay";
			Результат.reason = "write_without_operation_id";
			Возврат Результат;
		КонецЕсли;
		ПоследнийЭффект = НайтиПоследнийSideEffectПоOperationId(СсылкаДиалога, АналитикаDSL.operation_id);
		Если ЭтоКоммитящийSideEffect(ПоследнийЭффект) Тогда
			Результат.classification = "resume_only";
			Результат.reason = "write_committed_resume_only";
			Возврат Результат;
		КонецЕсли;
		Результат.classification = "resume_only";
		Результат.reason = "write_with_operation_id";
		Возврат Результат;
	КонецЕсли;
	Если АналитикаDSL.has_unsafe_retry_actions Тогда
		Если НЕ ПустаяСтрока(АналитикаDSL.operation_id) Тогда
			Результат.classification = "resume_only";
			Результат.reason = "unsafe_retry_action_with_operation_id";
		Иначе
			Результат.classification = "no_replay";
			Результат.reason = "unsafe_retry_action_without_operation_id";
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ОбеспечитьOperationIdДляWriteШагов(СсылкаДиалога, DSLСценарий, АртефактПлана = Неопределено)
	Если ПустаяСтрока(DSLСценарий) Тогда
		Возврат DSLСценарий;
	КонецЕсли;
	
	Попытка
		ТекстJSON = ИИА_DSL.НормализоватьJSONТекст(DSLСценарий);
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		Возврат DSLСценарий;
	КонецПопытки;
	
	Шаги = Неопределено;
	Если ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") Тогда
		Шаги = Сценарий.steps;
	Иначе
		Возврат DSLСценарий;
	КонецЕсли;
	
	БылиИзменения = Ложь;
	TraceId = "";
	АрхКонтекст = ИИА_Сервер.ПолучитьКонтекстАрхитектуры(СсылкаДиалога);
	Если АрхКонтекст <> Неопределено И АрхКонтекст.Свойство("trace_id") Тогда
		TraceId = СокрЛП(Строка(АрхКонтекст.trace_id));
	КонецЕсли;
	StepIdПлана = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlanStepId"), СокрЛП(Строка(АртефактПлана.PlanStepId)), "");
	
	Для Индекс = 0 По Шаги.Количество() - 1 Цикл
		Шаг = Шаги[Индекс];
		Если ТипЗнч(Шаг) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ Шаг.Свойство("action") Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ ЭтоWriteДействиеДляOperationId(Строка(Шаг.action)) Тогда
			Продолжить;
		КонецЕсли;
		Если Шаг.Свойство("operation_id") И НЕ ПустаяСтрока(СокрЛП(Строка(Шаг.operation_id))) Тогда
			Продолжить;
		КонецЕсли;
		
		OperationId = "op";
		Если НЕ ПустаяСтрока(TraceId) Тогда
			OperationId = OperationId + "_" + TraceId;
		КонецЕсли;
		Если НЕ ПустаяСтрока(StepIdПлана) Тогда
			OperationId = OperationId + "_" + StepIdПлана;
		КонецЕсли;
		OperationId = OperationId + "_" + Формат(Индекс + 1, "ЧН=0");
		OperationId = OperationId + "_" + НРег(Строка(Шаг.action));
		Шаг.Вставить("operation_id", OperationId);
		Шаги[Индекс] = Шаг;
		БылиИзменения = Истина;
	КонецЦикла;
	
	Если НЕ БылиИзменения Тогда
		Возврат DSLСценарий;
	КонецЕсли;
	
	Сценарий.steps = Шаги;
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Сценарий);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

Функция ОценитьРискDSLДляПодтверждения(DSLСценарий) Экспорт
	Результат = Новый Структура("risk_level,reason,requires_approval,actions_preview", "read_safe", "", Ложь, "");
	Если ПустаяСтрока(DSLСценарий) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		ТекстJSON = ИИА_DSL.НормализоватьJSONТекст(DSLСценарий);
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		Результат.risk_level = "read_expensive";
		Результат.reason = "Невозможно надежно разобрать DSL до исполнения.";
		Результат.requires_approval = Истина;
		Возврат Результат;
	КонецПопытки;
	
	Шаги = Новый Массив;
	Если ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") Тогда
		Шаги = Сценарий.steps;
	ИначеЕсли ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("action") Тогда
		Шаги.Добавить(Сценарий);
	КонецЕсли;
	
	Действия = Новый Массив;
	ТяжелоеЧтение = Ложь;
	
	Для Каждого Шаг Из Шаги Цикл
		Если ТипЗнч(Шаг) <> Тип("Структура") И ТипЗнч(Шаг) <> Тип("Соответствие") Тогда
			Продолжить;
		КонецЕсли;
		
		Действие = "";
		Если ТипЗнч(Шаг) = Тип("Структура") И Шаг.Свойство("action") Тогда
			Действие = СокрЛП(Строка(Шаг.action));
		ИначеЕсли ТипЗнч(Шаг) = Тип("Соответствие") И Шаг.Получить("action") <> Неопределено Тогда
			Действие = СокрЛП(Строка(Шаг.Получить("action")));
		КонецЕсли;
		Если ПустаяСтрока(Действие) Тогда
			Продолжить;
		КонецЕсли;
		
		Действия.Добавить(Действие);
		Если ЭтоИзменяющееДействиеДляApproval(Действие) Тогда
			Результат.risk_level = "write_or_mutation";
			Результат.reason = "DSL содержит действия изменения данных: " + СтрСоединить(Действия, ", ");
			Результат.requires_approval = Истина;
		КонецЕсли;
		
		Если ВРег(Действие) = "RUNQUERY" Тогда
			ТекстЗапроса = "";
			Если ТипЗнч(Шаг) = Тип("Структура") И Шаг.Свойство("query") Тогда
				ТекстЗапроса = Строка(Шаг.query);
			ИначеЕсли ТипЗнч(Шаг) = Тип("Соответствие") И Шаг.Получить("query") <> Неопределено Тогда
				ТекстЗапроса = Строка(Шаг.Получить("query"));
			КонецЕсли;
			ТекстЗапросаВРег = ВРег(ТекстЗапроса);
			Если СтрДлина(ТекстЗапроса) > 400
				ИЛИ СтрНайти(ТекстЗапросаВРег, " СОЕДИНЕНИЕ ") > 0
				ИЛИ СтрНайти(ТекстЗапросаВРег, " JOIN ") > 0
				ИЛИ СтрНайти(ТекстЗапросаВРег, " ОБЪЕДИНИТЬ ") > 0
				ИЛИ (СтрНайти(ТекстЗапросаВРег, " ИЗ ") > 0
					И СтрНайти(ТекстЗапросаВРег, "ПЕРВЫЕ ") = 0
					И СтрНайти(ТекстЗапросаВРег, " ГДЕ ") = 0) Тогда
				ТяжелоеЧтение = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Результат.actions_preview = СтрСоединить(Действия, ", ");
	Если Результат.risk_level = "write_or_mutation" Тогда
		Возврат Результат;
	КонецЕсли;
	Если ТяжелоеЧтение Тогда
		Результат.risk_level = "read_expensive";
		Результат.reason = "DSL содержит потенциально тяжелый RunQuery.";
		Результат.requires_approval = Истина;
	Иначе
		Результат.risk_level = "read_safe";
		Результат.reason = "DSL не содержит действий записи и не выглядит тяжелым.";
		Результат.requires_approval = Ложь;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ЭтоИзменяющееДействиеДляApproval(Действие)
	ДействиеВРег = ВРег(СокрЛП(Действие));
	Возврат ДействиеВРег = "CREATEDOCUMENT"
		ИЛИ ДействиеВРег = "CREATEREFERENCE"
		ИЛИ ДействиеВРег = "SETFIELD"
		ИЛИ ДействиеВРег = "WRITE";
КонецФункции

Функция ТребуетсяПодтверждениеПередИсполнением(ОценкаРиска)
	Возврат ОценкаРиска <> Неопределено
		И ОценкаРиска.Свойство("requires_approval")
		И ОценкаРиска.requires_approval;
КонецФункции

Функция СформироватьPreviewПодтверждения(DSLСценарий, ОценкаРиска)
	Текст = "Требуется подтверждение перед выполнением DSL." + Символы.ПС;
	Если ОценкаРиска <> Неопределено Тогда
		Текст = Текст + "Риск: " + ?(ОценкаРиска.Свойство("risk_level"), Строка(ОценкаРиска.risk_level), "") + Символы.ПС;
		Текст = Текст + "Причина: " + ?(ОценкаРиска.Свойство("reason"), Строка(ОценкаРиска.reason), "") + Символы.ПС;
		Если ОценкаРиска.Свойство("actions_preview") И НЕ ПустаяСтрока(Строка(ОценкаРиска.actions_preview)) Тогда
			Текст = Текст + "Действия: " + Строка(ОценкаРиска.actions_preview) + Символы.ПС;
		КонецЕсли;
	КонецЕсли;
	Текст = Текст + "DSL preview:" + Символы.ПС + Лев(DSLСценарий, 1500);
	Если СтрДлина(DSLСценарий) > 1500 Тогда
		Текст = Текст + Символы.ПС + "...(truncated)";
	КонецЕсли;
	Возврат Текст;
КонецФункции

Процедура ЗафиксироватьApprovalDecision(СсылкаДиалога, Decision, СостояниеПодтверждения, ИмяПодграфа, ПричинаРешения, ВидЧекпоинта, СледующаяСтадия = "", ПричинаСостояния = "", СообщениеВДиалог = "")
	ЛокИмяПодграфа = ?(ПустаяСтрока(ИмяПодграфа), "ExecuteSubgraph", ИмяПодграфа);
	Детали = Новый Структура("source,step_id,reason", "approval", ?(СостояниеПодтверждения <> Неопределено И СостояниеПодтверждения.Свойство("step_id"), Строка(СостояниеПодтверждения.step_id), ""), ПричинаРешения);
	Если СостояниеПодтверждения <> Неопределено И СостояниеПодтверждения.Свойство("risk_level") Тогда
		Детали.Вставить("risk_level", Строка(СостояниеПодтверждения.risk_level));
	КонецЕсли;
	ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "approval", Decision, ЛокИмяПодграфа, Детали);
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, ВидЧекпоинта, ?(ПустаяСтрока(СледующаяСтадия), "AwaitApproval", СледующаяСтадия), СостояниеПодтверждения, ПричинаСостояния);
	Если НЕ ПустаяСтрока(СообщениеВДиалог) Тогда
		ИИА_Сервер.ДобавитьСообщениеВДиалог(СсылкаДиалога, Перечисления.ИИА_АвторСообщения.Система, Перечисления.ИИА_ТипСообщения.Текст, СообщениеВДиалог);
	КонецЕсли;
	Если НЕ ПустаяСтрока(СледующаяСтадия) Тогда
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, СледующаяСтадия, ПричинаСостояния, Ложь);
	КонецЕсли;
КонецПроцедуры

Процедура ЗапроситьПодтверждениеПользователя(СсылкаДиалога, DSLСценарий, ОценкаРиска, АртефактПлана, ИмяПодграфа = "")
	StepId = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlanStepId"), Строка(АртефактПлана.PlanStepId), "");
	Preview = СформироватьPreviewПодтверждения(DSLСценарий, ОценкаРиска);
	СостояниеПодтверждения = Новый Структура;
	СостояниеПодтверждения.Вставить("status", "pending");
	СостояниеПодтверждения.Вставить("risk_level", ?(ОценкаРиска.Свойство("risk_level"), ОценкаРиска.risk_level, ""));
	СостояниеПодтверждения.Вставить("reason", ?(ОценкаРиска.Свойство("reason"), ОценкаРиска.reason, ""));
	СостояниеПодтверждения.Вставить("preview", Preview);
	СостояниеПодтверждения.Вставить("planned_dsl", DSLСценарий);
	СостояниеПодтверждения.Вставить("step_id", StepId);
	СостояниеПодтверждения.Вставить("requested_at", ТекущаяДатаСеанса());
	СостояниеПодтверждения.Вставить("decision_at", Неопределено);
	СостояниеПодтверждения.Вставить("decision", "");
	СостояниеПодтверждения.Вставить("subgraph_name", ?(ПустаяСтрока(ИмяПодграфа), "ExecuteSubgraph", ИмяПодграфа));
	ИИА_Сервер.СохранитьСостояниеПодтверждения(СсылкаДиалога, СостояниеПодтверждения);
	ЗафиксироватьApprovalDecision(СсылкаДиалога, "requested", СостояниеПодтверждения, ?(ПустаяСтрока(ИмяПодграфа), "ExecuteSubgraph", ИмяПодграфа), ?(ОценкаРиска.Свойство("reason"), Строка(ОценкаРиска.reason), ""), "approval_requested", "AwaitApproval", "approval_required", Preview);
	ОбновитьСтатусПоследнегоСообщения(СсылкаДиалога, "Ожидает подтверждения пользователя");
КонецПроцедуры

Функция ВыполнитьСтадиюValidate(СсылкаДиалога) Экспорт
	Возврат ВыполнитьValidateSubgraph(СсылкаДиалога);
КонецФункции

Функция ВыполнитьValidateSubgraph(СсылкаДиалога) Экспорт
	НачалоValidate = ТекущаяДата();
	Результат = СоздатьРезультатПодграфа("ValidateSubgraph", Ложь, "Validate->Recover", Неопределено, Ложь, "recover", Неопределено, "Recover", "no_executor_result", "validate_policy", "");
	ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "ValidateSubgraph", "enter");
	
	РезультатExecutor = ИИА_Сервер.ПолучитьРезультатExecutor(СсылкаДиалога);
	Если РезультатExecutor = Неопределено Тогда
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Validate", НачалоValidate, Ложь, "no_executor_result", "Validate->Recover");
		Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
	КонецЕсли;
	
	Если РезультатExecutor.Свойство("Успех") И РезультатExecutor.Успех Тогда
		АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
		StepId = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlanStepId"), Строка(АртефактПлана.PlanStepId), "");
		Если НЕ ПустаяСтрока(StepId) Тогда
			КраткийРезультат = ?(РезультатExecutor.Свойство("Сообщение"), Строка(РезультатExecutor.Сообщение), "Успешно");
			Если ПустаяСтрока(КраткийРезультат) Тогда
				КраткийРезультат = "Успешно";
			КонецЕсли;
			ОбновитьШагПлана(СсылкаДиалога, StepId, "done", КраткийРезультат, РезультатExecutor);
		КонецЕсли;
		Если ПланЗавершен(СсылкаДиалога) Тогда
			Результат.Transition = "Validate->Summarize";
			Результат.NextStage = "Summarize";
			Результат.Reason = "plan_completed";
		Иначе
			Результат.Transition = "Validate->Plan";
			Результат.NextStage = "Plan";
			Результат.Reason = "next_step";
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Decision = "continue";
		Результат.Policy = "validate_policy";
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Validate", НачалоValidate, Истина, "", ?(Результат.Свойство("Transition"), Результат.Transition, "Validate->Plan"));
		Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
	КонецЕсли;
	
	КодОшибки = ИзвлечьКодОшибки(РезультатExecutor);
	СообщениеОшибки = ?(РезультатExecutor.Свойство("Сообщение"), РезультатExecutor.Сообщение, "");
	Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
	ПопыткаНомер = ?(Состояние <> Неопределено И Состояние.Свойство("НомерПопытки"), Состояние.НомерПопытки, 0);
	
	Если ЭтоВосстановимаяОшибка(КодОшибки) Тогда
		АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
		DSLДляАнализаПовтора = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL"), АртефактПлана.PlannedDSL, "");
		Если ЗафиксироватьПовторОшибочногоRunQuery(СсылкаДиалога, DSLДляАнализаПовтора, КодОшибки, 2) Тогда
			УстановитьФлагПринудительнойСменыСтратегииRunQuery(СсылкаДиалога, Истина);
			ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[LOOP_GUARD] recovery_loop: повторяющийся неуспешный RunQuery, включен флаг принудительной смены стратегии (GetMetadata->GetObjectFields).");
			ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Validate", НачалоValidate, Ложь, "recovery_loop", "Validate->Recover", "recovery_loop", ПопыткаНомер + 1, "");
		КонецЕсли;
		
		МаксПопыток = ПолучитьМаксПопытокДляОшибки(КодОшибки);
		Если ПопыткаНомер >= МаксПопыток Тогда
			Результат.Transition = "Validate->Summarize";
			Результат.NextStage = "Summarize";
			Результат.Reason = "recovery_exhausted";
			ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[RECOVERY_EXHAUSTED] error_code=" + КодОшибки + ", attempts=" + Строка(ПопыткаНомер) + ", max_attempts=" + Строка(МаксПопыток));
			ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Validate", НачалоValidate, Ложь, СообщениеОшибки, "Validate->Summarize", "exhausted_" + КодОшибки, ПопыткаНомер, "");
		Иначе
			Результат.Transition = "Validate->Recover";
			Результат.NextStage = "Recover";
			Результат.Reason = "recoverable_error";
			ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Validate", НачалоValidate, Ложь, СообщениеОшибки, "Validate->Recover", КодОшибки, ПопыткаНомер + 1, "");
		КонецЕсли;
		Результат.Decision = "recover";
		Результат.Policy = "validate_policy";
		Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
	КонецЕсли;
	
	Результат.Transition = "Validate->Recover";
	Результат.NextStage = "Recover";
	Результат.Reason = "non_recoverable_error";
	Результат.Decision = "recover";
	Результат.Policy = "validate_policy";
	ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Validate", НачалоValidate, Ложь, СообщениеОшибки, "Validate->Recover", КодОшибки, ПопыткаНомер + 1, "");
	
	Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
КонецФункции

Функция ВыполнитьСтадиюRecover(СсылкаДиалога) Экспорт
	Возврат ВыполнитьRecoverySubgraph(СсылкаДиалога);
КонецФункции

Функция ВыполнитьRecoverySubgraph(СсылкаДиалога) Экспорт
	НачалоRecover = ТекущаяДата();
	ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "RecoverySubgraph", "enter");
	РезультатExecutor = ИИА_Сервер.ПолучитьРезультатExecutor(СсылкаДиалога);
	КодОшибки = ?(РезультатExecutor <> Неопределено И РезультатExecutor.Свойство("error_code"), Строка(РезультатExecutor.error_code), "");
	СообщениеОшибки = ?(РезультатExecutor <> Неопределено И РезультатExecutor.Свойство("Сообщение"), РезультатExecutor.Сообщение, "");
	Политика = ПрименитьПолитикуВосстановления(СсылкаДиалога, КодОшибки, СообщениеОшибки);
	СледующаяСтадия = ?(Политика.Свойство("СледующаяСтадия"), Политика.СледующаяСтадия, ?(Политика.Обработано, "Plan", "Summarize"));
	ПереходМетрики = ?(Политика.Обработано, "Recover->" + СледующаяСтадия, "Recover->Summarize");
	ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Recover", НачалоRecover, Политика.Обработано, СообщениеОшибки, ПереходМетрики, ?(Политика.Свойство("Идентификатор"), Политика.Идентификатор, ""), 0, "");
	Если НЕ Политика.Свойство("SubgraphName") Тогда
		Политика.Вставить("SubgraphName", "RecoverySubgraph");
	КонецЕсли;
	СостояниеОркестратора = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
	ActiveStepId = ?(СостояниеОркестратора <> Неопределено И СостояниеОркестратора.Свойство("active_step_id"), СостояниеОркестратора.active_step_id, "");
	Политика.Вставить("Decision", ?(Политика.Свойство("Решение"), Политика.Решение, ?(Политика.Обработано, "replan", "abort")));
	Политика.Вставить("NextStage", СледующаяСтадия);
	Политика.Вставить("Reason", ?(Политика.Свойство("Причина"), Политика.Причина, ?(Политика.Обработано, "recover_handled", "recover_failed")));
	Политика.Вставить("Policy", ?(Политика.Свойство("Идентификатор"), Политика.Идентификатор, ""));
	Политика.Вставить("StepId", ?(Политика.Свойство("StepId"), Политика.StepId, ActiveStepId));
	Возврат ПодготовитьРезультатПодграфаКВозврату(Политика);
КонецФункции

Процедура ЗафиксироватьRecoverySemantics(СсылкаДиалога, РезультатRecovery)
	Если РезультатRecovery = Неопределено
		Или ТипЗнч(РезультатRecovery) <> Тип("Структура")
		Или НЕ РезультатRecovery.Свойство("Обработано")
		Или НЕ РезультатRecovery.Обработано Тогда
		Возврат;
	КонецЕсли;
	Если РезультатRecovery.Свойство("SemanticsLogged") И РезультатRecovery.SemanticsLogged Тогда
		Возврат;
	КонецЕсли;
	DecisionValue = ?(РезультатRecovery.Свойство("Decision"), РезультатRecovery.Decision, ?(РезультатRecovery.Свойство("Решение"), РезультатRecovery.Решение, ""));
	ReasonValue = ?(РезультатRecovery.Свойство("Reason"), РезультатRecovery.Reason, ?(РезультатRecovery.Свойство("Причина"), РезультатRecovery.Причина, ""));
	PolicyValue = ?(РезультатRecovery.Свойство("Policy"), РезультатRecovery.Policy, ?(РезультатRecovery.Свойство("Идентификатор"), РезультатRecovery.Идентификатор, ""));
	StepIdValue = ?(РезультатRecovery.Свойство("StepId"), РезультатRecovery.StepId, "");
	ReplaySafety = КлассифицироватьReplaySafety(СсылкаДиалога);
	ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", ?(ПустаяСтрока(ReasonValue), ?(ПустаяСтрока(DecisionValue), "replan", DecisionValue), ReasonValue), "RecoverySubgraph", Новый Структура("source,step_id,policy_id,policy,reason,replay_safety", "recovery", StepIdValue, PolicyValue, PolicyValue, ReasonValue, ?(ReplaySafety.Свойство("classification"), ReplaySafety.classification, "")));
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "recovery_decision_" + ?(DecisionValue = "abort", "abort", ?(DecisionValue = "resume", "resume", "replan")), "Recover", Новый Структура("decision,policy_id,step_id,replay_safety", DecisionValue, PolicyValue, StepIdValue, ?(ReplaySafety.Свойство("classification"), ReplaySafety.classification, "")), ReasonValue);
	РезультатRecovery.Вставить("SemanticsLogged", Истина);
КонецПроцедуры

Процедура ПрименитьПереходRecoverSubgraph(СсылкаДиалога, РезультатRecover) Экспорт
	Если РезультатRecover <> Неопределено
		И РезультатRecover.Свойство("Обработано")
		И РезультатRecover.Обработано Тогда
		СледующаяСтадияRecover = ?(РезультатRecover.Свойство("СледующаяСтадия"), РезультатRecover.СледующаяСтадия, "Plan");
		ПричинаRecover = ?(РезультатRecover.Свойство("Причина"), РезультатRecover.Причина, "recover_handled");
		УвеличитьПопыткуRecover = (СледующаяСтадияRecover = "Recover");
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, СледующаяСтадияRecover, ПричинаRecover, УвеличитьПопыткуRecover);
	Иначе
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Summarize", "recover_failed", Ложь);
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьРеестрПолитикВосстановления() Экспорт
	Реестр = Новый Соответствие;
	Реестр.Вставить("table_not_found", Новый Структура("id,actions,max_attempts", "table_not_found_policy", "GetMetadata->GetObjectFields->RunQuery", 3));
	Реестр.Вставить("object_not_found", Новый Структура("id,actions,max_attempts", "object_not_found_policy", "GetMetadata->GetObjectFields->RunQuery", 3));
	Реестр.Вставить("field_not_found", Новый Структура("id,actions,max_attempts", "field_not_found_policy", "RepairDSL|SwitchObject", 3));
	Реестр.Вставить("query_syntax_error", Новый Структура("id,actions,max_attempts", "query_syntax_policy", "RepairDSL", 2));
	Реестр.Вставить("query_execution_error", Новый Структура("id,actions,max_attempts", "query_execution_policy", "RepairDSL|GetObjectFields", 2));
	Реестр.Вставить("parameter_missing", Новый Структура("id,actions,max_attempts", "parameter_missing_policy", "RepairDSL", 2));
	Реестр.Вставить("query_safety_violation", Новый Структура("id,actions,max_attempts", "query_safety_policy", "GetObjectFields|RepairDSL", 3));
	Реестр.Вставить("write_failed", Новый Структура("id,actions,max_attempts", "write_retry_same_operation_policy", "ResumeSameOperation|AbortUnsafeRetry", 2));
	Реестр.Вставить("storage_write_error", Новый Структура("id,actions,max_attempts", "storage_write_same_operation_policy", "ResumeSameOperation|AbortUnsafeRetry", 2));
	Реестр.Вставить("capability_violation", Новый Структура("id,actions,max_attempts", "capability_violation_policy", "AbortWithExplanation", 1));
	Возврат Реестр;
КонецФункции

Функция ИзвлечьКодОшибки(РезультатExecutor) Экспорт
	КодОшибки = "";
	Если РезультатExecutor = Неопределено Тогда
		Возврат КодОшибки;
	КонецЕсли;
	Если РезультатExecutor.Свойство("error_code") Тогда
		КодОшибки = Строка(РезультатExecutor.error_code);
	КонецЕсли;
	Если ПустаяСтрока(КодОшибки) И РезультатExecutor.Свойство("КодОшибки") Тогда
		КодОшибки = Строка(РезультатExecutor.КодОшибки);
	КонецЕсли;
	
	// В некоторых ветках executor возвращает общий step_failed.
	// Нормализуем его в recoverable-код по тексту ошибки, чтобы policy-движок не терял восстановление.
	Если ПустаяСтрока(КодОшибки)
		Или ВРег(СокрЛП(КодОшибки)) = "STEP_FAILED"
		Или ВРег(СокрЛП(КодОшибки)) = "INVALID_STEP" Тогда
		ТекстОшибки = ?(РезультатExecutor.Свойство("Сообщение"), Строка(РезультатExecutor.Сообщение), "");
		КодПоТексту = ОпределитьКодОшибкиПоТексту(ТекстОшибки);
		Если НЕ ПустаяСтрока(КодПоТексту) Тогда
			КодОшибки = КодПоТексту;
		КонецЕсли;
	КонецЕсли;
	
	Возврат НормализоватьКодОшибки(КодОшибки);
КонецФункции

Функция ОпределитьКодОшибкиПоТексту(ТекстОшибки) Экспорт
	Текст = ВРег(СокрЛП(ТекстОшибки));
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	
	Если СтрНайти(Текст, "ПОЛЕ НЕ НАЙДЕНО") > 0 Тогда
		Возврат "field_not_found";
	КонецЕсли;
	Если (СтрНайти(Текст, "ДОКУМЕНТ '") > 0
			ИЛИ СтрНайти(Текст, "СПРАВОЧНИК '") > 0
			ИЛИ СтрНайти(Текст, "РЕГИСТРНАКОПЛЕНИЯ '") > 0
			ИЛИ СтрНайти(Текст, "РЕГИСТРСВЕДЕНИЙ '") > 0)
		И СтрНайти(Текст, "НЕ НАЙДЕН") > 0 Тогда
		Возврат "object_not_found";
	КонецЕсли;
	Если СтрНайти(Текст, "ТАБЛИЦА") > 0 И (СтрНайти(Текст, "НЕ НАЙДЕНА") > 0 ИЛИ СтрНайти(Текст, "НЕ НАЙДЕН") > 0) Тогда
		Возврат "table_not_found";
	КонецЕсли;
	Если СтрНайти(Текст, "СИНТАКСИЧЕСКАЯ ОШИБКА") > 0
		ИЛИ СтрНайти(Текст, "ОЖИДАЕТСЯ ВЫРАЖЕНИЕ") > 0
		ИЛИ СтрНайти(Текст, "НЕОПОЗНАННЫЙ ОПЕРАТОР") > 0 Тогда
		Возврат "query_syntax_error";
	КонецЕсли;
	Если СтрНайти(Текст, "ПАРАМЕТР") > 0 И СтрНайти(Текст, "НЕ УСТАНОВЛЕН") > 0 Тогда
		Возврат "parameter_missing";
	КонецЕсли;
	Если СтрНайти(Текст, "QUERY SAFETY GATE") > 0
		ИЛИ СтрНайти(Текст, "FORBIDDEN_") > 0
		ИЛИ СтрНайти(Текст, "WHITELIST") > 0 Тогда
		Возврат "query_safety_violation";
	КонецЕсли;
	Если СтрНайти(Текст, "ОШИБКА ВЫПОЛНЕНИЯ ЗАПРОСА") > 0
		ИЛИ СтрНайти(Текст, "ОШИБКА ВЫПОЛНЕНИЯ ШАГА 'RUNQUERY'") > 0 Тогда
		Возврат "query_execution_error";
	КонецЕсли;
	Если СтрНайти(Текст, "ОШИБКА ЗАПИСИ ОБЪЕКТА") > 0
		ИЛИ СтрНайти(Текст, "ОШИБКА АВТОМАТИЧЕСКОЙ ЗАПИСИ ОБЪЕКТА") > 0 Тогда
		Возврат "write_failed";
	КонецЕсли;
	
	Возврат "";
КонецФункции

Функция ЭтоВосстановимаяОшибка(КодОшибки) Экспорт
	Код = НормализоватьКодОшибки(КодОшибки);
	Возврат Код = "field_not_found"
		Или Код = "table_not_found"
		Или Код = "object_not_found"
		Или Код = "query_syntax_error"
		Или Код = "query_execution_error"
		Или Код = "parameter_missing"
		Или Код = "query_safety_violation"
		Или Код = "write_failed"
		Или Код = "storage_write_error";
КонецФункции

Функция ПолучитьМаксПопытокДляОшибки(КодОшибки) Экспорт
	Код = НормализоватьКодОшибки(КодОшибки);
	Реестр = ПолучитьРеестрПолитикВосстановления();
	Политика = Реестр.Получить(Код);
	Если Политика <> Неопределено И Политика.Свойство("max_attempts") Тогда
		Возврат Политика.max_attempts;
	КонецЕсли;
	Возврат 1;
КонецФункции

Функция НормализоватьКодОшибки(КодОшибки) Экспорт
	КодВРег = ВРег(СокрЛП(КодОшибки));
	Если КодВРег = "FIELD_NOT_FOUND" Тогда
		Возврат "field_not_found";
	ИначеЕсли КодВРег = "TABLE_NOT_FOUND" Тогда
		Возврат "table_not_found";
	ИначеЕсли КодВРег = "OBJECT_NOT_FOUND" Тогда
		Возврат "object_not_found";
	ИначеЕсли КодВРег = "QUERY_SYNTAX_ERROR" Тогда
		Возврат "query_syntax_error";
	ИначеЕсли КодВРег = "QUERY_EXECUTION_ERROR" Тогда
		Возврат "query_execution_error";
	ИначеЕсли КодВРег = "PARAMETER_MISSING" Тогда
		Возврат "parameter_missing";
	ИначеЕсли КодВРег = "QUERY_SAFETY_VIOLATION" Тогда
		Возврат "query_safety_violation";
	ИначеЕсли КодВРег = "WRITE_FAILED" Тогда
		Возврат "write_failed";
	ИначеЕсли КодВРег = "STORAGE_WRITE_ERROR" Тогда
		Возврат "storage_write_error";
	ИначеЕсли КодВРег = "CAPABILITY_VIOLATION" Тогда
		Возврат "capability_violation";
	КонецЕсли;
	Возврат СокрЛП(КодОшибки);
КонецФункции

Функция ИзвлечьOperationIdИзРезультатаExecutor(РезультатExecutor) Экспорт
	Если РезультатExecutor = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Если РезультатExecutor.Свойство("operation_id") И НЕ ПустаяСтрока(СокрЛП(Строка(РезультатExecutor.operation_id))) Тогда
		Возврат СокрЛП(Строка(РезультатExecutor.operation_id));
	КонецЕсли;
	Если РезультатExecutor.Свойство("Результаты") И ТипЗнч(РезультатExecutor.Результаты) = Тип("Массив") Тогда
		Если РезультатExecutor.Результаты.Количество() = 0 Тогда
			Возврат "";
		КонецЕсли;
		Для Индекс = РезультатExecutor.Результаты.Количество() - 1 По 0 Цикл
			ШагРезультата = РезультатExecutor.Результаты[Индекс];
			Если ТипЗнч(ШагРезультата) = Тип("Структура")
				И ШагРезультата.Свойство("operation_id")
				И НЕ ПустаяСтрока(СокрЛП(Строка(ШагРезультата.operation_id))) Тогда
				Возврат СокрЛП(Строка(ШагРезультата.operation_id));
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат "";
КонецФункции

Функция НайтиПоследнийSideEffectПоOperationId(СсылкаДиалога, OperationId)
	Если ПустаяСтрока(OperationId) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Лог = ИИА_Сервер.ПолучитьSideEffectLog(СсылкаДиалога);
	Если ТипЗнч(Лог) <> Тип("Массив") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Лог.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	Для Индекс = Лог.Количество() - 1 По 0 Цикл
		Запись = Лог[Индекс];
		Если ТипЗнч(Запись) = Тип("Структура")
			И Запись.Свойство("operation_id")
			И СокрЛП(Строка(Запись.operation_id)) = OperationId Тогда
			Возврат Запись;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция ЭтоКоммитящийSideEffect(ЗаписьЛога)
	Если ЗаписьЛога = Неопределено Или ТипЗнч(ЗаписьЛога) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	Если НЕ ЗаписьЛога.Свойство("effect_type") Тогда
		Возврат Ложь;
	КонецЕсли;
	ВидЭффекта = ВРег(СокрЛП(Строка(ЗаписьЛога.effect_type)));
	Возврат ВидЭффекта = "OBJECT_WRITTEN" ИЛИ ВидЭффекта = "OBJECT_WRITTEN_AUTO";
КонецФункции

Функция ПопробоватьПрименитьWriteRecoveryPolicy(СсылкаДиалога, РезультатExecutor, КодОшибки, Результат)
	ЛокКод = НормализоватьКодОшибки(КодОшибки);
	Если ЛокКод <> "write_failed" И ЛокКод <> "storage_write_error" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
	DSLИсходный = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL"), АртефактПлана.PlannedDSL, "");
	OperationId = ИзвлечьOperationIdИзРезультатаExecutor(РезультатExecutor);
	ПоследнийЭффект = НайтиПоследнийSideEffectПоOperationId(СсылкаДиалога, OperationId);
	
	Если ЭтоКоммитящийSideEffect(ПоследнийЭффект) Тогда
		СинтетическийРезультат = Новый Структура("Успех,Сообщение,error_code,operation_id,recovered_by_policy", Истина, "Повтор Write пропущен: side effect уже зафиксирован для operation_id " + OperationId + ".", "", OperationId, "write_retry_committed_policy");
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, СинтетическийРезультат);
		Результат.Обработано = Истина;
		Результат.Идентификатор = "write_retry_committed_policy";
		Результат.Действие = "resume_after_committed_write";
		Результат.Решение = "resume";
		Результат.СледующаяСтадия = "Validate";
		Результат.Причина = "resume_after_committed_write";
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", "resume_after_committed_write", "RecoverySubgraph", Новый Структура("source,policy_id,reason,operation_id,error_code", "recovery", Результат.Идентификатор, ЛокКод, OperationId, ЛокКод));
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "recovery_decision_resume", "Recover", Новый Структура("decision,policy_id,operation_id,last_effect", "resume", Результат.Идентификатор, OperationId, ?(ПоследнийЭффект.Свойство("effect_type"), Строка(ПоследнийЭффект.effect_type), "")), "resume_after_committed_write");
		Результат.Вставить("SemanticsLogged", Истина);
		Возврат Истина;
	КонецЕсли;
	
	Если ПустаяСтрока(OperationId) Тогда
		ИИА_Сервер.ДобавитьСообщениеВДиалог(СсылкаДиалога, Перечисления.ИИА_АвторСообщения.Система, Перечисления.ИИА_ТипСообщения.Текст, "Recovery остановлен: write-path завершился ошибкой без operation_id, безопасный retry невозможен.");
		Результат.Обработано = Истина;
		Результат.Идентификатор = "write_retry_missing_operation_id_policy";
		Результат.Действие = "abort_unsafe_write_retry";
		Результат.Решение = "abort";
		Результат.СледующаяСтадия = "Summarize";
		Результат.Причина = "abort_unsafe_write_retry";
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", "abort_unsafe_write_retry", "RecoverySubgraph", Новый Структура("source,policy_id,reason,error_code", "recovery", Результат.Идентификатор, ЛокКод, ЛокКод));
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "recovery_decision_abort", "Recover", Новый Структура("decision,policy_id,error_code", "abort", Результат.Идентификатор, ЛокКод), "abort_unsafe_write_retry");
		Результат.Вставить("SemanticsLogged", Истина);
		Возврат Истина;
	КонецЕсли;
	
	Если ПустаяСтрока(DSLИсходный) Или СтрНайти(DSLИсходный, OperationId) = 0 Тогда
		ИИА_Сервер.ДобавитьСообщениеВДиалог(СсылкаДиалога, Перечисления.ИИА_АвторСообщения.Система, Перечисления.ИИА_ТипСообщения.Текст, "Recovery остановлен: не найден сохраненный DSL с тем же operation_id для безопасного повтора write-path.");
		Результат.Обработано = Истина;
		Результат.Идентификатор = "write_retry_missing_planned_dsl_policy";
		Результат.Действие = "abort_missing_same_operation";
		Результат.Решение = "abort";
		Результат.СледующаяСтадия = "Summarize";
		Результат.Причина = "abort_missing_same_operation";
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", "abort_missing_same_operation", "RecoverySubgraph", Новый Структура("source,policy_id,reason,operation_id,error_code", "recovery", Результат.Идентификатор, ЛокКод, OperationId, ЛокКод));
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "recovery_decision_abort", "Recover", Новый Структура("decision,policy_id,operation_id", "abort", Результат.Идентификатор, OperationId), "abort_missing_same_operation");
		Результат.Вставить("SemanticsLogged", Истина);
		Возврат Истина;
	КонецЕсли;
	
	ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалога, DSLИсходный, "recovery_resume_same_operation_id", ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlanStepId"), АртефактПлана.PlanStepId, ""));
	Результат.Обработано = Истина;
	Результат.Идентификатор = ?(ЛокКод = "storage_write_error", "storage_write_same_operation_policy", "write_retry_same_operation_policy");
	Результат.Действие = "resume_same_operation_id";
	Результат.Решение = "resume";
	Результат.СледующаяСтадия = "Execute";
	Результат.Причина = "resume_same_operation_id";
	ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", "resume_same_operation_id", "RecoverySubgraph", Новый Структура("source,policy_id,reason,operation_id,error_code", "recovery", Результат.Идентификатор, ЛокКод, OperationId, ЛокКод));
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "recovery_decision_resume", "Recover", Новый Структура("decision,policy_id,operation_id", "resume", Результат.Идентификатор, OperationId), "resume_same_operation_id");
	Результат.Вставить("SemanticsLogged", Истина);
	Возврат Истина;
КонецФункции

Функция ЭтоРанняяСдачаShowInfo(СсылкаДиалога, DSLСценарий) Экспорт
	Если ПустаяСтрока(DSLСценарий) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстDSLВРег = ВРег(DSLСценарий);
	ПохожеНаСдачуПоТексту = СтрНайти(ТекстDSLВРег, "SHOWINFO") > 0
		И (СтрНайти(ТекстDSLВРег, "ЗАДАЧА НЕ ВЫПОЛНЕНА") > 0 ИЛИ СтрНайти(ТекстDSLВРег, "НЕТ:") > 0);
	
	Попытка
		Чтение = Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(DSLСценарий);
		Данные = ПрочитатьJSON(Чтение);
		Чтение.Закрыть();
		ЕстьSteps = Ложь;
		Шаги = Неопределено;
		Если ТипЗнч(Данные) = Тип("Структура") И Данные.Свойство("steps") Тогда
			ЕстьSteps = Истина;
			Шаги = Данные.steps;
		ИначеЕсли ТипЗнч(Данные) = Тип("Соответствие") Тогда
			Шаги = Данные.Получить("steps");
			ЕстьSteps = Шаги <> Неопределено;
		КонецЕсли;
		Если НЕ ЕстьSteps Тогда
			Если НЕ ПохожеНаСдачуПоТексту Тогда
				Возврат Ложь;
			КонецЕсли;
			
			ПредРезультат = ИИА_Сервер.ПолучитьРезультатExecutor(СсылкаДиалога);
			КодОшибки = ИзвлечьКодОшибки(ПредРезультат);
			Если НЕ ЭтоВосстановимаяОшибка(КодОшибки) Тогда
				Возврат Ложь;
			КонецЕсли;
			Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
			ПопыткаНомер = ?(Состояние <> Неопределено И Состояние.Свойство("НомерПопытки"), Состояние.НомерПопытки, 0);
			МаксПопыток = ПолучитьМаксПопытокДляОшибки(КодОшибки);
			Возврат ПопыткаНомер < МаксПопыток;
		КонецЕсли;
		Если НЕ ЕстьSteps Тогда
			Возврат Ложь;
		КонецЕсли;
		Если ТипЗнч(Шаги) <> Тип("Массив") Или Шаги.Количество() <> 1 Тогда
			Возврат Ложь;
		КонецЕсли;
		Шаг = Шаги[0];
		Если ТипЗнч(Шаг) <> Тип("Структура") И ТипЗнч(Шаг) <> Тип("Соответствие") Тогда
			Возврат Ложь;
		КонецЕсли;
		ЕстьAction = Ложь;
		Действие = "";
		Если ТипЗнч(Шаг) = Тип("Структура") И Шаг.Свойство("action") Тогда
			ЕстьAction = Истина;
			Действие = Шаг.action;
		ИначеЕсли ТипЗнч(Шаг) = Тип("Соответствие") Тогда
			ЗначениеAction = Шаг.Получить("action");
			Если ЗначениеAction <> Неопределено Тогда
				ЕстьAction = Истина;
				Действие = ЗначениеAction;
			КонецЕсли;
		КонецЕсли;
		Если НЕ ЕстьAction Или ВРег(СокрЛП(Действие)) <> "SHOWINFO" Тогда
			Возврат Ложь;
		КонецЕсли;
		Сообщение = "";
		Если ТипЗнч(Шаг) = Тип("Структура") И Шаг.Свойство("message") Тогда
			Сообщение = ВРег(Строка(Шаг.message));
		ИначеЕсли ТипЗнч(Шаг) = Тип("Соответствие") И Шаг.Получить("message") <> Неопределено Тогда
			Сообщение = ВРег(Строка(Шаг.Получить("message")));
		КонецЕсли;
		Если СтрНайти(Сообщение, "ЗАДАЧА НЕ ВЫПОЛНЕНА") = 0 И СтрНайти(Сообщение, "НЕТ:") = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
		ПредРезультат = ИИА_Сервер.ПолучитьРезультатExecutor(СсылкаДиалога);
		КодОшибки = ИзвлечьКодОшибки(ПредРезультат);
		Если НЕ ЭтоВосстановимаяОшибка(КодОшибки) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		ПопыткаНомер = ?(Состояние <> Неопределено И Состояние.Свойство("НомерПопытки"), Состояние.НомерПопытки, 0);
		МаксПопыток = ПолучитьМаксПопытокДляОшибки(КодОшибки);
		Возврат ПопыткаНомер < МаксПопыток;
	Исключение
		Возврат Ложь;
	КонецПопытки;
КонецФункции

Функция СформироватьRecoveryDSLGetObjectFields(ИмяТаблицы) Экспорт
	ЛокИмя = СокрЛП(ИмяТаблицы);
	Если ПустаяСтрока(ЛокИмя) Тогда
		Возврат "";
	КонецЕсли;
	
	ПозицияТочки = СтрНайти(ЛокИмя, ".");
	Если ПозицияТочки = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Префикс = ВРег(Лев(ЛокИмя, ПозицияТочки - 1));
	ИмяОбъекта = СокрЛП(Сред(ЛокИмя, ПозицияТочки + 1));
	Если ПустаяСтрока(ИмяОбъекта) Тогда
		Возврат "";
	КонецЕсли;
	
	ТипОбъекта = "";
	Если Префикс = "ДОКУМЕНТ" Тогда
		ТипОбъекта = "Документ";
	ИначеЕсли Префикс = "СПРАВОЧНИК" Тогда
		ТипОбъекта = "Справочник";
	ИначеЕсли Префикс = "РЕГИСТРНАКОПЛЕНИЯ" Тогда
		ТипОбъекта = "РегистрНакопления";
	ИначеЕсли Префикс = "РЕГИСТРСВЕДЕНИЙ" Тогда
		ТипОбъекта = "РегистрСведений";
	КонецЕсли;
	
	Если ПустаяСтрока(ТипОбъекта) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат "{""dsl_version"":2,""steps"":[{""action"":""GetObjectFields"",""object_type"":""" + ТипОбъекта + """,""object_name"":""" + ИмяОбъекта + """}]}";
КонецФункции

Функция СохранитьRecoveryАртефактЕслиВалиден(СсылкаДиалога, DSLКандидат, Причина, Действие, Результат)
	Если ПустаяСтрока(DSLКандидат) Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ЭтоРанняяСдачаShowInfo(СсылкаДиалога, DSLКандидат) Тогда
		ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[ANTI_GIVEUP] Recovery-ответ отклонен: ранний negative ShowInfo.");
		Возврат Ложь;
	КонецЕсли;
	ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалога, DSLКандидат, Причина, Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss"));
	Результат.Обработано = Истина;
	Результат.Действие = Действие;
	Возврат Истина;
КонецФункции

Функция ПрименитьПолитикуВосстановления(СсылкаДиалога, КодОшибки, СообщениеОшибки) Экспорт
	Результат = Новый Структура("Обработано,Идентификатор,Действие,Решение,СледующаяСтадия,Причина", Ложь, "", "", "", "", "");
	ЛокКод = НормализоватьКодОшибки(КодОшибки);
	РезультатExecutor = ИИА_Сервер.ПолучитьРезультатExecutor(СсылкаДиалога);
	Если ПустаяСтрока(ЛокКод) Тогда
		ТекстВРег = ВРег(СообщениеОшибки);
		Если СтрНайти(ТекстВРег, "ТАБЛИЦА") > 0 И СтрНайти(ТекстВРег, "НЕ НАЙД") > 0 Тогда
			ЛокКод = "table_not_found";
		ИначеЕсли СтрНайти(ТекстВРег, "НЕ НАЙДЕН") > 0
			И (СтрНайти(ТекстВРег, "ДОКУМЕНТ") > 0
				ИЛИ СтрНайти(ТекстВРег, "СПРАВОЧНИК") > 0
				ИЛИ СтрНайти(ТекстВРег, "РЕГИСТР") > 0) Тогда
			ЛокКод = "object_not_found";
		ИначеЕсли СтрНайти(ТекстВРег, "ПОЛЕ НЕ НАЙД") > 0 Тогда
			ЛокКод = "field_not_found";
		ИначеЕсли СтрНайти(ТекстВРег, "СИНТАКС") > 0 Тогда
			ЛокКод = "query_syntax_error";
		КонецЕсли;
	КонецЕсли;
	
	Реестр = ПолучитьРеестрПолитикВосстановления();
	Политика = Реестр.Получить(ЛокКод);
	Если Политика = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.Идентификатор = Политика.id;
	
	Если ПопробоватьПрименитьWriteRecoveryPolicy(СсылкаДиалога, РезультатExecutor, ЛокКод, Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЛокКод = "table_not_found" ИЛИ ЛокКод = "object_not_found" ИЛИ ЛокКод = "query_execution_error" Тогда
		ИмяТаблицыОшибки = ИзвлечьИмяТаблицыИзОшибки(СообщениеОшибки);
		Если ПустаяСтрока(ИмяТаблицыОшибки) Тогда
			АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
			DSLИсходный = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL"), АртефактПлана.PlannedDSL, "");
			ИмяТаблицыОшибки = ИзвлечьИмяТаблицыИзТекстаЗапроса(DSLИсходный);
		КонецЕсли;
		
		Если ЗафиксироватьПовторНевалиднойТаблицыRunQuery(СсылкаДиалога, ИмяТаблицыОшибки, 3) Тогда
			ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[RECOVERY_GUARD] Повтор одного и того же невалидного источника RunQuery. Прерываем recovery для экономии токенов.");
			Результат.Идентификатор = "repeated_invalid_table_path";
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если ИзвлечьИОчиститьФлагПринудительнойСменыСтратегииRunQuery(СсылкаДиалога) Тогда
		ИмяТаблицыДляСмены = ИзвлечьИмяТаблицыИзТекстаЗапроса(СообщениеОшибки);
		Если ПустаяСтрока(ИмяТаблицыДляСмены) Тогда
			АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
			DSLИсходный = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL"), АртефактПлана.PlannedDSL, "");
			ИмяТаблицыДляСмены = ИзвлечьИмяТаблицыИзТекстаЗапроса(DSLИсходный);
		КонецЕсли;
		Если НЕ ПустаяСтрока(ИмяТаблицыДляСмены) И ДобавитьGetMetadataВПланПриТаблицаНеНайдена(СсылкаДиалога, ИмяТаблицыДляСмены) Тогда
			Результат.Обработано = Истина;
			Результат.Действие = "insert_getmetadata_loop_guard";
			Результат.Решение = "replan";
			Результат.СледующаяСтадия = "Plan";
			Результат.Причина = "reset_attempt";
			Результат.Идентификатор = "loop_guard_switch_object_policy";
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЛокКод = "table_not_found" ИЛИ ЛокКод = "object_not_found" Тогда
		ИмяТаблицы = ИзвлечьИмяТаблицыИзОшибки(СообщениеОшибки);
		Если НЕ ПустаяСтрока(ИмяТаблицы) И ДобавитьGetMetadataВПланПриТаблицаНеНайдена(СсылкаДиалога, ИмяТаблицы) Тогда
			Результат.Обработано = Истина;
			Результат.Действие = "insert_getmetadata";
			Результат.Решение = "replan";
		ИначеЕсли ДобавитьGetMetadataВПланПоКонтекстуОшибки(СсылкаДиалога, РезультатExecutor, СообщениеОшибки) Тогда
			Результат.Обработано = Истина;
			Результат.Действие = "insert_getmetadata";
			Результат.Решение = "replan";
		КонецЕсли;
	ИначеЕсли ЛокКод = "field_not_found" Тогда
		АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
		DSLИсходный = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL"), АртефактПлана.PlannedDSL, "");
		ТекстФактов = СобратьФактыПоследнихДействий(СсылкаДиалога);
		ПоляДляRetry = ИзвлечьРеквизитыИзФактов(ТекстФактов);
		ПринятоИсправление = Ложь;
		ЛокальноИсправленныйDSL = ПопробоватьЛокальноИсправитьFieldNotFoundDSL(СообщениеОшибки, DSLИсходный, ПоляДляRetry);
		Если НЕ ПустаяСтрока(ЛокальноИсправленныйDSL) Тогда
			ПринятоИсправление = СохранитьRecoveryАртефактЕслиВалиден(СсылкаДиалога, ЛокальноИсправленныйDSL, "recovery_field_not_found_local_repair", "repair_dsl_local", Результат);
		КонецЕсли;
		Если НЕ ПустаяСтрока(DSLИсходный) И НЕ ПустаяСтрока(ПоляДляRetry) Тогда
			Если НЕ ПринятоИсправление Тогда
				ПромптИсправления = ИИА_Промты.ПолучитьПромптИсправленияDSL(СообщениеОшибки, DSLИсходный, ПоляДляRetry);
				ОтветИсправления = ИИА_Сервер.ВызватьИИССистемнымСообщением(СсылкаДиалога, "Чат", ПромптИсправления, "", "dsl", , Ложь, Ложь);
				ПринятоИсправление = СохранитьRecoveryАртефактЕслиВалиден(СсылкаДиалога, ОтветИсправления.DSL, "recovery_field_not_found", "repair_dsl", Результат);
			КонецЕсли;
		КонецЕсли;
		
		Если НЕ ПринятоИсправление Тогда
			ИмяТаблицыДляПоля = ИзвлечьИмяТаблицыИзТекстаЗапроса(СообщениеОшибки);
			Если ПустаяСтрока(ИмяТаблицыДляПоля) Тогда
				ИмяТаблицыДляПоля = ИзвлечьИмяТаблицыИзТекстаЗапроса(DSLИсходный);
			КонецЕсли;
			Если НЕ ПустаяСтрока(ИмяТаблицыДляПоля) И ДобавитьGetObjectFieldsВПланПередRunQuery(СсылкаДиалога, ИмяТаблицыДляПоля) Тогда
				Результат.Обработано = Истина;
				Результат.Действие = "insert_getobjectfields";
				Результат.Решение = "replan";
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ЛокКод = "query_syntax_error" ИЛИ ЛокКод = "query_execution_error" Тогда
		АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
		DSLИсходный = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL"), АртефактПлана.PlannedDSL, "");
		ПринятоИсправление = Ложь;
		Если НЕ ПустаяСтрока(DSLИсходный) Тогда
			ПромптИсправления = ИИА_Промты.ПолучитьПромптИсправленияDSL(СообщениеОшибки, DSLИсходный, "");
			ОтветИсправления = ИИА_Сервер.ВызватьИИССистемнымСообщением(СсылкаДиалога, "Чат", ПромптИсправления, "", "dsl", , Ложь, Ложь);
			ПринятоИсправление = СохранитьRecoveryАртефактЕслиВалиден(СсылкаДиалога, ОтветИсправления.DSL, "recovery_query_repair", "repair_syntax", Результат);
		КонецЕсли;
		Если НЕ ПринятоИсправление Тогда
			ИмяТаблицыДляПоля = ИзвлечьИмяТаблицыИзТекстаЗапроса(СообщениеОшибки);
			Если ПустаяСтрока(ИмяТаблицыДляПоля) Тогда
				ИмяТаблицыДляПоля = ИзвлечьИмяТаблицыИзТекстаЗапроса(DSLИсходный);
			КонецЕсли;
			DSLGetObjectFields = СформироватьRecoveryDSLGetObjectFields(ИмяТаблицыДляПоля);
			Если НЕ ПустаяСтрока(DSLGetObjectFields) Тогда
				СохранитьRecoveryАртефактЕслиВалиден(СсылкаДиалога, DSLGetObjectFields, "recovery_query_getobjectfields", "insert_getobjectfields", Результат);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ЛокКод = "query_safety_violation" Тогда
		АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
		DSLИсходный = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL"), АртефактПлана.PlannedDSL, "");
		ИмяТаблицыДляПоля = ИзвлечьИмяТаблицыИзТекстаЗапроса(СообщениеОшибки);
		Если ПустаяСтрока(ИмяТаблицыДляПоля) Тогда
			ИмяТаблицыДляПоля = ИзвлечьИмяТаблицыИзТекстаЗапроса(DSLИсходный);
		КонецЕсли;
		
		DSLGetObjectFields = СформироватьRecoveryDSLGetObjectFields(ИмяТаблицыДляПоля);
		Если НЕ ПустаяСтрока(DSLGetObjectFields) Тогда
			СохранитьRecoveryАртефактЕслиВалиден(СсылкаДиалога, DSLGetObjectFields, "recovery_query_safety_getobjectfields", "insert_getobjectfields", Результат);
		КонецЕсли;
		
		Если НЕ Результат.Обработано И НЕ ПустаяСтрока(DSLИсходный) Тогда
			ПромптИсправления = ИИА_Промты.ПолучитьПромптИсправленияDSL(СообщениеОшибки, DSLИсходный, "");
			ОтветИсправления = ИИА_Сервер.ВызватьИИССистемнымСообщением(СсылкаДиалога, "Чат", ПромптИсправления, "", "dsl", , Ложь, Ложь);
			СохранитьRecoveryАртефактЕслиВалиден(СсылкаДиалога, ОтветИсправления.DSL, "recovery_query_safety_repair", "repair_dsl", Результат);
		КонецЕсли;
	ИначеЕсли ЛокКод = "capability_violation" Тогда
		ИИА_Сервер.ДобавитьСообщениеВДиалог(СсылкаДиалога, Перечисления.ИИА_АвторСообщения.Система, Перечисления.ИИА_ТипСообщения.Текст, "Действие отклонено политикой доступа (capability). Уточни задачу без операций записи или запроси права.");
		Результат.Обработано = Истина;
		Результат.Действие = "abort_with_explanation";
		Результат.Решение = "abort";
		Результат.СледующаяСтадия = "Summarize";
		Результат.Причина = "capability_abort";
	КонецЕсли;
	
	Если Результат.Обработано Тогда
		Если ПустаяСтрока(Результат.Решение) Тогда
			Результат.Решение = "replan";
		КонецЕсли;
		Если ПустаяСтрока(Результат.СледующаяСтадия) Тогда
			Результат.СледующаяСтадия = ?(Результат.Решение = "abort", "Summarize", ?(Результат.Решение = "resume", "Execute", "Plan"));
		КонецЕсли;
		Если ПустаяСтрока(Результат.Причина) Тогда
			Результат.Причина = ?(Результат.Решение = "abort", "recover_abort", ?(Результат.Решение = "resume", "recover_resume", "reset_attempt"));
		КонецЕсли;
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		НомерПопытки = ?(Состояние <> Неопределено И Состояние.Свойство("НомерПопытки"), Состояние.НомерПопытки, 0);
		ПереходМетрики = "Recover->" + Результат.СледующаяСтадия;
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Recover", ТекущаяДата(), Истина, "", ПереходМетрики, Результат.Идентификатор, НомерПопытки + 1, "");
		ЗафиксироватьRecoverySemantics(СсылкаДиалога, Результат);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция СгенерироватьПродолжениеВыполнения(СсылкаДиалога) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Унифицированный путь: continuation идёт через state-machine цикл.
	НачальныеТокены = ИИА_Сервер.ПолучитьОбщееКоличествоТокенов(СсылкаДиалога);
	Если НЕ ИИА_Сервер.ОркестраторВключенДляДиалога(СсылкаДиалога) Тогда
		ИИА_Сервер.УстановитьОркестраторВключен(СсылкаДиалога, Истина);
	КонецЕсли;
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Оркестратор] Продолжение через state-machine цикл.");
	ВыполнитьЦикл(СсылкаДиалога, НачальныеТокены);
	
	Возврат НЕ ИИА_Сервер.ОркестраторВключенДляДиалога(СсылкаДиалога);
	
КонецФункции

Функция ВозобновитьСЧекпоинта(СсылкаДиалога, ИндексЧекпоинта = -1, АвтоЗапуск = Истина) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИсторияЧекпоинтов = ИИА_Сервер.ПолучитьИсториюЧекпоинтовОркестратора(СсылкаДиалога, 100);
	Если ТипЗнч(ИсторияЧекпоинтов) <> Тип("Массив") Или ИсторияЧекпоинтов.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ИндексЧекпоинта < 0 Тогда
		ИндексЧекпоинта = ИсторияЧекпоинтов.Количество() - 1;
	КонецЕсли;
	Если ИндексЧекпоинта < 0 Или ИндексЧекпоинта >= ИсторияЧекпоинтов.Количество() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Чекпоинт = ИсторияЧекпоинтов[ИндексЧекпоинта];
	Если ТипЗнч(Чекпоинт) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	ReplaySafety = КлассифицироватьReplaySafety(СсылкаДиалога, ИндексЧекпоинта);
	Если ReplaySafety <> Неопределено
		И ReplaySafety.Свойство("classification")
		И ReplaySafety.classification = "no_replay" Тогда
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "checkpoint_resume", "requested", "RuntimeReplay", Новый Структура("source,step_id,reason,policy", "checkpoint", ?(ReplaySafety.Свойство("operation_id"), ReplaySafety.operation_id, ""), ?(ReplaySafety.Свойство("reason"), ReplaySafety.reason, "no_replay"), "no_replay"));
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "checkpoint_resume_requested", ?(ReplaySafety.Свойство("stage"), ReplaySafety.stage, ""), Новый Структура("checkpoint_index,replay_safety,reason", ИндексЧекпоинта, "no_replay", ?(ReplaySafety.Свойство("reason"), ReplaySafety.reason, "")), "checkpoint_resume_blocked");
		ИИА_Сервер.ДобавитьСообщениеВДиалог(СсылкаДиалога, Перечисления.ИИА_АвторСообщения.Система, Перечисления.ИИА_ТипСообщения.Текст, "Resume from checkpoint заблокирован: replay policy = no_replay (" + ?(ReplaySafety.Свойство("reason"), ReplaySafety.reason, "") + ").");
		Возврат Ложь;
	КонецЕсли;
	
	Стадия = ?(Чекпоинт.Свойство("stage"), Строка(Чекпоинт.stage), "");
	Переход = ?(Чекпоинт.Свойство("transition"), Строка(Чекпоинт.transition), "");
	Если ПустаяСтрока(Стадия) Тогда
		Стадия = "Intent";
	КонецЕсли;
	
	Детали = ?(Чекпоинт.Свойство("details"), Чекпоинт.details, Неопределено);
	Если Детали <> Неопределено И ТипЗнч(Детали) = Тип("Структура") Тогда
		Если Детали.Свойство("step_id") И НЕ ПустаяСтрока(Строка(Детали.step_id)) Тогда
			ИИА_Сервер.УстановитьActiveStepId(СсылкаДиалога, Строка(Детали.step_id));
		ИначеЕсли Детали.Свойство("active_step_id") И НЕ ПустаяСтрока(Строка(Детали.active_step_id)) Тогда
			ИИА_Сервер.УстановитьActiveStepId(СсылкаДиалога, Строка(Детали.active_step_id));
		КонецЕсли;
		Если Детали.Свойство("execution_policy") И НЕ ПустаяСтрока(Строка(Детали.execution_policy)) Тогда
			ИИА_Сервер.УстановитьExecutionPolicy(СсылкаДиалога, Строка(Детали.execution_policy));
		КонецЕсли;
		Если Детали.Свойство("subgraph") И НЕ ПустаяСтрока(Строка(Детали.subgraph)) Тогда
			ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, Строка(Детали.subgraph), "checkpoint_resume");
		КонецЕсли;
	КонецЕсли;
	
	ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "checkpoint_resume", "requested", "RuntimeReplay", Новый Структура("source,step_id,reason,policy", "checkpoint", ?(Чекпоинт.Свойство("step_id"), Строка(Чекпоинт.step_id), ""), ?(ReplaySafety <> Неопределено И ReplaySafety.Свойство("reason"), ReplaySafety.reason, "checkpoint_resume"), ?(ReplaySafety <> Неопределено И ReplaySafety.Свойство("classification"), ReplaySafety.classification, "safe_replay")));
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "checkpoint_resume_requested", Стадия, Новый Структура("checkpoint_index,checkpoint_type,replay_safety,reason", ИндексЧекпоинта, ?(Чекпоинт.Свойство("checkpoint_type"), Строка(Чекпоинт.checkpoint_type), ""), ?(ReplaySafety <> Неопределено И ReplaySafety.Свойство("classification"), ReplaySafety.classification, "safe_replay"), ?(ReplaySafety <> Неопределено И ReplaySafety.Свойство("reason"), ReplaySafety.reason, "checkpoint_resume")), "checkpoint_resume");
	ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, Стадия, "checkpoint_resume", Ложь);
	
	Если АвтоЗапуск Тогда
		Запустить(СсылкаДиалога, Истина);
	КонецЕсли;
	Возврат Истина;
КонецФункции

Функция ПодтвердитьОжидающееДействие(СсылкаДиалога, АвтоПродолжить = Истина) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СостояниеПодтверждения = ИИА_Сервер.ПолучитьСостояниеПодтверждения(СсылкаДиалога);
	Если СостояниеПодтверждения = Неопределено
		ИЛИ НЕ СостояниеПодтверждения.Свойство("status")
		ИЛИ ВРег(Строка(СостояниеПодтверждения.status)) <> "PENDING" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СостояниеПодтверждения.status = "approved";
	СостояниеПодтверждения.decision = "approve";
	СостояниеПодтверждения.decision_at = ТекущаяДатаСеанса();
	ИИА_Сервер.СохранитьСостояниеПодтверждения(СсылкаДиалога, СостояниеПодтверждения);
	ЗафиксироватьApprovalDecision(СсылкаДиалога, "approved", СостояниеПодтверждения, ?(СостояниеПодтверждения.Свойство("subgraph_name"), Строка(СостояниеПодтверждения.subgraph_name), "ExecuteSubgraph"), "user_approved", "approval_approved", "Execute", "approval_approved", "Пользователь подтвердил выполнение рискованного DSL. Возобновляю оркестратор.");
	Если АвтоПродолжить Тогда
		Запустить(СсылкаДиалога, Истина);
	КонецЕсли;
	Возврат Истина;
КонецФункции

Функция ОтклонитьОжидающееДействие(СсылкаДиалога, АвтоПродолжить = Истина) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СостояниеПодтверждения = ИИА_Сервер.ПолучитьСостояниеПодтверждения(СсылкаДиалога);
	Если СостояниеПодтверждения = Неопределено
		ИЛИ НЕ СостояниеПодтверждения.Свойство("status")
		ИЛИ ВРег(Строка(СостояниеПодтверждения.status)) <> "PENDING" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СостояниеПодтверждения.status = "rejected";
	СостояниеПодтверждения.decision = "reject";
	СостояниеПодтверждения.decision_at = ТекущаяДатаСеанса();
	ИИА_Сервер.СохранитьСостояниеПодтверждения(СсылкаДиалога, СостояниеПодтверждения);
	ЗафиксироватьApprovalDecision(СсылкаДиалога, "rejected", СостояниеПодтверждения, ?(СостояниеПодтверждения.Свойство("subgraph_name"), Строка(СостояниеПодтверждения.subgraph_name), "ExecuteSubgraph"), "user_rejected", "approval_rejected", "Plan", "approval_rejected", "Пользователь отклонил выполнение рискованного DSL. План будет перестроен.");
	
	Если СостояниеПодтверждения.Свойство("step_id") И НЕ ПустаяСтрока(Строка(СостояниеПодтверждения.step_id)) Тогда
		ОбновитьШагПлана(СсылкаДиалога, Строка(СостояниеПодтверждения.step_id), "pending", "Отклонено пользователем, требуется перепланирование");
	КонецЕсли;
	
	Если АвтоПродолжить Тогда
		Запустить(СсылкаДиалога, Истина);
	КонецЕсли;
	Возврат Истина;
КонецФункции

Функция ВключитьРежимБезПодтвержденияИПродолжить(СсылкаДиалога) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИИА_Сервер.УстановитьРежимБезПодтверждения(СсылкаДиалога, Истина);
	ИИА_Сервер.ДобавитьСообщениеВДиалог(СсылкаДиалога, Перечисления.ИИА_АвторСообщения.Система, Перечисления.ИИА_ТипСообщения.Текст, "Для текущего диалога включен режим: выполнять без подтверждения.");
	Возврат ПодтвердитьОжидающееДействие(СсылкаДиалога);
КонецФункции

#КонецОбласти

#Область ПроверкаИРезюме

Функция СгенерироватьSummary(СсылкаДиалога) Экспорт
	
	Попытка
		
		Диалог = СсылкаДиалога.ПолучитьОбъект();
		
		// Получаем все сообщения диалога для контекста
		МассивИстории = ИИА_Сервер.ПолучитьСообщенияДиалога(СсылкаДиалога, 100);
		История = ИИА_Сервер.ПреобразоватьМассивСообщенийВТаблицу(МассивИстории);
		
		// Получаем информацию о созданных/измененных объектах
		ТекстИзмененныхОбъектов = "";
		Если Диалог.ИзмененныеОбъекты.Количество() > 0 Тогда
			ТекстИзмененныхОбъектов = "Созданные/измененные объекты:" + Символы.ПС;
			Для Каждого СтрокаИзмененныхОбъектов Из Диалог.ИзмененныеОбъекты Цикл
				Если ЗначениеЗаполнено(СтрокаИзмененныхОбъектов.СсылкаНаОбъект) Тогда
					ТекстИзмененныхОбъектов = ТекстИзмененныхОбъектов + "- " + СтрокаИзмененныхОбъектов.СсылкаНаОбъект + Символы.ПС;
				КонецЕсли;
			КонецЦикла;
		Иначе
			ТекстИзмененныхОбъектов = "Объекты не создавались и не изменялись.";
		КонецЕсли;
		
		// Получаем все задачи пользователя из истории диалога
		ТекстЗадач = "";
		Для Каждого СтруктураСообщения Из МассивИстории Цикл
			Если СтруктураСообщения.Автор = Перечисления.ИИА_АвторСообщения.Пользователь Тогда
				ТекстЗадачи = СокрЛП(СтруктураСообщения.Текст);
				Если НЕ ПустаяСтрока(ТекстЗадачи) Тогда
					Если НЕ ПустаяСтрока(ТекстЗадач) Тогда
						ТекстЗадач = ТекстЗадач + Символы.ПС;
					КонецЕсли;
					ТекстЗадач = ТекстЗадач + ТекстЗадачи;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		// Извлекаем результаты выполнения DSL из системных сообщений
		ТекстРезультатовDSL = "";
		Для Индекс = 0 По МассивИстории.Количество() - 1 Цикл
			СтруктураСообщения = МассивИстории[Индекс];
			
			Если СтруктураСообщения.Автор = Перечисления.ИИА_АвторСообщения.ИИ 
				И НЕ ПустаяСтрока(СтруктураСообщения.ТекстКода) Тогда
				
				Если Индекс + 1 < МассивИстории.Количество() Тогда
					СледующееСообщение = МассивИстории[Индекс + 1];
					Если СледующееСообщение.Автор = Перечисления.ИИА_АвторСообщения.Система 
						И НЕ ПустаяСтрока(СледующееСообщение.Текст) Тогда
						
						ТекстРезультата = СокрЛП(СледующееСообщение.Текст);
						Если НЕ ПустаяСтрока(ТекстРезультата) Тогда
							Если НЕ ПустаяСтрока(ТекстРезультатовDSL) Тогда
								ТекстРезультатовDSL = ТекстРезультатовDSL + Символы.ПС;
							КонецЕсли;
							ТекстРезультатовDSL = ТекстРезультатовDSL + "DSL-сценарий: " + СокрЛП(СтруктураСообщения.ТекстКода) + Символы.ПС;
							ТекстРезультатовDSL = ТекстРезультатовDSL + "Результат: " + ТекстРезультата;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		// Получаем настройки ИИ для пользователя диалога
		Пользователь = Диалог.Пользователь;
		ПараметрыИИ = ИИА_Сервер.ПолучитьНастройкиПользователя(Пользователь);
		ПараметрыИИ.Вставить("Пользователь", Пользователь);
		
		// Формируем промпт для генерации summary
		ПромптSummary = ИИА_Промты.СформироватьПромптРезюме(ТекстЗадач, ТекстИзмененныхОбъектов, ТекстРезультатовDSL);
		
		// Вызываем ИИ для генерации summary
		ОтветИИ = ИИА_Сервер.ВызватьИИССистемнымСообщением(СсылкаДиалога, "Чат", ПромптSummary, "", "text");
		
		ТекстSummary = "";
		Если ОтветИИ.Свойство("Текст") И НЕ ПустаяСтрока(ОтветИИ.Текст) Тогда
			ТекстSummary = ОтветИИ.Текст;
		ИначеЕсли ОтветИИ.Свойство("DSL") И НЕ ПустаяСтрока(ОтветИИ.DSL) Тогда
			ТекстSummary = ОтветИИ.DSL;
		КонецЕсли;
		
		Если СтрНачинаетсяС(СокрЛП(ТекстSummary), "{") Тогда
			Попытка
				Чтение = Новый ЧтениеJSON;
				Чтение.УстановитьСтроку(ТекстSummary);
				ДанныеJSON = ПрочитатьJSON(Чтение);
				Чтение.Закрыть();
				
				Если ТипЗнч(ДанныеJSON) = Тип("Структура") Тогда
					Если ДанныеJSON.Свойство("summary") Тогда
						ТекстSummary = ДанныеJSON.summary;
					ИначеЕсли ДанныеJSON.Свойство("text") Тогда
						ТекстSummary = ДанныеJSON.text;
					ИначеЕсли ДанныеJSON.Свойство("резюме") Тогда
						ТекстSummary = ДанныеJSON.резюме;
					КонецЕсли;
				КонецЕсли;
			Исключение
				ТекстОшибки = ОписаниеОшибки();
			КонецПопытки;
		КонецЕсли;
		
		Возврат ТекстSummary;
		
	Исключение
		Возврат "Ошибка при генерации summary: " + ОписаниеОшибки();
	КонецПопытки;
	
КонецФункции

Функция ИзвлечьSummaryИзТекста(Знач ИсходныйТекст) Экспорт
	
	ЧистыйТекст = "";
	
	ТекстБезЗаголовка = СтрЗаменить(ИсходныйТекст, "=== РЕЗЮМЕ ВЫПОЛНЕННОЙ РАБОТЫ ===", "");
	
	ПозНачалаJSON = СтрНайти(ТекстБезЗаголовка, "```json");
	ПозКонцаJSON = СтрНайти(ТекстБезЗаголовка, "```", НаправлениеПоиска.СКонца);
	
	Если ПозНачалаJSON > 0 И ПозКонцаJSON > ПозНачалаJSON Тогда
		Префикс = Лев(ТекстБезЗаголовка, ПозНачалаJSON - 1);
		СтрокаJSON = Сред(ТекстБезЗаголовка, ПозНачалаJSON + 7, ПозКонцаJSON - (ПозНачалаJSON + 7));
		
		Попытка
			Чтение = Новый ЧтениеJSON;
			Чтение.УстановитьСтроку(СтрокаJSON);
			ДанныеJSON = ПрочитатьJSON(Чтение);
			Чтение.Закрыть();
			
			Если ТипЗнч(ДанныеJSON) = Тип("Структура") И ДанныеJSON.Свойство("summary") Тогда
				ЧистыйТекст = СокрЛП(Префикс) + Символы.ПС + Символы.ПС + ДанныеJSON.summary;
			ИначеЕсли ТипЗнч(ДанныеJSON) = Тип("Соответствие") И ДанныеJSON.Получить("summary") <> Неопределено Тогда
				ЧистыйТекст = СокрЛП(Префикс) + Символы.ПС + Символы.ПС + ДанныеJSON.Получить("summary");
			Иначе
				ЧистыйТекст = ТекстБезЗаголовка;
			КонецЕсли;
		Исключение
			ЧистыйТекст = ТекстБезЗаголовка;
		КонецПопытки;
	Иначе
		ЧистыйТекст = ТекстБезЗаголовка;
	КонецЕсли;
	
	Возврат СокрЛП(ЧистыйТекст);
	
КонецФункции

Процедура ВыполнитьФинальнуюПроверкуИSummary(СсылкаДиалога) Экспорт
	
	ИИА_Сервер.ОчиститьКонтекстDSLДиалога(СсылкаДиалога);
	
	РезультатПроверки = ПроверитьРезультатВыполненияЗадачи(СсылкаДиалога);
	ИИА_Сервер.УстановитьРезультатПроверкиВХранилище(СсылкаДиалога, РезультатПроверки.ПроверкаВыполнена, РезультатПроверки.Причина);
	
	ТекстSummary = СгенерироватьSummary(СсылкаДиалога);
	ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Summarize", ТекущаяДата(), НЕ ПустаяСтрока(ТекстSummary), "");
	Если НЕ ПустаяСтрока(ТекстSummary) Тогда
		Дополнение = "";
		Если НЕ ПустаяСтрока(РезультатПроверки.Причина) Тогда
			Дополнение = Символы.ПС + Символы.ПС + "Проверка: " + РезультатПроверки.Причина;
		КонецЕсли;
		
		ТекстSummary = ТекстSummary + Дополнение;
		
		ИИА_Сервер.ДобавитьСообщениеВДиалог(
			СсылкаДиалога,
			Перечисления.ИИА_АвторСообщения.Система,
			Перечисления.ИИА_ТипСообщения.Текст,
			"=== РЕЗЮМЕ ВЫПОЛНЕННОЙ РАБОТЫ ===" + Символы.ПС + Символы.ПС + ТекстSummary,
			"",
			"",
			0
		);
		// Явное уведомление о резюме с Сообщение в payload - на случай, если «НовоеСообщение» из фонового задания не дойдёт до клиента
		ПоследнийУИД = ИИА_Сервер.ПолучитьПоследнийУИДСообщенияДиалога(СсылкаДиалога);
		СообщениеРезюме = ИИА_Сервер.ПолучитьСообщениеПоУИД(СсылкаДиалога, ПоследнийУИД);
		ДопДанныеРезюме = ?(СообщениеРезюме <> Неопределено, Новый Структура("Сообщение", СообщениеРезюме), Неопределено);
		ОтправитьУведомление(СсылкаДиалога, "РезюмеДобавлено", ДопДанныеРезюме);
	Иначе
		// Запасное сообщение при ошибке или пустом ответе ИИ
		ИИА_Сервер.ДобавитьСообщениеВДиалог(
			СсылкаДиалога,
			Перечисления.ИИА_АвторСообщения.Система,
			Перечисления.ИИА_ТипСообщения.Текст,
			"=== РЕЗЮМЕ ВЫПОЛНЕННОЙ РАБОТЫ ===" + Символы.ПС + Символы.ПС + "Резюме не сформировано.",
			"",
			"",
			0
		);
		ПоследнийУИД = ИИА_Сервер.ПолучитьПоследнийУИДСообщенияДиалога(СсылкаДиалога);
		СообщениеРезюме = ИИА_Сервер.ПолучитьСообщениеПоУИД(СсылкаДиалога, ПоследнийУИД);
		ДопДанныеРезюме = ?(СообщениеРезюме <> Неопределено, Новый Структура("Сообщение", СообщениеРезюме), Неопределено);
		ОтправитьУведомление(СсылкаДиалога, "РезюмеДобавлено", ДопДанныеРезюме);
	КонецЕсли;
	
	// Отправляем финальное уведомление с Сообщение в payload - чтобы при перезагрузке чата резюме не исчезало
	ДопДанные = Новый Структура("Успех", РезультатПроверки.ПроверкаВыполнена);
	Если СообщениеРезюме <> Неопределено Тогда
		ДопДанные.Вставить("Сообщение", СообщениеРезюме);
	КонецЕсли;
	ИИА_Сервер.УведомитьОбОбновленииДиалога(СсылкаДиалога, "ЗадачаЗавершена", ДопДанные);
	
КонецПроцедуры

Функция ВыполнитьСтадиюSummarize(СсылкаДиалога) Экспорт
	Возврат ВыполнитьSummarizeSubgraph(СсылкаДиалога);
КонецФункции

Функция ВыполнитьSummarizeSubgraph(СсылкаДиалога) Экспорт
	ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "SummarizeSubgraph", "enter");
	ВыполнитьФинальнуюПроверкуИSummary(СсылкаДиалога);
	УспехSummary = Ложь;
	ПоследнийУИД = ИИА_Сервер.ПолучитьПоследнийУИДСообщенияДиалога(СсылкаДиалога);
	ПоследнееСообщение = ИИА_Сервер.ПолучитьСообщениеПоУИД(СсылкаДиалога, ПоследнийУИД);
	Если ПоследнееСообщение <> Неопределено
		И ПоследнееСообщение.Свойство("Текст")
		И СтрНайти(Строка(ПоследнееСообщение.Текст), "РЕЗЮМЕ ВЫПОЛНЕННОЙ РАБОТЫ") > 0 Тогда
		УспехSummary = Истина;
	КонецЕсли;
	Возврат ПодготовитьРезультатПодграфаКВозврату(СоздатьРезультатПодграфа("SummarizeSubgraph", УспехSummary, "Summarize->Stop", Неопределено, Ложь, "continue", Неопределено, "", ?(УспехSummary, "summary_completed", "summary_failed"), "summarize_policy", ""));
КонецФункции

Функция ПроверитьРезультатВыполненияЗадачи(СсылкаДиалога) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ПроверкаВыполнена", Ложь);
	Результат.Вставить("Причина", "");
	
	ПоследнееСообщение = ИИА_Сервер.ПолучитьПоследнееСообщениеПользователя(СсылкаДиалога);
	Если НЕ ПоследнееСообщение.Найдено Тогда
		Результат.Причина = "Не найдена задача пользователя";
		Возврат Результат;
	КонецЕсли;
	
	ТекстЗадачи = ПоследнееСообщение.Текст;
	Диалог = СсылкаДиалога.ПолучитьОбъект();

	// ДЕТЕРМИНИРОВАННАЯ ПРОВЕРКА
	ПоследнийСистРез = ПолучитьПоследнийDslSystemResult(СсылкаДиалога);
	Если ПоследнийСистРез.Найдено Тогда
		
		Если НЕ ПоследнийСистРез.Успех Тогда
			Результат.ПроверкаВыполнена = Ложь;
			Результат.Причина = "Последнее выполнение DSL завершилось ошибкой.";
			ИИА_Сервер.УстановитьРезультатПроверкиВХранилище(СсылкаДиалога, Результат.ПроверкаВыполнена, Результат.Причина);
			Возврат Результат;
		КонецЕсли;
		
		Если Диалог.ТипДиалога = Перечисления.ИИА_ТипДиалога.Запрос1С Тогда
			ПроверкаВывода = ПроверитьВыводДанныхЗапроса(СсылкаДиалога);
			Если ПроверкаВывода.ЕстьТабличныйДокумент Тогда
				Результат.ПроверкаВыполнена = Истина;
				Результат.Причина = "Данные выведены: " + ПроверкаВывода.Причина;
			Иначе
				Результат.ПроверкаВыполнена = Ложь;
				Результат.Причина = "Нет подтверждения вывода данных (RunQuery или таблица).";
			КонецЕсли;
			ИИА_Сервер.УстановитьРезультатПроверкиВХранилище(СсылкаДиалога, Результат.ПроверкаВыполнена, Результат.Причина);
			Возврат Результат;
		Иначе
			Результат.ПроверкаВыполнена = Истина;
			Результат.Причина = "Последнее выполнение DSL успешно.";
			ИИА_Сервер.УстановитьРезультатПроверкиВХранилище(СсылкаДиалога, Результат.ПроверкаВыполнена, Результат.Причина);
			Возврат Результат;
		КонецЕсли;
		
	КонецЕсли;

	ТекстРезультатов = "";
	Для Индекс = Макс(0, Диалог.Сообщения.Количество() - 20) По Диалог.Сообщения.Количество() - 1 Цикл
		СтрокаСообщения = Диалог.Сообщения[Индекс];
		Если СтрокаСообщения.Автор = Перечисления.ИИА_АвторСообщения.Система Тогда
			ТекстРезультатов = ТекстРезультатов + Символы.ПС + СтрокаСообщения.Текст;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ПустаяСтрока(ТекстРезультатов) Тогда
		ТекстВРег = ВРег(ТекстРезультатов);
		ЕстьУспех = (СтрНайти(ТекстВРег, "DSL_SYSTEM_RESULT") > 0 
			И СтрНайти(ТекстВРег, "SUCCESS") > 0 
			И СтрНайти(ТекстВРег, "TRUE") > 0);
		ЕстьДанные = (СтрНайти(ТекстВРег, "RUNQUERY") > 0 ИЛИ СтрНайти(ТекстВРег, "SHOWINFO") > 0);
		
		Если ЕстьУспех И ЕстьДанные Тогда
			Результат.ПроверкаВыполнена = Истина;
			Результат.Причина = "Подтверждено по системным результатам (RunQuery/ShowInfo).";
			ИИА_Сервер.УстановитьРезультатПроверкиВХранилище(СсылкаДиалога, Результат.ПроверкаВыполнена, Результат.Причина);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	ПромптПроверки = ИИА_Промты.СформироватьПромптПроверкиЗадачи(ТекстЗадачи, ТекстРезультатов);
	РезультатВызова = ИИА_Сервер.ВызватьИИССистемнымСообщением(СсылкаДиалога, "Чат", ПромптПроверки, "", "dsl", , Ложь, Ложь);
	
	ТекстОтвета = "";
	DSLДляРазбора = "";
	
	Если РезультатВызова.ТипОтвета = "DSL" И НЕ ПустаяСтрока(РезультатВызова.DSL) Тогда
		DSLДляРазбора = РезультатВызова.DSL;
	ИначеЕсли РезультатВызова.ТипОтвета = "ОшибкаКонтракта" 
		И РезультатВызова.Свойство("DSL") 
		И НЕ ПустаяСтрока(РезультатВызова.DSL) Тогда
		DSLДляРазбора = РезультатВызова.DSL;
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(DSLДляРазбора) Тогда
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(DSLДляРазбора);
			Сценарий = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
			
			Если ТипЗнч(Сценарий) = Тип("Структура") Тогда
				Если Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") Тогда
					Для Каждого Шаг Из Сценарий.steps Цикл
						Если Шаг.action = "ShowInfo" И Шаг.Свойство("message") Тогда
							ТекстОтвета = Шаг.message;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				ИначеЕсли Сценарий.Свойство("action") Тогда
					Если ВРег(Сценарий.action) = "SHOWINFO" И Сценарий.Свойство("message") Тогда
						ТекстОтвета = Сценарий.message;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
			// ignored
			ТекстОшибки = ОписаниеОшибки();
		КонецПопытки;
	КонецЕсли;
	
	Если ПустаяСтрока(ТекстОтвета) Тогда
		ТекстОтвета = РезультатВызова.Текст;
	КонецЕсли;
	
	ТекстОтветаВРег = ВРег(ТекстОтвета);
	
	Если СтрНачинаетсяС(ТекстОтветаВРег, "ДА") 
		ИЛИ СтрНачинаетсяС(ТекстОтветаВРег, "'ДА") 
		ИЛИ СтрНачинаетсяС(ТекстОтветаВРег, """ДА") Тогда
		
		Диалог = СсылкаДиалога.ПолучитьОбъект();
		Если Диалог.ТипДиалога = Перечисления.ИИА_ТипДиалога.Запрос1С Тогда
			
			ТаблицаПоказана = Ложь;
			РезультатИзХранилища = ИИА_Сервер.ПолучитьРезультатПроверкиИзХранилища(СсылкаДиалога);
			Если РезультатИзХранилища <> Неопределено И РезультатИзХранилища.Свойство("ТаблицаПоказана") Тогда
				ТаблицаПоказана = РезультатИзХранилища.ТаблицаПоказана;
			КонецЕсли;
			
			Если ТаблицаПоказана Тогда
				ЕстьТабличныйДокумент = Истина;
				ПричинаЛога = "Явный флаг ТаблицаПоказана из хранилища";
			Иначе
				ЕстьТабличныйДокумент = Ложь;
				ПричинаЛога = "";
				КоличествоСообщений = Диалог.Сообщения.Количество();
				Для Индекс = Макс(0, КоличествоСообщений - 6) По КоличествоСообщений - 2 Цикл
					СтрокаСообщения = Диалог.Сообщения[Индекс];
					Если СтрокаСообщения.Автор = Перечисления.ИИА_АвторСообщения.ИИ И СтрокаСообщения.ТипСообщения = Перечисления.ИИА_ТипСообщения.Код Тогда
						Попытка
							ЧтениеJSON = Новый ЧтениеJSON;
							ЧтениеJSON.УстановитьСтроку(СтрокаСообщения.ТекстКода);
							Сценарий = ПрочитатьJSON(ЧтениеJSON);
							ЧтениеJSON.Закрыть();
							
							Если Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") Тогда
								Для Каждого Шаг Из Сценарий.steps Цикл
									Если Шаг.Свойство("action") И (ВРег(Шаг.action) = "RUNQUERY" ИЛИ ВРег(Шаг.action) = "SHOWINFO") Тогда
										ЕстьТабличныйДокумент = Истина;
										ПричинаЛога = "Найден шаг " + Шаг.action + " в сообщении ИИ #" + Индекс;
										Прервать;
									КонецЕсли;
								КонецЦикла;
							КонецЕсли;
						Исключение
							ТекстКодаВРег = ВРег(СтрокаСообщения.ТекстКода);
							Если СтрНайти(ТекстКодаВРег, "RUNQUERY") > 0 Тогда
								ЕстьТабличныйДокумент = Истина;
								ПричинаЛога = "Найдена подстрока RUNQUERY в сообщении ИИ #" + Индекс;
							ИначеЕсли СтрНайти(ТекстКодаВРег, "SHOWINFO") > 0 Тогда
								ЕстьТабличныйДокумент = Истина;
								ПричинаЛога = "Найдена подстрока SHOWINFO в сообщении ИИ #" + Индекс;
							КонецЕсли;
						КонецПопытки;
						
						Если ЕстьТабличныйДокумент Тогда
							Прервать;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			ЗаписьЛога = "Проверка наличия вывода данных: " + ?(ЕстьТабличныйДокумент, "ДА (" + ПричинаЛога + ")", "НЕТ");
			ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, ЗаписьЛога);
			
			Если НЕ ЕстьТабличныйДокумент Тогда
				Результат.ПроверкаВыполнена = Ложь;
				Результат.Причина = "ИИ считает задачу выполненной, но не был выполнен шаг RunQuery для отображения данных (ТабличныйДокумент). Обязательно выполни запрос к базе данных.";
			Иначе
				Результат.ПроверкаВыполнена = Истина;
				Результат.Причина = ТекстОтвета;
			КонецЕсли;
			
		Иначе
			Результат.ПроверкаВыполнена = Истина;
			Результат.Причина = ТекстОтвета;
		КонецЕсли;
		
	Иначе
		Результат.ПроверкаВыполнена = Ложь;
		Результат.Причина = ТекстОтвета;
	КонецЕсли;
	
	ИИА_Сервер.УстановитьРезультатПроверкиВХранилище(СсылкаДиалога, Результат.ПроверкаВыполнена, Результат.Причина);
	Возврат Результат;
	
КонецФункции

#КонецОбласти

Процедура ОтправитьУведомление(СсылкаДиалога, ТипСобытия, ДополнительныеДанные = Неопределено)
	
	ИИА_Сервер.УведомитьОбОбновленииДиалога(СсылкаДиалога, ТипСобытия, ДополнительныеДанные);
	
КонецПроцедуры

Процедура ОбновитьСтатусПоследнегоСообщения(СсылкаДиалога, НовыйСтатус)
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	Если Диалог.Сообщения.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаСообщения = Диалог.Сообщения[Диалог.Сообщения.Количество() - 1];
	СтрокаСообщения.Статус = НовыйСтатус;
	Диалог.Записать();
	
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Система] Обновлен статус сообщения: " + НовыйСтатус);
	
КонецПроцедуры

Функция ПолучитьПоследнийDslSystemResult(СсылкаДиалога)
	
	Результат = Новый Структура;
	Результат.Вставить("Найдено", Ложь);
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Текст", "");
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	Если Диалог.Сообщения.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Индекс = Диалог.Сообщения.Количество() - 1 По 0 Цикл
		СтрокаСообщения = Диалог.Сообщения[Индекс];
		Если СтрокаСообщения.Автор = Перечисления.ИИА_АвторСообщения.Система
			И НЕ ПустаяСтрока(СтрокаСообщения.Текст)
			И СтрНайти(СтрокаСообщения.Текст, "dsl_system_result") > 0 Тогда
			
			ТекстJSON = ИИА_DSL.НормализоватьJSONТекст(СтрокаСообщения.Текст);
			
			Результат.Найдено = Истина;
			Результат.Текст = ?(ПустаяСтрока(ТекстJSON), СтрокаСообщения.Текст, ТекстJSON);
			
			Если НЕ ПустаяСтрока(ТекстJSON) Тогда
				Попытка
					ЧтениеJSON = Новый ЧтениеJSON;
					ЧтениеJSON.УстановитьСтроку(ТекстJSON);
					Данные = ПрочитатьJSON(ЧтениеJSON);
					ЧтениеJSON.Закрыть();
					
					Если ТипЗнч(Данные) = Тип("Структура") И Данные.Свойство("success") Тогда
						Результат.Успех = Данные.success;
					КонецЕсли;
				Исключение
					ТекстОшибки = ОписаниеОшибки();
				КонецПопытки;
			КонецЕсли;
			
			Возврат Результат;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьВыводДанныхЗапроса(СсылкаДиалога)
	
	Результат = Новый Структура("ЕстьТабличныйДокумент, Причина", Ложь, "");
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	
	ТаблицаПоказана = Ложь;
	РезультатИзХранилища = ИИА_Сервер.ПолучитьРезультатПроверкиИзХранилища(СсылкаДиалога);
	Если РезультатИзХранилища <> Неопределено
		И ТипЗнч(РезультатИзХранилища) = Тип("Структура")
		И РезультатИзХранилища.Свойство("ТаблицаПоказана") Тогда
		ТаблицаПоказана = РезультатИзХранилища.ТаблицаПоказана;
	КонецЕсли;
	
	Если ТаблицаПоказана Тогда
		Результат.ЕстьТабличныйДокумент = Истина;
		Результат.Причина = "Явный флаг ТаблицаПоказана из хранилища";
		Возврат Результат;
	КонецЕсли;
	
	КоличествоСообщений = Диалог.Сообщения.Количество();
	Для Индекс = Макс(0, КоличествоСообщений - 6) По КоличествоСообщений - 1 Цикл
		СтрокаСообщения = Диалог.Сообщения[Индекс];
		Если СтрокаСообщения.Автор = Перечисления.ИИА_АвторСообщения.ИИ
			И СтрокаСообщения.ТипСообщения = Перечисления.ИИА_ТипСообщения.Код
			И НЕ ПустаяСтрока(СтрокаСообщения.ТекстКода) Тогда
			
			Попытка
				ЧтениеJSON = Новый ЧтениеJSON;
				ЧтениеJSON.УстановитьСтроку(ИИА_DSL.НормализоватьJSONТекст(СтрокаСообщения.ТекстКода));
				Сценарий = ПрочитатьJSON(ЧтениеJSON);
				ЧтениеJSON.Закрыть();
				
				Если ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") Тогда
					Для Каждого Шаг Из Сценарий.steps Цикл
						Если Шаг.Свойство("action") Тогда
							Действие = ВРег(Шаг.action);
							Если Действие = "RUNQUERY" ИЛИ Действие = "SHOWINFO" Тогда
								Результат.ЕстьТабличныйДокумент = Истина;
								Результат.Причина = "Найден шаг " + Шаг.action;
								Возврат Результат;
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			Исключение
				ТекстОшибки = ОписаниеОшибки();
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#Область СлужебныеПроцедурыИФункции

// Сжимает JSON в одну строку для компактного вывода в лог (убирает переносы и лишние пробелы).
//
Функция СжатьJSONДляЛога(ТекстJSON)
	Если ПустаяСтрока(ТекстJSON) Тогда
		Возврат "";
	КонецЕсли;
	Результат = СтрЗаменить(ТекстJSON, Символы.ПС, " ");
	Результат = СтрЗаменить(Результат, Символы.ВТаб, " ");
	Пока СтрНайти(Результат, "  ") > 0 Цикл
		Результат = СтрЗаменить(Результат, "  ", " ");
	КонецЦикла;
	Возврат СокрЛП(Результат);
КонецФункции

// Извлекает блок "Реквизиты:" из текста фактов (результатов GetObjectFields) для передачи в промпт RunQuery
//
// Параметры:
//  ТекстФактов - Строка - текст из СобратьФактыПоследнихДействий
//
// Возвращаемое значение:
//  Строка - извлечённый список реквизитов или пустая строка
//
Функция ИзвлечьРеквизитыИзФактов(ТекстФактов) Экспорт
	
	Если ПустаяСтрока(ТекстФактов) Тогда
		Возврат "";
	КонецЕсли;
	
	ПозРеквизиты = СтрНайти(ТекстФактов, "Реквизиты:");
	Если ПозРеквизиты <= 0 Тогда
		Возврат "";
	КонецЕсли;
	
	// Берём текст после "Реквизиты:" до следующего структурного блока или конца
	Начало = ПозРеквизиты + СтрДлина("Реквизиты:");
	Остаток = Сред(ТекстФактов, Начало);
	
	// Обрезаем по "steps" или "dsl_system_result" или другому ключевому маркеру
	Маркеры = Новый Массив;
	Маркеры.Добавить("""steps""");
	Маркеры.Добавить("dsl_system_result");
	Маркеры.Добавить("Выполнен DSL");
	Маркеры.Добавить("Ошибка выполнения");
	
	КонецБлока = СтрДлина(Остаток) + 1;
	Для Каждого Маркер Из Маркеры Цикл
		Поз = СтрНайти(Остаток, Маркер);
		Если Поз > 0 И Поз < КонецБлока Тогда
			КонецБлока = Поз;
		КонецЕсли;
	КонецЦикла;
	
	БлокРеквизитов = Лев(Остаток, КонецБлока - 1);
	БлокРеквизитов = СокрЛП(БлокРеквизитов);
	
	// Ограничиваем длину (чтобы не раздувать промпт)
	Если СтрДлина(БлокРеквизитов) > 1500 Тогда
		БлокРеквизитов = Лев(БлокРеквизитов, 1500) + "...";
	КонецЕсли;
	
	Возврат БлокРеквизитов;
	
КонецФункции

// Извлекает имена объектов/таблиц, по которым уже была ошибка (таблица не найдена, поле не найдено).
// Используется для запрета возврата к ошибочным объектам в промпте генерации DSL.
//
// Параметры:
//  ТекстФактов - Строка - текст из СобратьФактыПоследнихДействий
//
// Возвращаемое значение:
//  Строка - список имён через запятую или пустая строка
//
Функция СобратьНеудачныеОбъектыИзФактов(ТекстФактов) Экспорт
	
	Если ПустаяСтрока(ТекстФактов) Тогда
		Возврат "";
	КонецЕсли;
	
	Уникальные = Новый Соответствие;
	
	// Паттерн "Таблица 'ИмяТаблицы' не найдена" или "не найдена в метаданных"
	Поз = 1;
	Пока Истина Цикл
		ПозТабл = СтрНайти(Сред(ТекстФактов, Поз), "Таблица ");
		Если ПозТабл <= 0 Тогда
			Прервать;
		КонецЕсли;
		Поз = Поз + ПозТабл + 7;
		Остаток = Сред(ТекстФактов, Поз);
		ПозКавычки = СтрНайти(Остаток, "'");
		Если ПозКавычки <= 0 Тогда
			ПозКавычки = СтрНайти(Остаток, """");
		КонецЕсли;
		Если ПозКавычки > 0 Тогда
			Остаток = Сред(Остаток, ПозКавычки + 1);
			ПозКонец = СтрНайти(Остаток, "'");
			Если ПозКонец <= 0 Тогда
				ПозКонец = СтрНайти(Остаток, """");
			КонецЕсли;
			Если ПозКонец > 0 Тогда
				ИмяТаблицы = Лев(Остаток, ПозКонец - 1);
				// Убираем префикс ДОКУМЕНТ./СПРАВОЧНИК.
				ИмяТаблицы = СтрЗаменить(ВРег(ИмяТаблицы), "ДОКУМЕНТ.", "");
				ИмяТаблицы = СтрЗаменить(ИмяТаблицы, "СПРАВОЧНИК.", "");
				ИмяТаблицы = СокрЛП(ИмяТаблицы);
				Если НЕ ПустаяСтрока(ИмяТаблицы) Тогда
					Уникальные.Вставить(ИмяТаблицы, Истина);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Поз = Поз + 50;
		Если Поз > СтрДлина(ТекстФактов) Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	// Паттерн "Поле не найдено ""Объект.Поле"""
	Поз = 1;
	Пока Истина Цикл
		ПозПоле = СтрНайти(Сред(ТекстФактов, Поз), "Поле не найдено");
		Если ПозПоле <= 0 Тогда
			Прервать;
		КонецЕсли;
		Поз = Поз + ПозПоле + 14;
		Остаток = Сред(ТекстФактов, Поз);
		ПозКавычки = СтрНайти(Остаток, """");
		Если ПозКавычки <= 0 Тогда
			ПозКавычки = СтрНайти(Остаток, "'");
		КонецЕсли;
		Если ПозКавычки > 0 Тогда
			Остаток = Сред(Остаток, ПозКавычки + 1);
			ПозКонец = СтрНайти(Остаток, """");
			Если ПозКонец <= 0 Тогда
				ПозКонец = СтрНайти(Остаток, "'");
			КонецЕсли;
			Если ПозКонец > 0 Тогда
				ОбъектПоле = Лев(Остаток, ПозКонец - 1);
				ПозТочки = СтрНайти(ОбъектПоле, ".");
				Если ПозТочки > 0 Тогда
					ИмяОбъекта = Лев(ОбъектПоле, ПозТочки - 1);
					Если НЕ ПустаяСтрока(ИмяОбъекта) Тогда
						Уникальные.Вставить(ИмяОбъекта, Истина);
					КонецЕсли;
				Иначе
					Уникальные.Вставить(ОбъектПоле, Истина);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Поз = Поз + 30;
		Если Поз > СтрДлина(ТекстФактов) Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Уникальные.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Список = "";
	Для Каждого КлючЗначение Из Уникальные Цикл
		Если НЕ ПустаяСтрока(Список) Тогда
			Список = Список + ", ";
		КонецЕсли;
		Список = Список + КлючЗначение.Ключ;
	КонецЦикла;
	Возврат Список;
	
КонецФункции

// Извлекает ключ последней ошибки DSL из фактов (для детекции повторяющихся ошибок).
// Возвращает пустую строку, если последний результат - успех.
//
// Параметры:
//  ТекстФактов - Строка - текст из СобратьФактыПоследнихДействий
//
// Возвращаемое значение:
//  Строка - ключ ошибки ("RunQuery" + первые 50 символов сообщения) или ""
//
Функция ПолучитьКлючПоследнейОшибкиИзФактов(ТекстФактов) Экспорт
	
	Если ПустаяСтрока(ТекстФактов) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстВРег = ВРег(ТекстФактов);
	
	// Компактный формат (ФорматироватьКомпактноДляЛога): "DSL Result: err | сообщение"
	ПозErr = СтрНайти(ТекстВРег, "DSL RESULT: ERR");
	Если ПозErr > 0 Тогда
		Остаток = Сред(ТекстФактов, ПозErr);
		ПозВер = СтрНайти(Остаток, "|");
		Если ПозВер > 0 Тогда
			Сообщение = СокрЛП(Сред(Остаток, ПозВер + 1));
			Возврат "RunQuery" + Лев(Сообщение, 50);
		КонецЕсли;
		Возврат "RunQuery";
	КонецЕсли;
	
	Если СтрНайти(ТекстВРег, """SUCCESS"":FALSE") = 0 И СтрНайти(ТекстВРег, """SUCCESS"": FALSE") = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	// Берём последний фрагмент (последний dsl_system_result)
	Чанки = СтрРазделить(ТекстФактов, "dsl_system_result", Ложь);
	Если Чанки.Количество() < 2 Тогда
		Возврат "RunQuery";
	КонецЕсли;
	
	ПоследнийЧанк = Чанки[Чанки.Количество() - 1];
	ПоследнийЧанкВРег = ВРег(ПоследнийЧанк);
	Если СтрНайти(ПоследнийЧанкВРег, """SUCCESS"":FALSE") = 0 И СтрНайти(ПоследнийЧанкВРег, """SUCCESS"": FALSE") = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ПозОшибки = СтрНайти(ПоследнийЧанк, """error"":""");
	Если ПозОшибки = 0 Тогда
		ПозОшибки = СтрНайти(ПоследнийЧанк, """error"": """);
	КонецЕсли;
	
	Если ПозОшибки > 0 Тогда
		Остаток = Сред(ПоследнийЧанк, ПозОшибки + 10);
		Ключ = "RunQuery" + Лев(Остаток, 50);
		Возврат Ключ;
	КонецЕсли;
	
	Возврат "RunQuery" + Лев(ПоследнийЧанк, 50);
	
КонецФункции

Функция ИзвлечьИмяТаблицыИзТекстаЗапроса(Текст)
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстВерх = ВРег(Текст);
	ПозИЗ = СтрНайти(ТекстВерх, " ИЗ ");
	Если ПозИЗ = 0 Тогда
		ПозИЗ = СтрНайти(ТекстВерх, Символы.ПС + "ИЗ ");
	КонецЕсли;
	Если ПозИЗ = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Остаток = СокрЛП(Сред(Текст, ПозИЗ + 4));
	Если ПустаяСтрока(Остаток) Тогда
		Возврат "";
	КонецЕсли;
	
	КонецИмени = СтрДлина(Остаток) + 1;
	Маркеры = Новый Массив;
	Маркеры.Добавить(" ");
	Маркеры.Добавить(Символы.ПС);
	Маркеры.Добавить(",");
	Маркеры.Добавить("ГДЕ ");
	Маркеры.Добавить("СГРУППИРОВАТЬ");
	Маркеры.Добавить("УПОРЯДОЧИТЬ");
	Для Каждого Маркер Из Маркеры Цикл
		ПозМаркер = СтрНайти(Остаток, Маркер);
		Если ПозМаркер > 0 И ПозМаркер < КонецИмени Тогда
			КонецИмени = ПозМаркер;
		КонецЕсли;
	КонецЦикла;
	
	ИмяТаблицы = СокрЛП(Лев(Остаток, КонецИмени - 1));
	Возврат ИмяТаблицы;
КонецФункции

Функция УвеличитьСчетчикОшибокПоляПоТаблице(СсылкаДиалога, ИмяТаблицы) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Или ПустаяСтрока(ИмяТаблицы) Тогда
		Возврат 0;
	КонецЕсли;
	
	СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено Или ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	
	Счетчики = Неопределено;
	Если СтруктураДанных.Свойство("СчетчикиОшибокПолейПоТаблицам") 
		И ТипЗнч(СтруктураДанных.СчетчикиОшибокПолейПоТаблицам) = Тип("Соответствие") Тогда
		Счетчики = СтруктураДанных.СчетчикиОшибокПолейПоТаблицам;
	Иначе
		Счетчики = Новый Соответствие;
	КонецЕсли;
	
	Ключ = ВРег(ИмяТаблицы);
	Текущее = Счетчики.Получить(Ключ);
	Если Текущее = Неопределено Тогда
		Текущее = 0;
	КонецЕсли;
	Текущее = Текущее + 1;
	Счетчики.Вставить(Ключ, Текущее);
	
	СтруктураДанных.Вставить("СчетчикиОшибокПолейПоТаблицам", Счетчики);
	ИИА_Сервер.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	
	Возврат Текущее;
КонецФункции

Функция ЗафиксироватьПовторНевалиднойТаблицыRunQuery(СсылкаДиалога, ИмяТаблицы, Порог = 3) Экспорт
	ЛокИмяТаблицы = СокрЛП(ИмяТаблицы);
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Или ПустаяСтрока(ЛокИмяТаблицы) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	КлючТаблицы = ВРег(ЛокИмяТаблицы);
	СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено Или ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	
	ПоследняяТаблица = ?(СтруктураДанных.Свойство("ПоследняяНевалиднаяТаблицаRunQuery"), ВРег(Строка(СтруктураДанных.ПоследняяНевалиднаяТаблицаRunQuery)), "");
	СчетчикТаблицы = ?(СтруктураДанных.Свойство("СчетчикНевалиднойТаблицыRunQuery"), Число(СтруктураДанных.СчетчикНевалиднойТаблицыRunQuery), 0);
	
	Если ПоследняяТаблица = КлючТаблицы Тогда
		СчетчикТаблицы = СчетчикТаблицы + 1;
	Иначе
		СчетчикТаблицы = 1;
	КонецЕсли;
	
	СтруктураДанных.Вставить("ПоследняяНевалиднаяТаблицаRunQuery", КлючТаблицы);
	СтруктураДанных.Вставить("СчетчикНевалиднойТаблицыRunQuery", СчетчикТаблицы);
	ИИА_Сервер.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	
	Возврат СчетчикТаблицы >= Порог;
КонецФункции

// Извлекает имя таблицы из сообщения об ошибке "Таблица 'X' не найдена".
//
// Параметры:
//  ТекстОшибки - Строка - сообщение об ошибке
//
// Возвращаемое значение:
//  Строка - имя таблицы (например Документ.РеализацияТоваровУслуг) или ""
//
Функция ИзвлечьИмяТаблицыИзОшибки(ТекстОшибки)
	
	Если ПустаяСтрока(ТекстОшибки) Тогда
		Возврат "";
	КонецЕсли;
	
	Маркер = "";
	ПозТабл = СтрНайти(ТекстОшибки, "Таблица ");
	Если ПозТабл > 0 Тогда
		Маркер = "Таблица ";
	ИначеЕсли СтрНайти(ТекстОшибки, "Документ ") > 0 Тогда
		ПозТабл = СтрНайти(ТекстОшибки, "Документ ");
		Маркер = "Документ ";
	ИначеЕсли СтрНайти(ТекстОшибки, "Справочник ") > 0 Тогда
		ПозТабл = СтрНайти(ТекстОшибки, "Справочник ");
		Маркер = "Справочник ";
	ИначеЕсли СтрНайти(ТекстОшибки, "РегистрНакопления ") > 0 Тогда
		ПозТабл = СтрНайти(ТекстОшибки, "РегистрНакопления ");
		Маркер = "РегистрНакопления ";
	ИначеЕсли СтрНайти(ТекстОшибки, "РегистрСведений ") > 0 Тогда
		ПозТабл = СтрНайти(ТекстОшибки, "РегистрСведений ");
		Маркер = "РегистрСведений ";
	ИначеЕсли СтрНайти(ТекстОшибки, "РегистрБухгалтерии ") > 0 Тогда
		ПозТабл = СтрНайти(ТекстОшибки, "РегистрБухгалтерии ");
		Маркер = "РегистрБухгалтерии ";
	Иначе
		Возврат "";
	КонецЕсли;
	
	Остаток = Сред(ТекстОшибки, ПозТабл + СтрДлина(Маркер));
	ПозОдной = СтрНайти(Остаток, "'");
	ПозДвойной = СтрНайти(Остаток, """");
	
	Если ПозОдной > 0 И (ПозДвойной <= 0 ИЛИ ПозОдной < ПозДвойной) Тогда
		СимволКавычки = "'";
		ПозОткрытия = ПозОдной;
	ИначеЕсли ПозДвойной > 0 Тогда
		СимволКавычки = """";
		ПозОткрытия = ПозДвойной;
	Иначе
		Возврат "";
	КонецЕсли;
	
	Остаток = Сред(Остаток, ПозОткрытия + 1);
	ПозЗакрытия = СтрНайти(Остаток, СимволКавычки);
	Если ПозЗакрытия <= 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ИмяОбъекта = СокрЛП(Лев(Остаток, ПозЗакрытия - 1));
	Если Маркер = "Таблица " Тогда
		Возврат ИмяОбъекта;
	КонецЕсли;
	Возврат СокрЛП(Лев(Маркер, СтрДлина(Маркер) - 1) + "." + ИмяОбъекта);
	
КонецФункции

// Определяет фильтр для GetMetadata из имени таблицы (например РеализацияТоваровУслуг → Реализация).
//
Функция ОпределитьФильтрGetMetadataИзИмениТаблицы(ИмяТаблицы)
	
	ИмяОбъекта = ИмяТаблицы;
	ПозТочки = СтрНайти(ИмяОбъекта, ".");
	Если ПозТочки > 0 Тогда
		ИмяОбъекта = Сред(ИмяОбъекта, ПозТочки + 1);
	КонецЕсли;
	
	ИмяВРег = ВРег(ИмяОбъекта);
	// Убираем типичные суффиксы: ТоваровУслуг, Товаров, Услуг
	Если СтрНайти(ИмяВРег, "ТОВАРОВУСЛУГ") > 0 Тогда
		Поз = СтрНайти(ИмяВРег, "ТОВАРОВУСЛУГ");
		ИмяОбъекта = Лев(ИмяОбъекта, Поз - 1);
	ИначеЕсли СтрНайти(ИмяВРег, "ТОВАРОВ") > 0 Тогда
		Поз = СтрНайти(ИмяВРег, "ТОВАРОВ");
		ИмяОбъекта = Лев(ИмяОбъекта, Поз - 1);
	ИначеЕсли СтрНайти(ИмяВРег, "УСЛУГ") > 0 И СтрДлина(ИмяОбъекта) > 5 Тогда
		Поз = СтрНайти(ИмяВРег, "УСЛУГ");
		ИмяОбъекта = Лев(ИмяОбъекта, Поз - 1);
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяОбъекта) Тогда
		Возврат ИмяТаблицы;
	КонецЕсли;
	
	Возврат ИмяОбъекта;
	
КонецФункции

Функция ОпределитьФильтрGetMetadataИзКонтекстаОшибки(РезультатExecutor, СообщениеОшибки)
	Если РезультатExecutor <> Неопределено
		И ТипЗнч(РезультатExecutor) = Тип("Структура")
		И РезультатExecutor.Свойство("error_context")
		И РезультатExecutor.error_context <> Неопределено
		И ТипЗнч(РезультатExecutor.error_context) = Тип("Структура") Тогда
		КонтекстОшибки = РезультатExecutor.error_context;
		Если КонтекстОшибки.Свойство("table_name") Тогда
			Фильтр = ОпределитьФильтрGetMetadataИзИмениТаблицы(Строка(КонтекстОшибки.table_name));
			Если НЕ ПустаяСтрока(Фильтр) Тогда
				Возврат Фильтр;
			КонецЕсли;
		КонецЕсли;
		Если КонтекстОшибки.Свойство("object_name") Тогда
			Возврат ОпределитьФильтрGetMetadataИзИмениТаблицы(Строка(КонтекстОшибки.object_name));
		КонецЕсли;
	КонецЕсли;

	ИмяТаблицы = ИзвлечьИмяТаблицыИзОшибки(СообщениеОшибки);
	Если НЕ ПустаяСтрока(ИмяТаблицы) Тогда
		Возврат ОпределитьФильтрGetMetadataИзИмениТаблицы(ИмяТаблицы);
	КонецЕсли;

	Возврат "";
КонецФункции

// Вставляет в typed plan шаг get_metadata перед первым невыполненным run_query.
// Возвращает Истина, если шаг добавлен.
//
Функция ДобавитьGetMetadataВПланПриТаблицаНеНайдена(СсылкаДиалога, ИмяТаблицы) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	Если План.steps.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Фильтр = ОпределитьФильтрGetMetadataИзИмениТаблицы(ИмяТаблицы);
	Если ПустаяСтрока(Фильтр) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ИндексВставки = -1;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		ШагПлана = План.steps[Индекс];
		Если СтатусШагаЗавершен(ШагПлана) Тогда
			Продолжить;
		КонецЕсли;
		KindШага = ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "kind", "")));
		InputШага = ПолучитьСвойствоJSONОбъекта(ШагПлана, "input", Неопределено);
		ЭтоПодходящийШаг = (KindШага = "RUN_QUERY" ИЛИ KindШага = "GET_OBJECT_FIELDS" ИЛИ KindШага = "CHECK_OBJECT_EXISTS");
		Если НЕ ЭтоПодходящийШаг И ЭтоJSONОбъект(InputШага) Тогда
			QueryКандидат = ПолучитьСвойствоJSONОбъекта(InputШага, "query", "");
			ЭтоПодходящийШаг = НЕ ПустаяСтрока(Строка(QueryКандидат));
		КонецЕсли;
		Если ЭтоПодходящийШаг Тогда
			ИндексВставки = Индекс;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если ИндексВставки < 0 Тогда
		Возврат Ложь;
	КонецЕсли;

	НовыйШаг = Новый Структура;
	НовыйШаг.Вставить("id", "step_inserted_get_metadata_" + Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss"));
	НовыйШаг.Вставить("kind", "get_metadata");
	НовыйШаг.Вставить("title", "Уточнить метаданные по фильтру """ + Фильтр + """");
	НовыйШаг.Вставить("depends_on", Новый Массив);
		Input = Новый Структура;
	Input.Вставить("filter", Фильтр);
	НовыйШаг.Вставить("input", Input);
	НовыйШаг.Вставить("status", "pending");
	НовыйШаг.Вставить("result_summary", "");
	НовыйШаг.Вставить("result_data", Неопределено);
	НовыйШаг.Вставить("seq_no", ИндексВставки + 1);

	НовыеШаги = Новый Массив;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		Если Индекс = ИндексВставки Тогда
			НовыеШаги.Добавить(НовыйШаг);
		КонецЕсли;
		НовыеШаги.Добавить(План.steps[Индекс]);
	КонецЦикла;
	Для Индекс = 0 По НовыеШаги.Количество() - 1 Цикл
		ШагПлана = НовыеШаги[Индекс];
		ШагПлана.seq_no = Индекс + 1;
		НовыеШаги[Индекс] = ШагПлана;
	КонецЦикла;
	План.steps = НовыеШаги;
	СохранитьTypedPlan(СсылкаДиалога, План);
	ИИА_Сервер.УведомитьОбОбновленииДиалога(СсылкаДиалога, "ПланОбновлен");
	Возврат Истина;
КонецФункции

Функция ДобавитьGetObjectFieldsВПланПередRunQuery(СсылкаДиалога, ПолноеИмяОбъекта) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	Если План.steps.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	РазборОбъекта = Новый Структура("ObjectType,ObjectName", "", "");
	ИмяОбъектаДляРазбора = СокрЛП(Строка(ПолноеИмяОбъекта));
	ПозТочки = СтрНайти(ИмяОбъектаДляРазбора, ".");
	Если ПозТочки > 0 Тогда
		РазборОбъекта.ObjectType = Лев(ИмяОбъектаДляРазбора, ПозТочки - 1);
		РазборОбъекта.ObjectName = Сред(ИмяОбъектаДляРазбора, ПозТочки + 1);
	Иначе
		РазборОбъекта.ObjectName = ИмяОбъектаДляРазбора;
	КонецЕсли;
	Если ПустаяСтрока(РазборОбъекта.ObjectType) ИЛИ ПустаяСтрока(РазборОбъекта.ObjectName) Тогда
		Возврат Ложь;
	КонецЕсли;
	ИндексВставки = -1;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		ШагПлана = План.steps[Индекс];
		Если СтатусШагаЗавершен(ШагПлана) Тогда
			Продолжить;
		КонецЕсли;
		KindШага = ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "kind", "")));
		Если KindШага <> "RUN_QUERY" Тогда
			Продолжить;
		КонецЕсли;
		InputШага = ПолучитьСвойствоJSONОбъекта(ШагПлана, "input", Неопределено);
		Если НЕ ЭтоJSONОбъект(InputШага) Тогда
			Продолжить;
		КонецЕсли;
		ИмяОбъектаШага = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object", ""));
		Если ПустаяСтрока(ИмяОбъектаШага) Тогда
			ИмяОбъектаШага = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object_name", ""));
		КонецЕсли;
		ТекстЗапроса = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "query", ""));
		Если ПустаяСтрока(ИмяОбъектаШага) И НЕ ПустаяСтрока(ТекстЗапроса) Тогда
			ИмяОбъектаШага = ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаЛокально(ТекстЗапроса);
		КонецЕсли;
		Если НЕ ПустаяСтрока(ИмяОбъектаШага) И ВРег(ИмяОбъектаШага) = ВРег(ПолноеИмяОбъекта) Тогда
			ИндексВставки = Индекс;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если ИндексВставки < 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		ШагПлана = План.steps[Индекс];
		Если ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "kind", ""))) = "GET_OBJECT_FIELDS" Тогда
			InputШага = ПолучитьСвойствоJSONОбъекта(ШагПлана, "input", Неопределено);
			Если ЭтоJSONОбъект(InputШага)
				И ВРег(Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object_type", ""))) = ВРег(РазборОбъекта.ObjectType)
				И ВРег(Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object_name", ""))) = ВРег(РазборОбъекта.ObjectName) Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	НовыйШаг = Новый Структура;
	НовыйStepId = "step_inserted_get_object_fields_" + Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss");
	НовыйШаг.Вставить("id", НовыйStepId);
	НовыйШаг.Вставить("kind", "get_object_fields");
	НовыйШаг.Вставить("title", "Уточнить поля объекта """ + ПолноеИмяОбъекта + """");
	НовыйШаг.Вставить("depends_on", Новый Массив);
	Input = Новый Структура;
	Input.Вставить("object_type", РазборОбъекта.ObjectType);
	Input.Вставить("object_name", РазборОбъекта.ObjectName);
	НовыйШаг.Вставить("input", Input);
	НовыйШаг.Вставить("status", "pending");
	НовыйШаг.Вставить("result_summary", "");
	НовыйШаг.Вставить("result_data", Неопределено);
	НовыйШаг.Вставить("seq_no", ИндексВставки + 1);
	НовыеШаги = Новый Массив;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		Если Индекс = ИндексВставки Тогда
			НовыеШаги.Добавить(НовыйШаг);
		КонецЕсли;
		Если Индекс = ИндексВставки Тогда
			ШагЦели = План.steps[Индекс];
			ЗависимостиШагаЦели = ПолучитьСвойствоJSONОбъекта(ШагЦели, "depends_on", Неопределено);
			Если НЕ ЭтоJSONArray(ЗависимостиШагаЦели) Тогда
				ЗависимостиШагаЦели = Новый Массив;
			КонецЕсли;
			Если ЗависимостиШагаЦели.Найти(НовыйStepId) = Неопределено Тогда
				ЗависимостиШагаЦели.Добавить(НовыйStepId);
			КонецЕсли;
			ШагЦели.depends_on = ЗависимостиШагаЦели;
			НовыеШаги.Добавить(ШагЦели);
			Продолжить;
		КонецЕсли;
		НовыеШаги.Добавить(План.steps[Индекс]);
	КонецЦикла;
	Для Индекс = 0 По НовыеШаги.Количество() - 1 Цикл
		ШагПлана = НовыеШаги[Индекс];
		ШагПлана.seq_no = Индекс + 1;
		НовыеШаги[Индекс] = ШагПлана;
	КонецЦикла;
	План.steps = НовыеШаги;
	СохранитьTypedPlan(СсылкаДиалога, План);
	ИИА_Сервер.УведомитьОбОбновленииДиалога(СсылкаДиалога, "ПланОбновлен");
	Возврат Истина;
КонецФункции

Функция ДобавитьGetMetadataВПланПоКонтекстуОшибки(СсылкаДиалога, РезультатExecutor, СообщениеОшибки) Экспорт
	Фильтр = ОпределитьФильтрGetMetadataИзКонтекстаОшибки(РезультатExecutor, СообщениеОшибки);
	Если ПустаяСтрока(Фильтр) Тогда
		Возврат Ложь;
	КонецЕсли;
	Возврат ДобавитьGetMetadataВПланПриТаблицаНеНайдена(СсылкаДиалога, Фильтр);
КонецФункции

Функция СобратьФактыПоследнихДействий(СсылкаДиалога) Экспорт
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	КоличествоСообщений = Диалог.Сообщения.Количество();
	
	МассивФрагментов = Новый Массив;
	СчетчикСистемных = 0;
	СчетчикDSL = 0;
	РеквизитыДобавлены = Ложь;
	
	Индекс = КоличествоСообщений - 1;
	Пока Индекс >= 0 Цикл
		СтрокаСообщения = Диалог.Сообщения[Индекс];
		
		АвторСообщения = СтрокаСообщения.Автор;
		ТипСообщения   = СтрокаСообщения.ТипСообщения;
		
		Если АвторСообщения = Перечисления.ИИА_АвторСообщения.Система 
			ИЛИ АвторСообщения = Перечисления.ИИА_АвторСообщения.ИИ Тогда
			
			Если АвторСообщения = Перечисления.ИИА_АвторСообщения.ИИ И НЕ ПустаяСтрока(СтрокаСообщения.ТекстКода) Тогда
				ТекстСообщения = СтрокаСообщения.ТекстКода;
			Иначе
				ТекстСообщения = СтрокаСообщения.Текст;
			КонецЕсли;
			ТекстСообщения = СокрЛП(ТекстСообщения);
			
			Если ПустаяСтрока(ТекстСообщения) Тогда
				Индекс = Индекс - 1;
				Продолжить;
			КонецЕсли;
			
			// Берем результаты DSL (dsl_system_result), ошибки, сообщения с Реквизитами (GetObjectFields) и DSL-команды ИИ
			ЭтоРезультат = (СтрНайти(ТекстСообщения, "dsl_system_result") > 0);
			ЭтоОшибка    = (ТипСообщения = Перечисления.ИИА_ТипСообщения.Ошибка);
			ЭтоРеквизиты = (АвторСообщения = Перечисления.ИИА_АвторСообщения.Система И СтрНайти(ТекстСообщения, "Реквизиты:") > 0);
			ЭтоDSL       = (АвторСообщения = Перечисления.ИИА_АвторСообщения.ИИ И НЕ ПустаяСтрока(СтрокаСообщения.ТекстКода));
			
			Если ЭтоРезультат ИЛИ ЭтоОшибка Тогда
				
				Если СчетчикСистемных < 5 Тогда
					СчетчикСистемных = СчетчикСистемных + 1;
					
					Если ЭтоРезультат Тогда
						ТекстДляДобавления = ИИА_Сервер.ФорматироватьКомпактноДляЛога(ТекстСообщения);
					Иначе
						ТекстДляДобавления = ТекстСообщения;
						Если СтрДлина(ТекстДляДобавления) > 3000 Тогда
							ТекстДляДобавления = Лев(ТекстДляДобавления, 3000) + "...(truncated)";
						КонецЕсли;
					КонецЕсли;
					
					МассивФрагментов.Вставить(0, ТекстДляДобавления);
				КонецЕсли;
				
			ИначеЕсли ЭтоРеквизиты И НЕ РеквизитыДобавлены Тогда
				
				// Сообщение "DSL-сценарий выполнен успешно" + блок Реквизиты - нужно для RunQuery
				РеквизитыДобавлены = Истина;
				ТекстДляДобавления = ТекстСообщения;
				Если СтрДлина(ТекстДляДобавления) > 2500 Тогда
					ТекстДляДобавления = Лев(ТекстДляДобавления, 2500) + "...(truncated)";
				КонецЕсли;
				МассивФрагментов.Вставить(0, ТекстДляДобавления);
				
			ИначеЕсли ЭтоDSL Тогда
				
				Если СчетчикDSL < 5 Тогда
					СчетчикDSL = СчетчикDSL + 1;
					
					ТекстDSL = ИИА_Сервер.ФорматироватьКомпактноДляЛога(ТекстСообщения);
					МассивФрагментов.Вставить(0, "Выполнен " + ТекстDSL);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если СчетчикСистемных >= 5 И СчетчикDSL >= 5 Тогда
			Прервать;
		КонецЕсли;
		
		Индекс = Индекс - 1;
	КонецЦикла;
	
	ТекстРезультатов = "";
	Для Каждого Фрагмент Из МассивФрагментов Цикл
		Если НЕ ПустаяСтрока(ТекстРезультатов) Тогда
			ТекстРезультатов = ТекстРезультатов + Символы.ПС;
		КонецЕсли;
		ТекстРезультатов = ТекстРезультатов + Фрагмент;
	КонецЦикла;
	
	Возврат ТекстРезультатов;
	
КонецФункции

#КонецОбласти
