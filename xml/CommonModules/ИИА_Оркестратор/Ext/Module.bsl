
// Запускает серверный оркестратор (фоновый цикл)
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
Процедура Запустить(СсылкаДиалога, ПродолжитьСЧекпоинта = Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) ИЛИ СсылкаДиалога.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если ИИА_Сервер.ОркестраторВключенДляДиалога(СсылкаДиалога) Тогда
		ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Оркестратор] Уже работает, повторный запуск пропущен");
		Возврат;
	КонецЕсли;
	
	ИИА_Сервер.УстановитьОркестраторВключен(СсылкаДиалога, Истина);
	
	ИмяЗадания = "ИИ_Оркестратор_" + Строка(СсылкаДиалога.УникальныйИдентификатор());
	Параметры = Новый Массив;
	Параметры.Добавить(СсылкаДиалога);
	
	// Получаем начальное количество токенов перед запуском
	НачальныеТокены = ИИА_Сервер.ПолучитьОбщееКоличествоТокенов(СсылкаДиалога);
	Параметры.Добавить(НачальныеТокены);
	Параметры.Добавить(ПродолжитьСЧекпоинта);
	
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Оркестратор] Запуск серверного движка...");
	
	ФоновыеЗадания.Выполнить("ИИА_Оркестратор.ВыполнитьЦикл", Параметры, , ИмяЗадания);
	
КонецПроцедуры

// Добавляет сообщение пользователя и запускает оркестратор
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//  Текст - Строка - текст сообщения
//  ТипДиалога - ПеречислениеСсылка.ИИА_ТипДиалога - тип диалога
//
Процедура ОтправитьИЗапустить(СсылкаДиалога, Текст, ТипДиалога) Экспорт
	
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Пользователь] " + Текст);
	
	// 1. Добавляем сообщение пользователя через серверный модуль
	ИИА_Сервер.ОтправитьСообщениеСервера(СсылкаДиалога, ТипДиалога, Текст);
	
	// 2. Запускаем оркестратор
	Запустить(СсылкаДиалога);
	
КонецПроцедуры

// Останавливает серверный оркестратор (мягкая остановка)
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
Процедура Остановить(СсылкаДиалога) Экспорт
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ИИА_Сервер.ОркестраторВключенДляДиалога(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	
	ИИА_Сервер.УстановитьОркестраторВключен(СсылкаДиалога, Ложь);
	
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Оркестратор] Остановка пользователем.");
	
	ОтправитьУведомление(СсылкаДиалога, "ОстановленПользователем");
	
КонецПроцедуры

// Основной цикл серверного оркестратора
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//  НачальныеТокены - Число - количество токенов на момент старта
//
Процедура ВыполнитьЦикл(СсылкаДиалога, НачальныеТокены = 0, ПродолжитьСЧекпоинта = Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	
	ДиалогОбъект = СсылкаДиалога.ПолучитьОбъект();
	Настройки = ИИА_Сервер.ПолучитьНастройкиПользователя(ДиалогОбъект.Пользователь);
	ЛимитНаЗапуск = Настройки.ЛимитТокеновНаЗапуск;
	
	// Очищаем файл лога отладки при каждом запуске (Запустить / Отправить из формы агента)
	ИИА_Сервер.ОчиститьФайлЛогаОтладки(СсылкаДиалога);
	ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
	ИИА_Сервер.УстановитьThreadId(СсылкаДиалога, Строка(СсылкаДиалога.УникальныйИдентификатор()));
	АрхКонтекст = ИИА_Сервер.ПолучитьКонтекстАрхитектуры(СсылкаДиалога);
	Если НЕ ПустаяСтрока(АрхКонтекст.trace_id) Тогда
		ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[TRACE] trace_id=" + АрхКонтекст.trace_id + ", prompt_version=" + АрхКонтекст.prompt_version);
	КонецЕсли;
	
	СчетчикИтераций = 0;
	МаксимумИтераций = 50; // защита от бесконечного цикла
	Если НЕ ПродолжитьСЧекпоинта Тогда
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Intent", "cycle_start", Ложь);
	Иначе
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "cycle_resumed");
	КонецЕсли;
	ДеталиЧекпоинта = Новый Структура;
	ДеталиЧекпоинта.Вставить("initial_tokens", НачальныеТокены);
	ДеталиЧекпоинта.Вставить("token_limit_per_run", ЛимитНаЗапуск);
	ДеталиЧекпоинта.Вставить("max_iterations", МаксимумИтераций);
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, ?(ПродолжитьСЧекпоинта, "cycle_resumed", "cycle_started"), "", ДеталиЧекпоинта, ?(ПродолжитьСЧекпоинта, "resume", "cycle_start"));
	
	Пока Истина Цикл
		
		Попытка
			Если НЕ ИИА_Сервер.ОркестраторВключенДляДиалога(СсылкаДиалога) Тогда
				Прервать;
			КонецЕсли;
			
			Если ЛимитНаЗапуск > 0 Тогда
				ТекущиеТокены = ИИА_Сервер.ПолучитьОбщееКоличествоТокенов(СсылкаДиалога);
				ПотраченоВЭтомЗапуске = ТекущиеТокены - НачальныеТокены;
				Если ПотраченоВЭтомЗапуске >= ЛимитНаЗапуск Тогда
					ИИА_Сервер.УстановитьОркестраторВключен(СсылкаДиалога, Ложь);
					ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Система] Остановка: превышен лимит токенов на запуск (" + Строка(ЛимитНаЗапуск) + ")");
					ОбновитьСтатусПоследнегоСообщения(СсылкаДиалога, "Остановлено: превышен лимит токенов на запуск (" + Строка(ЛимитНаЗапуск) + ")");
					ОтправитьУведомление(СсылкаДиалога, "ПревышенЛимитТокенов");
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			СчетчикИтераций = СчетчикИтераций + 1;
			Если СчетчикИтераций >= МаксимумИтераций Тогда
				ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Система] Остановка: достигнут лимит итераций (" + Строка(МаксимумИтераций) + "). Пропускаем невыполненные шаги.");
				ПропуститьНевыполненныеШагиПлана(СсылкаДиалога);
				ВыполнитьФинальнуюПроверкуИSummary(СсылкаДиалога);
				ИИА_Сервер.УстановитьОркестраторВключен(СсылкаДиалога, Ложь);
				Прервать;
			КонецЕсли;
			
			СостояниеОркестратора = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
			ТекущаяСтадия = СостояниеОркестратора.ТекущаяСтадия;
			
			Если ТекущаяСтадия = "Intent" Тогда
				НачалоIntent = ТекущаяДата();
				ВыполнитьСтадиюIntent(СсылкаДиалога);
				ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Intent", НачалоIntent, Истина, "", "Intent->Plan");
				ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Plan", "intent_done", Ложь);
				Продолжить;
			ИначеЕсли ТекущаяСтадия = "Plan" Тогда
				Если ПланЗавершен(СсылкаДиалога) Тогда
					ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Summarize", "plan_done", Ложь);
					Продолжить;
				КонецЕсли;
				РезультатPlan = ВыполнитьСтадиюPlan(СсылкаДиалога);
				Если РезультатPlan <> Неопределено
					И РезультатPlan.Свойство("Успех")
					И РезультатPlan.Успех Тогда
					СледующаяСтадияPlan = ?(РезультатPlan.Свойство("NextStage"), РезультатPlan.NextStage, "Execute");
					ПричинаPlan = ?(РезультатPlan.Свойство("Reason"), РезультатPlan.Reason, "plan_ready");
					ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, СледующаяСтадияPlan, ПричинаPlan, Ложь);
				Иначе
					ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", ?(РезультатPlan <> Неопределено И РезультатPlan.Свойство("Reason"), РезультатPlan.Reason, "plan_failed"), Истина);
				КонецЕсли;
				Продолжить;
			ИначеЕсли ТекущаяСтадия = "Execute" Тогда
				Если ВыполнитьСтадиюExecute(СсылкаДиалога) Тогда
					Если ИИА_Сервер.ЕстьОжидающееПодтверждение(СсылкаДиалога) Тогда
						ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "AwaitApproval", "approval_required", Ложь);
					Иначе
						ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Validate", "execute_done", Ложь);
					КонецЕсли;
				Иначе
					ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "execute_failed", Истина);
				КонецЕсли;
				Продолжить;
			ИначеЕсли ТекущаяСтадия = "AwaitApproval" Тогда
				СостояниеПодтверждения = ИИА_Сервер.ПолучитьСостояниеПодтверждения(СсылкаДиалога);
				ДопДанныеПодтверждения = Новый Структура;
				ДопДанныеПодтверждения.Вставить("ApprovalState", СостояниеПодтверждения);
				ОтправитьУведомление(СсылкаДиалога, "ОжидаетПодтверждения", ДопДанныеПодтверждения);
				ИИА_Сервер.УстановитьОркестраторВключен(СсылкаДиалога, Ложь);
				Прервать;
			ИначеЕсли ТекущаяСтадия = "Validate" Тогда
				РезультатValidate = ВыполнитьСтадиюValidate(СсылкаДиалога);
				Если РезультатValidate.Свойство("NextStage") Тогда
					СледующаяСтадия = РезультатValidate.NextStage;
					ПричинаПерехода = ?(РезультатValidate.Свойство("Reason"), РезультатValidate.Reason, "");
					УвеличитьПопытку = (СледующаяСтадия = "Recover");
					Если СледующаяСтадия = "Plan" Тогда
						ПричинаПерехода = "reset_attempt";
					КонецЕсли;
					ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, СледующаяСтадия, ПричинаПерехода, УвеличитьПопытку);
				Иначе
					ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Plan", "validate_default", Ложь);
				КонецЕсли;
				Продолжить;
			ИначеЕсли ТекущаяСтадия = "Recover" Тогда
				РезультатRecover = ВыполнитьСтадиюRecover(СсылкаДиалога);
				ПрименитьПереходRecoverSubgraph(СсылкаДиалога, РезультатRecover);
				Продолжить;
			ИначеЕсли ТекущаяСтадия = "Summarize" Тогда
				ВыполнитьСтадиюSummarize(СсылкаДиалога);
				ИИА_Сервер.УстановитьОркестраторВключен(СсылкаДиалога, Ложь);
				Прервать;
			Иначе
				ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Intent", "unknown_stage", Ложь);
			КонецЕсли;
			
		Исключение
			ТекстОшибки = ОписаниеОшибки();
			ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Оркестратор] КРИТИЧЕСКАЯ ОШИБКА: " + ТекстОшибки);
			ИИА_Сервер.УстановитьОркестраторВключен(СсылкаДиалога, Ложь);
			ОбновитьСтатусПоследнегоСообщения(СсылкаДиалога, "Остановлено: внутренняя ошибка");
			ОтправитьУведомление(СсылкаДиалога, "ОшибкаОркестратора");
			Прервать;
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

#Область ПланированиеИУправление

Функция ОпределитьRAGДляПлана(ТекстЗадачи, ТипДиалога) Экспорт
	
	Результат = Новый Структура("ИспользоватьRAG,Причина", Ложь, "");
	
	Если ПустаяСтрока(ТекстЗадачи) Тогда
		Результат.Причина = "Пустой текст задачи";
		Возврат Результат;
	КонецЕсли;
	
	// RAG всегда включён - пользователь работает с данными базы, подсказки по метаданным полезны
	Результат.ИспользоватьRAG = Истина;
	Результат.Причина = "RAG включён по умолчанию для работы с данными 1С";
	Возврат Результат;
	
КонецФункции

Функция СоздатьРезультатПодграфа(SubgraphName, Успех = Ложь, Transition = "", ExecutorResult = Неопределено, ApprovalPending = Ложь, Decision = "", Details = Неопределено, NextStage = "", Reason = "", Policy = "", StepId = "") Экспорт
	Результат = Новый Структура;
	Результат.Вставить("SubgraphName", SubgraphName);
	Результат.Вставить("Успех", Успех);
	Результат.Вставить("Transition", Transition);
	Результат.Вставить("ExecutorResult", ExecutorResult);
	Результат.Вставить("ApprovalPending", ApprovalPending);
	Результат.Вставить("Decision", НормализоватьTransitionDecision(Decision));
	Результат.Вставить("Details", ?(Details = Неопределено, Новый Структура, Details));
	Результат.Вставить("NextStage", NextStage);
	Результат.Вставить("Reason", НормализоватьTransitionReason(Reason));
	Результат.Вставить("Policy", НормализоватьTransitionPolicy(Policy));
	Результат.Вставить("StepId", StepId);
	Возврат Результат;
КонецФункции

Функция ПолучитьРеестрTransitionContract() Экспорт
	Реестр = Новый Структура;
	Реестр.Вставить("Decisions", Новый Массив);
	Реестр.Decisions.Добавить("continue");
	Реестр.Decisions.Добавить("recover");
	Реестр.Decisions.Добавить("await_approval");
	Реестр.Decisions.Добавить("resume");
	Реестр.Decisions.Добавить("replan");
	Реестр.Decisions.Добавить("abort");
	
	Реестр.Вставить("Reasons", Новый Массив);
	Реестр.Reasons.Добавить("discovery_completed");
	Реестр.Reasons.Добавить("plan_failed");
	Реестр.Reasons.Добавить("init_plan_failed");
	Реестр.Reasons.Добавить("plan_completed");
	Реестр.Reasons.Добавить("no_pending_step");
	Реестр.Reasons.Добавить("planner_empty_dsl");
	Реестр.Reasons.Добавить("plan_ready");
	Реестр.Reasons.Добавить("execute_failed");
	Реестр.Reasons.Добавить("approval_required");
	Реестр.Reasons.Добавить("execute_completed");
	Реестр.Reasons.Добавить("recover_handled");
	Реестр.Reasons.Добавить("recover_failed");
	Реестр.Reasons.Добавить("resume_after_committed_write");
	Реестр.Reasons.Добавить("abort_unsafe_write_retry");
	Реестр.Reasons.Добавить("abort_missing_same_operation");
	Реестр.Reasons.Добавить("resume_same_operation_id");
	Реестр.Reasons.Добавить("approval_approved");
	Реестр.Reasons.Добавить("approval_rejected");
	Реестр.Reasons.Добавить("reset_attempt");
	Реестр.Reasons.Добавить("recover_resume");
	Реестр.Reasons.Добавить("recover_abort");
	Реестр.Reasons.Добавить("capability_abort");
	Реестр.Reasons.Добавить("validate_ok");
	Реестр.Reasons.Добавить("no_executor_result");
	Реестр.Reasons.Добавить("next_step");
	Реестр.Reasons.Добавить("recoverable_error");
	Реестр.Reasons.Добавить("recovery_exhausted");
	Реестр.Reasons.Добавить("non_recoverable_error");
	Реестр.Reasons.Добавить("summary_completed");
	Реестр.Reasons.Добавить("summary_failed");
	Реестр.Reasons.Добавить("stage_policy_safe_replay");
	Реестр.Reasons.Добавить("stage_policy_resume_only");
	Реестр.Reasons.Добавить("stage_policy_no_replay");
	
	Реестр.Вставить("Policies", Новый Массив);
	Реестр.Policies.Добавить("safe-path");
	Реестр.Policies.Добавить("fast-path");
	Реестр.Policies.Добавить("planner_policy");
	Для Каждого Пара Из ПолучитьРеестрПолитикВосстановления() Цикл
		Если Пара.Значение <> Неопределено
			И ТипЗнч(Пара.Значение) = Тип("Структура")
			И Пара.Значение.Свойство("id")
			И НЕ ПустаяСтрока(СокрЛП(Строка(Пара.Значение.id)))
			И НЕ ЭтоЗначениеУжеВСписке(Реестр.Policies, Строка(Пара.Значение.id)) Тогда
			Реестр.Policies.Добавить(Строка(Пара.Значение.id));
		КонецЕсли;
	КонецЦикла;
	Реестр.Policies.Добавить("write_retry_committed_policy");
	Реестр.Policies.Добавить("write_retry_missing_operation_id_policy");
	Реестр.Policies.Добавить("write_retry_missing_planned_dsl_policy");
	Реестр.Policies.Добавить("validate_policy");
	Реестр.Policies.Добавить("summarize_policy");
	Реестр.Policies.Добавить("stage_execute_resume_only");
	Реестр.Policies.Добавить("stage_validate_safe_replay");
	Реестр.Policies.Добавить("stage_recover_resume_only");
	Реестр.Policies.Добавить("stage_summarize_safe_replay");
	
	Возврат Реестр;
КонецФункции

Функция ЭтоЗначениеУжеВСписке(СписокЗначений, Значение)
	Для Каждого ТекущееЗначение Из СписокЗначений Цикл
		Если СокрЛП(Строка(ТекущееЗначение)) = СокрЛП(Строка(Значение)) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция НормализоватьЗначениеTransitionRegistry(Категория, Значение)
	НормализованноеЗначение = СокрЛП(Строка(Значение));
	Если ПустаяСтрока(НормализованноеЗначение) Тогда
		Возврат "";
	КонецЕсли;
	Реестр = ПолучитьРеестрTransitionContract();
	ДопустимыеЗначения = Новый Массив;
	Если Категория = "decision" Тогда
		ДопустимыеЗначения = Реестр.Decisions;
	ИначеЕсли Категория = "reason" Тогда
		ДопустимыеЗначения = Реестр.Reasons;
	ИначеЕсли Категория = "policy" Тогда
		ДопустимыеЗначения = Реестр.Policies;
	КонецЕсли;
	Если ЭтоЗначениеУжеВСписке(ДопустимыеЗначения, НормализованноеЗначение) Тогда
		Возврат НормализованноеЗначение;
	КонецЕсли;
	Возврат "";
КонецФункции

Функция НормализоватьTransitionDecision(Decision) Экспорт
	Возврат НормализоватьЗначениеTransitionRegistry("decision", Decision);
КонецФункции

Функция НормализоватьTransitionReason(Reason) Экспорт
	Возврат НормализоватьЗначениеTransitionRegistry("reason", Reason);
КонецФункции

Функция НормализоватьTransitionPolicy(Policy) Экспорт
	Возврат НормализоватьЗначениеTransitionRegistry("policy", Policy);
КонецФункции

Функция ПодготовитьРезультатПодграфаКВозврату(РезультатПодграфа) Экспорт
	Если РезультатПодграфа = Неопределено Или ТипЗнч(РезультатПодграфа) <> Тип("Структура") Тогда
		Возврат РезультатПодграфа;
	КонецЕсли;
	Если РезультатПодграфа.Свойство("Decision") Тогда
		РезультатПодграфа.Decision = НормализоватьTransitionDecision(РезультатПодграфа.Decision);
	КонецЕсли;
	Если РезультатПодграфа.Свойство("Reason") Тогда
		РезультатПодграфа.Reason = НормализоватьTransitionReason(РезультатПодграфа.Reason);
	КонецЕсли;
	Если РезультатПодграфа.Свойство("Policy") Тогда
		РезультатПодграфа.Policy = НормализоватьTransitionPolicy(РезультатПодграфа.Policy);
	КонецЕсли;
	Возврат РезультатПодграфа;
КонецФункции

Функция ВыполнитьDiscoverySubgraph(СсылкаДиалога, ТекстЗадачи, ТипДиалога) Экспорт
	ПараметрыRAG = ОпределитьRAGДляПлана(ТекстЗадачи, ТипДиалога);
	ExecutionPolicy = ?(ПараметрыRAG.ИспользоватьRAG, "safe-path", "fast-path");
	Детали = Новый Структура;
	Детали.Вставить("ИспользоватьRAG", ?(ПараметрыRAG.Свойство("ИспользоватьRAG"), ПараметрыRAG.ИспользоватьRAG, Ложь));
	Детали.Вставить("Причина", ?(ПараметрыRAG.Свойство("Причина"), ПараметрыRAG.Причина, ""));
	Детали.Вставить("execution_policy", ExecutionPolicy);
	ИИА_Сервер.УстановитьExecutionPolicy(СсылкаДиалога, ExecutionPolicy);
	ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "DiscoverySubgraph", "rag_evaluated", Детали);
	ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "discovery_rag", ?(ПараметрыRAG.ИспользоватьRAG, "rag_on", "rag_off"), "DiscoverySubgraph", Новый Структура("source,reason", "discovery", Детали.Причина));
	ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "execution_policy", ExecutionPolicy, "DiscoverySubgraph", Новый Структура("source,reason", "discovery", "rag_evaluated"));
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "discovery_subgraph_evaluated", "Plan", Детали, "DiscoverySubgraph");
	Возврат ПодготовитьРезультатПодграфаКВозврату(СоздатьРезультатПодграфа("DiscoverySubgraph", Истина, "Discovery->Plan", Неопределено, Ложь, "continue", Детали, "Plan", "discovery_completed", ExecutionPolicy, ""));
КонецФункции

Функция ЭтоЗапросПодсчета(ТекстЗадачи) Экспорт
	
	Если ПустаяСтрока(ТекстЗадачи) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстВРег = ВРег(ТекстЗадачи);
	Если СтрНайти(ТекстВРег, "СКОЛЬКО") > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	Если СтрНайти(ТекстВРег, "КОЛИЧЕСТВ") > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция КлючДействияИзDSL(DSL_JSON)
	
	Если ПустаяСтрока(DSL_JSON) Тогда
		Возврат "";
	КонецЕсли;
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(DSL_JSON);
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Шаг = Неопределено;
		Если ТипЗнч(Сценарий) = Тип("Структура") Тогда
			Если Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") И Сценарий.steps.Количество() > 0 Тогда
				Шаг = Сценарий.steps[0];
			ИначеЕсли Сценарий.Свойство("action") Тогда
				Шаг = Сценарий;
			КонецЕсли;
		КонецЕсли;
		
		Если Шаг = Неопределено Или НЕ Шаг.Свойство("action") Тогда
			Возврат "";
		КонецЕсли;
		
		Ключ = ВРег(Строка(Шаг.action));
		Если Шаг.Свойство("object_type") И Шаг.Свойство("object_name") Тогда
			Ключ = Ключ + ":" + Строка(Шаг.object_type) + "." + Строка(Шаг.object_name);
		ИначеЕсли Шаг.Свойство("query") Тогда
			Ключ = Ключ + ":" + Лев(ВРег(Строка(Шаг.query)), 80);
		КонецЕсли;
		
		Возврат Ключ;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат "";
	
КонецФункции

Функция ЭтоПовторДействия(СсылкаДиалога, DSL_JSON, Порог = 2) Экспорт
	
	КлючНового = КлючДействияИзDSL(DSL_JSON);
	Если ПустаяСтрока(КлючНового) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	КоличествоСообщений = Диалог.Сообщения.Количество();
	Если КоличествоСообщений = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Счетчик = 0;
	Индекс = КоличествоСообщений - 1;
	Пока Индекс >= 0 Цикл
		СтрокаСообщения = Диалог.Сообщения[Индекс];
		Если СтрокаСообщения.Автор <> Перечисления.ИИА_АвторСообщения.ИИ Тогда
			Индекс = Индекс - 1;
			Продолжить;
		КонецЕсли;
		Если ПустаяСтрока(СтрокаСообщения.ТекстКода) Тогда
			Индекс = Индекс - 1;
			Продолжить;
		КонецЕсли;
		
		КлючПрошлого = КлючДействияИзDSL(СтрокаСообщения.ТекстКода);
		Если ПустаяСтрока(КлючПрошлого) Тогда
			Индекс = Индекс - 1;
			Продолжить;
		КонецЕсли;
		
		Если КлючПрошлого = КлючНового Тогда
			Счетчик = Счетчик + 1;
			Если Счетчик >= Порог Тогда
				Возврат Истина;
			КонецЕсли;
		ИначеЕсли Счетчик > 0 Тогда
			Прервать;
		КонецЕсли;
		
		Индекс = Индекс - 1;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция ПодготовитьDSLПередИсполнением(СсылкаДиалога, DSLДляИсполнения, СообщениеОшибки = "", КодОшибкиПроверки = "") Экспорт
	
	СообщениеОшибки = "";
	КодОшибкиПроверки = "";
	Если ПустаяСтрока(DSLДляИсполнения) Тогда
		СообщениеОшибки = "Пустой DSL для исполнения";
		КодОшибкиПроверки = "dsl_contract_error";
		Возврат "";
	КонецЕсли;
	
	Попытка
		ТекстJSON = ИИА_DSL.НормализоватьJSONТекст(DSLДляИсполнения);
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Шаги = Неопределено;
		Если ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("steps") Тогда
			Шаги = Сценарий.steps;
		ИначеЕсли ТипЗнч(Сценарий) = Тип("Соответствие") Тогда
			Шаги = Сценарий.Получить("steps");
		КонецЕсли;
		
		Если Шаги = Неопределено ИЛИ ТипЗнч(Шаги) <> Тип("Массив") Тогда
			СообщениеОшибки = "DSL precheck: отсутствует массив steps";
			КодОшибкиПроверки = "dsl_contract_error";
			Возврат "";
		КонецЕсли;
		
		Изменено = Ложь;
		Для Индекс = 0 По Шаги.Количество() - 1 Цикл
			Шаг = Шаги[Индекс];
			Если ТипЗнч(Шаг) <> Тип("Структура") Тогда
				СообщениеОшибки = "DSL precheck: шаг " + Формат(Индекс + 1, "ЧН=0") + " должен быть структурой";
				КодОшибкиПроверки = "dsl_contract_error";
				Возврат "";
			КонецЕсли;
			
			Если НЕ Шаг.Свойство("action") Тогда
				СообщениеОшибки = "DSL precheck: шаг " + Формат(Индекс + 1, "ЧН=0") + " не содержит action";
				КодОшибкиПроверки = "dsl_contract_error";
				Возврат "";
			КонецЕсли;
			
			Если ВРег(СокрЛП(Строка(Шаг.action))) = "SHOWINFO" И НЕ Шаг.Свойство("message") Тогда
				Если Шаг.Свойство("title") И Шаг.Свойство("data") Тогда
					Шаг.Вставить("message", СокрЛП(Строка(Шаг.title)) + ": " + СокрЛП(Строка(Шаг.data)));
					Изменено = Истина;
				ИначеЕсли Шаг.Свойство("title") Тогда
					Шаг.Вставить("message", СокрЛП(Строка(Шаг.title)));
					Изменено = Истина;
				ИначеЕсли Шаг.Свойство("data") Тогда
					Шаг.Вставить("message", СокрЛП(Строка(Шаг.data)));
					Изменено = Истина;
				Иначе
					СообщениеОшибки = "DSL precheck: ShowInfo требует message (или совместимые title/data)";
					КодОшибкиПроверки = "dsl_contract_error";
					Возврат "";
				КонецЕсли;
				Шаги[Индекс] = Шаг;
			КонецЕсли;
		КонецЦикла;
		
		РезультатПроверкиDSL = ИИА_DSL.ПроверитьDSL(ТекстJSON);
		Если НЕ РезультатПроверкиDSL.Успех Тогда
			СообщениеОшибки = "DSL precheck: " + РезультатПроверкиDSL.Сообщение;
			КодОшибкиПроверки = "dsl_contract_error";
			Возврат "";
		КонецЕсли;
		
		Если НЕ ПройденRetrievalFirstGuard(СсылкаДиалога, Сценарий) Тогда
			СообщениеОшибки = "Retrieval-first guard: первый RunQuery допускается только после подтверждения полей (RAG/GetObjectFields).";
			КодОшибкиПроверки = "query_safety_violation";
			Возврат "";
		КонецЕсли;
		
		Если НЕ Изменено Тогда
			Возврат ТекстJSON;
		КонецЕсли;
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, Сценарий);
		Возврат ЗаписьJSON.Закрыть();
	Исключение
		СообщениеОшибки = "DSL precheck: " + ОписаниеОшибки();
		КодОшибкиПроверки = "dsl_contract_error";
	КонецПопытки;
	
	Возврат "";
	
КонецФункции

Функция ПройденRetrievalFirstGuard(СсылкаДиалога, Сценарий)
	
	Если Сценарий = Неопределено Или ТипЗнч(Сценарий) <> Тип("Структура") Тогда
		Возврат Истина;
	КонецЕсли;
	Если НЕ Сценарий.Свойство("steps") Или ТипЗнч(Сценарий.steps) <> Тип("Массив") Тогда
		Возврат Истина;
	КонецЕсли;
	
	Шаги = Сценарий.steps;
	ИндексПервогоRunQuery = -1;
	ИндексПервогоGetObjectFields = -1;
	
	Для Индекс = 0 По Шаги.Количество() - 1 Цикл
		Шаг = Шаги[Индекс];
		Если ТипЗнч(Шаг) <> Тип("Структура") Или НЕ Шаг.Свойство("action") Тогда
			Продолжить;
		КонецЕсли;
		
		Действие = ВРег(СокрЛП(Строка(Шаг.action)));
		Если ИндексПервогоRunQuery < 0 И Действие = "RUNQUERY" Тогда
			ИндексПервогоRunQuery = Индекс;
		КонецЕсли;
		Если ИндексПервогоGetObjectFields < 0 И Действие = "GETOBJECTFIELDS" Тогда
			ИндексПервогоGetObjectFields = Индекс;
		КонецЕсли;
		
		Если ИндексПервогоRunQuery >= 0 И ИндексПервогоGetObjectFields >= 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ИндексПервогоRunQuery < 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ИндексПервогоGetObjectFields >= 0 И ИндексПервогоGetObjectFields < ИндексПервогоRunQuery Тогда
		Возврат Истина;
	КонецЕсли;
	
	ТекстФактов = СобратьФактыПоследнихДействий(СсылкаДиалога);
	ПодтвержденныеПоля = ИзвлечьРеквизитыИзФактов(ТекстФактов);
	Если НЕ ПустаяСтрока(СокрЛП(ПодтвержденныеПоля)) Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Для запросов с явным объектом (ИЗ <Объект>) без плейсхолдеров
	// разрешаем первый RunQuery даже без блока реквизитов.
	ТекстПервогоRunQuery = ПолучитьТекстПервогоRunQueryИзСценария(Сценарий);
	Если НЕ ПустаяСтрока(ТекстПервогоRunQuery) Тогда
		Если RunQueryСодержитЯвныйИсточникДанных(ТекстПервогоRunQuery) Тогда
			ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[RETRIEVAL_FIRST] Разрешен RunQuery с явным источником данных без плейсхолдеров.");
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[RETRIEVAL_FIRST] Блокировка RunQuery без подтвержденных полей. Требуется GetObjectFields или RAG с полями.");
	Возврат Ложь;
	
КонецФункции

Функция ПолучитьТекстПервогоRunQueryИзСценария(Сценарий)
	Если Сценарий = Неопределено Или ТипЗнч(Сценарий) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	Если НЕ Сценарий.Свойство("steps") Или ТипЗнч(Сценарий.steps) <> Тип("Массив") Тогда
		Возврат "";
	КонецЕсли;
	
	Для Каждого Шаг Из Сценарий.steps Цикл
		Если ТипЗнч(Шаг) <> Тип("Структура") Или НЕ Шаг.Свойство("action") Тогда
			Продолжить;
		КонецЕсли;
		Если ВРег(СокрЛП(Строка(Шаг.action))) = "RUNQUERY" Тогда
			Если Шаг.Свойство("query") Тогда
				Возврат СокрЛП(Строка(Шаг.query));
			КонецЕсли;
			Возврат "";
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
КонецФункции

Функция RunQueryСодержитЯвныйИсточникДанных(ТекстЗапроса)
	ТекстВРег = ВРег(СокрЛП(Строка(ТекстЗапроса)));
	Если ПустаяСтрока(ТекстВРег) Тогда
		Возврат Ложь;
	КонецЕсли;
	Если СтрНайти(ТекстВРег, "...") > 0 ИЛИ СтрНайти(ТекстВРег, "{") > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	Если СтрНайти(ТекстВРег, "ИЗ") = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	Если СтрНайти(ТекстВРег, "СПРАВОЧНИК.") > 0
		ИЛИ СтрНайти(ТекстВРег, "ДОКУМЕНТ.") > 0
		ИЛИ СтрНайти(ТекстВРег, "РЕГИСТР") > 0
		ИЛИ СтрНайти(ТекстВРег, "ОБРАБОТКА.") > 0
		ИЛИ СтрНайти(ТекстВРег, "ПЛАНВИДОВХАРАКТЕРИСТИК.") > 0
		ИЛИ СтрНайти(ТекстВРег, "ПЛАНСЧЕТОВ.") > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

Функция ПолучитьОтпечатокRunQueryИзDSL(DSL_JSON) Экспорт
	
	Если ПустаяСтрока(DSL_JSON) Тогда
		Возврат "";
	КонецЕсли;
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ИИА_DSL.НормализоватьJSONТекст(DSL_JSON));
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Шаги = Неопределено;
		Если ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("steps") Тогда
			Шаги = Сценарий.steps;
		КонецЕсли;
		Если Шаги = Неопределено ИЛИ ТипЗнч(Шаги) <> Тип("Массив") ИЛИ Шаги.Количество() = 0 Тогда
			Возврат "";
		КонецЕсли;
		
		ПервыйШаг = Шаги[0];
		Если ТипЗнч(ПервыйШаг) <> Тип("Структура") Или НЕ ПервыйШаг.Свойство("action") Тогда
			Возврат "";
		КонецЕсли;
		Если ВРег(СокрЛП(Строка(ПервыйШаг.action))) <> "RUNQUERY" Тогда
			Возврат "";
		КонецЕсли;
		Если НЕ ПервыйШаг.Свойство("query") Тогда
			Возврат "";
		КонецЕсли;
		
		ТекстЗапроса = ВРег(Строка(ПервыйШаг.query));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, Символы.ПС, " ");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, Символы.ВК, " ");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, Символы.Таб, " ");
		Пока СтрНайти(ТекстЗапроса, "  ") > 0 Цикл
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "  ", " ");
		КонецЦикла;
		ТекстЗапроса = СокрЛП(ТекстЗапроса);
		
		Возврат "RUNQUERY:" + Лев(ТекстЗапроса, 220);
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат "";
	
КонецФункции

Функция ЗафиксироватьПовторОшибочногоRunQuery(СсылкаДиалога, DSL_JSON, КодОшибки, Порог = 2) Экспорт
	
	Код = НормализоватьКодОшибки(КодОшибки);
	Если Код <> "field_not_found" И Код <> "query_syntax_error" И Код <> "query_execution_error" И Код <> "parameter_missing" И Код <> "query_safety_violation" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Отпечаток = ПолучитьОтпечатокRunQueryИзDSL(DSL_JSON);
	Если ПустаяСтрока(Отпечаток) Тогда
		Возврат Ложь;
	КонецЕсли;
	Отпечаток = Отпечаток + "|ERROR:" + Код;
	
	СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено Или ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	
	ПоследнийОтпечаток = ?(СтруктураДанных.Свойство("ПоследнийОтпечатокОшибочногоRunQuery"), Строка(СтруктураДанных.ПоследнийОтпечатокОшибочногоRunQuery), "");
	СчетчикПовтора = ?(СтруктураДанных.Свойство("СчетчикПовтораОшибочногоRunQuery"), Число(СтруктураДанных.СчетчикПовтораОшибочногоRunQuery), 0);
	
	Если ПоследнийОтпечаток = Отпечаток Тогда
		СчетчикПовтора = СчетчикПовтора + 1;
	Иначе
		СчетчикПовтора = 1;
	КонецЕсли;
	
	СтруктураДанных.Вставить("ПоследнийОтпечатокОшибочногоRunQuery", Отпечаток);
	СтруктураДанных.Вставить("СчетчикПовтораОшибочногоRunQuery", СчетчикПовтора);
	ИИА_Сервер.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	
	Возврат СчетчикПовтора >= Порог;
	
КонецФункции

Процедура УстановитьФлагПринудительнойСменыСтратегииRunQuery(СсылкаДиалога, ЗначениеФлага = Истина) Экспорт
	
	СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено Или ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	СтруктураДанных.Вставить("ПринудительнаяСменаСтратегииRunQuery", ЗначениеФлага);
	ИИА_Сервер.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	
КонецПроцедуры

Функция ИзвлечьИОчиститьФлагПринудительнойСменыСтратегииRunQuery(СсылкаДиалога) Экспорт
	
	СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено Или ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Флаг = ?(СтруктураДанных.Свойство("ПринудительнаяСменаСтратегииRunQuery"), СтруктураДанных.ПринудительнаяСменаСтратегииRunQuery, Ложь);
	Если Флаг Тогда
		СтруктураДанных.Вставить("ПринудительнаяСменаСтратегииRunQuery", Ложь);
		ИИА_Сервер.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	КонецЕсли;
	
	Возврат Флаг;
	
КонецФункции

Функция СериализоватьJSONЛокально(Значение)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Значение);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

Функция ЭтоСсылка1СДляJSON(Значение)
	Если Значение = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(Значение);
	Возврат Справочники.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ Документы.ТипВсеСсылки().СодержитТип(ТипЗначения)
		ИЛИ ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(ТипЗначения);
КонецФункции

Функция НормализоватьЗначениеДляJSONЛокально(Значение, Глубина = 0)
	Если Глубина > 8 Тогда
		Попытка
			Возврат Строка(Значение);
		Исключение
			Возврат "";
		КонецПопытки;
	КонецЕсли;
	
	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Строка")
		ИЛИ ТипЗначения = Тип("Число")
		ИЛИ ТипЗначения = Тип("Булево")
		ИЛИ ТипЗначения = Тип("Дата") Тогда
		Возврат Значение;
	КонецЕсли;
	
	Если ЭтоJSONОбъект(Значение) Тогда
		РезультатОбъект = Новый Структура;
		ЛокальныйОбъект = ПреобразоватьJSONОбъектВСтруктуру(Значение);
		Для Каждого Пара Из ЛокальныйОбъект Цикл
			РезультатОбъект.Вставить(Строка(Пара.Ключ), НормализоватьЗначениеДляJSONЛокально(Пара.Значение, Глубина + 1));
		КонецЦикла;
		Возврат РезультатОбъект;
	КонецЕсли;
	
	Если ЭтоJSONArray(Значение) Тогда
		РезультатМассив = Новый Массив;
		Для Каждого Элемент Из Значение Цикл
			РезультатМассив.Добавить(НормализоватьЗначениеДляJSONЛокально(Элемент, Глубина + 1));
		КонецЦикла;
		Возврат РезультатМассив;
	КонецЕсли;
	
	Если ТипЗначения = Тип("ТаблицаЗначений") Тогда
		РезультатТаблицы = Новый Массив;
		Для Каждого СтрокаТаблицы Из Значение Цикл
			СтруктураСтроки = Новый Структура;
			Для Каждого Колонка Из Значение.Колонки Цикл
				СтруктураСтроки.Вставить(Колонка.Имя, НормализоватьЗначениеДляJSONЛокально(СтрокаТаблицы[Колонка.Имя], Глубина + 1));
			КонецЦикла;
			РезультатТаблицы.Добавить(СтруктураСтроки);
		КонецЦикла;
		Возврат РезультатТаблицы;
	КонецЕсли;
	
	Если ЭтоСсылка1СДляJSON(Значение) Тогда
		СтруктураСсылки = Новый Структура;
		Попытка
			СтруктураСсылки.Вставить("guid", Строка(Значение.УникальныйИдентификатор()));
		Исключение
			СтруктураСсылки.Вставить("guid", "");
		КонецПопытки;
		Попытка
			СтруктураСсылки.Вставить("presentation", Строка(Значение));
		Исключение
			СтруктураСсылки.Вставить("presentation", "");
		КонецПопытки;
		СтруктураСсылки.Вставить("type", Строка(ТипЗначения));
		Возврат СтруктураСсылки;
	КонецЕсли;
	
	Попытка
		Возврат Строка(Значение);
	Исключение
		Возврат "";
	КонецПопытки;
КонецФункции

Функция НормализоватьРезультатШагаПланаДляХранения(ResultData)
	Если ResultData = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат НормализоватьЗначениеДляJSONЛокально(ResultData);
КонецФункции

Функция ЭтоJSONОбъект(Значение)
	ТипЗначения = ТипЗнч(Значение);
	Возврат ТипЗначения = Тип("Структура")
		ИЛИ ТипЗначения = Тип("Соответствие")
		ИЛИ ТипЗначения = Тип("ФиксированнаяСтруктура")
		ИЛИ ТипЗначения = Тип("ФиксированноеСоответствие");
КонецФункции

Функция ЭтоJSONArray(Значение)
	ТипЗначения = ТипЗнч(Значение);
	Возврат ТипЗначения = Тип("Массив") ИЛИ ТипЗначения = Тип("ФиксированныйМассив");
КонецФункции

Функция ПолучитьСвойствоJSONОбъекта(Значение, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
	Если ТипЗнч(Значение) = Тип("Структура") Тогда
		Если Значение.Свойство(ИмяСвойства) Тогда
			Возврат Значение[ИмяСвойства];
		КонецЕсли;
	ИначеЕсли ТипЗнч(Значение) = Тип("ФиксированнаяСтруктура") Тогда
		Если Значение.Свойство(ИмяСвойства) Тогда
			Возврат Значение[ИмяСвойства];
		КонецЕсли;
	ИначеЕсли ТипЗнч(Значение) = Тип("Соответствие") Тогда
		ЗначениеСвойства = Значение.Получить(ИмяСвойства);
		Если ЗначениеСвойства <> Неопределено Тогда
			Возврат ЗначениеСвойства;
		КонецЕсли;
	ИначеЕсли ТипЗнч(Значение) = Тип("ФиксированноеСоответствие") Тогда
		ЗначениеСвойства = Значение.Получить(ИмяСвойства);
		Если ЗначениеСвойства <> Неопределено Тогда
			Возврат ЗначениеСвойства;
		КонецЕсли;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ПреобразоватьJSONОбъектВСтруктуру(Значение)
	Если ТипЗнч(Значение) = Тип("Структура") Тогда
		Возврат Значение;
	КонецЕсли;
	Результат = Новый Структура;
	Если ТипЗнч(Значение) = Тип("Соответствие") ИЛИ ТипЗнч(Значение) = Тип("ФиксированноеСоответствие") Тогда
		Для Каждого Пара Из Значение Цикл
			Результат.Вставить(Строка(Пара.Ключ), Пара.Значение);
		КонецЦикла;
	ИначеЕсли ТипЗнч(Значение) = Тип("ФиксированнаяСтруктура") Тогда
		Для Каждого ИмяСвойства Из Значение Цикл
			Результат.Вставить(Строка(ИмяСвойства), Значение[ИмяСвойства]);
		КонецЦикла;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция СоздатьПустойTypedPlan(Цель = "")
	План = Новый Структура;
	План.Вставить("plan_version", 1);
	План.Вставить("goal", Цель);
	План.Вставить("steps", Новый Массив);
	Возврат План;
КонецФункции

Функция СтатусШагаЗавершен(ШагПлана)
	Если ШагПлана = Неопределено ИЛИ НЕ ЭтоJSONОбъект(ШагПлана) Тогда
		Возврат Ложь;
	КонецЕсли;
	Статус = ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "status", "pending")));
	Возврат Статус = "DONE" ИЛИ Статус = "SKIPPED";
КонецФункции

Функция ИзвлечьЗначениеИзСтроковогоФильтра(Знач ТекстФильтра, Знач ИмяПоля)
	Фильтр = СокрЛП(Строка(ТекстФильтра));
	Если ПустаяСтрока(Фильтр) Тогда
		Возврат "";
	КонецЕсли;
	ФильтрВРег = ВРег(Фильтр);
	ИмяПоляВРег = ВРег(ИмяПоля);
	Префикс1 = ИмяПоляВРег + " = """;
	Префикс2 = ИмяПоляВРег + " = '";
	Поз = СтрНайти(ФильтрВРег, Префикс1);
	ДлинаПрефикса = СтрДлина(Префикс1);
	СимволЗакрытия = """";
	Если Поз = 0 Тогда
		Поз = СтрНайти(ФильтрВРег, Префикс2);
		ДлинаПрефикса = СтрДлина(Префикс2);
		СимволЗакрытия = "'";
	КонецЕсли;
	Если Поз = 0 Тогда
		Возврат "";
	КонецЕсли;
	НачалоЗначения = Поз + ДлинаПрефикса;
	Остаток = Сред(Фильтр, НачалоЗначения);
	ПозЗакрытия = СтрНайти(Остаток, СимволЗакрытия);
	Если ПозЗакрытия = 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат Лев(Остаток, ПозЗакрытия - 1);
КонецФункции

Функция ПостроитьЯвныйЗапросПоискаСсылки(ПолноеИмяОбъекта, ИмяПоля, ЗначениеПоля)
	Если ПустаяСтрока(Строка(ПолноеИмяОбъекта)) Или ПустаяСтрока(Строка(ИмяПоля)) Или ПустаяСтрока(Строка(ЗначениеПоля)) Тогда
		Возврат "";
	КонецЕсли;
	Экранированное = СтрЗаменить(Строка(ЗначениеПоля), """", """""");
	Запрос = "ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка КАК Ссылка" + Символы.ПС
		+ "ИЗ" + Символы.ПС
		+ ПолноеИмяОбъекта + Символы.ПС
		+ "ГДЕ" + Символы.ПС
		+ ИмяПоля + " = """ + Экранированное + """";
	Если ВРег(ИмяПоля) = "НОМЕР" Тогда
		Запрос = Запрос + Символы.ПС + "УПОРЯДОЧИТЬ ПО Дата УБЫВ";
	КонецЕсли;
	Возврат Запрос;
КонецФункции

Процедура НормализоватьСпецШагиTypedPlan(ШагПлана, Цель = "")
	// Typed plan нормализуем только общими metadata-driven правилами.
	// Конфигурационные или field-specific переписывания шагов здесь запрещены.
	Возврат;
КонецПроцедуры

Функция НормализоватьШагTypedPlan(ШагПлана, Индекс, Цель = "")
	Результат = Новый Структура;
	Результат.Вставить("id", ?(НЕ ПустаяСтрока(Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "id", ""))), Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "id", "")), "step_" + Строка(Индекс + 1)));
	Результат.Вставить("seq_no", Индекс + 1);
	Результат.Вставить("kind", Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "kind", "")));
	Результат.Вставить("title", Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "title", "Шаг " + Строка(Индекс + 1))));
	Зависимости = ПолучитьСвойствоJSONОбъекта(ШагПлана, "depends_on", Неопределено);
	Если ЭтоJSONArray(Зависимости) Тогда
		Результат.Вставить("depends_on", Зависимости);
	Иначе
		Результат.Вставить("depends_on", Новый Массив);
	КонецЕсли;
	Input = ПолучитьСвойствоJSONОбъекта(ШагПлана, "input", Неопределено);
	Если ТипЗнч(Input) = Тип("Структура") Тогда
		Результат.Вставить("input", Input);
	ИначеЕсли ТипЗнч(Input) = Тип("Соответствие") Тогда
		Результат.Вставить("input", ПреобразоватьJSONОбъектВСтруктуру(Input));
	Иначе
		Результат.Вставить("input", Новый Структура);
	КонецЕсли;
	Результат.Вставить("status", Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "status", "pending")));
	Результат.Вставить("result_summary", Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "result_summary", "")));
	Результат.Вставить("result_data", ПолучитьСвойствоJSONОбъекта(ШагПлана, "result_data", Неопределено));
	НормализоватьСпецШагиTypedPlan(Результат, Цель);
	Возврат Результат;
КонецФункции

Функция НормализоватьTypedPlan(СырыеДанныеПлана, Цель = "")
	План = СоздатьПустойTypedPlan(Цель);
	Если СырыеДанныеПлана = Неопределено ИЛИ НЕ ЭтоJSONОбъект(СырыеДанныеПлана) Тогда
		Возврат План;
	КонецЕсли;
	План.plan_version = ПолучитьСвойствоJSONОбъекта(СырыеДанныеПлана, "plan_version", 1);
	ЦельПлана = Строка(ПолучитьСвойствоJSONОбъекта(СырыеДанныеПлана, "goal", ""));
	Если НЕ ПустаяСтрока(ЦельПлана) Тогда
		План.goal = ЦельПлана;
	КонецЕсли;
	ШагиСырые = ПолучитьСвойствоJSONОбъекта(СырыеДанныеПлана, "steps", Неопределено);
	Если НЕ ЭтоJSONArray(ШагиСырые) Тогда
		Возврат План;
	КонецЕсли;
	Для Индекс = 0 По ШагиСырые.Количество() - 1 Цикл
		Шаг = ШагиСырые[Индекс];
		Если ЭтоJSONОбъект(Шаг) Тогда
			План.steps.Добавить(НормализоватьШагTypedPlan(Шаг, Индекс, План.goal));
		КонецЕсли;
	КонецЦикла;
	Возврат План;
КонецФункции

Процедура СинхронизироватьТабличнуюЧастьПлана(СсылкаДиалога, План)
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	Диалог.План.Очистить();
	Если План = Неопределено ИЛИ ТипЗнч(План) <> Тип("Структура") ИЛИ НЕ План.Свойство("steps") Тогда
		Диалог.Записать();
		Возврат;
	КонецЕсли;
	Для Каждого ШагПлана Из План.steps Цикл
		НоваяСтрока = Диалог.План.Добавить();
		НоваяСтрока.Задача = ?(ШагПлана.Свойство("title"), Строка(ШагПлана.title), "");
		НоваяСтрока.Выполнена = СтатусШагаЗавершен(ШагПлана);
		НоваяСтрока.Результат = ?(ШагПлана.Свойство("result_summary"), Строка(ШагПлана.result_summary), "");
	КонецЦикла;
	Диалог.Записать();
КонецПроцедуры

Процедура СохранитьTypedPlan(СсылкаДиалога, План) Экспорт
	СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	КонецЕсли;
	СтруктураДанных.Вставить("Planner_TypedPlan", План);
	ИИА_Сервер.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
	СинхронизироватьТабличнуюЧастьПлана(СсылкаДиалога, План);
	
	ДеталиЧекпоинта = Новый Структура;
	ДеталиЧекпоинта.Вставить("steps_total", План.steps.Количество());
	ДеталиЧекпоинта.Вставить("completed_steps", 0);
	ДеталиЧекпоинта.Вставить("pending_steps", 0);
	Для Каждого ШагПлана Из План.steps Цикл
		Если СтатусШагаЗавершен(ШагПлана) Тогда
			ДеталиЧекпоинта.completed_steps = ДеталиЧекпоинта.completed_steps + 1;
		Иначе
			ДеталиЧекпоинта.pending_steps = ДеталиЧекпоинта.pending_steps + 1;
		КонецЕсли;
	КонецЦикла;
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "typed_plan_saved", "Plan", ДеталиЧекпоинта);
КонецПроцедуры

Функция ПолучитьTypedPlan(СсылкаДиалога) Экспорт
	СтруктураДанных = ИИА_Сервер.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных <> Неопределено И ТипЗнч(СтруктураДанных) = Тип("Структура") И СтруктураДанных.Свойство("Planner_TypedPlan") Тогда
		Возврат НормализоватьTypedPlan(СтруктураДанных.Planner_TypedPlan);
	КонецЕсли;
	Возврат СоздатьПустойTypedPlan();
КонецФункции

Функция ВсеЗависимостиШагаВыполнены(ШагПлана, План)
	Если ШагПлана = Неопределено ИЛИ ТипЗнч(ШагПлана) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	Если НЕ ШагПлана.Свойство("depends_on") ИЛИ ТипЗнч(ШагПлана.depends_on) <> Тип("Массив") ИЛИ ШагПлана.depends_on.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	Для Каждого ИдШага Из ШагПлана.depends_on Цикл
		Найден = Ложь;
		Для Каждого Кандидат Из План.steps Цикл
			Если Кандидат.Свойство("id") И Строка(Кандидат.id) = Строка(ИдШага) Тогда
				Найден = Истина;
				Если НЕ СтатусШагаЗавершен(Кандидат) Тогда
					Возврат Ложь;
				КонецЕсли;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если НЕ Найден Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Функция КлассифицироватьУсловиеВеткиПлана(ТекстУсловия)
	УсловиеВРег = ВРег(СокрЛП(Строка(ТекстУсловия)));
	Если ПустаяСтрока(УсловиеВРег) Тогда
		Возврат "";
	КонецЕсли;
	Если СтрНайти(УсловиеВРег, "НЕ НАЙДЕН") > 0
		ИЛИ СтрНайти(УсловиеВРег, "НЕ НАЙДЕНО") > 0
		ИЛИ СтрНайти(УсловиеВРег, "НЕ СУЩЕСТВУЕТ") > 0 Тогда
		Возврат "empty";
	КонецЕсли;
	Если СтрНайти(УсловиеВРег, "НАЙДЕН") > 0
		ИЛИ СтрНайти(УсловиеВРег, "НАЙДЕНО") > 0
		ИЛИ СтрНайти(УсловиеВРег, "УЖЕ СУЩЕСТВУЕТ") > 0
		ИЛИ СтрНайти(УсловиеВРег, "СУЩЕСТВУЕТ") > 0 Тогда
		Возврат "not_empty";
	КонецЕсли;
	Если СтрНайти(УсловиеВРег, "НЕ ПУСТ") > 0 ИЛИ СтрНайти(УсловиеВРег, "НЕПУСТ") > 0 Тогда
		Возврат "not_empty";
	КонецЕсли;
	Если СтрНайти(УсловиеВРег, "ПУСТ") > 0 Тогда
		Возврат "empty";
	КонецЕсли;
	Возврат "";
КонецФункции

Функция ШагПланаЗависитОтЛюбогоИдентификатора(ШагПлана, Идентификаторы)
	Если ШагПлана = Неопределено ИЛИ НЕ ЭтоJSONОбъект(ШагПлана) Тогда
		Возврат Ложь;
	КонецЕсли;
	Если Идентификаторы = Неопределено ИЛИ ТипЗнч(Идентификаторы) <> Тип("Соответствие") Тогда
		Возврат Ложь;
	КонецЕсли;
	Зависимости = ПолучитьСвойствоJSONОбъекта(ШагПлана, "depends_on", Неопределено);
	Если НЕ ЭтоJSONArray(Зависимости) Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Каждого ИдШага Из Зависимости Цикл
		Если Идентификаторы.Получить(Строка(ИдШага)) <> Неопределено Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция РезультатШагаСодержитНепустойRunQuery(ШагПлана)
	Если ШагПлана = Неопределено ИЛИ НЕ ЭтоJSONОбъект(ШагПлана) Тогда
		Возврат Ложь;
	КонецЕсли;
	РезультатШага = ПолучитьСвойствоJSONОбъекта(ШагПлана, "result_data", Неопределено);
	Если НЕ ЭтоJSONОбъект(РезультатШага) Тогда
		Возврат Ложь;
	КонецЕсли;
	МассивРезультатов = ПолучитьСвойствоJSONОбъекта(РезультатШага, "Результаты", Неопределено);
	Если НЕ ЭтоJSONArray(МассивРезультатов) Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Каждого ЭлементРезультата Из МассивРезультатов Цикл
		Если НЕ ЭтоJSONОбъект(ЭлементРезультата) Тогда
			Продолжить;
		КонецЕсли;
		ТипДействия = ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ЭлементРезультата, "ТипДействия", "")));
		Если ТипДействия <> "RUNQUERY" Тогда
			Продолжить;
		КонецЕсли;
		Если ПолучитьСвойствоJSONОбъекта(ЭлементРезультата, "ЕстьРезультатЗапроса", Ложь) Тогда
			Возврат Истина;
		КонецЕсли;
		Если Число(ПолучитьСвойствоJSONОбъекта(ЭлементРезультата, "КоличествоСтрок", 0)) > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция НайтиШагВПланеПоИдентификатору(План, StepId)
	Если План = Неопределено ИЛИ ТипЗнч(План) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Для Каждого ШагПлана Из План.steps Цикл
		Если ШагПлана.Свойство("id") И Строка(ШагПлана.id) = Строка(StepId) Тогда
			Возврат ШагПлана;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция ИзвлечьТекстИзРезультатаШагаПлана(ШагПлана)
	Текст = ?(ШагПлана.Свойство("result_summary"), Строка(ШагПлана.result_summary), "");
	РезультатШага = ПолучитьСвойствоJSONОбъекта(ШагПлана, "result_data", Неопределено);
	Если ЭтоJSONОбъект(РезультатШага) Тогда
		Сообщение = Строка(ПолучитьСвойствоJSONОбъекта(РезультатШага, "Сообщение", ""));
		Если НЕ ПустаяСтрока(Сообщение) Тогда
			Текст = Текст + Символы.ПС + Сообщение;
		КонецЕсли;
		МассивРезультатов = ПолучитьСвойствоJSONОбъекта(РезультатШага, "Результаты", Неопределено);
		Если ЭтоJSONArray(МассивРезультатов) Тогда
			Для Каждого ЭлементРезультата Из МассивРезультатов Цикл
				Если ЭтоJSONОбъект(ЭлементРезультата) Тогда
					СообщениеЭлемента = Строка(ПолучитьСвойствоJSONОбъекта(ЭлементРезультата, "Сообщение", ""));
					Если НЕ ПустаяСтрока(СообщениеЭлемента) Тогда
						Текст = Текст + Символы.ПС + СообщениеЭлемента;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Возврат Текст;
КонецФункции

Функция ЭтоСимволЛатиницыИлиКириллицыИлиЦифра(Символ)
	Если ПустаяСтрока(Символ) Тогда
		Возврат Ложь;
	КонецЕсли;
	Код = КодСимвола(Символ);
	Возврат (Код >= 48 И Код <= 57)
		ИЛИ (Код >= 65 И Код <= 90)
		ИЛИ (Код >= 97 И Код <= 122)
		ИЛИ (Код >= 1040 И Код <= 1103)
		ИЛИ Код = 1025
		ИЛИ Код = 1105;
КонецФункции

Функция ИзвлечьПолныеИменаОбъектовИзТекстаМетаданных(Текст)
	Результат = Новый Массив;
	Если ПустаяСтрока(Текст) Тогда
		Возврат Результат;
	КонецЕсли;
	Префиксы = Новый Массив;
	Префиксы.Добавить("Документ.");
	Префиксы.Добавить("Справочник.");
	Префиксы.Добавить("РегистрНакопления.");
	Префиксы.Добавить("РегистрСведений.");
	Префиксы.Добавить("ПланВидовХарактеристик.");
	Префиксы.Добавить("ПланСчетов.");
	Для Каждого Префикс Из Префиксы Цикл
		ПозицияПоиска = 1;
		ПрефиксВРег = ВРег(Префикс);
		Пока Истина Цикл
			ПозицияЛок = СтрНайти(Сред(ВРег(Текст), ПозицияПоиска), ПрефиксВРег);
			Если ПозицияЛок = 0 Тогда
				Прервать;
			КонецЕсли;
			Позиция = ПозицияПоиска + ПозицияЛок - 1;
			Кандидат = "";
			Индекс = Позиция;
			Пока Индекс <= СтрДлина(Текст) Цикл
				Символ = Сред(Текст, Индекс, 1);
				Если НЕ ЭтоСимволЛатиницыИлиКириллицыИлиЦифра(Символ) И Символ <> "." И Символ <> "_" Тогда
					Прервать;
				КонецЕсли;
				Кандидат = Кандидат + Символ;
				Индекс = Индекс + 1;
			КонецЦикла;
			Если НЕ ПустаяСтрока(Кандидат) И Результат.Найти(Кандидат) = Неопределено Тогда
				Результат.Добавить(Кандидат);
			КонецЕсли;
			ПозицияПоиска = Позиция + СтрДлина(Префикс);
		КонецЦикла;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаЛокально(ТекстЗапроса)
	Текст = СокрЛП(Строка(ТекстЗапроса));
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	ТекстВРег = ВРег(Текст);
	ПозицияИЗ = СтрНайти(ТекстВРег, Символы.ПС + "ИЗ");
	Если ПозицияИЗ = 0 Тогда
		ПозицияИЗ = СтрНайти(ТекстВРег, " ИЗ ");
	КонецЕсли;
	Если ПозицияИЗ > 0 Тогда
		ХвостЗапроса = СокрЛП(Сред(Текст, ПозицияИЗ + 3));
		КандидатыИсточника = ИзвлечьПолныеИменаОбъектовИзТекстаМетаданных(ХвостЗапроса);
		Если КандидатыИсточника.Количество() > 0 Тогда
			Возврат Строка(КандидатыИсточника[0]);
		КонецЕсли;
	КонецЕсли;
	Кандидаты = ИзвлечьПолныеИменаОбъектовИзТекстаМетаданных(Текст);
	Если Кандидаты.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат Строка(Кандидаты[0]);
КонецФункции

Функция РазбитьCamelCaseНаТокены(Имя)
	Токены = Новый Массив;
	Если ПустаяСтрока(Имя) Тогда
		Возврат Токены;
	КонецЕсли;
	ТекущееСлово = "";
	Для Индекс = 1 По СтрДлина(Имя) Цикл
		Символ = Сред(Имя, Индекс, 1);
		ЭтоВерхний = Символ = ВРег(Символ) И Символ <> НРег(Символ);
		Если ЭтоВерхний И НЕ ПустаяСтрока(ТекущееСлово) Тогда
			Токены.Добавить(ТекущееСлово);
			ТекущееСлово = Символ;
		Иначе
			ТекущееСлово = ТекущееСлово + Символ;
		КонецЕсли;
	КонецЦикла;
	Если НЕ ПустаяСтрока(ТекущееСлово) Тогда
		Токены.Добавить(ТекущееСлово);
	КонецЕсли;
	Возврат Токены;
КонецФункции

Функция ОценитьПохожестьИмениОбъекта(ИсходноеИмя, Кандидат)
	ИсходноеПростое = ИсходноеИмя;
	ПозТочки = СтрНайти(ИсходноеПростое, ".");
	Если ПозТочки > 0 Тогда
		ИсходноеПростое = Сред(ИсходноеПростое, ПозТочки + 1);
	КонецЕсли;
	КандидатПростой = Кандидат;
	ПозТочки = СтрНайти(КандидатПростой, ".");
	Если ПозТочки > 0 Тогда
		КандидатПростой = Сред(КандидатПростой, ПозТочки + 1);
	КонецЕсли;
	ИсходноеВРег = ВРег(ИсходноеПростое);
	КандидатВРег = ВРег(КандидатПростой);
	Оценка = 0;
	Для Индекс = 1 По Мин(СтрДлина(ИсходноеВРег), СтрДлина(КандидатВРег)) Цикл
		Если Сред(ИсходноеВРег, Индекс, 1) <> Сред(КандидатВРег, Индекс, 1) Тогда
			Прервать;
		КонецЕсли;
		Оценка = Оценка + 1;
	КонецЦикла;
	Токены = РазбитьCamelCaseНаТокены(ИсходноеПростое);
	Для Каждого Токен Из Токены Цикл
		Если СтрДлина(Токен) < 4 Тогда
			Продолжить;
		КонецЕсли;
		Сигнатура = ВРег(Лев(Токен, Мин(5, СтрДлина(Токен))));
		Если СтрНайти(КандидатВРег, Сигнатура) > 0 Тогда
			Оценка = Оценка + 10;
		КонецЕсли;
	КонецЦикла;
	Если СтрНайти(КандидатВРег, ИсходноеВРег) > 0 Тогда
		Оценка = Оценка + 30;
	КонецЕсли;
	Возврат Оценка;
КонецФункции

Функция ВыбратьЛучшийКандидатОбъекта(ИсходноеИмя, Кандидаты)
	ЛучшийКандидат = "";
	ЛучшаяОценка = -1;
	Для Каждого Кандидат Из Кандидаты Цикл
		Оценка = ОценитьПохожестьИмениОбъекта(ИсходноеИмя, Кандидат);
		Если Оценка > ЛучшаяОценка Тогда
			ЛучшаяОценка = Оценка;
			ЛучшийКандидат = Кандидат;
		КонецЕсли;
	КонецЦикла;
	Возврат ЛучшийКандидат;
КонецФункции

Процедура ПрименитьЭффектGetMetadataШагаПлана(План, ЗавершенныйШаг)
	Если План = Неопределено ИЛИ ТипЗнч(План) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	Если ЗавершенныйШаг = Неопределено ИЛИ НЕ ЭтоJSONОбъект(ЗавершенныйШаг) Тогда
		Возврат;
	КонецЕсли;
	Если ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ЗавершенныйШаг, "kind", ""))) <> "GET_METADATA" Тогда
		Возврат;
	КонецЕсли;
	ТекстМетаданных = ИзвлечьТекстИзРезультатаШагаПлана(ЗавершенныйШаг);
	Кандидаты = ИзвлечьПолныеИменаОбъектовИзТекстаМетаданных(ТекстМетаданных);
	Если Кандидаты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	ИзмененияЕсть = Ложь;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		ШагКандидат = План.steps[Индекс];
		Если СтатусШагаЗавершен(ШагКандидат) Тогда
			Продолжить;
		КонецЕсли;
		KindШага = ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагКандидат, "kind", "")));
		Если KindШага <> "RUN_QUERY" И KindШага <> "GET_OBJECT_FIELDS" И KindШага <> "CHECK_OBJECT_EXISTS" Тогда
			Продолжить;
		КонецЕсли;
		InputШага = ПолучитьСвойствоJSONОбъекта(ШагКандидат, "input", Неопределено);
		Если НЕ ЭтоJSONОбъект(InputШага) Тогда
			Продолжить;
		КонецЕсли;
		ИсходноеИмя = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object", ""));
		Если ПустаяСтрока(ИсходноеИмя) Тогда
			ИсходноеИмя = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object_name", ""));
		КонецЕсли;
		ТекстЗапроса = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "query", ""));
		Если ПустаяСтрока(ИсходноеИмя) И НЕ ПустаяСтрока(ТекстЗапроса) Тогда
			ИсходноеИмя = ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаЛокально(ТекстЗапроса);
		КонецЕсли;
		Если ПустаяСтрока(ИсходноеИмя) Тогда
			Продолжить;
		КонецЕсли;
		ЛучшийКандидат = ВыбратьЛучшийКандидатОбъекта(ИсходноеИмя, Кандидаты);
		Если ПустаяСтрока(ЛучшийКандидат) Тогда
			Продолжить;
		КонецЕсли;
		Если ВРег(ЛучшийКандидат) = ВРег(ИсходноеИмя) Тогда
			Продолжить;
		КонецЕсли;
		InputШага.Вставить("object", ЛучшийКандидат);
		InputШага.Вставить("object_name", ЛучшийКандидат);
		Если НЕ ПустаяСтрока(ТекстЗапроса) Тогда
			InputШага.Вставить("query", СтрЗаменить(ТекстЗапроса, ИсходноеИмя, ЛучшийКандидат));
		Иначе
			InputШага.Вставить("query", "");
		КонецЕсли;
		ШагКандидат.input = InputШага;
		ШагКандидат.title = СтрЗаменить(Строка(ПолучитьСвойствоJSONОбъекта(ШагКандидат, "title", "")), ИсходноеИмя, ЛучшийКандидат);
		План.steps[Индекс] = ШагКандидат;
		ИзмененияЕсть = Истина;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьWhitelistПолейИзРезультатаШага(ЗавершенныйШаг)
	Whitelist = Новый Массив;
	Если ЗавершенныйШаг = Неопределено ИЛИ НЕ ЭтоJSONОбъект(ЗавершенныйШаг) Тогда
		Возврат Whitelist;
	КонецЕсли;
	РезультатШага = ПолучитьСвойствоJSONОбъекта(ЗавершенныйШаг, "result_data", Неопределено);
	Если НЕ ЭтоJSONОбъект(РезультатШага) Тогда
		Возврат Whitelist;
	КонецЕсли;
	ИсходныйWhitelist = ПолучитьСвойствоJSONОбъекта(РезультатШага, "whitelist_fields", Неопределено);
	Если НЕ ЭтоJSONArray(ИсходныйWhitelist) Тогда
		Возврат Whitelist;
	КонецЕсли;
	Для Каждого Поле Из ИсходныйWhitelist Цикл
		ИмяПоля = СокрЛП(Строка(Поле));
		Если НЕ ПустаяСтрока(ИмяПоля) И Whitelist.Найти(ИмяПоля) = Неопределено Тогда
			Whitelist.Добавить(ИмяПоля);
		КонецЕсли;
	КонецЦикла;
	Возврат Whitelist;
КонецФункции

Функция ПолеЕстьВWhitelist(Whitelist, ИмяПоля)
	Для Каждого Кандидат Из Whitelist Цикл
		Если ВРег(Строка(Кандидат)) = ВРег(Строка(ИмяПоля)) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция ВыбратьЛучшееПолеПоWhitelist(ИсходноеПоле, Whitelist)
	ЛучшееПоле = "";
	ЛучшаяОценка = -1;
	Для Каждого Кандидат Из Whitelist Цикл
		Оценка = ОценитьПохожестьИмениОбъекта(Строка(ИсходноеПоле), Строка(Кандидат));
		Если Оценка > ЛучшаяОценка Тогда
			ЛучшаяОценка = Оценка;
			ЛучшееПоле = Строка(Кандидат);
		КонецЕсли;
	КонецЦикла;
	Если ЛучшаяОценка < 8 Тогда
		Возврат "";
	КонецЕсли;
	Возврат ЛучшееПоле;
КонецФункции

Функция ИзвлечьИмяОтсутствующегоПоляИзОшибки(СообщениеОшибки)
	Текст = Строка(СообщениеОшибки);
	ТекстВРег = ВРег(Текст);
	ПозПоля = СтрНайти(ТекстВРег, "ПОЛЕ НЕ НАЙДЕНО");
	Если ПозПоля = 0 Тогда
		Возврат "";
	КонецЕсли;
	Остаток = Сред(Текст, ПозПоля + СтрДлина("Поле не найдено"));
	ПозКавычки = СтрНайти(Остаток, """");
	Если ПозКавычки = 0 Тогда
		Возврат "";
	КонецЕсли;
	Остаток = Сред(Остаток, ПозКавычки + 1);
	ПозКонца = СтрНайти(Остаток, """");
	Если ПозКонца = 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат СокрЛП(Лев(Остаток, ПозКонца - 1));
КонецФункции

Функция ПреобразоватьСтрокуРеквизитовВWhitelist(ТекстРеквизитов)
	Whitelist = Новый Массив;
	Текст = СтрЗаменить(Строка(ТекстРеквизитов), Символы.ПС, " ");
	Для Каждого Часть Из СтрРазделить(Текст, ",") Цикл
		ИмяПоля = СокрЛП(Строка(Часть));
		Если НЕ ПустаяСтрока(ИмяПоля) И Whitelist.Найти(ИмяПоля) = Неопределено Тогда
			Whitelist.Добавить(ИмяПоля);
		КонецЕсли;
	КонецЦикла;
	Возврат Whitelist;
КонецФункции

Функция ПопробоватьЛокальноИсправитьFieldNotFoundDSL(СообщениеОшибки, DSLИсходный, ТекстРеквизитов)
	Если ПустаяСтрока(DSLИсходный) Тогда
		Возврат "";
	КонецЕсли;
	ИмяПоля = ИзвлечьИмяОтсутствующегоПоляИзОшибки(СообщениеОшибки);
	Если ПустаяСтрока(ИмяПоля) Тогда
		Возврат "";
	КонецЕсли;
	Whitelist = ПреобразоватьСтрокуРеквизитовВWhitelist(ТекстРеквизитов);
	Если Whitelist.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	ЗаменаПоля = ВыбратьЛучшееПолеПоWhitelist(ИмяПоля, Whitelist);
	Если ПустаяСтрока(ЗаменаПоля) И Whitelist.Найти("Ссылка") <> Неопределено Тогда
		ЗаменаПоля = "Ссылка";
	КонецЕсли;
	Если ПустаяСтрока(ЗаменаПоля) ИЛИ ВРег(ЗаменаПоля) = ВРег(ИмяПоля) Тогда
		Возврат "";
	КонецЕсли;
	ИсправленныйDSL = СтрЗаменить(DSLИсходный, ИмяПоля + " КАК " + ИмяПоля, ЗаменаПоля + " КАК " + ИмяПоля);
	Если ИсправленныйDSL = DSLИсходный Тогда
		ИсправленныйDSL = СтрЗаменить(DSLИсходный, ИмяПоля + " КАК ", ЗаменаПоля + " КАК ");
	КонецЕсли;
	Если ИсправленныйDSL = DSLИсходный Тогда
		ИсправленныйDSL = СтрЗаменить(DSLИсходный, "." + ИмяПоля, "." + ЗаменаПоля);
	КонецЕсли;
	Если ИсправленныйDSL = DSLИсходный Тогда
		ИсправленныйDSL = СтрЗаменить(DSLИсходный, Символы.ПС + ИмяПоля + " ", Символы.ПС + ЗаменаПоля + " ");
	КонецЕсли;
	Если ИсправленныйDSL = DSLИсходный Тогда
		ИсправленныйDSL = СтрЗаменить(DSLИсходный, " " + ИмяПоля + " ", " " + ЗаменаПоля + " ");
	КонецЕсли;
	Если ИсправленныйDSL = DSLИсходный Тогда
		ИсправленныйDSL = СтрЗаменить(DSLИсходный, "(" + ИмяПоля + ")", "(" + ЗаменаПоля + ")");
	КонецЕсли;
	Если ИсправленныйDSL = DSLИсходный Тогда
		ИсправленныйDSL = СтрЗаменить(DSLИсходный, Символы.ПС + ИмяПоля + "=", Символы.ПС + ЗаменаПоля + "=");
	КонецЕсли;
	Если ИсправленныйDSL = DSLИсходный Тогда
		Возврат "";
	КонецЕсли;
	Возврат ИсправленныйDSL;
КонецФункции

Функция ИзвлечьПсевдонимИсточникаИзТекстаЗапросаЛокально(ТекстЗапроса)
	Текст = СокрЛП(Строка(ТекстЗапроса));
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	ТекстВРег = ВРег(Текст);
	ПозКак = СтрНайти(ТекстВРег, " КАК ");
	Если ПозКак = 0 Тогда
		Возврат "";
	КонецЕсли;
	Остаток = Сред(Текст, ПозКак + 5);
	Разделители = Новый Массив;
	Разделители.Добавить(" ");
	Разделители.Добавить(Символы.ПС);
	Разделители.Добавить(Символы.Таб);
	ПозицияКонца = 0;
	Для Каждого Разделитель Из Разделители Цикл
		ПозРазделителя = СтрНайти(Остаток, Разделитель);
		Если ПозРазделителя > 0 И (ПозицияКонца = 0 ИЛИ ПозРазделителя < ПозицияКонца) Тогда
			ПозицияКонца = ПозРазделителя;
		КонецЕсли;
	КонецЦикла;
	Если ПозицияКонца = 0 Тогда
		Возврат СокрЛП(Остаток);
	КонецЕсли;
	Возврат СокрЛП(Лев(Остаток, ПозицияКонца - 1));
КонецФункции

Функция НормализоватьЯвныйRunQueryПоWhitelist(ТекстЗапроса, Whitelist)
	Текст = СокрЛП(Строка(ТекстЗапроса));
	Если ПустаяСтрока(Текст) Тогда
		Возврат Текст;
	КонецЕсли;
	Псевдоним = ИзвлечьПсевдонимИсточникаИзТекстаЗапросаЛокально(Текст);
	ТекстВРег = ВРег(Текст);
	Префикс = "ВЫБРАТЬ ";
	Если Лев(ТекстВРег, СтрДлина(Префикс)) <> Префикс Тогда
		Возврат Текст;
	КонецЕсли;
	ПозИз = СтрНайти(ТекстВРег, Символы.ПС + "ИЗ");
	Если ПозИз = 0 Тогда
		ПозИз = СтрНайти(ТекстВРег, " ИЗ ");
	КонецЕсли;
	Если ПозИз = 0 Тогда
		Возврат Текст;
	КонецЕсли;
	СекцияВыбрать = СокрЛП(Сред(Текст, СтрДлина(Префикс) + 1, ПозИз - СтрДлина(Префикс) - 1));
	Если ПустаяСтрока(СекцияВыбрать) Тогда
		Возврат Текст;
	КонецЕсли;
	ПсевдонимВРег = ВРег(Псевдоним);
	Если НЕ ПустаяСтрока(Псевдоним) И ВРег(СекцияВыбрать) = ПсевдонимВРег И ПолеЕстьВWhitelist(Whitelist, "Ссылка") Тогда
		Возврат СтрЗаменить(Текст, СекцияВыбрать, Псевдоним + ".Ссылка КАК Ссылка");
	КонецЕсли;
	Если СтрНайти(СекцияВыбрать, ",") = 0 И СтрНайти(ВРег(СекцияВыбрать), " КАК ") = 0 Тогда
		Выражение = СокрЛП(СекцияВыбрать);
		ИмяПоля = Выражение;
		Если СтрНайти(ИмяПоля, ".") > 0 Тогда
			ИмяПоля = Сред(ИмяПоля, СтрНайти(ИмяПоля, ".") + 1);
		КонецЕсли;
		Если НЕ ПолеЕстьВWhitelist(Whitelist, ИмяПоля) Тогда
			ЗаменаПоля = ?(ПолеЕстьВWhitelist(Whitelist, "Ссылка"), "Ссылка", ВыбратьЛучшееПолеПоWhitelist(ИмяПоля, Whitelist));
			Если НЕ ПустаяСтрока(ЗаменаПоля) Тогда
				Если НЕ ПустаяСтрока(Псевдоним) Тогда
					Возврат СтрЗаменить(Текст, СекцияВыбрать, Псевдоним + "." + ЗаменаПоля + " КАК " + ЗаменаПоля);
				Иначе
					Возврат СтрЗаменить(Текст, СекцияВыбрать, ЗаменаПоля);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Возврат Текст;
КонецФункции

Функция ИзвлечьИдентификаторыИзСтрокиФильтра(ТекстФильтра)
	Результат = Новый Массив;
	Текст = СтрЗаменить(Строка(ТекстФильтра), Символы.ПС, " ");
	Для Каждого Символ Из Новый Массив("(", ")", "=", "<", ">", ",") Цикл
		Текст = СтрЗаменить(Текст, Строка(Символ), " ");
	КонецЦикла;
	Для Каждого Часть Из СтрРазделить(Текст, " ") Цикл
		Идентификатор = СокрЛП(Строка(Часть));
		Если ПустаяСтрока(Идентификатор) Тогда
			Продолжить;
		КонецЕсли;
		Если Идентификатор = "И" ИЛИ Идентификатор = "ИЛИ" ИЛИ Идентификатор = "НЕ" Тогда
			Продолжить;
		КонецЕсли;
		Если Лев(Идентификатор, 1) = """" Тогда
			Продолжить;
		КонецЕсли;
		Попытка
			ЧисловоеЗначение = Число(Идентификатор);
			Продолжить;
		Исключение
		КонецПопытки;
		Если Результат.Найти(Идентификатор) = Неопределено Тогда
			Результат.Добавить(Идентификатор);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция НормализоватьСтроковыйФильтрПоWhitelist(ТекстФильтра, Whitelist)
	Фильтр = СокрЛП(Строка(ТекстФильтра));
	Если ПустаяСтрока(Фильтр) Тогда
		Возврат "";
	КонецЕсли;
	Если Whitelist = Неопределено ИЛИ Whitelist.Количество() = 0 Тогда
		Возврат Фильтр;
	КонецЕсли;
	Результат = Фильтр;
	Для Каждого Поле Из ИзвлечьИдентификаторыИзСтрокиФильтра(Фильтр) Цикл
		ИмяПоля = СокрЛП(Строка(Поле));
		Если ПустаяСтрока(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		Если ПолеЕстьВWhitelist(Whitelist, ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		ЗаменаПоля = ВыбратьЛучшееПолеПоWhitelist(ИмяПоля, Whitelist);
		Если ПустаяСтрока(ЗаменаПоля) И Whitelist.Количество() > 0 Тогда
			ЗаменаПоля = Строка(Whitelist[0]);
		КонецЕсли;
		Если ПустаяСтрока(ЗаменаПоля) ИЛИ ВРег(ЗаменаПоля) = ВРег(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		Результат = СтрЗаменить(Результат, ИмяПоля + " = ", ЗаменаПоля + " = ");
		Результат = СтрЗаменить(Результат, ИмяПоля + " < ", ЗаменаПоля + " < ");
		Результат = СтрЗаменить(Результат, ИмяПоля + " > ", ЗаменаПоля + " > ");
		Результат = СтрЗаменить(Результат, ИмяПоля + " <= ", ЗаменаПоля + " <= ");
		Результат = СтрЗаменить(Результат, ИмяПоля + " >= ", ЗаменаПоля + " >= ");
		Результат = СтрЗаменить(Результат, ИмяПоля + " <> ", ЗаменаПоля + " <> ");
		Результат = СтрЗаменить(Результат, "(" + ИмяПоля + " ", "(" + ЗаменаПоля + " ");
		Результат = СтрЗаменить(Результат, Символы.ПС + ИмяПоля + " ", Символы.ПС + ЗаменаПоля + " ");
	КонецЦикла;
	Возврат Результат;
КонецФункции

Процедура ПрименитьЭффектGetObjectFieldsШагаПлана(План, ЗавершенныйШаг)
	Если План = Неопределено ИЛИ ТипЗнч(План) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	Если ЗавершенныйШаг = Неопределено ИЛИ НЕ ЭтоJSONОбъект(ЗавершенныйШаг) Тогда
		Возврат;
	КонецЕсли;
	Если ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ЗавершенныйШаг, "kind", ""))) <> "GET_OBJECT_FIELDS" Тогда
		Возврат;
	КонецЕсли;
	Whitelist = ПолучитьWhitelistПолейИзРезультатаШага(ЗавершенныйШаг);
	Если Whitelist.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	InputЗавершенного = ПолучитьСвойствоJSONОбъекта(ЗавершенныйШаг, "input", Неопределено);
	ПолноеИмяОбъекта = "";
	Если ЭтоJSONОбъект(InputЗавершенного) Тогда
		ТипОбъекта = Строка(ПолучитьСвойствоJSONОбъекта(InputЗавершенного, "object_type", ""));
		ИмяОбъекта = Строка(ПолучитьСвойствоJSONОбъекта(InputЗавершенного, "object_name", ""));
		Если НЕ ПустаяСтрока(ТипОбъекта) И НЕ ПустаяСтрока(ИмяОбъекта) Тогда
			ПолноеИмяОбъекта = ТипОбъекта + "." + ИмяОбъекта;
		КонецЕсли;
	КонецЕсли;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		ШагКандидат = План.steps[Индекс];
		Если СтатусШагаЗавершен(ШагКандидат) Тогда
			Продолжить;
		КонецЕсли;
		KindШага = ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагКандидат, "kind", "")));
		Если KindШага <> "RUN_QUERY" Тогда
			Продолжить;
		КонецЕсли;
		InputШага = ПолучитьСвойствоJSONОбъекта(ШагКандидат, "input", Неопределено);
		Если НЕ ЭтоJSONОбъект(InputШага) Тогда
			Продолжить;
		КонецЕсли;
		ИмяОбъектаШага = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object", ""));
		Если ПустаяСтрока(ИмяОбъектаШага) Тогда
			ИмяОбъектаШага = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object_name", ""));
		КонецЕсли;
		ТекстЗапроса = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "query", ""));
		Если ПустаяСтрока(ИмяОбъектаШага) И НЕ ПустаяСтрока(ТекстЗапроса) Тогда
			ИмяОбъектаШага = ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаЛокально(ТекстЗапроса);
		КонецЕсли;
		Если НЕ ПустаяСтрока(ПолноеИмяОбъекта) И НЕ ПустаяСтрока(ИмяОбъектаШага) И ВРег(ИмяОбъектаШага) <> ВРег(ПолноеИмяОбъекта) Тогда
			Продолжить;
		КонецЕсли;
		ПоляШага = ПолучитьСвойствоJSONОбъекта(InputШага, "fields", Неопределено);
		Если ЭтоJSONArray(ПоляШага) Тогда
			НовыеПоля = Новый Массив;
			Для Каждого Поле Из ПоляШага Цикл
				ИмяПоля = СокрЛП(Строка(Поле));
				Если ПустаяСтрока(ИмяПоля) Тогда
					Продолжить;
				КонецЕсли;
				Если ПолеЕстьВWhitelist(Whitelist, ИмяПоля) Тогда
					НовыеПоля.Добавить(ИмяПоля);
				Иначе
					ЗаменаПоля = ВыбратьЛучшееПолеПоWhitelist(ИмяПоля, Whitelist);
					Если НЕ ПустаяСтрока(ЗаменаПоля) И НовыеПоля.Найти(ЗаменаПоля) = Неопределено Тогда
						НовыеПоля.Добавить(ЗаменаПоля);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			Если НовыеПоля.Количество() = 0 Тогда
				Если ПолеЕстьВWhitelist(Whitelist, "Ссылка") Тогда
					НовыеПоля.Добавить("Ссылка");
				Иначе
					НовыеПоля.Добавить(Whitelist[0]);
				КонецЕсли;
			КонецЕсли;
			InputШага.Вставить("fields", НовыеПоля);
			InputШага.Вставить("query", "");
		ИначеЕсли НЕ ПустаяСтрока(ТекстЗапроса) Тогда
			InputШага.Вставить("query", НормализоватьЯвныйRunQueryПоWhitelist(ТекстЗапроса, Whitelist));
		КонецЕсли;
		ФильтрШага = ПолучитьСвойствоJSONОбъекта(InputШага, "filter", Неопределено);
		Если ТипЗнч(ФильтрШага) = Тип("Строка") И НЕ ПустаяСтрока(Строка(ФильтрШага)) Тогда
			InputШага.Вставить("filter", НормализоватьСтроковыйФильтрПоWhitelist(Строка(ФильтрШага), Whitelist));
			InputШага.Вставить("query", "");
		КонецЕсли;
		Если НЕ ПустаяСтрока(ПолноеИмяОбъекта) Тогда
			InputШага.Вставить("object", ПолноеИмяОбъекта);
			InputШага.Вставить("object_name", ПолноеИмяОбъекта);
		КонецЕсли;
		ШагКандидат.input = InputШага;
		План.steps[Индекс] = ШагКандидат;
		Прервать;
	КонецЦикла;
КонецПроцедуры

Процедура ПрименитьУсловныйТерминальныйЭффектШагаПлана(План, ЗавершенныйШаг)
	Если План = Неопределено ИЛИ ТипЗнч(План) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	Если ЗавершенныйШаг = Неопределено ИЛИ НЕ ЭтоJSONОбъект(ЗавершенныйШаг) Тогда
		Возврат;
	КонецЕсли;
	Если ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ЗавершенныйШаг, "kind", ""))) <> "SHOW_INFO" Тогда
		Возврат;
	КонецЕсли;
	
	InputШага = ПолучитьСвойствоJSONОбъекта(ЗавершенныйШаг, "input", Неопределено);
	КлассУсловия = "";
	Если ЭтоJSONОбъект(InputШага) Тогда
		КлассУсловия = КлассифицироватьУсловиеВеткиПлана(ПолучитьСвойствоJSONОбъекта(InputШага, "condition", ""));
	КонецЕсли;
	
	ИндексЗавершенного = -1;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		Кандидат = План.steps[Индекс];
		Если Кандидат.Свойство("id") И Строка(Кандидат.id) = Строка(ЗавершенныйШаг.id) Тогда
			ИндексЗавершенного = Индекс;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если ИндексЗавершенного < 0 Тогда
		Возврат;
	КонецЕсли;

	ТерминальныйНепустойПоиск = Ложь;
	ЗависимостиТерминальнойВетки = Новый Соответствие;
	Если ПустаяСтрока(КлассУсловия) Тогда
		ЗависимостиЗавершенного = ПолучитьСвойствоJSONОбъекта(ЗавершенныйШаг, "depends_on", Неопределено);
		Если ЭтоJSONArray(ЗависимостиЗавершенного) Тогда
			Для Каждого ИдЗависимости Из ЗависимостиЗавершенного Цикл
				ЗависимостиТерминальнойВетки.Вставить(Строка(ИдЗависимости), Истина);
				ШагЗависимости = НайтиШагВПланеПоИдентификатору(План, Строка(ИдЗависимости));
				Если РезультатШагаСодержитНепустойRunQuery(ШагЗависимости) Тогда
					ТерминальныйНепустойПоиск = Истина;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если НЕ ТерминальныйНепустойПоиск Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ПропущенныеШаги = Новый Соответствие;
	ИзмененияЕсть = Ложь;
	Для Индекс = ИндексЗавершенного + 1 По План.steps.Количество() - 1 Цикл
		ШагКандидат = План.steps[Индекс];
		Если СтатусШагаЗавершен(ШагКандидат) Тогда
			Продолжить;
		КонецЕсли;
		
		InputКандидата = ПолучитьСвойствоJSONОбъекта(ШагКандидат, "input", Неопределено);
		КлассКандидата = "";
		Если ЭтоJSONОбъект(InputКандидата) Тогда
			КлассКандидата = КлассифицироватьУсловиеВеткиПлана(ПолучитьСвойствоJSONОбъекта(InputКандидата, "condition", ""));
		КонецЕсли;
		
		НужноПропустить = Ложь;
		Если КлассУсловия = "not_empty" И КлассКандидата = "empty" Тогда
			НужноПропустить = Истина;
		ИначеЕсли КлассУсловия = "empty" И КлассКандидата = "not_empty" Тогда
			НужноПропустить = Истина;
		ИначеЕсли ТерминальныйНепустойПоиск
			И ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагКандидат, "kind", ""))) <> "SHOW_INFO"
			И ШагПланаЗависитОтЛюбогоИдентификатора(ШагКандидат, ЗависимостиТерминальнойВетки) Тогда
			НужноПропустить = Истина;
		ИначеЕсли ШагПланаЗависитОтЛюбогоИдентификатора(ШагКандидат, ПропущенныеШаги) Тогда
			НужноПропустить = Истина;
		КонецЕсли;
		
		Если НужноПропустить Тогда
			ШагКандидат.status = "skipped";
			ШагКандидат.result_summary = "Пропущено: альтернативная ветка уже завершена";
			ШагКандидат.result_data = Неопределено;
			План.steps[Индекс] = ШагКандидат;
			ПропущенныеШаги.Вставить(Строка(ШагКандидат.id), Истина);
			ИзмененияЕсть = Истина;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьШагПланаПоИдентификатору(СсылкаДиалога, StepId) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	Для Каждого ШагПлана Из План.steps Цикл
		Если ШагПлана.Свойство("id") И Строка(ШагПлана.id) = Строка(StepId) Тогда
			Возврат ШагПлана;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция ПолучитьСледующийШагПлана(СсылкаДиалога) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	Для Каждого ШагПлана Из План.steps Цикл
		Если СтатусШагаЗавершен(ШагПлана) Тогда
			Продолжить;
		КонецЕсли;
		Если ВсеЗависимостиШагаВыполнены(ШагПлана, План) Тогда
			Если ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "kind", ""))) = "RUN_QUERY" Тогда
				InputШага = ПолучитьСвойствоJSONОбъекта(ШагПлана, "input", Неопределено);
				Если ЭтоJSONОбъект(InputШага) Тогда
					ЯвныйЗапрос = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "query", ""));
					ИмяОбъектаШага = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object", ""));
					Если ПустаяСтрока(ИмяОбъектаШага) Тогда
						ИмяОбъектаШага = Строка(ПолучитьСвойствоJSONОбъекта(InputШага, "object_name", ""));
					КонецЕсли;
					Если ПустаяСтрока(ЯвныйЗапрос) И НЕ ПустаяСтрока(ИмяОбъектаШага) Тогда
						Если ДобавитьGetObjectFieldsВПланПередRunQuery(СсылкаДиалога, ИмяОбъектаШага) Тогда
							Возврат ПолучитьСледующийШагПлана(СсылкаДиалога);
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			Возврат ШагПлана;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Процедура ОбновитьШагПлана(СсылкаДиалога, StepId, Status, ResultSummary = "", ResultData = Неопределено) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	НормализованныйResultData = НормализоватьРезультатШагаПланаДляХранения(ResultData);
	ОбновленныйШаг = Неопределено;
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		ШагПлана = План.steps[Индекс];
		Если ШагПлана.Свойство("id") И Строка(ШагПлана.id) = Строка(StepId) Тогда
			ШагПлана.status = Status;
			ШагПлана.result_summary = ResultSummary;
			ШагПлана.result_data = НормализованныйResultData;
			План.steps[Индекс] = ШагПлана;
			ОбновленныйШаг = ШагПлана;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если ВРег(Строка(Status)) = "DONE" Тогда
		ПрименитьЭффектGetMetadataШагаПлана(План, ОбновленныйШаг);
		ПрименитьЭффектGetObjectFieldsШагаПлана(План, ОбновленныйШаг);
		ПрименитьУсловныйТерминальныйЭффектШагаПлана(План, ОбновленныйШаг);
	КонецЕсли;
	СохранитьTypedPlan(СсылкаДиалога, План);
	
	ДеталиЧекпоинта = Новый Структура;
	ДеталиЧекпоинта.Вставить("step_id", StepId);
	ДеталиЧекпоинта.Вставить("status", Status);
	Если НЕ ПустаяСтрока(ResultSummary) Тогда
		ДеталиЧекпоинта.Вставить("result_summary", Лев(ResultSummary, 500));
	КонецЕсли;
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "plan_step_updated", "Execute", ДеталиЧекпоинта);
КонецПроцедуры

Функция ИнициализироватьПлан(СсылкаДиалога) Экспорт
	
	// Получаем последнюю задачу пользователя (для последующих команд в диалоге)
	РезультатЗадачи = ИИА_Сервер.ПолучитьПоследнееСообщениеПользователя(СсылкаДиалога);
	Если НЕ РезультатЗадачи.Найдено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстЗадачи = РезультатЗадачи.Текст;
	
	// Формируем промпт для создания плана
	ПромптПлана = ИИА_Промты.ПолучитьПромптСозданияПлана(ТекстЗадачи, СсылкаДиалога);
	Если ЭтоЗапросПодсчета(ТекстЗадачи) Тогда
		ПромптПлана = ПромптПлана + Символы.ПС +
		"Дополнительно: если задача содержит 'сколько/количество', план должен включать RunQuery с КОЛИЧЕСТВО(...) и ShowInfo.";
	КонецЕсли;
	
	// Вызываем ИИ (через системное сообщение)
	РезультатDiscovery = ВыполнитьDiscoverySubgraph(СсылкаДиалога, ТекстЗадачи, СсылкаДиалога.ТипДиалога);
	ПараметрыRAG = ?(РезультатDiscovery <> Неопределено И РезультатDiscovery.Свойство("Details"), РезультатDiscovery.Details, Новый Структура("ИспользоватьRAG,Причина", Ложь, ""));
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[RAG_DECISION] План: " + ?(ПараметрыRAG.ИспользоватьRAG, "включен", "выключен") + ". " + ПараметрыRAG.Причина);
	ОтветИИ = ИИА_Сервер.ВызватьИИССистемнымСообщением(СсылкаДиалога, "Чат", ПромптПлана, ИИА_Промты.ПолучитьТекстПромптаПланировщика(), "plan", , ПараметрыRAG.ИспользоватьRAG);
	
	Если ПустаяСтрока(ОтветИИ.Текст) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Парсим typed plan JSON
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ОтветИИ.Текст);
		СыройПлан = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		План = НормализоватьTypedPlan(СыройПлан, ТекстЗадачи);
		Если План.steps.Количество() = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СохранитьTypedPlan(СсылкаДиалога, План);
		
		// Отправляем уведомление клиенту о завершении планирования
		ИИА_Сервер.УведомитьОбОбновленииДиалога(СсылкаДиалога, "ПланИнициализирован");
		
		Возврат Истина;
		
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

// Дополняет план новыми задачами для последующей команды пользователя (режим продолжения диалога)
//
// Параметры:
//  СсылкаДиалога - СправочникСсылка.ИИА_Диалоги - ссылка на диалог
//
// Возвращаемое значение:
//  Булево - Истина при успехе, Ложь при ошибке (вызывающий код может очистить план и использовать ИнициализироватьПлан)
//
Функция ДополнитьПлан(СсылкаДиалога) Экспорт
	
	// Получаем последнюю задачу пользователя
	РезультатЗадачи = ИИА_Сервер.ПолучитьПоследнееСообщениеПользователя(СсылкаДиалога);
	Если НЕ РезультатЗадачи.Найдено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстЗадачи = РезультатЗадачи.Текст;
	
	План = ПолучитьTypedPlan(СсылкаДиалога);
	Если План.steps.Количество() = 0 Тогда
		// План пуст - дополнять нечего, используем обычную инициализацию
		Возврат Ложь;
	КонецЕсли;
	
	ПланJSON = СжатьJSONДляЛога(СериализоватьJSONЛокально(План));
	
	// Формируем промпт для дополнения плана
	ПромптДополнения = ИИА_Промты.ПолучитьПромптДополненияПлана(ТекстЗадачи, ПланJSON, СсылкаДиалога);
	
	// Вызываем ИИ
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[План] Дополнение плана новой задачей...");
	РезультатDiscovery = ВыполнитьDiscoverySubgraph(СсылкаДиалога, ТекстЗадачи, СсылкаДиалога.ТипДиалога);
	ПараметрыRAG = ?(РезультатDiscovery <> Неопределено И РезультатDiscovery.Свойство("Details"), РезультатDiscovery.Details, Новый Структура("ИспользоватьRAG,Причина", Ложь, ""));
	ОтветИИ = ИИА_Сервер.ВызватьИИССистемнымСообщением(СсылкаДиалога, "Чат", ПромптДополнения, ИИА_Промты.ПолучитьТекстПромптаПланировщика(), "plan", , ПараметрыRAG.ИспользоватьRAG);
	
	Если ПустаяСтрока(ОтветИИ.Текст) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ОтветИИ.Текст);
		СыройНовыйПлан = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		НовыйПлан = НормализоватьTypedPlan(СыройНовыйПлан, ТекстЗадачи);
		Если НовыйПлан.steps.Количество() = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Для Каждого НовыйШаг Из НовыйПлан.steps Цикл
			Если НовыйШаг.Свойство("depends_on") И НовыйШаг.depends_on.Количество() = 0 И План.steps.Количество() > 0 Тогда
				ПоследнийШаг = План.steps[План.steps.Количество() - 1];
				НовыйШаг.depends_on.Добавить(Строка(ПоследнийШаг.id));
			КонецЕсли;
			НовыйШаг.seq_no = План.steps.Количество() + 1;
			План.steps.Добавить(НовыйШаг);
		КонецЦикла;
		СохранитьTypedPlan(СсылкаДиалога, План);
		
		ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[План] План дополнен " + Строка(НовыйПлан.steps.Количество()) + " новыми шагами.");
		ИИА_Сервер.УведомитьОбОбновленииДиалога(СсылкаДиалога, "ПланИнициализирован");
		
		Возврат Истина;
		
	Исключение
		ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[План] Ошибка дополнения плана: " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

Функция ПолучитьПланДиалога(СсылкаДиалога) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	Если План = Неопределено ИЛИ ТипЗнч(План) <> Тип("Структура") ИЛИ НЕ План.Свойство("steps") Тогда
		Возврат Новый Массив;
	КонецЕсли;
	Возврат План.steps;
КонецФункции

Функция ОбновитьПланПоРезультатам(СсылкаДиалога) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	СинхронизироватьТабличнуюЧастьПлана(СсылкаДиалога, План);
	ИИА_Сервер.УведомитьОбОбновленииДиалога(СсылкаДиалога, "ПланОбновлен");
	Возврат Истина;
КонецФункции

Функция ПолучитьСледующийПунктПлана(СсылкаДиалога) Экспорт
	ШагПлана = ПолучитьСледующийШагПлана(СсылкаДиалога);
	Если ШагПлана = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Возврат ?(ШагПлана.Свойство("title"), Строка(ШагПлана.title), "");
КонецФункции

Функция ПланЗавершен(СсылкаДиалога) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	Если План.steps.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Каждого ШагПлана Из План.steps Цикл
		Если НЕ СтатусШагаЗавершен(ШагПлана) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Помечает все невыполненные шаги плана как выполненные с результатом "Пропущено (лимит итераций)"
Процедура ПропуститьНевыполненныеШагиПлана(СсылкаДиалога) Экспорт
	План = ПолучитьTypedPlan(СсылкаДиалога);
	Для Индекс = 0 По План.steps.Количество() - 1 Цикл
		ШагПлана = План.steps[Индекс];
		Если НЕ СтатусШагаЗавершен(ШагПлана) Тогда
			ШагПлана.status = "skipped";
			ШагПлана.result_summary = "Пропущено (лимит итераций)";
			План.steps[Индекс] = ШагПлана;
		КонецЕсли;
	КонецЦикла;
	СохранитьTypedPlan(СсылкаДиалога, План);
КонецПроцедуры

// Пропускает шаги плана (ShowInfo об открытии формы), бессмысленные без GUI.
// SelectObject выполняется в режиме агента 1С (загрузка объекта в контекст) - НЕ пропускаем.
Функция ПропуститьПроблемныеШагиПлана(СсылкаДиалога) Экспорт
	ШагПлана = ПолучитьСледующийШагПлана(СсылкаДиалога);
	Если ШагПлана = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "kind", ""))) = "SHOW_INFO" И СтрНайти(ВРег(Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "title", ""))), "ОТКРЫТ") > 0 Тогда
		ОбновитьШагПлана(СсылкаДиалога, ШагПлана.id, "skipped", "Пропущено (режим без GUI)");
		ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[Система] Шаг """ + Строка(ПолучитьСвойствоJSONОбъекта(ШагПлана, "title", "")) + """ пропущен (нет интерфейса).");
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

Функция ПолучитьНевыполненныеЗадачиПользователя(СсылкаДиалога) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Найдено", Ложь);
	Результат.Вставить("ТекстЗадач", "");
	Результат.Вставить("КоличествоЗадач", 0);
	
	Диалог = СсылкаДиалога.ПолучитьОбъект();
	
	Если Диалог.Сообщения.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	МассивЗадач = Новый Массив;
	
	Для Каждого СтрокаСообщения Из Диалог.Сообщения Цикл
		Если СтрокаСообщения.Автор = Перечисления.ИИА_АвторСообщения.Пользователь Тогда
			ТекстЗадачи = СокрЛП(СтрокаСообщения.Текст);
			Если НЕ ПустаяСтрока(ТекстЗадачи) Тогда
				МассивЗадач.Добавить(ТекстЗадачи);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если МассивЗадач.Количество() > 0 Тогда
		Результат.Найдено = Истина;
		Результат.КоличествоЗадач = МассивЗадач.Количество();
		
		ТекстЗадач = "";
		Для Индекс = 0 По МассивЗадач.Количество() - 1 Цикл
			Если Индекс > 0 Тогда
				ТекстЗадач = ТекстЗадач + Символы.ПС;
			КонецЕсли;
			ТекстЗадач = ТекстЗадач + МассивЗадач[Индекс];
		КонецЦикла;
		
		Результат.ТекстЗадач = ТекстЗадач;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПротоколироватьМетрикуСтадии(СсылкаДиалога, StageName, Начало, Успех, Ошибка = "", StateTransition = "", RecoveryPolicyId = "", AttemptNo = 0, SafetyGateResult = "")
	ДлительностьМС = 0;
	Попытка
		ДлительностьМС = Цел(((ТекущаяДата() - Начало) * 1000));
	Исключение
		ДлительностьМС = 0;
	КонецПопытки;
	
	АрхКонтекст = ИИА_Сервер.ПолучитьКонтекстАрхитектуры(СсылкаДиалога);
	Trace = ?(АрхКонтекст <> Неопределено И АрхКонтекст.Свойство("trace_id"), АрхКонтекст.trace_id, "");
	Сообщение = "[OBSERVE] stage=" + StageName + ", success=" + ?(Успех, "true", "false") + ", duration_ms=" + Строка(ДлительностьМС);
	Если НЕ ПустаяСтрока(Строка(Trace)) Тогда
		Сообщение = Сообщение + ", trace_id=" + Строка(Trace);
	КонецЕсли;
	Если НЕ ПустаяСтрока(Ошибка) Тогда
		Сообщение = Сообщение + ", error=" + Ошибка;
	КонецЕсли;
	Если НЕ ПустаяСтрока(StateTransition) Тогда
		Сообщение = Сообщение + ", state_transition=" + StateTransition;
	КонецЕсли;
	Если НЕ ПустаяСтрока(RecoveryPolicyId) Тогда
		Сообщение = Сообщение + ", recovery_policy_id=" + RecoveryPolicyId;
	КонецЕсли;
	Если AttemptNo > 0 Тогда
		Сообщение = Сообщение + ", attempt_no=" + Строка(AttemptNo);
	КонецЕсли;
	Если НЕ ПустаяСтрока(SafetyGateResult) Тогда
		Сообщение = Сообщение + ", safety_gate_result=" + SafetyGateResult;
	КонецЕсли;
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, Сообщение);
КонецПроцедуры

Функция ВыполнитьСтадиюIntent(СсылкаДиалога)
	Результат = ПолучитьНевыполненныеЗадачиПользователя(СсылкаДиалога);
	Возврат Результат;
КонецФункции

Функция ВыполнитьСтадиюPlan(СсылкаДиалога) Экспорт
	Возврат ВыполнитьPlanningSubgraph(СсылкаДиалога);
КонецФункции

Функция ВыполнитьPlanningSubgraph(СсылкаДиалога) Экспорт
	НачалоPlan = ТекущаяДата();
	Результат = СоздатьРезультатПодграфа("PlanningSubgraph", Ложь, "Plan->Recover", Неопределено, Ложь, "recover", Неопределено, "Recover", "plan_failed");
	Если ЗначениеЗаполнено(СсылкаДиалога) Тогда
		ИИА_Сервер.УстановитьThreadId(СсылкаДиалога, Строка(СсылкаДиалога.УникальныйИдентификатор()));
	КонецЕсли;
	ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "PlanningSubgraph", "enter");
	
	ПланДанные = ПолучитьПланДиалога(СсылкаДиалога);
	Если ПланДанные.Количество() = 0 Тогда
		Если НЕ ИнициализироватьПлан(СсылкаДиалога) Тогда
			ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Plan", НачалоPlan, Ложь, "init_plan_failed", "Plan->Recover");
			Результат.Reason = "init_plan_failed";
			Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
		КонецЕсли;
		ПланДанные = ПолучитьПланДиалога(СсылкаДиалога);
	КонецЕсли;
	
	Если ПланЗавершен(СсылкаДиалога) Тогда
		ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "PlanningSubgraph", "plan_completed");
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Plan", НачалоPlan, Истина, "plan_completed", "Plan->Summarize");
		Результат.Успех = Истина;
		Результат.Transition = "Plan->Summarize";
		Результат.Decision = "continue";
		Результат.NextStage = "Summarize";
		Результат.Reason = "plan_completed";
		Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
	КонецЕсли;
	
	План = ПолучитьTypedPlan(СсылкаДиалога);
	ТекущийШаг = ПолучитьСледующийШагПлана(СсылкаДиалога);
	Если ТекущийШаг = Неопределено Тогда
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Plan", НачалоPlan, Ложь, "no_pending_step", "Plan->Recover");
		Результат.Reason = "no_pending_step";
		Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
	КонецЕсли;
	ПланJSON = СжатьJSONДляЛога(СериализоватьJSONЛокально(План));
	ТекущийШагJSON = СжатьJSONДляЛога(СериализоватьJSONЛокально(ТекущийШаг));
	ТекстРезультатов = СобратьФактыПоследнихДействий(СсылкаДиалога);
	ДоступныеПоля = ИзвлечьРеквизитыИзФактов(ТекстРезультатов);
	НеудачныеОбъекты = СобратьНеудачныеОбъектыИзФактов(ТекстРезультатов);
	ПромптСледующегоШага = ИИА_Промты.ПолучитьПромптPlannerСледующегоШага(ПланJSON, ТекущийШагJSON, ТекстРезультатов, ДоступныеПоля, НеудачныеОбъекты);
	ExecutionPolicy = ?(ПустаяСтрока(ДоступныеПоля), "safe-path", "fast-path");
	ИИА_Сервер.УстановитьExecutionPolicy(СсылкаДиалога, ExecutionPolicy);
	ИИА_Сервер.УстановитьActiveStepId(СсылкаДиалога, Строка(ТекущийШаг.id));
	ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "PlanningSubgraph", "next_step_generation", Новый Структура("active_step_id,execution_policy", Строка(ТекущийШаг.id), ExecutionPolicy));
	ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "execution_policy", ExecutionPolicy, "PlanningSubgraph", Новый Структура("source,step_id,reason", "planning", Строка(ТекущийШаг.id), "next_step_generation"));
	ЛокальныйШагDSL = ИИА_Провайдеры.ПопыткаЛокальноСгенерироватьNextStepDSL(СсылкаДиалога, Строка(ТекущийШаг.id));
	Если ЛокальныйШагDSL <> Неопределено
		И ЛокальныйШагDSL.Свойство("DSL")
		И НЕ ПустаяСтрока(ЛокальныйШагDSL.DSL) Тогда
		StepIdАртефакта = ?(НЕ ПустаяСтрока(ЛокальныйШагDSL.PlanStepId), ЛокальныйШагDSL.PlanStepId, Строка(ТекущийШаг.id));
		ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалога, ЛокальныйШагDSL.DSL, "planner_local_typed_step", StepIdАртефакта);
		ИИА_Сервер.УстановитьActiveStepId(СсылкаДиалога, StepIdАртефакта);
		ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "PlanningSubgraph", "planned_next_step", Новый Структура("active_step_id", StepIdАртефакта));
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "next_step_selected", StepIdАртефакта, "PlanningSubgraph", Новый Структура("source,step_id,reason", "planning", StepIdАртефакта, "planner_local_typed_step"));
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Plan", НачалоPlan, Истина, "", "Plan->Execute");
		Результат.Успех = Истина;
		Результат.Transition = "Plan->Execute";
		Результат.Decision = "continue";
		Результат.NextStage = "Execute";
		Результат.Reason = "plan_ready";
		Результат.Policy = ExecutionPolicy;
		Результат.StepId = StepIdАртефакта;
		Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
	КонецЕсли;
	ОтветПланировщика = ИИА_Сервер.ВызватьИИССистемнымСообщением(СсылкаДиалога, "Чат", ПромптСледующегоШага, "", "next_step_dsl", , Истина, Ложь);
	
	Если ПустаяСтрока(ОтветПланировщика.DSL) Тогда
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Plan", НачалоPlan, Ложь, "planner_empty_dsl", "Plan->Recover");
		Результат.Reason = "planner_empty_dsl";
		Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
	КонецЕсли;
	
	StepIdАртефакта = ?(НЕ ПустаяСтрока(ОтветПланировщика.PlanStepId), ОтветПланировщика.PlanStepId, Строка(ТекущийШаг.id));
	ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалога, ОтветПланировщика.DSL, "planner_generated", StepIdАртефакта);
	ИИА_Сервер.УстановитьActiveStepId(СсылкаДиалога, StepIdАртефакта);
	ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "PlanningSubgraph", "planned_next_step", Новый Структура("active_step_id", StepIdАртефакта));
	ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "next_step_selected", StepIdАртефакта, "PlanningSubgraph", Новый Структура("source,step_id,reason", "planning", StepIdАртефакта, "planner_generated"));
	ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Plan", НачалоPlan, Истина, "", "Plan->Execute");
	Результат.Успех = Истина;
	Результат.Transition = "Plan->Execute";
	Результат.Decision = "continue";
	Результат.NextStage = "Execute";
	Результат.Reason = "plan_ready";
	Результат.Policy = ExecutionPolicy;
	Результат.StepId = StepIdАртефакта;
	Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
КонецФункции

Функция ВыполнитьСтадиюExecute(СсылкаДиалога) Экспорт
	НачалоExecute = ТекущаяДата();
	АртефактПлана = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
	DSLДляИсполнения = "";
	Если АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlannedDSL") Тогда
		DSLДляИсполнения = АртефактПлана.PlannedDSL;
	КонецЕсли;
	
	Если ПустаяСтрока(DSLДляИсполнения) Тогда
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Execute", НачалоExecute, Ложь, "empty_planned_dsl", "Execute->Recover");
		Возврат Ложь;
	КонецЕсли;

	СообщениеPrecheck = "";
	КодОшибкиPrecheck = "";
	DSLПодготовленный = ПодготовитьDSLПередИсполнением(СсылкаДиалога, DSLДляИсполнения, СообщениеPrecheck, КодОшибкиPrecheck);
	Если ПустаяСтрока(DSLПодготовленный) Тогда
		КодОшибкиВозврата = ?(ПустаяСтрока(КодОшибкиPrecheck), "dsl_contract_error", КодОшибкиPrecheck);
		РезультатPrecheck = Новый Структура("Успех,Сообщение,error_code,error_context", Ложь, "Ошибка pre-execution DSL check: " + СообщениеPrecheck, КодОшибкиВозврата, Новый Структура("stage,reason", "Execute", "pre_execution_schema_check"));
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, РезультатPrecheck);
		ПричинаPrecheck = ?(КодОшибкиВозврата = "dsl_contract_error", "dsl_contract_error", "pre_execution_schema_check");
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Execute", НачалоExecute, Ложь, ПричинаPrecheck, "Execute->Recover");
		Возврат Ложь;
	КонецЕсли;
	Если СокрЛП(DSLПодготовленный) <> СокрЛП(DSLДляИсполнения) Тогда
		ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалога, DSLПодготовленный, "executor_precheck_normalized", Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss"));
	КонецЕсли;
	DSLДляИсполнения = DSLПодготовленный;
	
	DSLСOperationIds = ОбеспечитьOperationIdДляWriteШагов(СсылкаДиалога, DSLДляИсполнения, АртефактПлана);
	Если НЕ ПустаяСтрока(DSLСOperationIds) И СокрЛП(DSLСOperationIds) <> СокрЛП(DSLДляИсполнения) Тогда
		ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалога, DSLСOperationIds, "executor_operation_ids_attached", ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlanStepId"), АртефактПлана.PlanStepId, ""));
		DSLДляИсполнения = DSLСOperationIds;
	КонецЕсли;
	
	Если ЭтоПовторДействия(СсылкаДиалога, DSLДляИсполнения, 2) Тогда
		ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, "[LOOP_GUARD] Повтор шага DSL обнаружен, выполнение пропущено.");
		РезультатLoopGuard = Новый Структура("Успех,Сообщение,error_code,error_context", Ложь, "Повтор шага DSL обнаружен (loop_guard). Требуется смена стратегии восстановления.", "query_safety_violation", Новый Структура("stage,reason", "Execute", "loop_guard"));
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, РезультатLoopGuard);
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Execute", НачалоExecute, Ложь, "loop_guard", "Execute->Recover");
		Возврат Ложь;
	КонецЕсли;
	
	Если ЭтоРанняяСдачаShowInfo(СсылкаДиалога, DSLДляИсполнения) Тогда
		РезультатБлокировки = Новый Структура("Успех,Сообщение,error_code,error_context", Ложь, "Блокировка anti-giveup: ранний ShowInfo с отказом до исчерпания recovery-попыток.", "premature_giveup_blocked", Новый Структура("stage,reason", "Execute", "anti_giveup_guard"));
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, РезультатБлокировки);
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Execute", НачалоExecute, Ложь, "premature_giveup_blocked", "Execute->Recover");
		Возврат Ложь;
	КонецЕсли;
	
	ПроверкаCapabilityDSL = ПроверитьCapabilityDSLПередИсполнением(СсылкаДиалога, DSLДляИсполнения);
	Если ПроверкаCapabilityDSL <> Неопределено И ПроверкаCapabilityDSL.Свойство("Успех") И НЕ ПроверкаCapabilityDSL.Успех Тогда
		РезультатCapability = Новый Структура("Успех,Сообщение,error_code,error_context", Ложь, ПроверкаCapabilityDSL.Сообщение, "capability_violation", Новый Структура("stage,reason,action,required_capability", "Execute", "pre_execute_capability_guard", ?(ПроверкаCapabilityDSL.Свойство("Действие"), ПроверкаCapabilityDSL.Действие, ""), ?(ПроверкаCapabilityDSL.Свойство("Требуемое"), ПроверкаCapabilityDSL.Требуемое, "")));
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, РезультатCapability);
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Execute", НачалоExecute, Ложь, "capability_violation", "Execute->Recover");
		Возврат Ложь;
	КонецЕсли;
	
	РезультатПодграфа = ВыполнитьExecuteSubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана);
	Если РезультатПодграфа = Неопределено Тогда
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Execute", НачалоExecute, Ложь, "execute_subgraph_failed", "Execute->Recover");
		Возврат Ложь;
	КонецЕсли;
	Если РезультатПодграфа.Свойство("ApprovalPending") И РезультатПодграфа.ApprovalPending Тогда
		ПротоколироватьМетрикуСтадии(СсылкаДиалога, "Execute", НачалоExecute, Истина, "", ?(РезультатПодграфа.Свойство("Transition"), РезультатПодграфа.Transition, "Execute->AwaitApproval"));
		Возврат Истина;
	КонецЕсли;
	РезультатАвтоDSL = ?(РезультатПодграфа.Свойство("ExecutorResult"), РезультатПодграфа.ExecutorResult, Неопределено);
	Если РезультатАвтоDSL <> Неопределено Тогда
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, РезультатАвтоDSL);
	КонецЕсли;
	ПротоколироватьМетрикуСтадии(
		СсылкаДиалога,
		"Execute",
		НачалоExecute,
		?(РезультатПодграфа.Свойство("Успех"), РезультатПодграфа.Успех, ?(РезультатАвтоDSL <> Неопределено И РезультатАвтоDSL.Успех, Истина, Ложь)),
		?(РезультатАвтоDSL <> Неопределено И РезультатАвтоDSL.Свойство("Сообщение"), РезультатАвтоDSL.Сообщение, ""),
		?(РезультатПодграфа.Свойство("Transition"), РезультатПодграфа.Transition, "Execute->Validate")
	);
	
	Возврат ?(РезультатПодграфа.Свойство("Успех"), РезультатПодграфа.Успех, Истина);
КонецФункции

Функция ПроверитьCapabilityDSLПередИсполнением(СсылкаДиалога, DSLСценарий)
	Результат = Новый Структура("Успех,Сообщение,Требуемое,Действие", Истина, "", "", "");
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Или ПустаяСтрока(DSLСценарий) Тогда
		Возврат Результат;
	КонецЕсли;
	
	КонтекстАрхитектуры = ИИА_Сервер.ПолучитьКонтекстАрхитектуры(СсылкаДиалога);
	Если КонтекстАрхитектуры = Неопределено
		Или НЕ КонтекстАрхитектуры.Свойство("DSL_Capabilities")
		Или ТипЗнч(КонтекстАрхитектуры.DSL_Capabilities) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		ТекстJSON = ИИА_DSL.НормализоватьJSONТекст(DSLСценарий);
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТекстJSON);
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
	Исключение
		Возврат Результат;
	КонецПопытки;
	
	Шаги = Новый Массив;
	Если ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("steps") И ТипЗнч(Сценарий.steps) = Тип("Массив") Тогда
		Шаги = Сценарий.steps;
	ИначеЕсли ТипЗнч(Сценарий) = Тип("Структура") И Сценарий.Свойство("action") Тогда
		Шаги.Добавить(Сценарий);
	Иначе
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Шаг Из Шаги Цикл
		ПроверкаCapability = ИИА_DSL.ПроверитьCapabilityШага(Шаг, КонтекстАрхитектуры);
		Если НЕ ПроверкаCapability.Успех Тогда
			Результат.Успех = Ложь;
			Результат.Сообщение = ПроверкаCapability.Сообщение;
			Результат.Требуемое = ?(ПроверкаCapability.Свойство("Требуемое"), ПроверкаCapability.Требуемое, "");
			Если ТипЗнч(Шаг) = Тип("Структура") И Шаг.Свойство("action") Тогда
				Результат.Действие = Строка(Шаг.action);
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ВыполнитьExecuteSubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана = Неопределено) Экспорт
	ДескрипторПодграфа = ОпределитьИсполнительныйПодграф(DSLДляИсполнения);
	ИмяПодграфа = ?(ДескрипторПодграфа <> Неопределено И ДескрипторПодграфа.Свойство("SubgraphName"), ДескрипторПодграфа.SubgraphName, "GenericExecuteSubgraph");
	ИИА_Сервер.УстановитьActiveStepId(СсылкаДиалога, ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlanStepId"), АртефактПлана.PlanStepId, ""));
	ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, ИмяПодграфа, "selected");
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "execute_subgraph_selected", "Execute", Новый Структура("subgraph", ИмяПодграфа), ИмяПодграфа);
	
	Если ИмяПодграфа = "WriteActionSubgraph" Тогда
		Возврат ВыполнитьWriteActionSubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана, ДескрипторПодграфа);
	ИначеЕсли ИмяПодграфа = "ReadQuerySubgraph" Тогда
		Возврат ВыполнитьReadQuerySubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана, ДескрипторПодграфа);
	КонецЕсли;
	
	Возврат ВыполнитьGenericExecuteSubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана, ДескрипторПодграфа);
КонецФункции

Функция ВыполнитьWriteActionSubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана = Неопределено, ДескрипторПодграфа = Неопределено) Экспорт
	StepId = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlanStepId"), Строка(АртефактПлана.PlanStepId), "");
	Результат = СоздатьРезультатПодграфа("WriteActionSubgraph", Ложь, "Execute->Recover", Неопределено, Ложь, "", Неопределено, "Recover", "execute_failed", "", StepId);
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "execute_subgraph_entered", "Execute", Новый Структура("subgraph", "WriteActionSubgraph"), "WriteActionSubgraph");
	
	Если ОбработатьApprovalПередExecuteSubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана, "WriteActionSubgraph") Тогда
		Результат.Успех = Истина;
		Результат.Transition = "Execute->AwaitApproval";
		Результат.ApprovalPending = Истина;
		Результат.Decision = "await_approval";
		Результат.NextStage = "AwaitApproval";
		Результат.Reason = "approval_required";
		Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
	КонецЕсли;
	
	Результат.ExecutorResult = ИИА_Сервер.ВыполнитьDSLСценарийССообщениями(СсылкаДиалога, DSLДляИсполнения);
	Результат.Успех = ?(Результат.ExecutorResult <> Неопределено И Результат.ExecutorResult.Успех, Истина, Ложь);
	Результат.Transition = ?(Результат.Успех, "Execute->Validate", "Execute->Recover");
	Результат.Decision = ?(Результат.Успех, "continue", "recover");
	Результат.NextStage = ?(Результат.Успех, "Validate", "Recover");
	Результат.Reason = ?(Результат.Успех, "execute_completed", "execute_failed");
	Возврат ПодготовитьРезультатПодграфаКВозврату(Результат);
КонецФункции

