Функция ВыполнитьGenericExecuteSubgraph(СсылкаДиалога, DSLДляИсполнения, АртефактПлана = Неопределено, ДескрипторПодграфа = Неопределено) Экспорт
	StepId = ?(АртефактПлана <> Неопределено И АртефактПлана.Свойство("PlanStepId"), Строка(АртефактПлана.PlanStepId), "");
	Результат = СоздатьРезультатПодграфа("GenericExecuteSubgraph", Ложь, "Execute->Recover", Неопределено, Ложь, "", Неопределено, "Recover", "execute_failed", "", StepId);
	ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "execute_subgraph_entered", "Execute", Новый Структура("subgraph", "GenericExecuteSubgraph"), "GenericExecuteSubgraph");
