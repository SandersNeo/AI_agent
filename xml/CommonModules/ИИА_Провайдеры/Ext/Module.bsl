#Область ПрограммныйИнтерфейс

// Вызывает ИИ для получения ответа
//
// Параметры:
//  ТипСообщения - Строка - тип сообщения ("Чат" или "Запрос")
//  ТекстПользователя - Строка - текст от пользователя
//  История - ТаблицаЗначений - история сообщений
//  ПараметрыИИ - Структура - настройки пользователя
//  СистемныйПромпт - Строка - (опционально) переопределение системного промпта
//  Температура - Число - (опционально) температура модели
//
// Возвращаемое значение:
//  Структура - структура ответа
//
Функция ВызватьИИ(ТипСообщения, ТекстПользователя, История, ПараметрыИИ, СистемныйПромпт = "", Температура = Неопределено) Экспорт
	
	// Режим холостого хода: при наличии MockОтвет возвращаем его без вызова API
	Если ПараметрыИИ.Свойство("MockОтвет") И ПараметрыИИ.MockОтвет <> Неопределено Тогда
		Возврат НормализоватьMockОтвет(ПараметрыИИ.MockОтвет);
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ТипОтвета", "Текст");
	Результат.Вставить("Текст", "");
	Результат.Вставить("Запрос", "");
	Результат.Вставить("DSL", "");
	Результат.Вставить("ВыполнитьDSL", Ложь);
	Результат.Вставить("Usage", Неопределено);
	Результат.Вставить("Ошибки", Неопределено);
	
	// Проверяем настройки подключения.
	// Для локальных OpenAI-совместимых HTTP-серверов API key может отсутствовать.
	URLПровайдера = "";
	Если ПараметрыИИ.Свойство("Provider_BaseUrl") Тогда
		URLПровайдера = СокрЛП(Строка(ПараметрыИИ.Provider_BaseUrl));
	КонецЕсли;
	ЛокальныйHTTPПровайдер = Лев(НРег(URLПровайдера), 7) = "http://";
	Если ПустаяСтрока(URLПровайдера) ИЛИ (ПустаяСтрока(ПараметрыИИ.Provider_ApiKey) И НЕ ЛокальныйHTTPПровайдер) Тогда
		
		// Hard DSL mode: это системная ошибка, а не «текстовый ответ»
		Результат.ТипОтвета = "Ошибка";
		Результат.Текст = "Не настроен URL провайдера или API ключ. Для локального OpenAI-совместимого HTTP-сервера API key можно не заполнять.";
		Возврат Результат;
		
	КонецЕсли;
	
	// Теперь у нас только OpenAI-совместимый провайдер (Gitsell или прямой OpenAI)
	Результат = ВызватьGitsellAiProxy(ТипСообщения, ТекстПользователя, История, ПараметрыИИ, СистемныйПромпт, Температура);
	
	Возврат Результат;
	
КонецФункции

// Публичный контракт провайдера LLM.
Функция ПолучитьКонтрактПровайдера() Экспорт
	Возврат Новый Структура("messages,tools,tool_choice,response_format,temperature,timeout", "required", "optional", "optional", "optional", "optional", "optional");
КонецФункции

Функция СоздатьБазовыйРезультатИИ()
	Результат = Новый Структура;
	Результат.Вставить("ТипОтвета", "Текст");
	Результат.Вставить("Текст", "");
	Результат.Вставить("Запрос", "");
	Результат.Вставить("DSL", "");
	Результат.Вставить("ВыполнитьDSL", Ложь);
	Результат.Вставить("Usage", Неопределено);
	Результат.Вставить("Ошибки", Неопределено);
	Результат.Вставить("ToolCalls", Неопределено);
	Результат.Вставить("ToolName", "");
	Результат.Вставить("ToolArguments", "");
	Результат.Вставить("PlanStepId", "");
	Результат.Вставить("FinishReason", "");
	Результат.Вставить("RawModelText", "");
	Возврат Результат;
КонецФункции

Функция ПолучитьОжидаемыйФорматОтвета(ПараметрыИИ)
	ОжидаемыйФормат = "dsl";
	Если ПараметрыИИ <> Неопределено И ТипЗнч(ПараметрыИИ) = Тип("Структура") И ПараметрыИИ.Свойство("ExpectedResponseFormat") Тогда
		ОжидаемыйФормат = Строка(ПараметрыИИ.ExpectedResponseFormat);
	КонецЕсли;
	Возврат ОжидаемыйФормат;
КонецФункции

Функция СериализоватьJSONВСтроку(ЗначениеJSON) Экспорт
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ЗначениеJSON);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

Функция СоздатьСвойствоJSON(ТипСвойства, Описание = "")
	СвойствоJSON = Новый Структура;
	СвойствоJSON.Вставить("type", ТипСвойства);
	Если НЕ ПустаяСтрока(Описание) Тогда
		СвойствоJSON.Вставить("description", Описание);
	КонецЕсли;
	Возврат СвойствоJSON;
КонецФункции

Функция СоздатьИнструментФункции(Имя, Описание, Параметры)
	ФункцияJSON = Новый Структура;
	ФункцияJSON.Вставить("name", Имя);
	ФункцияJSON.Вставить("description", Описание);
	ФункцияJSON.Вставить("parameters", Параметры);
	
	Инструмент = Новый Структура;
	Инструмент.Вставить("type", "function");
	Инструмент.Вставить("function", ФункцияJSON);
	Возврат Инструмент;
КонецФункции

Функция СоздатьToolChoiceДляФункции(ИмяФункции)
	ФункцияJSON = Новый Структура("name", ИмяФункции);
	Результат = Новый Структура;
	Результат.Вставить("type", "function");
	Результат.Вставить("function", ФункцияJSON);
	Возврат Результат;
КонецФункции

Функция НужнаСовместимостьToolChoiceСПровайдером(ПараметрыИИ)
	Если ПараметрыИИ = Неопределено ИЛИ ТипЗнч(ПараметрыИИ) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	Если НЕ ПараметрыИИ.Свойство("Provider_BaseUrl") Тогда
		Возврат Ложь;
	КонецЕсли;
	URLВРег = ВРег(Строка(ПараметрыИИ.Provider_BaseUrl));
	Возврат СтрНайти(URLВРег, "openai") = 0 И СтрНайти(URLВРег, "gitsell") = 0;
КонецФункции

Функция НормализоватьToolChoiceДляПровайдера(ToolChoice, ПараметрыИИ)
	Если ToolChoice = Неопределено Тогда
		Возврат ToolChoice;
	КонецЕсли;
	Если НЕ НужнаСовместимостьToolChoiceСПровайдером(ПараметрыИИ) Тогда
		Возврат ToolChoice;
	КонецЕсли;
	Если ТипЗнч(ToolChoice) = Тип("Структура") Тогда
		Возврат "required";
	КонецЕсли;
	Возврат ToolChoice;
КонецФункции

Функция ПолучитьТаймаутChatCompletions(ПараметрыИИ)
	Таймаут = 30;
	Если НужнаСовместимостьToolChoiceСПровайдером(ПараметрыИИ) Тогда
		Таймаут = 120;
	КонецЕсли;
	Если ПараметрыИИ <> Неопределено И ТипЗнч(ПараметрыИИ) = Тип("Структура") Тогда
		Если ПараметрыИИ.Свойство("timeout") И ПараметрыИИ.timeout <> Неопределено Тогда
			Попытка
				Таймаут = Макс(10, Мин(600, Число(ПараметрыИИ.timeout)));
			Исключение
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	Возврат Таймаут;
КонецФункции

Функция ПолучитьMaxTokensChatCompletions(ПараметрыИИ)
	Если НужнаСовместимостьToolChoiceСПровайдером(ПараметрыИИ) Тогда
		Возврат 512;
	КонецЕсли;
	Возврат 4000;
КонецФункции

Функция ЭтоИнструментВложения(ИмяИнструмента)
	Возврат ИмяИнструмента = "get_attachment_text" ИЛИ ИмяИнструмента = "search_attachments";
КонецФункции

Функция ПровайдерПоддерживаетНативныеВложения(ПараметрыИИ)
	Если ПараметрыИИ = Неопределено ИЛИ ТипЗнч(ПараметрыИИ) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ПараметрыИИ.Свойство("UseNativeAttachments") Тогда
		Возврат ПараметрыИИ.UseNativeAttachments;
	КонецЕсли;
	Если НЕ ПараметрыИИ.Свойство("Provider_BaseUrl") Тогда
		Возврат Ложь;
	КонецЕсли;
	URLВРег = ВРег(Строка(ПараметрыИИ.Provider_BaseUrl));
	Возврат СтрНайти(URLВРег, "openai") > 0 ИЛИ СтрНайти(URLВРег, "gitsell") > 0;
КонецФункции

Функция ПодготовитьСообщенияСНативнымиВложениями(Сообщения, ПараметрыИИ) Экспорт
	Если Сообщения = Неопределено ИЛИ ТипЗнч(Сообщения) <> Тип("Массив") Тогда
		Возврат Сообщения;
	КонецЕсли;
	Если ПараметрыИИ = Неопределено ИЛИ ТипЗнч(ПараметрыИИ) <> Тип("Структура") Тогда
		Возврат Сообщения;
	КонецЕсли;
	Если НЕ ПараметрыИИ.Свойство("СсылкаДиалога") ИЛИ ПараметрыИИ.СсылкаДиалога = Неопределено Тогда
		Возврат Сообщения;
	КонецЕсли;
	НативныеВложения = ИИА_Вложения.ПолучитьНативныеВложенияДляМодели(ПараметрыИИ.СсылкаДиалога);
	Если НативныеВложения = Неопределено ИЛИ НативныеВложения.Количество() = 0 Тогда
		Возврат Сообщения;
	КонецЕсли;
	
	ПоследнийИндексПользователя = -1;
	Для Индекс = 0 По Сообщения.Количество() - 1 Цикл
		Сообщение = Сообщения[Индекс];
		Если Сообщение.Свойство("role") И Строка(Сообщение.role) = "user" Тогда
			ПоследнийИндексПользователя = Индекс;
		КонецЕсли;
	КонецЦикла;
	Если ПоследнийИндексПользователя < 0 Тогда
		Возврат Сообщения;
	КонецЕсли;
	
	ИсходноеСообщениеПользователя = Сообщения[ПоследнийИндексПользователя];
	КонтентМассив = Новый Массив;
	ТекстоваяЧасть = Новый Структура;
	ТекстоваяЧасть.Вставить("type", "text");
	ТекстоваяЧасть.Вставить("text", ?(ИсходноеСообщениеПользователя.Свойство("content"), Строка(ИсходноеСообщениеПользователя.content), ""));
	КонтентМассив.Добавить(ТекстоваяЧасть);
	
	КоличествоНативных = 0;
	Для Каждого Вложение Из НативныеВложения Цикл
		DataUrl = "";
		ИмяФайла = "file";
		Транспорт = "";
		Если НЕ Вложение.Свойство("data_url", DataUrl) Тогда
			Продолжить;
		КонецЕсли;
		Если Вложение.Свойство("file_name", ИмяФайла) = Ложь Тогда
			ИмяФайла = "file";
		КонецЕсли;
		Если Вложение.Свойство("native_transport", Транспорт) = Ложь Тогда
			Транспорт = "";
		КонецЕсли;
		Если Транспорт = "image_url" Тогда
			ЧастьИзображения = Новый Структура;
			ЧастьИзображения.Вставить("type", "image_url");
			ЧастьИзображения.Вставить("image_url", Новый Структура("url", DataUrl));
			КонтентМассив.Добавить(ЧастьИзображения);
			КоличествоНативных = КоличествоНативных + 1;
		ИначеЕсли Транспорт = "file" Тогда
			ЧастьФайла = Новый Структура;
			ЧастьФайла.Вставить("type", "file");
			ЧастьФайла.Вставить("file", Новый Структура("filename,file_data", ИмяФайла, DataUrl));
			КонтентМассив.Добавить(ЧастьФайла);
			КоличествоНативных = КоличествоНативных + 1;
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоНативных = 0 Тогда
		Возврат Сообщения;
	КонецЕсли;
	СообщениеПользователя = Новый Структура;
	Для Каждого КлючЗначение Из ИсходноеСообщениеПользователя Цикл
		Если КлючЗначение.Ключ <> "content" Тогда
			СообщениеПользователя.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
		КонецЕсли;
	КонецЦикла;
	СообщениеПользователя.Вставить("content", КонтентМассив);
	Результат = Новый Массив;
	Для Индекс = 0 По Сообщения.Количество() - 1 Цикл
		Если Индекс = ПоследнийИндексПользователя Тогда
			Результат.Добавить(СообщениеПользователя);
		Иначе
			Результат.Добавить(Сообщения[Индекс]);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ПостроитьИнструментыВложений(ПараметрыИИ, ОжидаемыйФормат)
	Инструменты = Новый Массив;
	Если ОжидаемыйФормат <> "text" Тогда
		Возврат Инструменты;
	КонецЕсли;
	Если ПараметрыИИ = Неопределено ИЛИ ТипЗнч(ПараметрыИИ) <> Тип("Структура") Тогда
		Возврат Инструменты;
	КонецЕсли;
	Если НЕ ПараметрыИИ.Свойство("СсылкаДиалога") ИЛИ ПараметрыИИ.СсылкаДиалога = Неопределено Тогда
		Возврат Инструменты;
	КонецЕсли;
	Вложения = ИИА_Вложения.ПолучитьВложенияДиалога(ПараметрыИИ.СсылкаДиалога);
	Если Вложения = Неопределено ИЛИ Вложения.Количество() = 0 Тогда
		Возврат Инструменты;
	КонецЕсли;
	
	СвойстваТекста = Новый Структура;
	СвойстваТекста.Вставить("attachment_id", СоздатьСвойствоJSON("string", "Идентификатор вложения из контекста диалога."));
	СвойстваТекста.Вставить("attachment_name", СоздатьСвойствоJSON("string", "Имя файла вложения или его часть."));
	СвойстваТекста.Вставить("start_char", СоздатьСвойствоJSON("integer", "Символьное смещение начала фрагмента. По умолчанию 0."));
	СвойстваТекста.Вставить("max_chars", СоздатьСвойствоJSON("integer", "Максимум символов в возвращаемом фрагменте. По умолчанию 12000."));
	ПараметрыТекста = Новый Структура;
	ПараметрыТекста.Вставить("type", "object");
	ПараметрыТекста.Вставить("properties", СвойстваТекста);
	ПараметрыТекста.Вставить("additionalProperties", Ложь);
	Инструменты.Добавить(СоздатьИнструментФункции(
		"get_attachment_text",
		"Читает распознанный текст вложения из контекста диалога. Используй, когда нужен полный текст или фрагмент файла без раздувания основного prompt.",
		ПараметрыТекста
	));
	
	СвойстваПоиска = Новый Структура;
	СвойстваПоиска.Вставить("query", СоздатьСвойствоJSON("string", "Текст или фраза для поиска по распознанным вложениям."));
	СвойстваПоиска.Вставить("attachment_id", СоздатьСвойствоJSON("string", "Идентификатор вложения, если поиск нужен только по одному файлу."));
	СвойстваПоиска.Вставить("attachment_name", СоздатьСвойствоJSON("string", "Имя файла вложения или его часть."));
	СвойстваПоиска.Вставить("limit", СоздатьСвойствоJSON("integer", "Максимум совпадений. По умолчанию 20."));
	ПараметрыПоиска = Новый Структура;
	ПараметрыПоиска.Вставить("type", "object");
	ПараметрыПоиска.Вставить("properties", СвойстваПоиска);
	ОбязательныеПоляПоиска = Новый Массив;
	ОбязательныеПоляПоиска.Добавить("query");
	ПараметрыПоиска.Вставить("required", ОбязательныеПоляПоиска);
	ПараметрыПоиска.Вставить("additionalProperties", Ложь);
	Инструменты.Добавить(СоздатьИнструментФункции(
		"search_attachments",
		"Ищет строки по распознанным вложениям диалога и возвращает совпадения с именем файла и номером строки.",
		ПараметрыПоиска
	));
	
	Возврат Инструменты;
КонецФункции

Функция ПолучитьИнструментыВложенийДляДиалога(СсылкаДиалога) Экспорт
	ПараметрыИИ = Новый Структура;
	ПараметрыИИ.Вставить("СсылкаДиалога", СсылкаДиалога);
	Возврат ПостроитьИнструментыВложений(ПараметрыИИ, "text");
КонецФункции

Функция ПрочитатьАргументыToolCall(АргументыJSON)
	Если ПустаяСтрока(АргументыJSON) Тогда
		Возврат Новый Структура;
	КонецЕсли;
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(АргументыJSON);
		Данные = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		Если ТипЗнч(Данные) = Тип("Структура") Тогда
			Возврат Данные;
		КонецЕсли;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	Возврат Новый Структура;
КонецФункции

Функция ОграничитьТекстДляИнструмента(Текст, Максимум = 12000)
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	Если СтрДлина(Текст) > Максимум Тогда
		Возврат Лев(Текст, Максимум);
	КонецЕсли;
	Возврат Текст;
КонецФункции

Процедура ДобавитьЛогИнструментаВложения(СсылкаДиалога, Этап, ИмяИнструмента, ТекстДанных)
	Если СсылкаДиалога = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекстЛога = "[" + Этап + "] " + ИмяИнструмента;
	Если НЕ ПустаяСтрока(ТекстДанных) Тогда
		ТекстЛога = ТекстЛога + ": " + ОграничитьТекстДляИнструмента(ТекстДанных, 1000);
	КонецЕсли;
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(СсылкаДиалога, ТекстЛога, "ATTACHMENT_TOOL");
КонецПроцедуры

Функция ВыполнитьИнструментВложения(ИмяИнструмента, АргументыJSON, СсылкаДиалога) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("ok", Ложь);
	Результат.Вставить("tool", ИмяИнструмента);
	ДобавитьЛогИнструментаВложения(СсылкаДиалога, "ATTACHMENT_TOOL_EXECUTE", ИмяИнструмента, АргументыJSON);
	
	Если СсылкаДиалога = Неопределено Тогда
		Результат.Вставить("error", "СсылкаДиалога не передана");
		Возврат СериализоватьJSONВСтроку(Результат);
	КонецЕсли;
	
	Аргументы = ПрочитатьАргументыToolCall(АргументыJSON);
	ИдентификаторИлиИмя = "";
	Если Аргументы.Свойство("attachment_id") И НЕ ПустаяСтрока(Строка(Аргументы.attachment_id)) Тогда
		ИдентификаторИлиИмя = Строка(Аргументы.attachment_id);
	ИначеЕсли Аргументы.Свойство("attachment_name") И НЕ ПустаяСтрока(Строка(Аргументы.attachment_name)) Тогда
		ИдентификаторИлиИмя = Строка(Аргументы.attachment_name);
	КонецЕсли;
	
	Если ИмяИнструмента = "get_attachment_text" Тогда
		Вложение = ИИА_Вложения.НайтиВложениеДиалога(СсылкаДиалога, ИдентификаторИлиИмя);
		Если Вложение = Неопределено Тогда
			Результат.Вставить("error", "Вложение не найдено");
			ТекстРезультата = СериализоватьJSONВСтроку(Результат);
			ДобавитьЛогИнструментаВложения(СсылкаДиалога, "ATTACHMENT_TOOL_RESULT", ИмяИнструмента, ТекстРезультата);
			Возврат ТекстРезультата;
		КонецЕсли;
		ПолныйТекст = ИИА_Вложения.ПолучитьПолныйТекстВложения(СсылкаДиалога, ИдентификаторИлиИмя);
		Начало = 0;
		Максимум = 12000;
		Если Аргументы.Свойство("start_char") Тогда
			Начало = Макс(0, Число(Аргументы.start_char));
		КонецЕсли;
		Если Аргументы.Свойство("max_chars") Тогда
			Максимум = Макс(500, Мин(20000, Число(Аргументы.max_chars)));
		КонецЕсли;
		Если Начало >= СтрДлина(ПолныйТекст) Тогда
			Начало = 0;
		КонецЕсли;
		Фрагмент = Сред(ПолныйТекст, Начало + 1);
		Фрагмент = ОграничитьТекстДляИнструмента(Фрагмент, Максимум);
		Результат.ok = Истина;
		Результат.Вставить("attachment_id", ?(Вложение.Свойство("id"), Строка(Вложение.id), ""));
		Результат.Вставить("attachment_name", ?(Вложение.Свойство("file_name"), Строка(Вложение.file_name), ""));
		Результат.Вставить("total_chars", СтрДлина(ПолныйТекст));
		Результат.Вставить("start_char", Начало);
		Результат.Вставить("returned_chars", СтрДлина(Фрагмент));
		Результат.Вставить("is_truncated", Начало + СтрДлина(Фрагмент) < СтрДлина(ПолныйТекст));
		Результат.Вставить("content", Фрагмент);
		ТекстРезультата = СериализоватьJSONВСтроку(Результат);
		ДобавитьЛогИнструментаВложения(СсылкаДиалога, "ATTACHMENT_TOOL_RESULT", ИмяИнструмента, ТекстРезультата);
		Возврат ТекстРезультата;
	КонецЕсли;
	
	Если ИмяИнструмента = "search_attachments" Тогда
		ЗапросПоиска = ?(Аргументы.Свойство("query"), Строка(Аргументы.query), "");
		Лимит = ?(Аргументы.Свойство("limit"), Число(Аргументы.limit), 20);
		Лимит = Макс(1, Мин(100, Лимит));
		Совпадения = ИИА_Вложения.НайтиВоВложениях(СсылкаДиалога, ЗапросПоиска, Лимит, ИдентификаторИлиИмя);
		Результат.ok = Истина;
		Результат.Вставить("query", ЗапросПоиска);
		Результат.Вставить("match_count", Совпадения.Количество());
		Результат.Вставить("matches", Совпадения);
		ТекстРезультата = СериализоватьJSONВСтроку(Результат);
		ДобавитьЛогИнструментаВложения(СсылкаДиалога, "ATTACHMENT_TOOL_RESULT", ИмяИнструмента, ТекстРезультата);
		Возврат ТекстРезультата;
	КонецЕсли;
	
	Результат.Вставить("error", "Неподдерживаемый инструмент: " + ИмяИнструмента);
	ТекстРезультата = СериализоватьJSONВСтроку(Результат);
	ДобавитьЛогИнструментаВложения(СсылкаДиалога, "ATTACHMENT_TOOL_RESULT", ИмяИнструмента, ТекстРезультата);
	Возврат ТекстРезультата;
КонецФункции

Функция ПостроитьВстроенныеИнструменты(ОжидаемыйФормат)
	Результат = Новый Структура("Tools,ToolChoice", Неопределено, Неопределено);
	Свойства = Новый Структура;
	Обязательные = Новый Массив;
	ИмяФункции = "";
	Описание = "";
	
	Если ОжидаемыйФормат = "dsl" Тогда
		ИмяФункции = "submit_dsl";
		Описание = "Верни валидный DSL-сценарий как аргументы функции без дополнительного текста.";
		Свойства.Вставить("dsl_version", СоздатьСвойствоJSON("integer", "Версия DSL-контракта."));
		Шаг = СоздатьСвойствоJSON("object", "Один шаг DSL-сценария.");
		Шаг.Вставить("additionalProperties", Истина);
		Шаги = СоздатьСвойствоJSON("array", "Массив шагов DSL-сценария.");
		Шаги.Вставить("items", Шаг);
		Свойства.Вставить("steps", Шаги);
		Обязательные.Добавить("dsl_version");
		Обязательные.Добавить("steps");
	ИначеЕсли ОжидаемыйФормат = "plan" Тогда
		ИмяФункции = "submit_plan";
		Описание = "Верни типизированный план как объект с steps без дополнительного текста.";
		Свойства.Вставить("plan_version", СоздатьСвойствоJSON("integer", "Версия контракта typed plan."));
		Свойства.Вставить("goal", СоздатьСвойствоJSON("string", "Краткая цель плана."));
		ШагСвойства = Новый Структура;
		ШагСвойства.Вставить("id", СоздатьСвойствоJSON("string", "Стабильный идентификатор шага, например step_1."));
		ШагСвойства.Вставить("kind", СоздатьСвойствоJSON("string", "Тип шага плана."));
		ШагСвойства.Вставить("title", СоздатьСвойствоJSON("string", "Короткое человекочитаемое описание шага."));
		Зависимости = СоздатьСвойствоJSON("array", "Список id шагов, от которых зависит текущий шаг.");
		Зависимости.Вставить("items", СоздатьСвойствоJSON("string"));
		ШагСвойства.Вставить("depends_on", Зависимости);
		InputСвойство = СоздатьСвойствоJSON("object", "Структурированные входные параметры шага.");
		InputСвойство.Вставить("additionalProperties", Истина);
		ШагСвойства.Вставить("input", InputСвойство);
		ШагПараметры = Новый Структура;
		ШагПараметры.Вставить("type", "object");
		ШагПараметры.Вставить("properties", ШагСвойства);
		ШагОбязательные = Новый Массив;
		ШагОбязательные.Добавить("id");
		ШагОбязательные.Добавить("kind");
		ШагОбязательные.Добавить("title");
		ШагОбязательные.Добавить("depends_on");
		ШагОбязательные.Добавить("input");
		ШагПараметры.Вставить("required", ШагОбязательные);
		ШагПараметры.Вставить("additionalProperties", Ложь);
		ПланСвойство = СоздатьСвойствоJSON("array", "Типизированные шаги плана.");
		ПланСвойство.Вставить("items", ШагПараметры);
		Свойства.Вставить("steps", ПланСвойство);
		Обязательные.Добавить("plan_version");
		Обязательные.Добавить("goal");
		Обязательные.Добавить("steps");
	ИначеЕсли ОжидаемыйФормат = "next_step_dsl" Тогда
		ИмяФункции = "submit_next_step";
		Описание = "Верни исполнимый DSL для текущего шага typed plan без дополнительного текста.";
		Свойства.Вставить("step_id", СоздатьСвойствоJSON("string", "Идентификатор шага плана, для которого построен DSL."));
		Свойства.Вставить("dsl_version", СоздатьСвойствоJSON("integer", "Версия DSL-контракта."));
		Шаг = СоздатьСвойствоJSON("object", "Один шаг DSL-сценария.");
		Шаг.Вставить("additionalProperties", Истина);
		Шаги = СоздатьСвойствоJSON("array", "Массив шагов DSL-сценария.");
		Шаги.Вставить("items", Шаг);
		Свойства.Вставить("steps", Шаги);
		Обязательные.Добавить("step_id");
		Обязательные.Добавить("dsl_version");
		Обязательные.Добавить("steps");
	Иначе
		Возврат Результат;
	КонецЕсли;
	
	Параметры = Новый Структура;
	Параметры.Вставить("type", "object");
	Параметры.Вставить("properties", Свойства);
	Параметры.Вставить("required", Обязательные);
	Параметры.Вставить("additionalProperties", Ложь);
	
	Инструменты = Новый Массив;
	Инструменты.Добавить(СоздатьИнструментФункции(ИмяФункции, Описание, Параметры));
	Результат.Tools = Инструменты;
	Результат.ToolChoice = СоздатьToolChoiceДляФункции(ИмяФункции);
	Возврат Результат;
КонецФункции

Функция ФорматОтветаТребуетВстроенныйToolCall(ОжидаемыйФормат)
	Возврат ОжидаемыйФормат = "dsl"
		ИЛИ ОжидаемыйФормат = "plan"
		ИЛИ ОжидаемыйФормат = "next_step_dsl";
КонецФункции

Функция ФорматОтветаТребуетJSONMode(ПараметрыИИ, ОжидаемыйФормат)
	Если ФорматОтветаТребуетВстроенныйToolCall(ОжидаемыйФормат) Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ПараметрыИИ <> Неопределено И ТипЗнч(ПараметрыИИ) = Тип("Структура") Тогда
		Если ПараметрыИИ.Свойство("ResponseFormat") И ПараметрыИИ.ResponseFormat <> Неопределено Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	Возврат ОжидаемыйФормат = "json_object";
КонецФункции

Функция ПостроитьСтратегиюОтвета(ПараметрыИИ, ОжидаемыйФормат) Экспорт
	Стратегия = Новый Структура;
	Стратегия.Вставить("UseBuiltInToolCall", ФорматОтветаТребуетВстроенныйToolCall(ОжидаемыйФормат));
	Стратегия.Вставить("UseJsonMode", ФорматОтветаТребуетJSONMode(ПараметрыИИ, ОжидаемыйФормат));
	Стратегия.Вставить("AllowAttachmentTools", ОжидаемыйФормат = "text");
	Возврат Стратегия;
КонецФункции

Функция ДобавитьИнструментыВТелоЗапроса(ТелоЗапроса, ПараметрыИИ, ОжидаемыйФормат, Стратегия = Неопределено)
	ИнструментыДляЗапроса = Новый Массив;
	ToolChoice = Неопределено;
	
	Если Стратегия = Неопределено Тогда
		Стратегия = ПостроитьСтратегиюОтвета(ПараметрыИИ, ОжидаемыйФормат);
	КонецЕсли;
	
	Если Стратегия.UseBuiltInToolCall Тогда
		ВстроенныеИнструменты = ПостроитьВстроенныеИнструменты(ОжидаемыйФормат);
		Если ВстроенныеИнструменты.Tools <> Неопределено Тогда
			Для Каждого Инструмент Из ВстроенныеИнструменты.Tools Цикл
				ИнструментыДляЗапроса.Добавить(Инструмент);
			КонецЦикла;
			ToolChoice = ВстроенныеИнструменты.ToolChoice;
		КонецЕсли;
	КонецЕсли;
	
	Если Стратегия.AllowAttachmentTools Тогда
		ИнструментыВложений = ПостроитьИнструментыВложений(ПараметрыИИ, ОжидаемыйФормат);
		Для Каждого ИнструментВложения Из ИнструментыВложений Цикл
			ИнструментыДляЗапроса.Добавить(ИнструментВложения);
		КонецЦикла;
	КонецЕсли;
	
	Если ПараметрыИИ <> Неопределено И ТипЗнч(ПараметрыИИ) = Тип("Структура") Тогда
		Если ПараметрыИИ.Свойство("Tools") И ПараметрыИИ.Tools <> Неопределено Тогда
			Если ТипЗнч(ПараметрыИИ.Tools) = Тип("Массив") Тогда
				Для Каждого ИнструментПользователя Из ПараметрыИИ.Tools Цикл
					ИнструментыДляЗапроса.Добавить(ИнструментПользователя);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
		Если ПараметрыИИ.Свойство("ToolChoice") И ПараметрыИИ.ToolChoice <> Неопределено Тогда
			ToolChoice = ПараметрыИИ.ToolChoice;
		КонецЕсли;
	КонецЕсли;
	
	Если ИнструментыДляЗапроса.Количество() > 0 Тогда
		ТелоЗапроса.Вставить("tools", ИнструментыДляЗапроса);
		Если ToolChoice <> Неопределено Тогда
			ТелоЗапроса.Вставить("tool_choice", НормализоватьToolChoiceДляПровайдера(ToolChoice, ПараметрыИИ));
		КонецЕсли;
	КонецЕсли;
КонецФункции

Функция ДобавитьРежимJSONВТелоЗапроса(ТелоЗапроса, ПараметрыИИ, ОжидаемыйФормат, Стратегия = Неопределено)
	Если ПараметрыИИ = Неопределено ИЛИ ТипЗнч(ПараметрыИИ) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Стратегия = Неопределено Тогда
		Стратегия = ПостроитьСтратегиюОтвета(ПараметрыИИ, ОжидаемыйФормат);
	КонецЕсли;
	
	Если НЕ Стратегия.UseJsonMode Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ПараметрыИИ.Свойство("ResponseFormat") И ПараметрыИИ.ResponseFormat <> Неопределено Тогда
		ТелоЗапроса.Вставить("response_format", ПараметрыИИ.ResponseFormat);
		Возврат Неопределено;
	КонецЕсли;
	
	Если ОжидаемыйФормат = "json_object" Тогда
		ТелоЗапроса.Вставить("response_format", Новый Структура("type", "json_object"));
	КонецЕсли;
КонецФункции

Функция ИзвлечьПервыйToolCall(Сообщение)
	Результат = Новый Структура("Успех,ToolCall,ToolName,ArgumentsText,Ошибка", Ложь, Неопределено, "", "", "");
	Если Сообщение = Неопределено ИЛИ НЕ Сообщение.Свойство("tool_calls") Тогда
		Возврат Результат;
	КонецЕсли;
	Если ТипЗнч(Сообщение.tool_calls) <> Тип("Массив") ИЛИ Сообщение.tool_calls.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ToolCall = Сообщение.tool_calls[0];
	Результат.ToolCall = ToolCall;
	Если ТипЗнч(ToolCall) <> Тип("Структура") Тогда
		Результат.Ошибка = "tool_calls[0] имеет неподдерживаемый формат";
		Возврат Результат;
	КонецЕсли;
	Если НЕ ToolCall.Свойство("function") ИЛИ ТипЗнч(ToolCall.function) <> Тип("Структура") Тогда
		Результат.Ошибка = "tool_calls[0].function отсутствует";
		Возврат Результат;
	КонецЕсли;
	
	Если ToolCall.function.Свойство("name") Тогда
		Результат.ToolName = Строка(ToolCall.function.name);
	КонецЕсли;
	Если ToolCall.function.Свойство("arguments") Тогда
		Результат.ArgumentsText = Строка(ToolCall.function.arguments);
	КонецЕсли;
	Результат.Успех = Истина;
	Возврат Результат;
КонецФункции

Функция ИзвлечьJSONПолеИзАргументовToolCall(АргументыJSON, ИмяПоля)
	Если ПустаяСтрока(АргументыJSON) Тогда
		Возврат "";
	КонецЕсли;
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(АргументыJSON);
		Данные = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		ЗначениеПоля = Неопределено;
		Если ТипЗнч(Данные) = Тип("Структура") И Данные.Свойство(ИмяПоля, ЗначениеПоля) Тогда
			Возврат СериализоватьJSONВСтроку(ЗначениеПоля);
		КонецЕсли;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат "";
КонецФункции

Функция АргументыToolCallПохожиНаDSL(АргументыJSON)
	Если ПустаяСтрока(АргументыJSON) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(АргументыJSON);
		Данные = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Если ТипЗнч(Данные) <> Тип("Структура") Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Если Данные.Свойство("dsl") Тогда
			Возврат Ложь;
		КонецЕсли;
		
		Возврат Данные.Свойство("steps") ИЛИ Данные.Свойство("action") ИЛИ Данные.Свойство("dsl_version");
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат Ложь;
КонецФункции

Функция ПолучитьПараметрШагаПлана(ШагПлана, ИмяПараметра, ЗначениеПоУмолчанию = "")
	Если ШагПлана = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Вход = Неопределено;
	Если ТипЗнч(ШагПлана) = Тип("Структура") И ШагПлана.Свойство("input", Вход) И ТипЗнч(Вход) = Тип("Структура") Тогда
		Если Вход.Свойство(ИмяПараметра) Тогда
			Возврат Вход[ИмяПараметра];
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(ШагПлана) = Тип("Структура") И ШагПлана.Свойство(ИмяПараметра) Тогда
		Возврат ШагПлана[ИмяПараметра];
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ПолучитьСвойствоИзСтруктуры(Объект, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
	Если Объект = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Попытка
		Если (ТипЗнч(Объект) = Тип("Структура") Или ТипЗнч(Объект) = Тип("ФиксированнаяСтруктура")) И Объект.Свойство(ИмяСвойства) Тогда
			Возврат Объект[ИмяСвойства];
		КонецЕсли;
		Если ТипЗнч(Объект) = Тип("Соответствие") Или ТипЗнч(Объект) = Тип("ФиксированноеСоответствие") Тогда
			ЗначениеСвойства = Объект.Получить(ИмяСвойства);
			Если ЗначениеСвойства <> Неопределено Тогда
				Возврат ЗначениеСвойства;
			КонецЕсли;
		КонецЕсли;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ЭтоМассивоподобноеЗначение(Значение)
	ТипЗначения = ТипЗнч(Значение);
	Возврат ТипЗначения = Тип("Массив") Или ТипЗначения = Тип("ФиксированныйМассив");
КонецФункции

Функция ПолучитьЭлементМассиваУниверсально(Коллекция, Индекс)
	Если Коллекция = Неопределено Или НЕ ЭтоМассивоподобноеЗначение(Коллекция) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Индекс < 0 Или Индекс >= Коллекция.Количество() Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат Коллекция[Индекс];
КонецФункции

Функция ЭкранироватьСтрокуДляЗапроса(Значение)
	Возврат СтрЗаменить(Строка(Значение), """", """""");
КонецФункции

Функция ФорматироватьЦелоеДляЗапроса(Значение)
	Возврат Формат(Число(Значение), "ЧГ=0; ЧН=0");
КонецФункции

Функция ПостроитьЛитералДаты1С(ДатаЗначение)
	Возврат "ДАТАВРЕМЯ(" 
		+ ФорматироватьЦелоеДляЗапроса(Год(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(Месяц(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(День(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(Час(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(Минута(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(Секунда(ДатаЗначение)) + ")";
КонецФункции

Функция ПолучитьНачалоКалендарнойНедели(МоментВремени)
	НомерДняНедели = ДеньНедели(МоментВремени);
	Если НомерДняНедели <= 0 Тогда
		НомерДняНедели = 7;
	КонецЕсли;
	Возврат НачалоДня(МоментВремени - (НомерДняНедели - 1) * 24 * 60 * 60);
КонецФункции

Функция ПолучитьНачалоМесяцаЛокально(МоментВремени)
	Возврат Дата(Год(МоментВремени), Месяц(МоментВремени), 1);
КонецФункции

Функция ПолучитьКонецМесяцаЛокально(МоментВремени)
	ГодЗнач = Год(МоментВремени);
	МесяцЗнач = Месяц(МоментВремени);
	Если МесяцЗнач = 12 Тогда
		СледующийМесяц = Дата(ГодЗнач + 1, 1, 1);
	Иначе
		СледующийМесяц = Дата(ГодЗнач, МесяцЗнач + 1, 1);
	КонецЕсли;
	Возврат КонецДня(СледующийМесяц - 24 * 60 * 60);
КонецФункции

Функция ОпределитьЕдиницуПериодаИзТекста(ПериодВРег)
	Если СтрНайти(ПериодВРег, "ДЕН") > 0 Тогда
		Возврат "DAY";
	КонецЕсли;
	Если СтрНайти(ПериодВРег, "НЕДЕЛ") > 0 Тогда
		Возврат "WEEK";
	КонецЕсли;
	Если СтрНайти(ПериодВРег, "МЕСЯЦ") > 0 Тогда
		Возврат "MONTH";
	КонецЕсли;
	Возврат "";
КонецФункции

Функция СодержитЛюбойМаркерПериода(ПериодВРег, Маркеры)
	Для Каждого Маркер Из Маркеры Цикл
		Если СтрНайти(ПериодВРег, ВРег(Строка(Маркер))) > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция ПопробоватьПолучитьГраницыСтандартногоПериода(ПериодВРег, Сейчас)
	Результат = Новый Структура("Начало,Конец", Неопределено, Неопределено);
	Единица = ОпределитьЕдиницуПериодаИзТекста(ПериодВРег);
	Если ПустаяСтрока(Единица) Тогда
		Возврат Результат;
	КонецЕсли;
	
	МаркерыПрошлого = Новый Массив;
	МаркерыПрошлого.Добавить("ПРОШЛ");
	МаркерыПрошлого.Добавить("ПРЕДЫДУЩ");
	МаркерыТекущего = Новый Массив;
	МаркерыТекущего.Добавить("ТЕКУЩ");
	МаркерыСкользящего = Новый Массив;
	МаркерыСкользящего.Добавить("ЗА ");
	МаркерыСкользящего.Добавить("ПОСЛЕДН");
	ЭтоПрошлыйЗавершенный = СодержитЛюбойМаркерПериода(ПериодВРег, МаркерыПрошлого);
	ЭтоТекущий = СодержитЛюбойМаркерПериода(ПериодВРег, МаркерыТекущего);
	ЭтоСкользящий = СодержитЛюбойМаркерПериода(ПериодВРег, МаркерыСкользящего);
	
	Если ЭтоПрошлыйЗавершенный Тогда
		Если Единица = "WEEK" Тогда
			НачалоТекущейНедели = ПолучитьНачалоКалендарнойНедели(Сейчас);
			Результат.Начало = НачалоТекущейНедели - 7 * 24 * 60 * 60;
			Результат.Конец = КонецДня(НачалоТекущейНедели - 24 * 60 * 60);
			Возврат Результат;
		ИначеЕсли Единица = "MONTH" Тогда
			НачалоТекущегоМесяца = ПолучитьНачалоМесяцаЛокально(Сейчас);
			ПоследнийДеньПрошлогоМесяца = НачалоТекущегоМесяца - 24 * 60 * 60;
			Результат.Начало = ПолучитьНачалоМесяцаЛокально(ПоследнийДеньПрошлогоМесяца);
			Результат.Конец = КонецДня(ПоследнийДеньПрошлогоМесяца);
			Возврат Результат;
		ИначеЕсли Единица = "DAY" Тогда
			Вчера = Сейчас - 24 * 60 * 60;
			Результат.Начало = НачалоДня(Вчера);
			Результат.Конец = КонецДня(Вчера);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоТекущий Тогда
		Если Единица = "WEEK" Тогда
			Результат.Начало = ПолучитьНачалоКалендарнойНедели(Сейчас);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		ИначеЕсли Единица = "MONTH" Тогда
			Результат.Начало = ПолучитьНачалоМесяцаЛокально(Сейчас);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		ИначеЕсли Единица = "DAY" Тогда
			Результат.Начало = НачалоДня(Сейчас);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоСкользящий Тогда
		Если Единица = "WEEK" Тогда
			Результат.Начало = НачалоДня(Сейчас - 7 * 24 * 60 * 60);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		ИначеЕсли Единица = "MONTH" Тогда
			Результат.Начало = НачалоДня(Сейчас - 30 * 24 * 60 * 60);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		ИначеЕсли Единица = "DAY" Тогда
			Результат.Начало = НачалоДня(Сейчас);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьГраницыПериодаИзТекста(ТекстПериода)
	Результат = Новый Структура("Начало,Конец", Неопределено, Неопределено);
	ПериодВРег = ВРег(СокрЛП(Строка(ТекстПериода)));
	Сейчас = ТекущаяДата();
	
	Если ПериодВРег = "СЕГОДНЯ" Тогда
		Результат.Начало = НачалоДня(Сейчас);
		Результат.Конец = КонецДня(Сейчас);
		Возврат Результат;
	КонецЕсли;
	
	Если ПериодВРег = "ВЧЕРА" Тогда
		Вчера = Сейчас - 24 * 60 * 60;
		Результат.Начало = НачалоДня(Вчера);
		Результат.Конец = КонецДня(Вчера);
		Возврат Результат;
	КонецЕсли;
	
	Результат = ПопробоватьПолучитьГраницыСтандартногоПериода(ПериодВРег, Сейчас);
	Если Результат.Начало <> Неопределено ИЛИ Результат.Конец <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ЭтоРазделительТокенаПериода(Символ)
	Если ПустаяСтрока(Символ) Тогда
		Возврат Истина;
	КонецЕсли;
	Разделители = " ,.;:()[]{}=<>+-*/\""'%" + Символы.ПС + Символы.Таб;
	Возврат СтрНайти(Разделители, Символ) > 0;
КонецФункции

Функция НормализоватьТокенПериода(Токен)
	ИсходныйТокен = Строка(Токен);
	ТокенВРег = ВРег(СокрЛП(ИсходныйТокен));
	Если ПустаяСтрока(ТокенВРег) Тогда
		Возврат ИсходныйТокен;
	КонецЕсли;
	
	ТипГраницы = "";
	ИмяПериода = "";
	Если СтрНайти(ТокенВРег, "НАЧАЛО_") = 1 Тогда
		ТипГраницы = "НАЧАЛО";
		ИмяПериода = Сред(ТокенВРег, СтрДлина("НАЧАЛО_") + 1);
	ИначеЕсли СтрНайти(ТокенВРег, "КОНЕЦ_") = 1 Тогда
		ТипГраницы = "КОНЕЦ";
		ИмяПериода = Сред(ТокенВРег, СтрДлина("КОНЕЦ_") + 1);
	Иначе
		Возврат ИсходныйТокен;
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяПериода) Тогда
		Возврат ИсходныйТокен;
	КонецЕсли;
	
	ИмяПериода = СтрЗаменить(ИмяПериода, "_", " ");
	Границы = ПолучитьГраницыПериодаИзТекста(ИмяПериода);
	Если ТипГраницы = "НАЧАЛО" И Границы.Начало <> Неопределено Тогда
		Возврат ПостроитьЛитералДаты1С(Границы.Начало);
	КонецЕсли;
	Если ТипГраницы = "КОНЕЦ" И Границы.Конец <> Неопределено Тогда
		Возврат ПостроитьЛитералДаты1С(Границы.Конец);
	КонецЕсли;
	
	Возврат ИсходныйТокен;
КонецФункции

Функция НормализоватьПлейсхолдерыПериодаВТекстеЗапроса(ТекстЗапроса)
	Текст = Строка(ТекстЗапроса);
	Если ПустаяСтрока(СокрЛП(Текст)) Тогда
		Возврат Текст;
	КонецЕсли;
	
	Результат = "";
	ТекущийТокен = "";
	Для Позиция = 1 По СтрДлина(Текст) Цикл
		Символ = Сред(Текст, Позиция, 1);
		Если ЭтоРазделительТокенаПериода(Символ) Тогда
			Если НЕ ПустаяСтрока(ТекущийТокен) Тогда
				Результат = Результат + НормализоватьТокенПериода(ТекущийТокен);
				ТекущийТокен = "";
			КонецЕсли;
			Результат = Результат + Символ;
		Иначе
			ТекущийТокен = ТекущийТокен + Символ;
		КонецЕсли;
	КонецЦикла;
	Если НЕ ПустаяСтрока(ТекущийТокен) Тогда
		Результат = Результат + НормализоватьТокенПериода(ТекущийТокен);
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаПровайдера(ТекстЗапроса)
	Текст = СокрЛП(Строка(ТекстЗапроса));
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	ТекстВРег = ВРег(Текст);
	ПозИз = СтрНайти(ТекстВРег, Символы.ПС + "ИЗ");
	Если ПозИз = 0 Тогда
		ПозИз = СтрНайти(ТекстВРег, " ИЗ ");
	КонецЕсли;
	Если ПозИз = 0 Тогда
		Возврат "";
	КонецЕсли;
	Остаток = СокрЛП(Сред(Текст, ПозИз + 3));
	Если Лев(Остаток, 1) = Символы.ПС Тогда
		Остаток = СокрЛП(Сред(Остаток, 2));
	КонецЕсли;
	Если ПустаяСтрока(Остаток) Тогда
		Возврат "";
	КонецЕсли;
	Разделители = Новый Массив;
	Разделители.Добавить(" ");
	Разделители.Добавить(Символы.ПС);
	Разделители.Добавить(Символы.Таб);
	ПозКонца = 0;
	Для Каждого Разделитель Из Разделители Цикл
		ПозРазделителя = СтрНайти(Остаток, Разделитель);
		Если ПозРазделителя > 0 И (ПозКонца = 0 ИЛИ ПозРазделителя < ПозКонца) Тогда
			ПозКонца = ПозРазделителя;
		КонецЕсли;
	КонецЦикла;
	Если ПозКонца = 0 Тогда
		Возврат СокрЛП(Остаток);
	КонецЕсли;
	Возврат СокрЛП(Лев(Остаток, ПозКонца - 1));
КонецФункции

Функция ИзвлечьПсевдонимИсточникаИзТекстаЗапросаПровайдера(ТекстЗапроса)
	Текст = СокрЛП(Строка(ТекстЗапроса));
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	ТекстВРег = ВРег(Текст);
	ПозКак = СтрНайти(ТекстВРег, " КАК ");
	Если ПозКак = 0 Тогда
		Возврат "";
	КонецЕсли;
	Остаток = Сред(Текст, ПозКак + 5);
	Разделители = Новый Массив;
	Разделители.Добавить(" ");
	Разделители.Добавить(Символы.ПС);
	Разделители.Добавить(Символы.Таб);
	ПозицияКонца = 0;
	Для Каждого Разделитель Из Разделители Цикл
		ПозРазделителя = СтрНайти(Остаток, Разделитель);
		Если ПозРазделителя > 0 И (ПозицияКонца = 0 ИЛИ ПозРазделителя < ПозицияКонца) Тогда
			ПозицияКонца = ПозРазделителя;
		КонецЕсли;
	КонецЦикла;
	Если ПозицияКонца = 0 Тогда
		Возврат СокрЛП(Остаток);
	КонецЕсли;
	Возврат СокрЛП(Лев(Остаток, ПозицияКонца - 1));
КонецФункции

Функция НормализоватьЯвныйRunQueryПоМетаданным(ТекстЗапроса, ПолноеИмяОбъекта)
	Текст = НормализоватьПлейсхолдерыПериодаВТекстеЗапроса(Строка(ТекстЗапроса));
	Если ПустаяСтрока(СокрЛП(Текст)) Тогда
		Возврат Текст;
	КонецЕсли;
	Если ПустаяСтрока(ПолноеИмяОбъекта) Тогда
		ПолноеИмяОбъекта = ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаПровайдера(Текст);
	КонецЕсли;
	Whitelist = ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта);
	Если Whitelist.Количество() = 0 Тогда
		Возврат Текст;
	КонецЕсли;
	Псевдоним = ИзвлечьПсевдонимИсточникаИзТекстаЗапросаПровайдера(Текст);
	ТекстВРег = ВРег(Текст);
	Префикс = "ВЫБРАТЬ ";
	Если Лев(ТекстВРег, СтрДлина(Префикс)) <> Префикс Тогда
		Возврат Текст;
	КонецЕсли;
	ПозИз = СтрНайти(ТекстВРег, Символы.ПС + "ИЗ");
	Если ПозИз = 0 Тогда
		ПозИз = СтрНайти(ТекстВРег, " ИЗ ");
	КонецЕсли;
	Если ПозИз = 0 Тогда
		Возврат Текст;
	КонецЕсли;
	СекцияВыбрать = СокрЛП(Сред(Текст, СтрДлина(Префикс) + 1, ПозИз - СтрДлина(Префикс) - 1));
	Если ПустаяСтрока(СекцияВыбрать) Тогда
		Возврат Текст;
	КонецЕсли;
	ПсевдонимВРег = ВРег(Псевдоним);
	Если НЕ ПустаяСтрока(Псевдоним) И ВРег(СекцияВыбрать) = ПсевдонимВРег И ПолеЕстьВWhitelistЛокально(Whitelist, "Ссылка") Тогда
		Возврат СтрЗаменить(Текст, СекцияВыбрать, Псевдоним + ".Ссылка КАК Ссылка");
	КонецЕсли;
	Если СтрНайти(СекцияВыбрать, ",") = 0 И СтрНайти(ВРег(СекцияВыбрать), " КАК ") = 0 Тогда
		Выражение = СокрЛП(СекцияВыбрать);
		ИмяПоля = Выражение;
		Если СтрНайти(ИмяПоля, ".") > 0 Тогда
			ИмяПоля = Сред(ИмяПоля, СтрНайти(ИмяПоля, ".") + 1);
		КонецЕсли;
		Если НЕ ПолеЕстьВWhitelistЛокально(Whitelist, ИмяПоля) Тогда
			ЗаменаПоля = ?(ПолеЕстьВWhitelistЛокально(Whitelist, "Ссылка"), "Ссылка", ВыбратьЛучшееПолеПоWhitelistЛокально(ИмяПоля, Whitelist));
			Если НЕ ПустаяСтрока(ЗаменаПоля) Тогда
				Если НЕ ПустаяСтрока(Псевдоним) Тогда
					Возврат СтрЗаменить(Текст, СекцияВыбрать, Псевдоним + "." + ЗаменаПоля + " КАК " + ЗаменаПоля);
				ИначеЕсли ЗаменаПоля = "Ссылка" Тогда
					Возврат СтрЗаменить(Текст, СекцияВыбрать, "Ссылка КАК Ссылка");
				Иначе
					Возврат СтрЗаменить(Текст, СекцияВыбрать, ЗаменаПоля + " КАК " + ЗаменаПоля);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Возврат Текст;
КонецФункции

Функция РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта)
	Результат = Новый Структура("ObjectType,ObjectName", "", "");
	Имя = СокрЛП(Строка(ПолноеИмяОбъекта));
	ПозТочки = СтрНайти(Имя, ".");
	Если ПозТочки > 0 Тогда
		Результат.ObjectType = Лев(Имя, ПозТочки - 1);
		Результат.ObjectName = Сред(Имя, ПозТочки + 1);
	Иначе
		Результат.ObjectName = Имя;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта)
	Whitelist = Новый Массив;
	Разбор = РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта);
	Если ПустаяСтрока(Разбор.ObjectType) ИЛИ ПустаяСтрока(Разбор.ObjectName) Тогда
		Возврат Whitelist;
	КонецЕсли;
	ИнформацияОбОбъекте = Неопределено;
	Если Разбор.ObjectType = "Справочник" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыСправочника(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "Документ" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыДокумента(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "РегистрНакопления" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыРегистраНакопления(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "РегистрСведений" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыРегистраСведений(Разбор.ObjectName);
	КонецЕсли;
	Если ИнформацияОбОбъекте = Неопределено
		ИЛИ ТипЗнч(ИнформацияОбОбъекте) <> Тип("Структура")
		ИЛИ НЕ ИнформацияОбОбъекте.Свойство("Найден")
		ИЛИ НЕ ИнформацияОбОбъекте.Найден Тогда
		Возврат Whitelist;
	КонецЕсли;
	Если ИнформацияОбОбъекте.Свойство("Реквизиты") И ТипЗнч(ИнформацияОбОбъекте.Реквизиты) = Тип("Массив") Тогда
		Для Каждого Реквизит Из ИнформацияОбОбъекте.Реквизиты Цикл
			Если ТипЗнч(Реквизит) = Тип("Структура") И Реквизит.Свойство("Имя") Тогда
				ИмяРеквизита = СокрЛП(Строка(Реквизит.Имя));
				Если НЕ ПустаяСтрока(ИмяРеквизита) И Лев(ВРег(ИмяРеквизита), 6) <> "УДАЛИТ" И Whitelist.Найти(ИмяРеквизита) = Неопределено Тогда
					Whitelist.Добавить(ИмяРеквизита);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если Whitelist.Найти("Ссылка") = Неопределено Тогда
		Whitelist.Добавить("Ссылка");
	КонецЕсли;
	Возврат Whitelist;
КонецФункции

Функция ОценитьПохожестьПоля(ИсходноеПоле, Кандидат)
	ИсходноеСырое = СокрЛП(Строка(ИсходноеПоле));
	КандидатСырой = СокрЛП(Строка(Кандидат));
	Исходное = ВРег(ИсходноеСырое);
	КандидатВРег = ВРег(КандидатСырой);
	Если ПустаяСтрока(Исходное) ИЛИ ПустаяСтрока(КандидатВРег) Тогда
		Возврат -1;
	КонецЕсли;
	Если Исходное = КандидатВРег Тогда
		Возврат 1000;
	КонецЕсли;
	Если СовпадаютТокеныCamelCaseПоля(ИсходноеСырое, КандидатСырой) Тогда
		Возврат 900;
	КонецЕсли;
	Оценка = 0;
	Для Индекс = 1 По Мин(СтрДлина(Исходное), СтрДлина(КандидатВРег)) Цикл
		Если Сред(Исходное, Индекс, 1) <> Сред(КандидатВРег, Индекс, 1) Тогда
			Прервать;
		КонецЕсли;
		Оценка = Оценка + 5;
	КонецЦикла;
	Если СтрНайти(КандидатВРег, Исходное) > 0 Тогда
		Оценка = Оценка + 40;
	КонецЕсли;
	Если СтрНайти(Исходное, КандидатВРег) > 0 Тогда
		Оценка = Оценка + 20;
	КонецЕсли;
	Если СтрНайти(Исходное, "СУММА") > 0 И СтрНайти(КандидатВРег, "СУММА") > 0 Тогда
		Оценка = Оценка + 30;
	КонецЕсли;
	Возврат Оценка;
КонецФункции

Функция ЭтоГраницаCamelCase(ПредыдущийСимвол, ТекущийСимвол)
	Если ПустаяСтрока(Строка(ПредыдущийСимвол)) Или ПустаяСтрока(Строка(ТекущийСимвол)) Тогда
		Возврат Ложь;
	КонецЕсли;
	КодПред = КодСимвола(ПредыдущийСимвол);
	КодТек = КодСимвола(ТекущийСимвол);
	ЭтоПредБуква = ((КодПред >= 65 И КодПред <= 90) Или (КодПред >= 97 И КодПред <= 122)
		Или (КодПред >= 1040 И КодПред <= 1103) Или КодПред = 1025 Или КодПред = 1105);
	ЭтоТекБуква = ((КодТек >= 65 И КодТек <= 90) Или (КодТек >= 97 И КодТек <= 122)
		Или (КодТек >= 1040 И КодТек <= 1103) Или КодТек = 1025 Или КодТек = 1105);
	Если НЕ ЭтоПредБуква Или НЕ ЭтоТекБуква Тогда
		Возврат Ложь;
	КонецЕсли;
	ЭтоПредСтрочная = ((КодПред >= 97 И КодПред <= 122) Или (КодПред >= 1072 И КодПред <= 1103) Или КодПред = 1105);
	ЭтоТекЗаглавная = ((КодТек >= 65 И КодТек <= 90) Или (КодТек >= 1040 И КодТек <= 1071) Или КодТек = 1025);
	Возврат ЭтоПредСтрочная И ЭтоТекЗаглавная;
КонецФункции

Функция РазбитьCamelCaseПолеНаТокены(ИмяПоля)
	Результат = Новый Массив;
	Текст = СокрЛП(Строка(ИмяПоля));
	Если ПустаяСтрока(Текст) Тогда
		Возврат Результат;
	КонецЕсли;
	ТекущийТокен = "";
	ПредыдущийСимвол = "";
	Для Индекс = 1 По СтрДлина(Текст) Цикл
		Символ = Сред(Текст, Индекс, 1);
		Если НЕ ПустаяСтрока(ТекущийТокен) И ЭтоГраницаCamelCase(ПредыдущийСимвол, Символ) Тогда
			Результат.Добавить(ВРег(ТекущийТокен));
			ТекущийТокен = Символ;
		Иначе
			ТекущийТокен = ТекущийТокен + Символ;
		КонецЕсли;
		ПредыдущийСимвол = Символ;
	КонецЦикла;
	Если НЕ ПустаяСтрока(ТекущийТокен) Тогда
		Результат.Добавить(ВРег(ТекущийТокен));
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция СовпадаютТокеныCamelCaseПоля(ИсходноеПоле, Кандидат)
	ТокеныИсходного = РазбитьCamelCaseПолеНаТокены(ИсходноеПоле);
	ТокеныКандидата = РазбитьCamelCaseПолеНаТокены(Кандидат);
	Если ТокеныИсходного.Количество() < 2 Или ТокеныИсходного.Количество() <> ТокеныКандидата.Количество() Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Каждого Токен Из ТокеныИсходного Цикл
		Если ТокеныКандидата.Найти(Токен) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Функция ПолеЕстьВWhitelistЛокально(Whitelist, ИмяПоля)
	Для Каждого Кандидат Из Whitelist Цикл
		Если ВРег(Строка(Кандидат)) = ВРег(Строка(ИмяПоля)) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция ВыбратьЛучшееПолеПоWhitelistЛокально(ИсходноеПоле, Whitelist)
	ЛучшееПоле = "";
	ЛучшаяОценка = -1;
	Для Каждого Кандидат Из Whitelist Цикл
		Оценка = ОценитьПохожестьПоля(ИсходноеПоле, Кандидат);
		Если Оценка > ЛучшаяОценка Тогда
			ЛучшаяОценка = Оценка;
			ЛучшееПоле = Строка(Кандидат);
		КонецЕсли;
	КонецЦикла;
	Возврат ЛучшееПоле;
КонецФункции

Функция НормализоватьПоляШагаПоМетаданным(ПолноеИмяОбъекта, Поля)
	Если НЕ ЭтоМассивоподобноеЗначение(Поля) Тогда
		Возврат Поля;
	КонецЕсли;
	Whitelist = ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта);
	Если Whitelist.Количество() = 0 Тогда
		Возврат Поля;
	КонецЕсли;
	НовыеПоля = Новый Массив;
	Для Каждого Поле Из Поля Цикл
		ИмяПоля = СокрЛП(Строка(Поле));
		Если ПустаяСтрока(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		ЛучшееПоле = ИмяПоля;
		ЛучшаяОценка = -1;
		Для Каждого Кандидат Из Whitelist Цикл
			Оценка = ОценитьПохожестьПоля(ИмяПоля, Кандидат);
			Если Оценка > ЛучшаяОценка Тогда
				ЛучшаяОценка = Оценка;
				ЛучшееПоле = Строка(Кандидат);
			КонецЕсли;
		КонецЦикла;
		Если НЕ ПустаяСтрока(ЛучшееПоле) И НовыеПоля.Найти(ЛучшееПоле) = Неопределено Тогда
			НовыеПоля.Добавить(ЛучшееПоле);
		ИначеЕсли НовыеПоля.Найти(ИмяПоля) = Неопределено Тогда
			НовыеПоля.Добавить(ИмяПоля);
		КонецЕсли;
	КонецЦикла;
	Возврат НовыеПоля;
КонецФункции

Функция НормализоватьСтруктуруФильтраПоМетаданным(ПолноеИмяОбъекта, Фильтр)
	Если Фильтр = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Whitelist = ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта);
	Если Whitelist.Количество() = 0 Тогда
		Возврат Фильтр;
	КонецЕсли;
	Если ТипЗнч(Фильтр) = Тип("Структура") ИЛИ ТипЗнч(Фильтр) = Тип("ФиксированнаяСтруктура") Тогда
		НовыйФильтр = Новый Структура;
		Для Каждого Пара Из Фильтр Цикл
			ИмяПоля = Строка(Пара.Ключ);
			Если ПолеЕстьВWhitelistЛокально(Whitelist, ИмяПоля) Тогда
				НовыйФильтр.Вставить(ИмяПоля, Пара.Значение);
			Иначе
				ЗаменаПоля = ВыбратьЛучшееПолеПоWhitelistЛокально(ИмяПоля, Whitelist);
				Если ПустаяСтрока(ЗаменаПоля) Тогда
					НовыйФильтр.Вставить(ИмяПоля, Пара.Значение);
				Иначе
					НовыйФильтр.Вставить(ЗаменаПоля, Пара.Значение);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Возврат НовыйФильтр;
	КонецЕсли;
	Если ТипЗнч(Фильтр) = Тип("Строка") Тогда
		Результат = Строка(Фильтр);
		Для Каждого Поле Из Whitelist Цикл
		КонецЦикла;
		Для Каждого Поле Из СтрРазделить(Результат, " ") Цикл
			ИмяПоля = СокрЛП(Строка(Поле));
			Если ПустаяСтрока(ИмяПоля) Тогда
				Продолжить;
			КонецЕсли;
			Если ПолеЕстьВWhitelistЛокально(Whitelist, ИмяПоля) Тогда
				Продолжить;
			КонецЕсли;
			ЗаменаПоля = ВыбратьЛучшееПолеПоWhitelistЛокально(ИмяПоля, Whitelist);
			Если ПустаяСтрока(ЗаменаПоля) ИЛИ ВРег(ЗаменаПоля) = ВРег(ИмяПоля) Тогда
				Продолжить;
			КонецЕсли;
			Результат = СтрЗаменить(Результат, ИмяПоля + " = ", ЗаменаПоля + " = ");
			Результат = СтрЗаменить(Результат, ИмяПоля + " < ", ЗаменаПоля + " < ");
			Результат = СтрЗаменить(Результат, ИмяПоля + " > ", ЗаменаПоля + " > ");
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	Возврат Фильтр;
КонецФункции

Функция ПостроитьСписокПолейДляЗапроса(ПолноеИмяОбъекта, Поля)
	Если НЕ ЭтоМассивоподобноеЗначение(Поля) Или Поля.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Части = Новый Массив;
	Для Каждого Поле Из Поля Цикл
		ИмяПоля = СокрЛП(Строка(Поле));
		Если ПустаяСтрока(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		Части.Добавить(ИмяПоля + " КАК " + ИмяПоля);
	КонецЦикла;
	
	Если Части.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат СтрСоединить(Части, ", ");
КонецФункции

Функция НормализоватьСтроковыйФильтрДляЗапроса(Знач ИсходныйФильтр)
	Фильтр = СокрЛП(Строка(ИсходныйФильтр));
	Если ПустаяСтрока(Фильтр) Тогда
		Возврат "";
	КонецЕсли;
	
	Фильтр = СтрЗаменить(Фильтр, "Объект.", "");
	Фильтр = СтрЗаменить(Фильтр, "объект.", "");
	Фильтр = СтрЗаменить(Фильтр, "'", """");
	Фильтр = СтрЗаменить(Фильтр, "по дате ", "");
	Фильтр = СтрЗаменить(Фильтр, "По дате ", "");
	Фильтр = СтрЗаменить(Фильтр, "ПО ДАТЕ ", "");
	Фильтр = НормализоватьПлейсхолдерыПериодаВТекстеЗапроса(Фильтр);
	ФильтрВРег = ВРег(СтрЗаменить(СтрЗаменить(Фильтр, Символы.ПС, " "), Символы.Таб, " "));
	Если СтрНайти(ФильтрВРег, "=") > 0 Тогда
		ЧастиРавенства = СтрРазделить(Фильтр, "=");
		Если ЧастиРавенства.Количество() = 2 Тогда
			ЛеваяЧасть = СокрЛП(Строка(ЧастиРавенства[0]));
			ПраваяЧасть = СокрЛП(Строка(ЧастиРавенства[1]));
			Если (ВРег(ЛеваяЧасть) = "ПЕРИОД" ИЛИ ВРег(ЛеваяЧасть) = "ДАТА") И НЕ ПустаяСтрока(ПраваяЧасть) Тогда
				ГраницыЯвногоПериода = ПолучитьГраницыПериодаИзТекста(ПраваяЧасть);
				Если ГраницыЯвногоПериода.Начало <> Неопределено И ГраницыЯвногоПериода.Конец <> Неопределено Тогда
					Возврат "Дата МЕЖДУ " + ПостроитьЛитералДаты1С(ГраницыЯвногоПериода.Начало) + " И " + ПостроитьЛитералДаты1С(ГраницыЯвногоПериода.Конец);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если СтрНайти(Фильтр, "=") = 0
		И СтрНайти(Фильтр, ">") = 0
		И СтрНайти(Фильтр, "<") = 0
		И СтрНайти(ВРег(Фильтр), " МЕЖДУ ") = 0
		И СтрНайти(ВРег(Фильтр), " ПОДОБНО ") = 0 Тогда
		Границы = ПолучитьГраницыПериодаИзТекста(Фильтр);
		Если Границы.Начало <> Неопределено И Границы.Конец <> Неопределено Тогда
			Возврат "Дата МЕЖДУ " + ПостроитьЛитералДаты1С(Границы.Начало) + " И " + ПостроитьЛитералДаты1С(Границы.Конец);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Фильтр;
КонецФункции

Функция ВыбратьПолеПериодаПоWhitelist(ПолноеИмяОбъекта)
	Whitelist = ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта);
	Если Whitelist.Количество() = 0 Тогда
		Возврат "Дата";
	КонецЕсли;
	ЛучшееПоле = "";
	ЛучшаяОценка = -1;
	Для Каждого Поле Из Whitelist Цикл
		ИмяПоля = Строка(Поле);
		ИмяПоляВРег = ВРег(ИмяПоля);
		Оценка = 0;
		Если ИмяПоляВРег = "ДАТА" Тогда
			Оценка = Оценка + 100;
		КонецЕсли;
		Если ИмяПоляВРег = "ПЕРИОД" Тогда
			Оценка = Оценка + 95;
		КонецЕсли;
		Если СтрНайти(ИмяПоляВРег, "ДАТ") > 0 Тогда
			Оценка = Оценка + 40;
		КонецЕсли;
		Если СтрНайти(ИмяПоляВРег, "ПЕРИОД") > 0 Тогда
			Оценка = Оценка + 35;
		КонецЕсли;
		Если СтрНайти(ИмяПоляВРег, "МОМЕНТ") > 0 Тогда
			Оценка = Оценка + 20;
		КонецЕсли;
		Если СтрНайти(ИмяПоляВРег, "TIME") > 0 ИЛИ СтрНайти(ИмяПоляВРег, "DATE") > 0 Тогда
			Оценка = Оценка + 10;
		КонецЕсли;
		Если Оценка > ЛучшаяОценка Тогда
			ЛучшаяОценка = Оценка;
			ЛучшееПоле = ИмяПоля;
		КонецЕсли;
	КонецЦикла;
	Если ПустаяСтрока(ЛучшееПоле) Тогда
		Возврат "Дата";
	КонецЕсли;
	Возврат ЛучшееПоле;
КонецФункции

Функция НормализоватьПолноеИмяОбъектаПоМетаданным(ПолноеИмяОбъекта)
	ИмяПолное = СокрЛП(Строка(ПолноеИмяОбъекта));
	Если ПустаяСтрока(ИмяПолное) ИЛИ СтрНайти(ИмяПолное, ".") = 0 Тогда
		Возврат ИмяПолное;
	КонецЕсли;
	Разбор = РазобратьПолноеИмяОбъекта(ИмяПолное);
	ТипОбъекта = Разбор.ObjectType;
	ИмяОбъекта = Разбор.ObjectName;
	Если ПустаяСтрока(ТипОбъекта) ИЛИ ПустаяСтрока(ИмяОбъекта) Тогда
		Возврат ИмяПолное;
	КонецЕсли;
	Если ТипОбъекта = "Документ" И ИИА_Метаданные.СуществуетДокумент(ИмяОбъекта) Тогда
		Возврат ТипОбъекта + "." + ИмяОбъекта;
	КонецЕсли;
	Если ТипОбъекта = "Справочник" И ИИА_Метаданные.СуществуетСправочник(ИмяОбъекта) Тогда
		Возврат ТипОбъекта + "." + ИмяОбъекта;
	КонецЕсли;
	Похожие = ИИА_Метаданные.НайтиПохожиеОбъекты(ИмяОбъекта, ТипОбъекта);
	Для Каждого Похожий Из Похожие Цикл
		Если ТипОбъекта = "Документ" И ИИА_Метаданные.СуществуетДокумент(Похожий) Тогда
			Возврат ТипОбъекта + "." + Похожий;
		КонецЕсли;
		Если ТипОбъекта = "Справочник" И ИИА_Метаданные.СуществуетСправочник(Похожий) Тогда
			Возврат ТипОбъекта + "." + Похожий;
		КонецЕсли;
	КонецЦикла;
	Возврат ИмяПолное;
КонецФункции

Функция ПостроитьУсловияЗапросаИзФильтра(ПолноеИмяОбъекта, Фильтр)
	Если Фильтр = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	ПолеПериода = ВыбратьПолеПериодаПоWhitelist(ПолноеИмяОбъекта);
	
	Если ТипЗнч(Фильтр) = Тип("Строка") Тогда
		ТекстУсловия = НормализоватьСтроковыйФильтрДляЗапроса(Фильтр);
		Если НЕ ПустаяСтрока(ПолеПериода) И ВРег(ПолеПериода) <> "ДАТА" Тогда
			ТекстУсловия = СтрЗаменить(ТекстУсловия, "Дата МЕЖДУ ", ПолеПериода + " МЕЖДУ ");
		КонецЕсли;
		Возврат ТекстУсловия;
	КонецЕсли;
	
	Если ТипЗнч(Фильтр) <> Тип("Структура") И ТипЗнч(Фильтр) <> Тип("ФиксированнаяСтруктура") Тогда
		Возврат "";
	КонецЕсли;
	
	Условия = Новый Массив;
	Для Каждого Пара Из Фильтр Цикл
		ИмяПоля = Строка(Пара.Ключ);
		ЗначениеФильтра = Пара.Значение;
		ИмяПоляВРег = ВРег(ИмяПоля);
		
		Если ИмяПоляВРег = "ПЕРИОД" Тогда
			Границы = ПолучитьГраницыПериодаИзТекста(ЗначениеФильтра);
			Если Границы.Начало <> Неопределено И Границы.Конец <> Неопределено Тогда
				Условия.Добавить(ПолеПериода + " МЕЖДУ " + ПостроитьЛитералДаты1С(Границы.Начало) + " И " + ПостроитьЛитералДаты1С(Границы.Конец));
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если (ИмяПоляВРег = "ДАТА" ИЛИ ИмяПоляВРег = "ПЕРИОД")
			И (ТипЗнч(ЗначениеФильтра) = Тип("Структура") ИЛИ ТипЗнч(ЗначениеФильтра) = Тип("ФиксированнаяСтруктура")) Тогда
			ДатаС = ПолучитьСвойствоИзСтруктуры(ЗначениеФильтра, "from", Неопределено);
			ДатаПо = ПолучитьСвойствоИзСтруктуры(ЗначениеФильтра, "to", Неопределено);
			НачДата = ПопыткаПрочитатьДатуИзСтроки(ДатаС);
			КонДата = ПопыткаПрочитатьДатуИзСтроки(ДатаПо);
			Если НачДата <> Неопределено И КонДата <> Неопределено Тогда
				Условия.Добавить(ИмяПоля + " МЕЖДУ " + ПостроитьЛитералДаты1С(НачалоДня(НачДата)) + " И " + ПостроитьЛитералДаты1С(КонецДня(КонДата)));
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ЗначениеФильтра) = Тип("Строка") Тогда
			Условия.Добавить(ИмяПоля + " = """ + ЭкранироватьСтрокуДляЗапроса(ЗначениеФильтра) + """");
		ИначеЕсли ТипЗнч(ЗначениеФильтра) = Тип("Число") Тогда
			Условия.Добавить(ИмяПоля + " = " + Строка(ЗначениеФильтра));
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрСоединить(Условия, Символы.ПС + " И ");
КонецФункции

Функция НормализоватьАгрегациюДляЗапроса(Знач Агрегация, Знач Поля)
	ТекстАгрегации = СокрЛП(Строка(Агрегация));
	Если ПустаяСтрока(ТекстАгрегации) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстАгрегации = СтрЗаменить(ТекстАгрегации, "Объект.", "");
	ТекстАгрегации = СтрЗаменить(ТекстАгрегации, "объект.", "");
	ТекстАгрегации = СтрЗаменить(ТекстАгрегации, " AS ", " КАК ");
	ТекстАгрегации = СтрЗаменить(ТекстАгрегации, " as ", " КАК ");
	Если СтрНайти(ВРег(ТекстАгрегации), "СУММА(") = 0 И СтрНайти(ВРег(ТекстАгрегации), "SUM(") > 0 Тогда
		ТекстАгрегации = СтрЗаменить(ТекстАгрегации, "SUM(", "СУММА(");
	КонецЕсли;
	Возврат ТекстАгрегации;
КонецФункции

Функция ПопыткаПрочитатьДатуИзСтроки(Знач СтрокаДаты)
	СтрокаЗначения = СокрЛП(Строка(СтрокаДаты));
	Если ПустаяСтрока(СтрокаЗначения) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Если СтрДлина(СтрокаЗначения) >= 10 И Сред(СтрокаЗначения, 5, 1) = "-" И Сред(СтрокаЗначения, 8, 1) = "-" Тогда
			ГодЗнач = Число(Лев(СтрокаЗначения, 4));
			МесяцЗнач = Число(Сред(СтрокаЗначения, 6, 2));
			ДеньЗнач = Число(Сред(СтрокаЗначения, 9, 2));
			Возврат Дата(ГодЗнач, МесяцЗнач, ДеньЗнач);
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
КонецФункции

Функция ЭтоПохожеНаВалидныйTypedPlanJSON(ТекстJSON)
	Текст = ВРег(СокрЛП(Строка(ТекстJSON)));
	Если ПустаяСтрока(Текст) Тогда
		Возврат Ложь;
	КонецЕсли;
	Возврат СтрНайти(Текст, """PLAN_VERSION""") > 0
		И СтрНайти(Текст, """STEPS""") > 0
		И СтрНайти(Текст, "[{") > 0;
КонецФункции

Функция ИзвлечьДанныеИзРезультатаШагаПлана(РезультатШага)
	Если РезультатШага = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "Данные", Неопределено);
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "data", Неопределено);
	КонецЕсли;
	Если Данные <> Неопределено Тогда
		Возврат Данные;
	КонецЕсли;
	
	Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "ДанныеЗапроса", Неопределено);
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "ДанныеЗапросаДляТаблицы", Неопределено);
	КонецЕсли;
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "rows", Неопределено);
	КонецЕсли;
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "СсылкиОбъектов", Неопределено);
	КонецЕсли;
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "changed_objects", Неопределено);
	КонецЕсли;
	Если Данные <> Неопределено Тогда
		Возврат Данные;
	КонецЕсли;
	
	RunQueryДанные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "run_query", Неопределено);
	Если ЭтоМассивоподобноеЗначение(RunQueryДанные) И RunQueryДанные.Количество() > 0 Тогда
		ПервыйRunQuery = ПолучитьЭлементМассиваУниверсально(RunQueryДанные, 0);
		Если ПервыйRunQuery <> Неопределено Тогда
			Данные = ПолучитьСвойствоИзСтруктуры(ПервыйRunQuery, "rows", Неопределено);
			Если Данные <> Неопределено Тогда
				Возврат Данные;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Результаты = ПолучитьСвойствоИзСтруктуры(РезультатШага, "Результаты", Неопределено);
	Если ЭтоМассивоподобноеЗначение(Результаты) Тогда
		Для Индекс = 0 По Результаты.Количество() - 1 Цикл
			ЭлементРезультата = ПолучитьЭлементМассиваУниверсально(Результаты, Индекс);
			Если ЭлементРезультата = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ДанныеЭлемента = ПолучитьСвойствоИзСтруктуры(ЭлементРезультата, "Данные", Неопределено);
			Если ДанныеЭлемента = Неопределено Тогда
				ДанныеЭлемента = ПолучитьСвойствоИзСтруктуры(ЭлементРезультата, "data", Неопределено);
			КонецЕсли;
			Если ДанныеЭлемента = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ДанныеЗапроса = ПолучитьСвойствоИзСтруктуры(ДанныеЭлемента, "ДанныеЗапроса", Неопределено);
			Если ДанныеЗапроса = Неопределено Тогда
				ДанныеЗапроса = ПолучитьСвойствоИзСтруктуры(ДанныеЭлемента, "ДанныеЗапросаДляТаблицы", Неопределено);
			КонецЕсли;
			Если ДанныеЗапроса = Неопределено Тогда
				ДанныеЗапроса = ПолучитьСвойствоИзСтруктуры(ДанныеЭлемента, "rows", Неопределено);
			КонецЕсли;
			Если ДанныеЗапроса <> Неопределено Тогда
				Возврат ДанныеЗапроса;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

Функция РазрешитьЗначениеИзРезультатовПлана(СсылкаДиалога, ИсходноеЗначение)
	Если ТипЗнч(ИсходноеЗначение) <> Тип("Строка") Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	Выражение = СокрЛП(ИсходноеЗначение);
	Если Лев(ВРег(Выражение), 9) = "РЕЗУЛЬТАТ " Тогда
		Выражение = СокрЛП(Сред(Выражение, 10));
	ИначеЕсли Лев(ВРег(Выражение), 12) = "РЕЗУЛЬТАТ ИЗ " Тогда
		Выражение = СокрЛП(Сред(Выражение, 13));
	КонецЕсли;
	ВыражениеВРег = ВРег(Выражение);
	Если Лев(ВыражениеВРег, 3) = "ИЗ " Тогда
		Выражение = СокрЛП(Сред(Выражение, 4));
		ВыражениеВРег = ВРег(Выражение);
	КонецЕсли;
	Если Лев(ВыражениеВРег, 5) <> "STEP_" Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	
	ПозТочки = СтрНайти(Выражение, ".");
	Если ПозТочки = 0 Тогда
		StepId = Выражение;
		Хвост = "";
	Иначе
		StepId = Лев(Выражение, ПозТочки - 1);
		Хвост = Сред(Выражение, ПозТочки + 1);
	КонецЕсли;
	
	ИмяПоля = "";
	Если Лев(ВРег(Хвост), 9) = "RESULT[0]" Тогда
		ПозПоля = СтрНайти(Хвост, "].");
		Если ПозПоля > 0 Тогда
			ИмяПоля = Сред(Хвост, ПозПоля + 2);
		КонецЕсли;
	Иначе
		ИмяПоля = Хвост;
	КонецЕсли;
	
	ШагПлана = ИИА_TypedPlan.ПолучитьШагПланаПоИдентификатору(СсылкаДиалога, StepId);
	Если ШагПлана = Неопределено Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	РезультатШага = ПолучитьСвойствоИзСтруктуры(ШагПлана, "result_data", Неопределено);
	Если РезультатШага = Неопределено Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	Данные = ИзвлечьДанныеИзРезультатаШагаПлана(РезультатШага);
	ПерваяСтрока = ПолучитьЭлементМассиваУниверсально(Данные, 0);
	Если ПерваяСтрока = Неопределено Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	Если ПустаяСтрока(ИмяПоля) Тогда
		Если ТипЗнч(ПерваяСтрока) = Тип("Структура") ИЛИ ТипЗнч(ПерваяСтрока) = Тип("ФиксированнаяСтруктура") Тогда
			СсылкаЗначение = ПолучитьСвойствоИзСтруктуры(ПерваяСтрока, "Ссылка", Неопределено);
			Если СсылкаЗначение <> Неопределено Тогда
				Возврат СсылкаЗначение;
			КонецЕсли;
		КонецЕсли;
		Возврат ПерваяСтрока;
	КонецЕсли;
	Возврат ПолучитьСвойствоИзСтруктуры(ПерваяСтрока, ИмяПоля, ИсходноеЗначение);
КонецФункции

Процедура ДобавитьШагВСценарийDSL(Шаги, Действие, Параметры = Неопределено)
	Если Шаги = Неопределено ИЛИ ТипЗнч(Шаги) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	Шаг = Новый Структура;
	Шаг.Вставить("action", Действие);
	Если Параметры <> Неопределено Тогда
		Если ТипЗнч(Параметры) = Тип("Структура") Тогда
			Для Каждого КлючИЗначение Из Параметры Цикл
				Шаг.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
			КонецЦикла;
		ИначеЕсли ТипЗнч(Параметры) = Тип("Соответствие") Тогда
			Для Каждого КлючИЗначение Из Параметры Цикл
				Шаг.Вставить(Строка(КлючИЗначение.Ключ), КлючИЗначение.Значение);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Шаги.Добавить(Шаг);
КонецПроцедуры

Функция ПолучитьСледующийШагПланаДляВосстановления(СсылкаДиалога)
	Если СсылкаДиалога = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат ИИА_TypedPlan.ПолучитьСледующийШагПлана(СсылкаДиалога);
КонецФункции

Функция ИзвлечьШагиИзDSLJSON(DSL_JSON)
	Если ПустаяСтрока(DSL_JSON) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ИИА_DSL.НормализоватьJSONТекст(DSL_JSON));
		DSLСтруктура = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		Если ТипЗнч(DSLСтруктура) = Тип("Структура")
			И DSLСтруктура.Свойство("steps")
			И ТипЗнч(DSLСтруктура.steps) = Тип("Массив") Тогда
			Возврат DSLСтруктура.steps;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

Функция ПолучитьСвойствоШагаПланаЛокально(Значение, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Структура") И Значение.Свойство(ИмяСвойства) Тогда
		Возврат Значение[ИмяСвойства];
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("ФиксированнаяСтруктура") И Значение.Свойство(ИмяСвойства) Тогда
		Возврат Значение[ИмяСвойства];
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ЭтоСтартЦепочкиЗаписывающегоКонтекста(Kind)
	KindВРег = ВРег(СокрЛП(Строка(Kind)));
	Возврат KindВРег = "CREATE_DOCUMENT"
		ИЛИ KindВРег = "CREATE_REFERENCE"
		ИЛИ KindВРег = "FIND_REFERENCE_BY_NAME";
КонецФункции

Функция ЭтоПродолжениеЦепочкиЗаписывающегоКонтекста(Kind)
	KindВРег = ВРег(СокрЛП(Строка(Kind)));
	Возврат KindВРег = "SET_FIELD"
		ИЛИ KindВРег = "WRITE_OBJECT"
		ИЛИ KindВРег = "SHOW_INFO";
КонецФункции

Функция МожноВключитьШагВЦепочкуDSL(ШагПлана, УжеВключенныеШаги, СсылкаДиалога)
	Если ШагПлана = Неопределено ИЛИ ТипЗнч(ШагПлана) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ШагПлана.Свойство("status") И ВРег(Строка(ШагПлана.status)) = "DONE" Тогда
		Возврат Ложь;
	КонецЕсли;
	Зависимости = ПолучитьСвойствоШагаПланаЛокально(ШагПлана, "depends_on", Неопределено);
	Если ТипЗнч(Зависимости) = Тип("Массив") Тогда
		Для Индекс = 0 По Зависимости.Количество() - 1 Цикл
			Зависимость = Строка(ПолучитьЭлементМассиваУниверсально(Зависимости, Индекс));
			Если ПустаяСтрока(Зависимость) Тогда
				Продолжить;
			КонецЕсли;
			Если УжеВключенныеШаги.Найти(ВРег(Зависимость)) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ШагЗависимости = ИИА_TypedPlan.ПолучитьШагПланаПоИдентификатору(СсылкаДиалога, Зависимость);
			Если ШагЗависимости = Неопределено
				ИЛИ НЕ ШагЗависимости.Свойство("status")
				ИЛИ ВРег(Строка(ШагЗависимости.status)) <> "DONE" Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если ВРег(Строка(ПолучитьСвойствоШагаПланаЛокально(ШагПлана, "kind", ""))) = "SET_FIELD" Тогда
		ЗначениеПоля = ПолучитьПараметрШагаПлана(ШагПлана, "value", "");
		Если СсылкаДиалога <> Неопределено Тогда
			ЗначениеПоля = РазрешитьЗначениеИзРезультатовПлана(СсылкаДиалога, ЗначениеПоля);
		КонецЕсли;
		Если ТипЗнч(ЗначениеПоля) = Тип("Строка") И Лев(ВРег(СокрЛП(ЗначениеПоля)), 5) = "STEP_" Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	Возврат Истина;
КонецФункции

Функция ПостроитьРезультатИзToolCall(Сообщение, ТипСообщения, ПараметрыИИ) Экспорт
	Результат = СоздатьБазовыйРезультатИИ();
	Если Сообщение <> Неопределено И Сообщение.Свойство("content") Тогда
		Результат.RawModelText = Строка(Сообщение.content);
	КонецЕсли;
	Если Сообщение <> Неопределено И Сообщение.Свойство("tool_calls") Тогда
		Результат.ToolCalls = Сообщение.tool_calls;
	КонецЕсли;
	
	ИзвлеченныйTool = ИзвлечьПервыйToolCall(Сообщение);
	Если НЕ ИзвлеченныйTool.Успех Тогда
		Результат.ТипОтвета = "ОшибкаКонтракта";
		Результат.Текст = "Провайдер вернул tool_calls, но первый вызов не удалось разобрать: " + ИзвлеченныйTool.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Результат.ToolName = ИзвлеченныйTool.ToolName;
	Результат.ToolArguments = ИзвлеченныйTool.ArgumentsText;
	Если ПустаяСтрока(Результат.RawModelText) Тогда
		Результат.RawModelText = ИзвлеченныйTool.ArgumentsText;
	КонецЕсли;
	
	Если ИзвлеченныйTool.ToolName = "submit_dsl" Тогда
		DSL_JSON = ИзвлечьJSONПолеИзАргументовToolCall(ИзвлеченныйTool.ArgumentsText, "dsl");
		Если ПустаяСтрока(DSL_JSON) Тогда
			Если АргументыToolCallПохожиНаDSL(ИзвлеченныйTool.ArgumentsText) Тогда
				DSL_JSON = ИзвлеченныйTool.ArgumentsText;
				Если ПараметрыИИ <> Неопределено 
					И ТипЗнч(ПараметрыИИ) = Тип("Структура")
					И ПараметрыИИ.Свойство("СсылкаДиалога")
					И ЗначениеЗаполнено(ПараметрыИИ.СсылкаДиалога) Тогда
					ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(ПараметрыИИ.СсылкаДиалога, "[CONTRACT_RECOVERED] submit_dsl получен без обертки dsl");
				КонецЕсли;
			Иначе
				Результат.ТипОтвета = "ОшибкаКонтракта";
				Результат.Текст = "Tool submit_dsl не содержит поля dsl.";
				Возврат Результат;
			КонецЕсли;
		КонецЕсли;
		DSL_JSON = ПопыткаВосстановитьDSL(DSL_JSON, ПараметрыИИ);
		РезультатПроверкиDSL = ИИА_DSL.ПроверитьDSL(DSL_JSON);
		Если НЕ РезультатПроверкиDSL.Успех И СтрНайти(РезультатПроверкиDSL.Сообщение, "steps") > 0 Тогда
			ВосстановленныйDSL = ИИА_DSLПостроитель.ПопыткаВосстановитьDSLИзТекущегоПлана(ПараметрыИИ);
			Если НЕ ПустаяСтрока(ВосстановленныйDSL) Тогда
				DSL_JSON = ВосстановленныйDSL;
				РезультатПроверкиDSL = ИИА_DSL.ПроверитьDSL(DSL_JSON);
			КонецЕсли;
		КонецЕсли;
		РезультатDSL = СоздатьБазовыйРезультатИИ();
		Если РезультатПроверкиDSL.Успех Тогда
			РезультатDSL.ТипОтвета = "DSL";
			РезультатDSL.DSL = DSL_JSON;
			РезультатDSL.ВыполнитьDSL = Истина;
		Иначе
			РезультатDSL.ТипОтвета = "ОшибкаКонтракта";
			РезультатDSL.Текст = "Tool submit_dsl вернул JSON, но он не проходит проверку DSL: " + РезультатПроверкиDSL.Сообщение;
			РезультатDSL.DSL = DSL_JSON;
			РезультатDSL.ВыполнитьDSL = Ложь;
		КонецЕсли;
		РезультатDSL.ToolCalls = Результат.ToolCalls;
		РезультатDSL.ToolName = Результат.ToolName;
		РезультатDSL.ToolArguments = Результат.ToolArguments;
		Если ПустаяСтрока(РезультатDSL.RawModelText) Тогда
			РезультатDSL.RawModelText = Результат.RawModelText;
		КонецЕсли;
		Возврат РезультатDSL;
	КонецЕсли;
	
	Если ИзвлеченныйTool.ToolName = "submit_plan" Тогда
		Если ПустаяСтрока(ИзвлеченныйTool.ArgumentsText) Тогда
			Результат.ТипОтвета = "ОшибкаКонтракта";
			Результат.Текст = "Tool submit_plan не содержит arguments.";
			Возврат Результат;
		КонецЕсли;
		РезультатПлана = РаспознатьОтветИИ(ИзвлеченныйTool.ArgumentsText, ТипСообщения, ПараметрыИИ);
		РезультатПлана.ToolCalls = Результат.ToolCalls;
		РезультатПлана.ToolName = Результат.ToolName;
		РезультатПлана.ToolArguments = Результат.ToolArguments;
		Если ПустаяСтрока(РезультатПлана.RawModelText) Тогда
			РезультатПлана.RawModelText = Результат.RawModelText;
		КонецЕсли;
		Возврат РезультатПлана;
	КонецЕсли;
	
	Если ИзвлеченныйTool.ToolName = "submit_next_step" Тогда
		Если ПустаяСтрока(ИзвлеченныйTool.ArgumentsText) Тогда
			Результат.ТипОтвета = "ОшибкаКонтракта";
			Результат.Текст = "Tool submit_next_step не содержит arguments.";
			Возврат Результат;
		КонецЕсли;
		РезультатШага = РаспознатьОтветИИ(ИзвлеченныйTool.ArgumentsText, ТипСообщения, ПараметрыИИ);
		Если РезультатШага.ТипОтвета = "ОшибкаКонтракта" Тогда
			StepIdКандидат = ИзвлечьJSONПолеИзАргументовToolCall(ИзвлеченныйTool.ArgumentsText, "step_id");
			ВосстановленныйШаг = ИИА_DSLПостроитель.ПопыткаВосстановитьNextStepDSLИзТекущегоПлана(ПараметрыИИ, StepIdКандидат);
			Если ВосстановленныйШаг <> Неопределено Тогда
				ВосстановленныйШаг.ToolCalls = Результат.ToolCalls;
				ВосстановленныйШаг.ToolName = Результат.ToolName;
				ВосстановленныйШаг.ToolArguments = Результат.ToolArguments;
				Возврат ВосстановленныйШаг;
			КонецЕсли;
		КонецЕсли;
		РезультатШага.ToolCalls = Результат.ToolCalls;
		РезультатШага.ToolName = Результат.ToolName;
		РезультатШага.ToolArguments = Результат.ToolArguments;
		Если ПустаяСтрока(РезультатШага.RawModelText) Тогда
			РезультатШага.RawModelText = Результат.RawModelText;
		КонецЕсли;
		Возврат РезультатШага;
	КонецЕсли;
	
	Результат.ТипОтвета = "ToolCall";
	Результат.Текст = ?(Сообщение <> Неопределено И Сообщение.Свойство("content"), Строка(Сообщение.content), "");
	Возврат Результат;
КонецФункции

Функция СформироватьОшибкуИнструмента(Код, Категория, Рекомендация, Детали = "") Экспорт
	ОшибкаИнструмента = Новый Структура;
	ОшибкаИнструмента.Вставить("code", Код);
	ОшибкаИнструмента.Вставить("category", Категория);
	ОшибкаИнструмента.Вставить("recommendation", Рекомендация);
	ОшибкаИнструмента.Вставить("details", Детали);
	Возврат ОшибкаИнструмента;
КонецФункции

Функция ПредставлениеОшибкиИнструмента(Ошибка) Экспорт
	Если Ошибка = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Если ТипЗнч(Ошибка) <> Тип("Структура") Тогда
		Возврат Строка(Ошибка);
	КонецЕсли;
	
	Части = Новый Массив;
	Код = "";
	Категория = "";
	Рекомендация = "";
	Детали = "";
	Если Ошибка.Свойство("code", Код) И НЕ ПустаяСтрока(Строка(Код)) Тогда
		Части.Добавить("code=" + Строка(Код));
	КонецЕсли;
	Если Ошибка.Свойство("category", Категория) И НЕ ПустаяСтрока(Строка(Категория)) Тогда
		Части.Добавить("category=" + Строка(Категория));
	КонецЕсли;
	Если Ошибка.Свойство("recommendation", Рекомендация) И НЕ ПустаяСтрока(Строка(Рекомендация)) Тогда
		Части.Добавить("recommendation=" + Строка(Рекомендация));
	КонецЕсли;
	Если Ошибка.Свойство("details", Детали) И НЕ ПустаяСтрока(Строка(Детали)) Тогда
		Части.Добавить("details=" + Строка(Детали));
	КонецЕсли;
	Если Части.Количество() = 0 Тогда
		Возврат СериализоватьJSONВСтроку(Ошибка);
	КонецЕсли;
	Возврат СтрСоединить(Части, "; ");
КонецФункции

Функция РазобратьBaseUrlПровайдера(URLИзНастроек, БазовыйПутьПоУмолчанию = "/api/v1") Экспорт
	Результат = Новый Структура("Схема,Хост,Порт,БазовыйПуть,ПолныйURL", "https", "", 443, "", "");
	URL = СокрЛП(Строка(URLИзНастроек));
	Если ПустаяСтрока(URL) Тогда
		Результат.БазовыйПуть = БазовыйПутьПоУмолчанию;
		Возврат Результат;
	КонецЕсли;
	
	Если Лев(НРег(URL), 7) = "http://" Тогда
		Результат.Схема = "http";
		URL = Сред(URL, 8);
		Результат.Порт = 80;
	ИначеЕсли Лев(НРег(URL), 8) = "https://" Тогда
		Результат.Схема = "https";
		URL = Сред(URL, 9);
		Результат.Порт = 443;
	КонецЕсли;
	
	ПозицияСлеша = СтрНайти(URL, "/");
	Если ПозицияСлеша > 0 Тогда
		ХостСПортом = Лев(URL, ПозицияСлеша - 1);
		Результат.БазовыйПуть = Сред(URL, ПозицияСлеша);
	Иначе
		ХостСПортом = URL;
		Результат.БазовыйПуть = БазовыйПутьПоУмолчанию;
	КонецЕсли;
	
	Если ПустаяСтрока(Результат.БазовыйПуть) Тогда
		Результат.БазовыйПуть = БазовыйПутьПоУмолчанию;
	КонецЕсли;
	Если Прав(Результат.БазовыйПуть, 1) = "/" Тогда
		Результат.БазовыйПуть = Лев(Результат.БазовыйПуть, СтрДлина(Результат.БазовыйПуть) - 1);
	КонецЕсли;
	Если Лев(Результат.БазовыйПуть, 1) <> "/" Тогда
		Результат.БазовыйПуть = "/" + Результат.БазовыйПуть;
	КонецЕсли;
	
	ПозицияДвоеточия = СтрНайти(ХостСПортом, ":");
	Если ПозицияДвоеточия > 0 Тогда
		Результат.Хост = Лев(ХостСПортом, ПозицияДвоеточия - 1);
		ПортСтрокой = Сред(ХостСПортом, ПозицияДвоеточия + 1);
		Попытка
			Результат.Порт = Число(ПортСтрокой);
		Исключение
		КонецПопытки;
	Иначе
		Результат.Хост = ХостСПортом;
	КонецЕсли;
	
	Результат.ПолныйURL = Результат.Схема + "://" + Результат.Хост + ":" + Строка(Результат.Порт) + Результат.БазовыйПуть;
	Возврат Результат;
КонецФункции

Функция СоздатьHTTPСоединениеБезПрокси(БазовыйДомен, Порт = 443, ИспользоватьTLS = Истина, Таймаут = 30)
	Прокси = Неопределено;
	Попытка
		// Явно отключаем proxy для LLM-вызовов 1С.
		// Это защищает automation и COM-прогоны от shell/system proxy,
		// которые могут быть нужны браузеру/VPN, но ломают HTTP-стек 1С.
		Прокси = Новый ИнтернетПрокси(Ложь);
	Исключение
		Прокси = Неопределено;
	КонецПопытки;
	Если ИспользоватьTLS Тогда
		Возврат Новый HTTPСоединение(БазовыйДомен, Порт, , , Прокси, Таймаут, Новый ЗащищенноеСоединениеOpenSSL());
	КонецЕсли;
	Возврат Новый HTTPСоединение(БазовыйДомен, Порт, , , Прокси, Таймаут);
КонецФункции

// Унифицированный Tooling Layer для HTTP-вызовов с retry/timeout.
Функция ВыполнитьHTTPИнструмент(БазовыйДомен, URLПуть, Заголовки, JSONТело, Таймаут = 30, МаксПопыток = 3, Порт = 443, ИспользоватьTLS = Истина)
	Результат = Новый Структура("Успех,КодСостояния,Тело,Ошибка,Заголовки", Ложь, 0, "", Неопределено, Неопределено);
	
	Для ПопыткаНомер = 1 По МаксПопыток Цикл
		Попытка
			HTTPСоединение = СоздатьHTTPСоединениеБезПрокси(БазовыйДомен, Порт, ИспользоватьTLS, Таймаут);
			HTTPЗапрос = Новый HTTPЗапрос(URLПуть, Заголовки);
			HTTPЗапрос.УстановитьТелоИзСтроки(JSONТело);
			Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
			Результат.КодСостояния = Ответ.КодСостояния;
			Результат.Тело = Ответ.ПолучитьТелоКакСтроку();
			Результат.Заголовки = Ответ.Заголовки;
			
			Если Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300 Тогда
				Результат.Успех = Истина;
				Возврат Результат;
			КонецЕсли;
			
			Если Ответ.КодСостояния = 429 ИЛИ (Ответ.КодСостояния >= 500 И Ответ.КодСостояния <= 599) Тогда
				Если ПопыткаНомер < МаксПопыток Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			Результат.Ошибка = СформироватьОшибкуИнструмента("http_error", "provider_http", "Проверьте API ключ/лимиты/доступность провайдера.", Результат.Тело);
			Возврат Результат;
			
		Исключение
			Если ПопыткаНомер < МаксПопыток Тогда
				Продолжить;
			КонецЕсли;
			ТекстОшибки = ОписаниеОшибки();
			Если СтрНайти(ВРег(ТекстОшибки), "БЕЗОПАСН") > 0 ИЛИ СтрНайти(ВРег(ТекстОшибки), "SAFE") > 0 Тогда
				Результат.Ошибка = СформироватьОшибкуИнструмента("connection_error", "network",
					"Расширение подключено в безопасном режиме. Снимите флаг «Безопасный режим» (Все функции → Расширения конфигурации) и перезапустите 1С.",
					ТекстОшибки);
			ИначеЕсли СтрНайти(ВРег(ТекстОшибки), "PROXY") > 0 Тогда
				Результат.Ошибка = СформироватьОшибкуИнструмента("connection_error", "network",
					"Проверьте proxy/VPN окружение процесса 1С. Для LLM-вызовов используйте прямой доступ в интернет без HTTP_PROXY/HTTPS_PROXY.",
					ТекстОшибки);
			ИначеЕсли СтрНайти(ВРег(ТекстОшибки), "RESOLVE HOST") > 0 ИЛИ СтрНайти(ВРег(ТекстОшибки), "HOST NAME") > 0 Тогда
				Результат.Ошибка = СформироватьОшибкуИнструмента("connection_error", "network",
					"Не удалось разрешить адрес провайдера. Проверьте DNS, VPN/proxy и доступность хоста из процесса 1С.",
					ТекстОшибки);
			Иначе
				Результат.Ошибка = СформироватьОшибкуИнструмента("connection_error", "network", "Проверьте сеть и URL провайдера.", ТекстОшибки);
			КонецЕсли;
			Возврат Результат;
		КонецПопытки;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ВыполнитьЗапросChatCompletions(БазовыйДомен, URLПуть, Заголовки, ТелоЗапроса, Порт = 443, ИспользоватьTLS = Истина, Таймаут = 30)
	РезультатЗапроса = Новый Структура("Успех,Данные,ТекстОтвета,Ошибка,КодСостояния,Заголовки,TotalTokensRaw", Ложь, Неопределено, "", Неопределено, 0, Неопределено, 0);
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ТелоЗапроса);
	JSONТело = ЗаписьJSON.Закрыть();
	
	РезультатHTTP = ВыполнитьHTTPИнструмент(БазовыйДомен, URLПуть, Заголовки, JSONТело, Таймаут, 3, Порт, ИспользоватьTLS);
	РезультатЗапроса.КодСостояния = РезультатHTTP.КодСостояния;
	РезультатЗапроса.Ошибка = РезультатHTTP.Ошибка;
	РезультатЗапроса.ТекстОтвета = РезультатHTTP.Тело;
	РезультатЗапроса.Заголовки = РезультатHTTP.Заголовки;
	РезультатЗапроса.TotalTokensRaw = ИзвлечьЧислоПослеМаркера(РезультатHTTP.Тело, """total_tokens""");
	Если РезультатЗапроса.TotalTokensRaw = 0 Тогда
		РезультатЗапроса.TotalTokensRaw = ИзвлечьЧислоПослеМаркера(РезультатHTTP.Тело, """gitsell_tokens""");
	КонецЕсли;
	Если НЕ РезультатHTTP.Успех Тогда
		Возврат РезультатЗапроса;
	КонецЕсли;
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(РезультатHTTP.Тело);
		РезультатЗапроса.Данные = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		Попытка
			КонтейнерUsage = Неопределено;
			Если ТипЗнч(РезультатЗапроса.Данные) = Тип("Структура")
				ИЛИ ТипЗнч(РезультатЗапроса.Данные) = Тип("ФиксированнаяСтруктура") Тогда
				Если РезультатЗапроса.Данные.Свойство("usage") Тогда
					КонтейнерUsage = РезультатЗапроса.Данные.usage;
				КонецЕсли;
			ИначеЕсли ТипЗнч(РезультатЗапроса.Данные) = Тип("Соответствие")
				ИЛИ ТипЗнч(РезультатЗапроса.Данные) = Тип("ФиксированноеСоответствие") Тогда
				КонтейнерUsage = РезультатЗапроса.Данные.Получить("usage");
			КонецЕсли;
			
			Если КонтейнерUsage <> Неопределено Тогда
				Если ТипЗнч(КонтейнерUsage) = Тип("Структура")
					ИЛИ ТипЗнч(КонтейнерUsage) = Тип("ФиксированнаяСтруктура") Тогда
					Если КонтейнерUsage.Свойство("total_tokens") Тогда
						РезультатЗапроса.TotalTokensRaw = Число(КонтейнерUsage.total_tokens);
					КонецЕсли;
				ИначеЕсли ТипЗнч(КонтейнерUsage) = Тип("Соответствие")
					ИЛИ ТипЗнч(КонтейнерUsage) = Тип("ФиксированноеСоответствие") Тогда
					ЗначениеTotal = КонтейнерUsage.Получить("total_tokens");
					Если ЗначениеTotal <> Неопределено Тогда
						РезультатЗапроса.TotalTokensRaw = Число(ЗначениеTotal);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
		РезультатЗапроса.Успех = Истина;
	Исключение
		РезультатЗапроса.Ошибка = СформироватьОшибкуИнструмента("invalid_json", "provider_contract", "Провайдер вернул невалидный JSON.", ОписаниеОшибки());
	КонецПопытки;
	
	Возврат РезультатЗапроса;
КонецФункции

Функция ПолучитьПолеJSON(Контейнер, ИмяПоля)
	Если Контейнер = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если ТипЗнч(Контейнер) = Тип("Структура") Тогда
		Если Контейнер.Свойство(ИмяПоля) Тогда
			Возврат Контейнер[ИмяПоля];
		КонецЕсли;
	ИначеЕсли ТипЗнч(Контейнер) = Тип("ФиксированнаяСтруктура") Тогда
		Если Контейнер.Свойство(ИмяПоля) Тогда
			Возврат Контейнер[ИмяПоля];
		КонецЕсли;
	ИначеЕсли ТипЗнч(Контейнер) = Тип("Соответствие") Тогда
		Возврат Контейнер.Получить(ИмяПоля);
	ИначеЕсли ТипЗнч(Контейнер) = Тип("ФиксированноеСоответствие") Тогда
		Возврат Контейнер.Получить(ИмяПоля);
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция ПолучитьЧислоJSON(Контейнер, ИмяПоля)
	ЗначениеПоля = ПолучитьПолеJSON(Контейнер, ИмяПоля);
	Если ЗначениеПоля = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	Попытка
		Возврат Число(ЗначениеПоля);
	Исключение
		Возврат 0;
	КонецПопытки;
КонецФункции

Функция ИзвлечьTotalTokensИзКонтейнераUsage(КонтейнерUsage)
	Если КонтейнерUsage = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	ИменаПолей = Новый Массив;
	ИменаПолей.Добавить("gitsell_tokens");
	ИменаПолей.Добавить("total_tokens");
	ИменаПолей.Добавить("totalTokens");
	ИменаПолей.Добавить("total");
	Для Каждого ИмяПоля Из ИменаПолей Цикл
		ЗначениеТокенов = ПолучитьЧислоJSON(КонтейнерUsage, ИмяПоля);
		Если ЗначениеТокенов > 0 Тогда
			Возврат ЗначениеТокенов;
		КонецЕсли;
	КонецЦикла;
	
	PromptTokens = 0;
	CompletionTokens = 0;
	ИменаPrompt = Новый Массив;
	ИменаPrompt.Добавить("prompt_tokens");
	ИменаPrompt.Добавить("input_tokens");
	ИменаPrompt.Добавить("promptTokens");
	ИменаPrompt.Добавить("inputTokens");
	Для Каждого ИмяПоля Из ИменаPrompt Цикл
		PromptTokens = ПолучитьЧислоJSON(КонтейнерUsage, ИмяПоля);
		Если PromptTokens > 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	ИменаCompletion = Новый Массив;
	ИменаCompletion.Добавить("completion_tokens");
	ИменаCompletion.Добавить("output_tokens");
	ИменаCompletion.Добавить("completionTokens");
	ИменаCompletion.Добавить("outputTokens");
	Для Каждого ИмяПоля Из ИменаCompletion Цикл
		CompletionTokens = ПолучитьЧислоJSON(КонтейнерUsage, ИмяПоля);
		Если CompletionTokens > 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если PromptTokens > 0 ИЛИ CompletionTokens > 0 Тогда
		Возврат PromptTokens + CompletionTokens;
	КонецЕсли;
	
	Возврат 0;
КонецФункции

Функция ИзвлечьUsageИзОтветаПровайдера(Данные, ТекстОтвета = "")
	UsageStruct = Новый Структура("TotalTokens", 0);
	Если Данные <> Неопределено Тогда
		ИменаКонтейнеров = Новый Массив;
		ИменаКонтейнеров.Добавить("usage");
		ИменаКонтейнеров.Добавить("metrics");
		ИменаКонтейнеров.Добавить("token_usage");
		ИменаКонтейнеров.Добавить("usage_metadata");
		ИменаКонтейнеров.Добавить("usageMetadata");
		Для Каждого ИмяКонтейнера Из ИменаКонтейнеров Цикл
			КонтейнерUsage = ПолучитьПолеJSON(Данные, ИмяКонтейнера);
			TotalTokens = ИзвлечьTotalTokensИзКонтейнераUsage(КонтейнерUsage);
			Если TotalTokens > 0 Тогда
				UsageStruct.TotalTokens = TotalTokens;
				Возврат UsageStruct;
			КонецЕсли;
		КонецЦикла;
		
		TotalTokens = ПолучитьЧислоJSON(Данные, "gitsell_tokens");
		Если TotalTokens = 0 Тогда
			TotalTokens = ПолучитьЧислоJSON(Данные, "total_tokens");
		КонецЕсли;
		Если TotalTokens = 0 Тогда
			TotalTokens = ПолучитьЧислоJSON(Данные, "totalTokens");
		КонецЕсли;
		Если TotalTokens > 0 Тогда
			UsageStruct.TotalTokens = TotalTokens;
			Возврат UsageStruct;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ИзвлечьUsageИзТекстаОтветаПровайдера(ТекстОтвета);
КонецФункции

Функция ИзвлечьЧислоПослеМаркера(ТекстОтвета, Маркер)
	Если ПустаяСтрока(ТекстОтвета) Или ПустаяСтрока(Маркер) Тогда
		Возврат 0;
	КонецЕсли;
	ПозицияМаркера = СтрНайти(ВРег(ТекстОтвета), ВРег(Маркер));
	Если ПозицияМаркера = 0 Тогда
		Возврат 0;
	КонецЕсли;
	Позиция = ПозицияМаркера + СтрДлина(Маркер);
	ДлинаТекста = СтрДлина(ТекстОтвета);
	Пока Позиция <= ДлинаТекста Цикл
		Символ = Сред(ТекстОтвета, Позиция, 1);
		КодСим = КодСимвола(Символ);
		Если КодСим >= 48 И КодСим <= 57 Тогда
			Прервать;
		КонецЕсли;
		Позиция = Позиция + 1;
	КонецЦикла;
	Если Позиция > ДлинаТекста Тогда
		Возврат 0;
	КонецЕсли;
	НачалоЧисла = Позиция;
	Пока Позиция <= ДлинаТекста Цикл
		Символ = Сред(ТекстОтвета, Позиция, 1);
		КодСим = КодСимвола(Символ);
		Если КодСим < 48 ИЛИ КодСим > 57 Тогда
			Прервать;
		КонецЕсли;
		Позиция = Позиция + 1;
	КонецЦикла;
	Попытка
		Возврат Число(Сред(ТекстОтвета, НачалоЧисла, Позиция - НачалоЧисла));
	Исключение
		Возврат 0;
	КонецПопытки;
КонецФункции

Функция ИзвлечьUsageИзТекстаОтветаПровайдера(ТекстОтвета)
	UsageStruct = Новый Структура("TotalTokens", 0);
	Если ПустаяСтрока(ТекстОтвета) Тогда
		Возврат UsageStruct;
	КонецЕсли;
	
	TotalTokens = ИзвлечьЧислоПослеМаркера(ТекстОтвета, """gitsell_tokens""");
	Если TotalTokens = 0 Тогда
		TotalTokens = ИзвлечьЧислоПослеМаркера(ТекстОтвета, """total_tokens""");
	КонецЕсли;
	Если TotalTokens = 0 Тогда
		TotalTokens = ИзвлечьЧислоПослеМаркера(ТекстОтвета, """totalTokens""");
	КонецЕсли;
	Если TotalTokens = 0 Тогда
		PromptTokens = ИзвлечьЧислоПослеМаркера(ТекстОтвета, """prompt_tokens""");
		Если PromptTokens = 0 Тогда
			PromptTokens = ИзвлечьЧислоПослеМаркера(ТекстОтвета, """input_tokens""");
		КонецЕсли;
		CompletionTokens = ИзвлечьЧислоПослеМаркера(ТекстОтвета, """completion_tokens""");
		Если CompletionTokens = 0 Тогда
			CompletionTokens = ИзвлечьЧислоПослеМаркера(ТекстОтвета, """output_tokens""");
		КонецЕсли;
		Если PromptTokens > 0 ИЛИ CompletionTokens > 0 Тогда
			TotalTokens = PromptTokens + CompletionTokens;
		КонецЕсли;
	КонецЕсли;
	UsageStruct.TotalTokens = TotalTokens;
	Возврат UsageStruct;
КонецФункции

Функция ИзвлечьTotalTokensИзТекстаОтветаПровайдера(ТекстОтвета) Экспорт
	UsageStruct = ИзвлечьUsageИзТекстаОтветаПровайдера(ТекстОтвета);
	Возврат ?(UsageStruct <> Неопределено И UsageStruct.Свойство("TotalTokens"), UsageStruct.TotalTokens, 0);
КонецФункции

Функция ДобавитьСообщениеАссистентаСТулколлом(Сообщения, СообщениеМодели)
	СообщениеАссистента = Новый Структура;
	СообщениеАссистента.Вставить("role", "assistant");
	СообщениеАссистента.Вставить("content", ?(СообщениеМодели.Свойство("content"), Строка(СообщениеМодели.content), ""));
	СообщениеАссистента.Вставить("tool_calls", СообщениеМодели.tool_calls);
	Сообщения.Добавить(СообщениеАссистента);
КонецФункции

Процедура ДобавитьСообщениеРезультатаИнструмента(Сообщения, ToolCallId, Содержимое)
	СообщениеИнструмента = Новый Структура;
	СообщениеИнструмента.Вставить("role", "tool");
	СообщениеИнструмента.Вставить("tool_call_id", ToolCallId);
	СообщениеИнструмента.Вставить("content", Содержимое);
	Сообщения.Добавить(СообщениеИнструмента);
КонецПроцедуры

Функция ПредставлениеКонтентаСообщенияДляЛога(Содержимое)
	Если Содержимое = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Если ТипЗнч(Содержимое) = Тип("Строка") Тогда
		Возврат Содержимое;
	КонецЕсли;
	Попытка
		Возврат СериализоватьJSONВСтроку(Содержимое);
	Исключение
		Возврат Строка(Содержимое);
	КонецПопытки;
КонецФункции

// Вызывает API Gitsell AI Proxy (OpenAI-compatible)
//
// Параметры:
//  ТипСообщения - Строка
//  ТекстПользователя - Строка
//  История - ТаблицаЗначений
//  ПараметрыИИ - Структура
//  СистемныйПромпт - Строка
//  Температура - Число - (опционально) температура модели
//
// Возвращаемое значение:
//  Структура - результат
//
Функция ВызватьGitsellAiProxy(ТипСообщения, ТекстПользователя, История, ПараметрыИИ, СистемныйПромпт = "", Температура = Неопределено)
	
	Результат = СоздатьБазовыйРезультатИИ();
	
	// URL
	URLИзНастроек = ПараметрыИИ.Provider_BaseUrl;
	Если ПустаяСтрока(URLИзНастроек) Тогда
		URLИзНастроек = "https://gitsell.ru/api/v1";
	КонецЕсли;
	ПараметрыURL = РазобратьBaseUrlПровайдера(URLИзНастроек, "/api/v1");
	БазовыйДомен = ПараметрыURL.Хост;
	URLПуть = ПараметрыURL.БазовыйПуть + "/chat/completions";
	ИспользоватьTLS = ПараметрыURL.Схема = "https";
	Порт = ПараметрыURL.Порт;
	
	Токен = ПараметрыИИ.Provider_ApiKey;
	Если ПустаяСтрока(Токен) И ИспользоватьTLS Тогда
		Результат.ТипОтвета = "Ошибка";
		Результат.Текст = "Не указан API ключ (токен) для ИИ-провайдера";
		Возврат Результат;
	КонецЕсли;
	
	// Промпт
	ТипДиалога = Неопределено;
	Если ПараметрыИИ.Свойство("ТипДиалога") Тогда
		ТипДиалога = ПараметрыИИ.ТипДиалога;
	КонецЕсли;
	
	// Передаем СсылкаДиалога для логирования RAG, если она есть в параметрах
	СсылкаДиалога = Неопределено;
	Если ПараметрыИИ.Свойство("СсылкаДиалога") Тогда
		СсылкаДиалога = ПараметрыИИ.СсылкаДиалога;
	КонецЕсли;
	
	// Защита от бесконечной рекурсии RAG
	ИспользоватьRAG = Ложь;
	Если ПараметрыИИ.Свойство("ИспользоватьRAG") Тогда
		ИспользоватьRAG = ПараметрыИИ.ИспользоватьRAG;
	КонецЕсли;
	
	Промпт = ИИА_Промты.СформироватьПромпт(ТипДиалога, ТипСообщения, ТекстПользователя, История, СистемныйПромпт, СсылкаДиалога, ИспользоватьRAG);
	
	// Логирование промпта
	ТекстПромпта = "";
	Для Каждого Сообщение Из Промпт.Сообщения Цикл
		Роль = ?(Сообщение.Свойство("role"), Сообщение.role, "");
		Содержимое = ?(Сообщение.Свойство("content"), Сообщение.content, "");
		ТекстПромпта = ТекстПромпта + "[" + Роль + "]" + Символы.ПС + ПредставлениеКонтентаСообщенияДляЛога(Содержимое) + Символы.ПС + Символы.ПС;
	КонецЦикла;
	Результат.Вставить("Промпт", ТекстПромпта);
	
	// Тело запроса
	ТелоЗапроса = Новый Структура;
	
	Модель = ?(ПараметрыИИ.Свойство("Модель") И НЕ ПустаяСтрока(ПараметрыИИ.Модель), ПараметрыИИ.Модель, "deepseek-chat");
	
	ТелоЗапроса.Вставить("model", Модель);
	ТелоЗапроса.Вставить("messages", ПодготовитьСообщенияСНативнымиВложениями(Промпт.Сообщения, ПараметрыИИ));
	
	ОжидаемыйФормат = ПолучитьОжидаемыйФорматОтвета(ПараметрыИИ);
	СтратегияОтвета = ПостроитьСтратегиюОтвета(ПараметрыИИ, ОжидаемыйФормат);
	ДобавитьИнструментыВТелоЗапроса(ТелоЗапроса, ПараметрыИИ, ОжидаемыйФормат, СтратегияОтвета);
	ДобавитьРежимJSONВТелоЗапроса(ТелоЗапроса, ПараметрыИИ, ОжидаемыйФормат, СтратегияОтвета);
	
	// ТЕМПЕРАТУРА: Используем переданную или 0.0 по умолчанию
	ЗначениеТемпературы = ?(Температура = Неопределено, 0.0, Температура);
	ТелоЗапроса.Вставить("temperature", ЗначениеТемпературы);
	
	// Явно ограничиваем max_tokens, чтобы провайдер не резервировал дефолтные 65536 токенов
	// и не отклонял запросы по budget/credits до фактического выполнения.
	ТелоЗапроса.Вставить("max_tokens", ПолучитьMaxTokensChatCompletions(ПараметрыИИ));
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("Accept", "application/json");
	Если НЕ ПустаяСтрока(Токен) Тогда
		Заголовки.Вставить("Authorization", "Bearer " + Токен);
	КонецЕсли;
	Если СтрНайти(НРег(URLИзНастроек), "gitsell.ru") > 0 Тогда
		Заголовки.Вставить("X-Gitsell-Repo", "msrv-tech/AI_agent");
	КонецЕсли;
	Если ПараметрыИИ.Свойство("trace_id") И НЕ ПустаяСтрока(Строка(ПараметрыИИ.trace_id)) Тогда
		Заголовки.Вставить("X-Trace-Id", Строка(ПараметрыИИ.trace_id));
	КонецЕсли;
	
	КоличествоШаговИнструментов = 0;
	НакопленныеТокеныUsage = 0;
	ТаймаутЗапроса = ПолучитьТаймаутChatCompletions(ПараметрыИИ);
	Пока Истина Цикл
		РезультатЗапроса = ВыполнитьЗапросChatCompletions(БазовыйДомен, URLПуть, Заголовки, ТелоЗапроса, Порт, ИспользоватьTLS, ТаймаутЗапроса);
		Если НЕ РезультатЗапроса.Успех Тогда
			КодСостояния = РезультатЗапроса.КодСостояния;
			Результат.ТипОтвета = "Ошибка";
			Если КодСостояния = 401 Тогда
				Результат.Текст = "Ошибка 401: Требуется авторизация. Токен отозван или невалиден.";
			ИначеЕсли КодСостояния = 0 И РезультатЗапроса.Ошибка <> Неопределено Тогда
				Результат.Текст = "Ошибка API (0): " + ПредставлениеОшибкиИнструмента(РезультатЗапроса.Ошибка);
			Иначе
				Результат.Текст = "Ошибка API (" + Строка(КодСостояния) + "): " + РезультатЗапроса.ТекстОтвета;
			КонецЕсли;
			Если РезультатЗапроса.Ошибка <> Неопределено Тогда
				Результат.Ошибки = РезультатЗапроса.Ошибка;
			Иначе
				Результат.Ошибки = РезультатЗапроса.ТекстОтвета;
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;
		
		Данные = РезультатЗапроса.Данные;
		UsageStruct = Новый Структура("TotalTokens", ?(РезультатЗапроса.Свойство("TotalTokensRaw"), РезультатЗапроса.TotalTokensRaw, 0));
		Если UsageStruct.TotalTokens = 0 Тогда
			UsageStruct = ИзвлечьUsageИзОтветаПровайдера(Данные, РезультатЗапроса.ТекстОтвета);
		КонецЕсли;
		Если UsageStruct.TotalTokens > 0 Тогда
			НакопленныеТокеныUsage = НакопленныеТокеныUsage + UsageStruct.TotalTokens;
			Результат.Usage = Новый Структура("TotalTokens", НакопленныеТокеныUsage);
		КонецЕсли;
		
		Если НЕ Данные.Свойство("choices") ИЛИ Данные.choices.Количество() = 0 Тогда
			Результат.ТипОтвета = "ОшибкаКонтракта";
			Результат.Текст = "Ответ модели не содержит choices.";
			Возврат Результат;
		КонецЕсли;
		
		Choice = Данные.choices[0];
		Если Choice.Свойство("finish_reason") Тогда
			Результат.FinishReason = Строка(Choice.finish_reason);
		КонецЕсли;
		Если НЕ Choice.Свойство("message") Тогда
			Результат.ТипОтвета = "ОшибкаКонтракта";
			Результат.Текст = "Ответ модели не содержит message.";
			Возврат Результат;
		КонецЕсли;
		
		Если Choice.message.Свойство("tool_calls") И ТипЗнч(Choice.message.tool_calls) = Тип("Массив") И Choice.message.tool_calls.Количество() > 0 Тогда
			ИзвлеченныйTool = ИзвлечьПервыйToolCall(Choice.message);
			Если ИзвлеченныйTool.Успех И ЭтоИнструментВложения(ИзвлеченныйTool.ToolName) Тогда
				Если КоличествоШаговИнструментов >= 3 Тогда
					Результат.ТипОтвета = "ОшибкаКонтракта";
					Результат.Текст = "Превышен лимит внутренних вызовов инструментов вложений.";
					Возврат Результат;
				КонецЕсли;
				ДобавитьЛогИнструментаВложения(СсылкаДиалога, "ATTACHMENT_TOOL_REQUESTED_BY_MODEL", ИзвлеченныйTool.ToolName, ИзвлеченныйTool.ArgumentsText);
				ToolCallId = "";
				Если ТипЗнч(ИзвлеченныйTool.ToolCall) = Тип("Структура") И ИзвлеченныйTool.ToolCall.Свойство("id") Тогда
					ToolCallId = Строка(ИзвлеченныйTool.ToolCall.id);
				КонецЕсли;
				Если ПустаяСтрока(ToolCallId) Тогда
					ToolCallId = Строка(Новый УникальныйИдентификатор);
				КонецЕсли;
				РезультатИнструмента = ВыполнитьИнструментВложения(ИзвлеченныйTool.ToolName, ИзвлеченныйTool.ArgumentsText, СсылкаДиалога);
				ДобавитьСообщениеАссистентаСТулколлом(ТелоЗапроса.messages, Choice.message);
				ДобавитьСообщениеРезультатаИнструмента(ТелоЗапроса.messages, ToolCallId, РезультатИнструмента);
				КоличествоШаговИнструментов = КоличествоШаговИнструментов + 1;
				Продолжить;
			КонецЕсли;
			
			РезультатРаспознавания = ПостроитьРезультатИзToolCall(Choice.message, ТипСообщения, ПараметрыИИ);
		ИначеЕсли СтратегияОтвета.UseBuiltInToolCall Тогда
			РезультатРаспознавания = СоздатьБазовыйРезультатИИ();
			РезультатРаспознавания.ТипОтвета = "ОшибкаКонтракта";
			РезультатРаспознавания.Текст = "Модель не вернула tool_calls для обязательного structured-output режима. Провайдер/модель не поддерживает required tool-calling.";
		ИначеЕсли Choice.message.Свойство("content") Тогда
			ТекстОтветаИИ = Строка(Choice.message.content);
			РезультатРаспознавания = РаспознатьОтветИИ(ТекстОтветаИИ, ТипСообщения, ПараметрыИИ);
		Иначе
			РезультатРаспознавания = СоздатьБазовыйРезультатИИ();
			РезультатРаспознавания.ТипОтвета = "ОшибкаКонтракта";
			РезультатРаспознавания.Текст = "Ответ модели не содержит ни content, ни tool_calls.";
		КонецЕсли;
		
		Для Каждого КлючЗначение Из РезультатРаспознавания Цикл
			Если КлючЗначение.Ключ = "Usage"
				И КлючЗначение.Значение = Неопределено
				И Результат.Свойство("Usage")
				И Результат.Usage <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			Результат.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
		КонецЦикла;
		Прервать;
	КонецЦикла;
	
	Если НакопленныеТокеныUsage > 0 Тогда
		Результат.Вставить("Usage", Новый Структура("TotalTokens", НакопленныеТокеныUsage));
	КонецЕсли;
	
	Если КоличествоШаговИнструментов > 0 Тогда
		Результат.Вставить("ToolName", "attachment_tool_loop");
		Если ПустаяСтрока(Результат.RawModelText) И НЕ ПустаяСтрока(Результат.Текст) Тогда
			Результат.RawModelText = Результат.Текст;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Формирует промпт для ИИ с учетом контекста
//
// Параметры:
//  ТипСообщения - Строка - тип сообщения
//  ТекстПользователя - Строка - текст от пользователя
//  История - ТаблицаЗначений - история сообщений
//
// Возвращаемое значение:
//  Структура - структура с сообщениями для ИИ
//
Функция СформироватьПромптДляИИ(ТипСообщения, ТекстПользователя, История) Экспорт
	
	// Функция перенесена в общий модуль ИИА_Промты
	// Оставлена для совместимости
	// Используем Агент как тип по умолчанию
	Возврат ИИА_Промты.СформироватьПромпт(Перечисления.ИИА_ТипДиалога.Агент, ТипСообщения, ТекстПользователя, История, "");
	
КонецФункции

// Распознает ответ ИИ и определяет его тип
//
// Параметры:
//  ТекстОтветаИИ - Строка - текст ответа от ИИ
//  ТипСообщения - Строка - тип исходного сообщения
//  ПараметрыИИ - Структура - (опционально) настройки провайдера
//
// Возвращаемое значение:
//  Структура - структура результата с распознанным типом и данными
//
Функция РаспознатьОтветИИ(ТекстОтветаИИ, ТипСообщения, ПараметрыИИ = Неопределено) Экспорт
	
	Результат = СоздатьБазовыйРезультатИИ();
	Результат.Текст = ТекстОтветаИИ;
	Результат.RawModelText = ТекстОтветаИИ;
	
	ОжидаемыйФормат = ПолучитьОжидаемыйФорматОтвета(ПараметрыИИ);
	
	Если ОжидаемыйФормат = "plan" Тогда
		Норм = ИИА_DSL.НормализоватьJSONТекст(ТекстОтветаИИ);
		Если ПустаяСтрока(Норм) Тогда
			Результат.ТипОтвета = "ОшибкаКонтракта";
			Результат.Текст = "Ожидался typed plan JSON, но JSON не найден.";
			Возврат Результат;
		КонецЕсли;
		
		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(Норм);
			Данные = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();
			
			ШагиПлана = ПолучитьСвойствоИзСтруктуры(Данные, "steps", Неопределено);
			Если ЭтоМассивоподобноеЗначение(ШагиПлана) И ШагиПлана.Количество() > 0 Тогда
				Результат.ТипОтвета = "Текст";
				Результат.Текст = Норм;
				Возврат Результат;
			КонецЕсли;
			Если ЭтоПохожеНаВалидныйTypedPlanJSON(Норм) Тогда
				Результат.ТипОтвета = "Текст";
				Результат.Текст = Норм;
				Возврат Результат;
			КонецЕсли;
		Исключение
			// упадем ниже
			ТекстОшибки = ОписаниеОшибки();
		КонецПопытки;

		Если ЭтоПохожеНаВалидныйTypedPlanJSON(Норм) Тогда
			Результат.ТипОтвета = "Текст";
			Результат.Текст = Норм;
			Возврат Результат;
		КонецЕсли;
		
		Результат.ТипОтвета = "ОшибкаКонтракта";
		Результат.Текст = "Ожидался typed plan JSON с массивом steps, но получен другой формат.";
		Возврат Результат;
	КонецЕсли;
	
	Если ОжидаемыйФормат = "next_step_dsl" Тогда
		Норм = ИИА_DSL.НормализоватьJSONТекст(ТекстОтветаИИ);
		Если ПустаяСтрока(Норм) Тогда
			Результат.ТипОтвета = "ОшибкаКонтракта";
			Результат.Текст = "Ожидался JSON объект submit_next_step, но JSON не найден.";
			Возврат Результат;
		КонецЕсли;

		Попытка
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(Норм);
			Данные = ПрочитатьJSON(ЧтениеJSON);
			ЧтениеJSON.Закрыть();

			Если ТипЗнч(Данные) = Тип("Структура") И Данные.Свойство("step_id") И Данные.Свойство("steps") Тогда
				ШагИД = Строка(Данные.step_id);
				DSLСтруктура = Новый Структура;
				Если Данные.Свойство("dsl_version") Тогда
					DSLСтруктура.Вставить("dsl_version", Данные.dsl_version);
				Иначе
					DSLСтруктура.Вставить("dsl_version", 2);
				КонецЕсли;
				DSLСтруктура.Вставить("steps", Данные.steps);
				DSLJSON = СериализоватьJSONВСтроку(DSLСтруктура);
				РезультатПроверкиDSL = ИИА_DSL.ПроверитьDSL(DSLJSON);
				Если НЕ РезультатПроверкиDSL.Успех Тогда
					Результат.ТипОтвета = "ОшибкаКонтракта";
					Результат.Текст = "Tool submit_next_step вернул JSON, но он не проходит проверку DSL: " + РезультатПроверкиDSL.Сообщение;
					Результат.DSL = DSLJSON;
					Возврат Результат;
				КонецЕсли;
				Результат.ТипОтвета = "DSL";
				Результат.DSL = DSLJSON;
				Результат.ВыполнитьDSL = Истина;
				Результат.PlanStepId = ШагИД;
				Результат.Текст = Норм;
				Возврат Результат;
			КонецЕсли;
		Исключение
			ТекстОшибки = ОписаниеОшибки();
		КонецПопытки;

		Результат.ТипОтвета = "ОшибкаКонтракта";
		Результат.Текст = "Ожидался JSON объект submit_next_step со свойствами step_id и steps.";
		Возврат Результат;
	КонецЕсли;
	
	// Явно разрешенный текстовый ответ (без DSL-контракта), например для summary.
	Если ОжидаемыйФормат = "text" Тогда
		Результат.ТипОтвета = "Текст";
		Результат.Текст = ТекстОтветаИИ;
		Возврат Результат;
	КонецЕсли;
	
	Если ОжидаемыйФормат = "dsl" Тогда
		Результат.ТипОтвета = "ОшибкаКонтракта";
		Результат.Текст = "Structured DSL-режим требует native tool-calling submit_dsl. Текстовый DSL fallback отключен.";
		Возврат Результат;
	КонецЕсли;
	
	Результат.ТипОтвета = "ОшибкаКонтракта";
	Результат.Текст = "Неподдерживаемый structured-output режим без native tool-calling или json-mode.";
	
	Возврат Результат;
	
КонецФункции

Функция ПопыткаВосстановитьDSL(DSL_JSON, ПараметрыИИ)
	
	Если ПустаяСтрока(DSL_JSON) Тогда
		Возврат DSL_JSON;
	КонецЕсли;
	
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(DSL_JSON);
		Сценарий = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		
		Если ТипЗнч(Сценарий) = Тип("Структура") Тогда
			Если НЕ Сценарий.Свойство("steps") И Сценарий.Свойство("action") Тогда
				Обертка = Новый Структура;
				Обертка.Вставить("dsl_version", 1);
				Шаги = Новый Массив;
				Шаги.Добавить(Сценарий);
				Обертка.Вставить("steps", Шаги);
				
				ЗаписьJSON = Новый ЗаписьJSON;
				ЗаписьJSON.УстановитьСтроку();
				ЗаписатьJSON(ЗаписьJSON, Обертка);
				НовыйJSON = ЗаписьJSON.Закрыть();
				
				Если НЕ ПустаяСтрока(НовыйJSON) Тогда
					Если ПараметрыИИ <> Неопределено 
						И ТипЗнч(ПараметрыИИ) = Тип("Структура")
						И ПараметрыИИ.Свойство("СсылкаДиалога")
						И ЗначениеЗаполнено(ПараметрыИИ.СсылкаДиалога) Тогда
						ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(ПараметрыИИ.СсылкаДиалога, "[CONTRACT_RECOVERED] DSL обернут в steps");
					КонецЕсли;
					
					Возврат НовыйJSON;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат DSL_JSON;
	
КонецФункции

// Нормализует mock-ответ к структуре, совместимой с ответом ВызватьИИ (режим холостого хода)
//
Функция НормализоватьMockОтвет(MockОтвет)
	Результат = СоздатьБазовыйРезультатИИ();
	
	Если ТипЗнч(MockОтвет) = Тип("Строка") Тогда
		Результат.Текст = MockОтвет;
		Результат.RawModelText = MockОтвет;
	ИначеЕсли ТипЗнч(MockОтвет) = Тип("Структура") Тогда
		Если MockОтвет.Свойство("Текст") Тогда
			Результат.Текст = MockОтвет.Текст;
		КонецЕсли;
		Если MockОтвет.Свойство("ТипОтвета") Тогда
			Результат.ТипОтвета = MockОтвет.ТипОтвета;
		КонецЕсли;
		Если MockОтвет.Свойство("DSL") Тогда
			Результат.DSL = MockОтвет.DSL;
		КонецЕсли;
		Если MockОтвет.Свойство("Запрос") Тогда
			Результат.Запрос = MockОтвет.Запрос;
		КонецЕсли;
		Если MockОтвет.Свойство("ВыполнитьDSL") Тогда
			Результат.ВыполнитьDSL = MockОтвет.ВыполнитьDSL;
		КонецЕсли;
		Если MockОтвет.Свойство("Usage") Тогда
			Результат.Usage = MockОтвет.Usage;
		КонецЕсли;
		Если MockОтвет.Свойство("Ошибки") Тогда
			Результат.Ошибки = MockОтвет.Ошибки;
		КонецЕсли;
		Если MockОтвет.Свойство("ToolCalls") Тогда
			Результат.ToolCalls = MockОтвет.ToolCalls;
		КонецЕсли;
		Если MockОтвет.Свойство("ToolName") Тогда
			Результат.ToolName = MockОтвет.ToolName;
		КонецЕсли;
		Если MockОтвет.Свойство("ToolArguments") Тогда
			Результат.ToolArguments = MockОтвет.ToolArguments;
		КонецЕсли;
		Если MockОтвет.Свойство("PlanStepId") Тогда
			Результат.PlanStepId = MockОтвет.PlanStepId;
		КонецЕсли;
		Если MockОтвет.Свойство("FinishReason") Тогда
			Результат.FinishReason = MockОтвет.FinishReason;
		КонецЕсли;
		Если MockОтвет.Свойство("RawModelText") Тогда
			Результат.RawModelText = MockОтвет.RawModelText;
		ИначеЕсли НЕ ПустаяСтрока(Результат.Текст) Тогда
			Результат.RawModelText = Результат.Текст;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

#КонецОбласти






