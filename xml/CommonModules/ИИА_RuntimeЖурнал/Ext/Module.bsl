#Область ПрограммныйИнтерфейс

Функция ПолучитьСостояниеОркестратора(СсылкаДиалога) Экспорт
	Результат = Новый Структура("ТекущаяСтадия,ПоследнийПереход,НомерПопытки,execution_policy,active_subgraph,subgraph_history,decision_log,active_step_id,thread_id", "Intent", "", 0, "", "", Новый Массив, Новый Массив, "", "");
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Оркестратор_Стадия") Тогда
		Результат.ТекущаяСтадия = Строка(СтруктураДанных.Оркестратор_Стадия);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Оркестратор_Переход") Тогда
		Результат.ПоследнийПереход = Строка(СтруктураДанных.Оркестратор_Переход);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Оркестратор_Попытка") Тогда
		Результат.НомерПопытки = СтруктураДанных.Оркестратор_Попытка;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Execution_Policy") Тогда
		Результат.execution_policy = Строка(СтруктураДанных.Execution_Policy);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Active_Subgraph") Тогда
		Результат.active_subgraph = Строка(СтруктураДанных.Active_Subgraph);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Subgraph_History") И ТипЗнч(СтруктураДанных.Subgraph_History) = Тип("Массив") Тогда
		Результат.subgraph_history = СтруктураДанных.Subgraph_History;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Decision_Log") И ТипЗнч(СтруктураДанных.Decision_Log) = Тип("Массив") Тогда
		Результат.decision_log = СтруктураДанных.Decision_Log;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Active_Step_Id") Тогда
		Результат.active_step_id = Строка(СтруктураДанных.Active_Step_Id);
	КонецЕсли;
	Если СтруктураДанных.Свойство("Thread_Id") Тогда
		Результат.thread_id = Строка(СтруктураДанных.Thread_Id);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьDecisionTimeline(СсылкаДиалога, Лимит = 20) Экспорт
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат "";
	КонецЕсли;
	
	Состояние = ПолучитьСостояниеОркестратора(СсылкаДиалога);
	Если Состояние = Неопределено
		ИЛИ НЕ Состояние.Свойство("decision_log")
		ИЛИ ТипЗнч(Состояние.decision_log) <> Тип("Массив")
		ИЛИ Состояние.decision_log.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Если Лимит <= 0 Тогда
		Лимит = 20;
	КонецЕсли;
	
	НачальныйИндекс = Макс(0, Состояние.decision_log.Количество() - Лимит);
	СтрокиТаймлайна = Новый Массив;
	Для Индекс = НачальныйИндекс По Состояние.decision_log.Количество() - 1 Цикл
		ЗаписьРешения = Состояние.decision_log[Индекс];
		Если ТипЗнч(ЗаписьРешения) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаРешения = "";
		Если ЗаписьРешения.Свойство("timestamp") И ЗаписьРешения.timestamp <> Неопределено Тогда
			СтрокаРешения = Формат(ЗаписьРешения.timestamp, "ДФ=dd.MM HH:mm:ss") + " | ";
		КонецЕсли;
		СтрокаРешения = СтрокаРешения + ?(ЗаписьРешения.Свойство("kind"), Строка(ЗаписьРешения.kind), "");
		СтрокаРешения = СтрокаРешения + " -> " + ?(ЗаписьРешения.Свойство("decision"), Строка(ЗаписьРешения.decision), "");
		Если ЗаписьРешения.Свойство("source") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.source)) Тогда
			СтрокаРешения = СтрокаРешения + " | source=" + Строка(ЗаписьРешения.source);
		КонецЕсли;
		Если ЗаписьРешения.Свойство("step_id") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.step_id)) Тогда
			СтрокаРешения = СтрокаРешения + " | step=" + Строка(ЗаписьРешения.step_id);
		КонецЕсли;
		Если ЗаписьРешения.Свойство("policy") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.policy)) Тогда
			СтрокаРешения = СтрокаРешения + " | policy=" + Строка(ЗаписьРешения.policy);
		КонецЕсли;
		Если ЗаписьРешения.Свойство("reason") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.reason)) Тогда
			СтрокаРешения = СтрокаРешения + " | reason=" + Строка(ЗаписьРешения.reason);
		КонецЕсли;
		СтрокиТаймлайна.Добавить(СтрокаРешения);
	КонецЦикла;
	
	Возврат СтрСоединить(СтрокиТаймлайна, Символы.ПС);
КонецФункции

Функция ПолучитьПоследнийЧекпоинтОркестратора(СсылкаДиалога) Экспорт
	Результат = Новый Структура;
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Оркестратор_ПоследнийЧекпоинт")
		И ТипЗнч(СтруктураДанных.Оркестратор_ПоследнийЧекпоинт) = Тип("Структура") Тогда
		Возврат СтруктураДанных.Оркестратор_ПоследнийЧекпоинт;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьИсториюЧекпоинтовОркестратора(СсылкаДиалога, Лимит = 20) Экспорт
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	Если Лимит <= 0 Тогда
		Лимит = 20;
	КонецЕсли;
	
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено
		ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура")
		ИЛИ НЕ СтруктураДанных.Свойство("Оркестратор_ИсторияЧекпоинтов")
		ИЛИ ТипЗнч(СтруктураДанных.Оркестратор_ИсторияЧекпоинтов) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	
	TraceId = ?(СтруктураДанных.Свойство("trace_id"), Строка(СтруктураДанных.trace_id), "");
	ThreadId = ?(СтруктураДанных.Свойство("Thread_Id"), Строка(СтруктураДанных.Thread_Id), "");
	История = СтруктураДанных.Оркестратор_ИсторияЧекпоинтов;
	ИндексНачала = Макс(0, История.Количество() - Лимит);
	ИндексПоследнего = История.Количество() - 1;
	
	Для Индекс = ИндексНачала По ИндексПоследнего Цикл
		Запись = История[Индекс];
		Если ТипЗнч(Запись) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		НормЗапись = Новый Структура;
		НормЗапись.Вставить("checkpoint_index", Индекс);
		НормЗапись.Вставить("is_latest", Индекс = ИндексПоследнего);
		НормЗапись.Вставить("timestamp", ?(Запись.Свойство("timestamp"), Запись.timestamp, Неопределено));
		НормЗапись.Вставить("checkpoint_type", ?(Запись.Свойство("checkpoint_type"), Строка(Запись.checkpoint_type), ""));
		НормЗапись.Вставить("stage", ?(Запись.Свойство("stage"), Строка(Запись.stage), ""));
		НормЗапись.Вставить("transition", ?(Запись.Свойство("transition"), Строка(Запись.transition), ""));
		НормЗапись.Вставить("attempt", ?(Запись.Свойство("attempt"), Запись.attempt, 0));
		НормЗапись.Вставить("trace_id", TraceId);
		НормЗапись.Вставить("thread_id", ThreadId);
		НормЗапись.Вставить("details", ?(Запись.Свойство("details"), Запись.details, Неопределено));
		НормЗапись.Вставить("step_id", "");
		НормЗапись.Вставить("policy", "");
		НормЗапись.Вставить("reason", "");
		НормЗапись.Вставить("replay_safety", "");
		НормЗапись.Вставить("source", "checkpoint");
		Если НормЗапись.details <> Неопределено И ТипЗнч(НормЗапись.details) = Тип("Структура") Тогда
			Если НормЗапись.details.Свойство("step_id") Тогда
				НормЗапись.step_id = Строка(НормЗапись.details.step_id);
			ИначеЕсли НормЗапись.details.Свойство("active_step_id") Тогда
				НормЗапись.step_id = Строка(НормЗапись.details.active_step_id);
			КонецЕсли;
			Если НормЗапись.details.Свойство("policy") Тогда
				НормЗапись.policy = Строка(НормЗапись.details.policy);
			ИначеЕсли НормЗапись.details.Свойство("policy_id") Тогда
				НормЗапись.policy = Строка(НормЗапись.details.policy_id);
			КонецЕсли;
			Если НормЗапись.details.Свойство("reason") Тогда
				НормЗапись.reason = Строка(НормЗапись.details.reason);
			КонецЕсли;
			Если НормЗапись.details.Свойство("replay_safety") Тогда
				НормЗапись.replay_safety = Строка(НормЗапись.details.replay_safety);
			КонецЕсли;
			Если НормЗапись.details.Свойство("source") Тогда
				НормЗапись.source = Строка(НормЗапись.details.source);
			КонецЕсли;
		КонецЕсли;
		Результат.Добавить(НормЗапись);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьDiffЧекпоинтовОркестратора(СсылкаДиалога, ИндексДо = -1, ИндексПосле = -1) Экспорт
	Результат = Новый Структура("before,after,changed_fields", Неопределено, Неопределено, Новый Массив);
	История = ПолучитьИсториюЧекпоинтовОркестратора(СсылкаДиалога, 100);
	Если ТипЗнч(История) <> Тип("Массив") Или История.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	Если ИндексПосле < 0 Тогда
		ИндексПосле = История.Количество() - 1;
	КонецЕсли;
	Если ИндексДо < 0 Тогда
		ИндексДо = Макс(0, ИндексПосле - 1);
	КонецЕсли;
	Если ИндексДо < 0 Или ИндексДо >= История.Количество() Или ИндексПосле < 0 Или ИндексПосле >= История.Количество() Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.before = История[ИндексДо];
	Результат.after = История[ИндексПосле];
	ПоляДляСравнения = Новый Массив;
	ПоляДляСравнения.Добавить("checkpoint_type");
	ПоляДляСравнения.Добавить("stage");
	ПоляДляСравнения.Добавить("transition");
	ПоляДляСравнения.Добавить("attempt");
	ПоляДляСравнения.Добавить("step_id");
	ПоляДляСравнения.Добавить("policy");
	ПоляДляСравнения.Добавить("reason");
	ПоляДляСравнения.Добавить("replay_safety");
	ПоляДляСравнения.Добавить("source");
	Для Каждого ИмяПоля Из ПоляДляСравнения Цикл
		ЗначениеДо = Неопределено;
		Результат.before.Свойство(ИмяПоля, ЗначениеДо);
		ЗначениеПосле = Неопределено;
		Результат.after.Свойство(ИмяПоля, ЗначениеПосле);
		Если Строка(ЗначениеДо) <> Строка(ЗначениеПосле) Тогда
			Результат.changed_fields.Добавить(Новый Структура("field,before,after", ИмяПоля, ЗначениеДо, ЗначениеПосле));
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьRuntimeTrace(СсылкаДиалога, Лимит = 100) Экспорт
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	Если Лимит <= 0 Тогда
		Лимит = 100;
	КонецЕсли;
	
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	TraceId = ?(СтруктураДанных.Свойство("trace_id"), Строка(СтруктураДанных.trace_id), "");
	ThreadId = ?(СтруктураДанных.Свойство("Thread_Id"), Строка(СтруктураДанных.Thread_Id), "");
	ДобавитьСобытияТрейса(Результат, СтруктураДанных, TraceId, ThreadId);
	
	Если Результат.Количество() <= Лимит Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИндексНачала = Результат.Количество() - Лимит;
	ОграниченныйРезультат = Новый Массив;
	Для Индекс = ИндексНачала По Результат.Количество() - 1 Цикл
		ОграниченныйРезультат.Добавить(Результат[Индекс]);
	КонецЦикла;
	Возврат ОграниченныйРезультат;
КонецФункции

Функция ПолучитьМетрикиОркестратора(СсылкаДиалога) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("approval_requested", 0);
	Результат.Вставить("approval_approved", 0);
	Результат.Вставить("approval_rejected", 0);
	Результат.Вставить("approval_rate", 0);
	Результат.Вставить("recovery_resume_count", 0);
	Результат.Вставить("recovery_replan_count", 0);
	Результат.Вставить("recovery_abort_count", 0);
	Результат.Вставить("recovery_success_rate", 0);
	Результат.Вставить("checkpoint_count", 0);
	Результат.Вставить("decision_count", 0);
	Результат.Вставить("top_failure_reasons", Новый Массив);
	Результат.Вставить("execution_path_frequency", Новый Массив);
	Результат.Вставить("transition_frequency", Новый Массив);
	Результат.Вставить("retry_count_per_policy", Новый Массив);
	Результат.Вставить("stage_outcome_metrics", Новый Массив);
	
	Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено Или ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	СчетчикиПричин = Новый Соответствие;
	СчетчикиПутей = Новый Соответствие;
	СчетчикиПереходов = Новый Соответствие;
	СчетчикиПолитик = Новый Соответствие;
	СчетчикиУспехаСтадий = Новый Соответствие;
	СчетчикиОшибокСтадий = Новый Соответствие;
	
	Если СтруктураДанных.Свойство("Оркестратор_ИсторияЧекпоинтов")
		И ТипЗнч(СтруктураДанных.Оркестратор_ИсторияЧекпоинтов) = Тип("Массив") Тогда
		Результат.checkpoint_count = СтруктураДанных.Оркестратор_ИсторияЧекпоинтов.Количество();
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Decision_Log")
		И ТипЗнч(СтруктураДанных.Decision_Log) = Тип("Массив") Тогда
		Результат.decision_count = СтруктураДанных.Decision_Log.Количество();
		Для Каждого ЗаписьРешения Из СтруктураДанных.Decision_Log Цикл
			Если ТипЗнч(ЗаписьРешения) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Kind = ?(ЗаписьРешения.Свойство("kind"), Строка(ЗаписьРешения.kind), "");
			Decision = ?(ЗаписьРешения.Свойство("decision"), Строка(ЗаписьРешения.decision), "");
			Reason = ?(ЗаписьРешения.Свойство("reason"), Строка(ЗаписьРешения.reason), "");
			Если Kind = "approval" Тогда
				Если Decision = "requested" Тогда
					Результат.approval_requested = Результат.approval_requested + 1;
				ИначеЕсли Decision = "approved" Тогда
					Результат.approval_approved = Результат.approval_approved + 1;
				ИначеЕсли Decision = "rejected" Тогда
					Результат.approval_rejected = Результат.approval_rejected + 1;
				КонецЕсли;
			ИначеЕсли Kind = "recovery_policy" Тогда
				Если СтрНайти(Decision, "resume") > 0 Тогда
					Результат.recovery_resume_count = Результат.recovery_resume_count + 1;
				ИначеЕсли СтрНайти(Decision, "abort") > 0 Тогда
					Результат.recovery_abort_count = Результат.recovery_abort_count + 1;
				Иначе
					Результат.recovery_replan_count = Результат.recovery_replan_count + 1;
				КонецЕсли;
			КонецЕсли;
			Если ЗаписьРешения.Свойство("policy") И НЕ ПустаяСтрока(Строка(ЗаписьРешения.policy)) Тогда
				УвеличитьСчетчикМетрики(СчетчикиПолитик, Строка(ЗаписьРешения.policy));
			КонецЕсли;
			Если ЭтоПохожеНаПричинуСбоя(Reason) Тогда
				УвеличитьСчетчикМетрики(СчетчикиПричин, Reason);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Оркестратор_ИсторияСобытий")
		И ТипЗнч(СтруктураДанных.Оркестратор_ИсторияСобытий) = Тип("Массив") Тогда
		Для Каждого ИстСобытие Из СтруктураДанных.Оркестратор_ИсторияСобытий Цикл
			Если ТипЗнч(ИстСобытие) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			TransitionValue = ?(ИстСобытие.Свойство("transition"), Строка(ИстСобытие.transition), "");
			StageValue = ?(ИстСобытие.Свойство("stage"), Строка(ИстСобытие.stage), "");
			Если НЕ ПустаяСтрока(TransitionValue) Тогда
				УвеличитьСчетчикМетрики(СчетчикиПереходов, TransitionValue);
				УвеличитьСчетчикМетрики(СчетчикиПутей, StageValue + ":" + TransitionValue);
			КонецЕсли;
			Если НЕ ПустаяСтрока(StageValue) Тогда
				Если СтрНайти(НРег(TransitionValue), "failed") > 0
					ИЛИ СтрНайти(НРег(TransitionValue), "error") > 0
					ИЛИ TransitionValue = "approval_rejected"
					ИЛИ TransitionValue = "recovery_exhausted" Тогда
					УвеличитьСчетчикМетрики(СчетчикиОшибокСтадий, StageValue);
				ИначеЕсли НЕ ПустаяСтрока(TransitionValue) Тогда
					УвеличитьСчетчикМетрики(СчетчикиУспехаСтадий, StageValue);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Subgraph_History")
		И ТипЗнч(СтруктураДанных.Subgraph_History) = Тип("Массив") Тогда
		Для Каждого ЗаписьПодграфа Из СтруктураДанных.Subgraph_History Цикл
			Если ТипЗнч(ЗаписьПодграфа) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			ИмяПодграфа = ?(ЗаписьПодграфа.Свойство("subgraph"), Строка(ЗаписьПодграфа.subgraph), "");
			Если НЕ ПустаяСтрока(ИмяПодграфа) Тогда
				УвеличитьСчетчикМетрики(СчетчикиПутей, ИмяПодграфа);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Результат.approval_requested > 0 Тогда
		Результат.approval_rate = Результат.approval_approved / Результат.approval_requested;
	КонецЕсли;
	ВсегоRecovery = Результат.recovery_resume_count + Результат.recovery_replan_count + Результат.recovery_abort_count;
	Если ВсегоRecovery > 0 Тогда
		Результат.recovery_success_rate = (Результат.recovery_resume_count + Результат.recovery_replan_count) / ВсегоRecovery;
	КонецЕсли;
	
	Результат.top_failure_reasons = СчетчикиВСортированныйМассив(СчетчикиПричин);
	Результат.execution_path_frequency = СчетчикиВСортированныйМассив(СчетчикиПутей);
	Результат.transition_frequency = СчетчикиВСортированныйМассив(СчетчикиПереходов);
	Результат.retry_count_per_policy = СчетчикиВСортированныйМассив(СчетчикиПолитик);
	Результат.stage_outcome_metrics = СформироватьМетрикиПоСтадиям(СчетчикиУспехаСтадий, СчетчикиОшибокСтадий);
	Возврат Результат;
КонецФункции

Функция ПолучитьЦепочкиСбоевОркестратора(СсылкаДиалога, Лимит = 5) Экспорт
	Результат = Новый Массив;
	Trace = ПолучитьRuntimeTrace(СсылкаДиалога, 200);
	Если ТипЗнч(Trace) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	Для Каждого Событие Из Trace Цикл
		Если ТипЗнч(Событие) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		TransitionValue = ?(Событие.Свойство("transition"), Строка(Событие.transition), "");
		ReasonValue = ?(Событие.Свойство("reason"), Строка(Событие.reason), "");
		Если НЕ ЭтоПохожеНаПричинуСбоя(ReasonValue)
			И СтрНайти(НРег(TransitionValue), "recover") = 0
			И СтрНайти(НРег(TransitionValue), "failed") = 0
			И TransitionValue <> "approval_rejected"
			И TransitionValue <> "recovery_exhausted" Тогда
			Продолжить;
		КонецЕсли;
		Результат.Добавить(Новый Структура(
			"timestamp,trace_type,kind,stage,transition,reason,source,policy,step_id,subgraph",
			?(Событие.Свойство("timestamp"), Событие.timestamp, Неопределено),
			?(Событие.Свойство("trace_type"), Строка(Событие.trace_type), ""),
			?(Событие.Свойство("kind"), Строка(Событие.kind), ""),
			?(Событие.Свойство("stage"), Строка(Событие.stage), ""),
			TransitionValue,
			ReasonValue,
			?(Событие.Свойство("source"), Строка(Событие.source), ""),
			?(Событие.Свойство("policy"), Строка(Событие.policy), ""),
			?(Событие.Свойство("step_id"), Строка(Событие.step_id), ""),
			?(Событие.Свойство("subgraph"), Строка(Событие.subgraph), "")
		));
	КонецЦикла;
	Если Результат.Количество() > Лимит Тогда
		ИндексНачала = Результат.Количество() - Лимит;
		ОграниченныйРезультат = Новый Массив;
		Для Индекс = ИндексНачала По Результат.Количество() - 1 Цикл
			ОграниченныйРезультат.Добавить(Результат[Индекс]);
		КонецЦикла;
		Возврат ОграниченныйРезультат;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПочемуОстановилсяОркестратор(СсылкаДиалога) Экспорт
	Результат = Новый Структура("stage,transition,awaiting_approval,last_failure,replay_safety", "", "", Ложь, Неопределено, "");
	Состояние = ПолучитьСостояниеОркестратора(СсылкаДиалога);
	Если Состояние <> Неопределено Тогда
		Результат.stage = ?(Состояние.Свойство("ТекущаяСтадия"), Состояние.ТекущаяСтадия, "");
		Результат.transition = ?(Состояние.Свойство("ПоследнийПереход"), Состояние.ПоследнийПереход, "");
	КонецЕсли;
	Результат.awaiting_approval = ЕстьОжидающееПодтверждение(СсылкаДиалога);
	FailureChains = ПолучитьЦепочкиСбоевОркестратора(СсылкаДиалога, 1);
	Если ТипЗнч(FailureChains) = Тип("Массив") И FailureChains.Количество() > 0 Тогда
		Результат.last_failure = FailureChains[FailureChains.Количество() - 1];
	КонецЕсли;
	ИсторияЧекпоинтов = ПолучитьИсториюЧекпоинтовОркестратора(СсылкаДиалога, 1);
	Если ТипЗнч(ИсторияЧекпоинтов) = Тип("Массив") И ИсторияЧекпоинтов.Количество() > 0 Тогда
		ПоследнийЧекпоинт = ИсторияЧекпоинтов[ИсторияЧекпоинтов.Количество() - 1];
		Если ПоследнийЧекпоинт.Свойство("replay_safety") Тогда
			Результат.replay_safety = Строка(ПоследнийЧекпоинт.replay_safety);
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;
КонецФункции

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьСобытияТрейса(Результат, СтруктураДанных, TraceId, ThreadId)
	Если СтруктураДанных.Свойство("Оркестратор_ИсторияСобытий")
		И ТипЗнч(СтруктураДанных.Оркестратор_ИсторияСобытий) = Тип("Массив") Тогда
		Для Каждого ИстСобытие Из СтруктураДанных.Оркестратор_ИсторияСобытий Цикл
			Если ТипЗнч(ИстСобытие) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Событие = СоздатьСобытиеRuntimeTrace("event_history", ?(ИстСобытие.Свойство("timestamp"), ИстСобытие.timestamp, Неопределено));
			Событие.kind = ?(ИстСобытие.Свойство("event_type"), Строка(ИстСобытие.event_type), "");
			Событие.stage = ?(ИстСобытие.Свойство("stage"), Строка(ИстСобытие.stage), "");
			Событие.transition = ?(ИстСобытие.Свойство("transition"), Строка(ИстСобытие.transition), "");
			Событие.attempt = ?(ИстСобытие.Свойство("attempt"), ИстСобытие.attempt, 0);
			Событие.source = "orchestrator";
			Событие.trace_id = TraceId;
			Событие.thread_id = ThreadId;
			Событие.details = ?(ИстСобытие.Свойство("details"), ИстСобытие.details, Неопределено);
			ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Событие.details);
			Результат.Добавить(Событие);
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Оркестратор_ИсторияЧекпоинтов")
		И ТипЗнч(СтруктураДанных.Оркестратор_ИсторияЧекпоинтов) = Тип("Массив") Тогда
		Для Каждого ИстЧекпоинт Из СтруктураДанных.Оркестратор_ИсторияЧекпоинтов Цикл
			Если ТипЗнч(ИстЧекпоинт) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Событие = СоздатьСобытиеRuntimeTrace("checkpoint", ?(ИстЧекпоинт.Свойство("timestamp"), ИстЧекпоинт.timestamp, Неопределено));
			Событие.kind = ?(ИстЧекпоинт.Свойство("checkpoint_type"), Строка(ИстЧекпоинт.checkpoint_type), "");
			Событие.stage = ?(ИстЧекпоинт.Свойство("stage"), Строка(ИстЧекпоинт.stage), "");
			Событие.transition = ?(ИстЧекпоинт.Свойство("transition"), Строка(ИстЧекпоинт.transition), "");
			Событие.attempt = ?(ИстЧекпоинт.Свойство("attempt"), ИстЧекпоинт.attempt, 0);
			Событие.source = "checkpoint";
			Событие.trace_id = TraceId;
			Событие.thread_id = ThreadId;
			Событие.details = ?(ИстЧекпоинт.Свойство("details"), ИстЧекпоинт.details, Неопределено);
			ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Событие.details);
			Результат.Добавить(Событие);
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Subgraph_History")
		И ТипЗнч(СтруктураДанных.Subgraph_History) = Тип("Массив") Тогда
		Для Каждого ИстПодграф Из СтруктураДанных.Subgraph_History Цикл
			Если ТипЗнч(ИстПодграф) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Событие = СоздатьСобытиеRuntimeTrace("subgraph_history", ?(ИстПодграф.Свойство("timestamp"), ИстПодграф.timestamp, Неопределено));
			Событие.subgraph = ?(ИстПодграф.Свойство("subgraph"), Строка(ИстПодграф.subgraph), "");
			Событие.decision = ?(ИстПодграф.Свойство("decision"), Строка(ИстПодграф.decision), "");
			Событие.source = "subgraph";
			Событие.trace_id = TraceId;
			Событие.thread_id = ThreadId;
			Событие.details = ?(ИстПодграф.Свойство("details"), ИстПодграф.details, Неопределено);
			ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Событие.details);
			Результат.Добавить(Событие);
		КонецЦикла;
	КонецЕсли;
	
	Если СтруктураДанных.Свойство("Decision_Log")
		И ТипЗнч(СтруктураДанных.Decision_Log) = Тип("Массив") Тогда
		Для Каждого ЗаписьРешения Из СтруктураДанных.Decision_Log Цикл
			Если ТипЗнч(ЗаписьРешения) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Событие = СоздатьСобытиеRuntimeTrace("decision_log", ?(ЗаписьРешения.Свойство("timestamp"), ЗаписьРешения.timestamp, Неопределено));
			Событие.kind = ?(ЗаписьРешения.Свойство("kind"), Строка(ЗаписьРешения.kind), "");
			Событие.decision = ?(ЗаписьРешения.Свойство("decision"), Строка(ЗаписьРешения.decision), "");
			Событие.source = ?(ЗаписьРешения.Свойство("source"), Строка(ЗаписьРешения.source), "");
			Событие.step_id = ?(ЗаписьРешения.Свойство("step_id"), Строка(ЗаписьРешения.step_id), "");
			Событие.policy = ?(ЗаписьРешения.Свойство("policy"), Строка(ЗаписьРешения.policy), "");
			Событие.reason = ?(ЗаписьРешения.Свойство("reason"), Строка(ЗаписьРешения.reason), "");
			Событие.subgraph = ?(ЗаписьРешения.Свойство("subgraph"), Строка(ЗаписьРешения.subgraph), "");
			Событие.trace_id = TraceId;
			Событие.thread_id = ThreadId;
			Событие.details = ?(ЗаписьРешения.Свойство("details"), ЗаписьРешения.details, Неопределено);
			ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Событие.details);
			Результат.Добавить(Событие);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция СоздатьСобытиеRuntimeTrace(TraceType, Timestamp = Неопределено)
	Событие = Новый Структура;
	Событие.Вставить("timestamp", Timestamp);
	Событие.Вставить("trace_type", TraceType);
	Событие.Вставить("kind", "");
	Событие.Вставить("decision", "");
	Событие.Вставить("source", "");
	Событие.Вставить("step_id", "");
	Событие.Вставить("policy", "");
	Событие.Вставить("reason", "");
	Событие.Вставить("subgraph", "");
	Событие.Вставить("stage", "");
	Событие.Вставить("transition", "");
	Событие.Вставить("attempt", 0);
	Событие.Вставить("trace_id", "");
	Событие.Вставить("thread_id", "");
	Событие.Вставить("details", Неопределено);
	Возврат Событие;
КонецФункции

Процедура ДополнитьСобытиеRuntimeTraceИзDetails(Событие, Details)
	Если Событие = Неопределено
		ИЛИ ТипЗнч(Событие) <> Тип("Структура")
		ИЛИ Details = Неопределено
		ИЛИ ТипЗнч(Details) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	Если Details.Свойство("source") И НЕ ПустаяСтрока(Строка(Details.source)) Тогда
		Событие.source = Строка(Details.source);
	КонецЕсли;
	Если Details.Свойство("step_id") И НЕ ПустаяСтрока(Строка(Details.step_id)) Тогда
		Событие.step_id = Строка(Details.step_id);
	ИначеЕсли Details.Свойство("active_step_id") И НЕ ПустаяСтрока(Строка(Details.active_step_id)) Тогда
		Событие.step_id = Строка(Details.active_step_id);
	КонецЕсли;
	Если Details.Свойство("policy") И НЕ ПустаяСтрока(Строка(Details.policy)) Тогда
		Событие.policy = Строка(Details.policy);
	ИначеЕсли Details.Свойство("policy_id") И НЕ ПустаяСтрока(Строка(Details.policy_id)) Тогда
		Событие.policy = Строка(Details.policy_id);
	КонецЕсли;
	Если Details.Свойство("reason") И НЕ ПустаяСтрока(Строка(Details.reason)) Тогда
		Событие.reason = Строка(Details.reason);
	КонецЕсли;
КонецПроцедуры

Процедура УвеличитьСчетчикМетрики(Счетчики, Ключ)
	Если Счетчики = Неопределено Или ТипЗнч(Счетчики) <> Тип("Соответствие") Или ПустаяСтрока(СокрЛП(Строка(Ключ))) Тогда
		Возврат;
	КонецЕсли;
	ТекущееЗначение = Счетчики.Получить(Ключ);
	Если ТекущееЗначение = Неопределено Тогда
		ТекущееЗначение = 0;
	КонецЕсли;
	Счетчики.Вставить(Ключ, ТекущееЗначение + 1);
КонецПроцедуры

Функция СчетчикиВСортированныйМассив(Счетчики)
	Результат = Новый Массив;
	Если Счетчики = Неопределено Или ТипЗнч(Счетчики) <> Тип("Соответствие") Тогда
		Возврат Результат;
	КонецЕсли;
	Для Каждого Пара Из Счетчики Цикл
		Результат.Добавить(Новый Структура("key,count", Строка(Пара.Ключ), Пара.Значение));
	КонецЦикла;
	Для Левый = 0 По Результат.Количество() - 2 Цикл
		Для Правый = Левый + 1 По Результат.Количество() - 1 Цикл
			Если Результат[Правый].count > Результат[Левый].count Тогда
				ВременноеЗначение = Результат[Левый];
				Результат[Левый] = Результат[Правый];
				Результат[Правый] = ВременноеЗначение;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ЭтоПохожеНаПричинуСбоя(Причина)
	ТекстПричины = НРег(СокрЛП(Строка(Причина)));
	Если ПустаяСтрока(ТекстПричины) Тогда
		Возврат Ложь;
	КонецЕсли;
	Возврат СтрНайти(ТекстПричины, "fail") > 0
		Или СтрНайти(ТекстПричины, "error") > 0
		Или СтрНайти(ТекстПричины, "abort") > 0
		Или СтрНайти(ТекстПричины, "rejected") > 0
		Или СтрНайти(ТекстПричины, "missing") > 0
		Или СтрНайти(ТекстПричины, "unsafe") > 0;
КонецФункции

Функция СформироватьМетрикиПоСтадиям(СчетчикиУспехаСтадий, СчетчикиОшибокСтадий)
	Результат = Новый Массив;
	ИменаСтадий = Новый Массив;
	Для Каждого Пара Из СчетчикиУспехаСтадий Цикл
		Если ИменаСтадий.Найти(Строка(Пара.Ключ)) = Неопределено Тогда
			ИменаСтадий.Добавить(Строка(Пара.Ключ));
		КонецЕсли;
	КонецЦикла;
	Для Каждого Пара Из СчетчикиОшибокСтадий Цикл
		Если ИменаСтадий.Найти(Строка(Пара.Ключ)) = Неопределено Тогда
			ИменаСтадий.Добавить(Строка(Пара.Ключ));
		КонецЕсли;
	КонецЦикла;
	Для Каждого ИмяСтадии Из ИменаСтадий Цикл
		SuccessCount = ?(СчетчикиУспехаСтадий.Получить(ИмяСтадии) = Неопределено, 0, СчетчикиУспехаСтадий.Получить(ИмяСтадии));
		FailureCount = ?(СчетчикиОшибокСтадий.Получить(ИмяСтадии) = Неопределено, 0, СчетчикиОшибокСтадий.Получить(ИмяСтадии));
		Результат.Добавить(Новый Структура("stage,success_count,failure_count", ИмяСтадии, SuccessCount, FailureCount));
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ЕстьОжидающееПодтверждение(СсылкаДиалога)
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	Если СтруктураДанных.Свойство("Approval_Состояние")
		И ТипЗнч(СтруктураДанных.Approval_Состояние) = Тип("Структура")
		И СтруктураДанных.Approval_Состояние.Свойство("status") Тогда
		Возврат ВРег(Строка(СтруктураДанных.Approval_Состояние.status)) = "PENDING";
	КонецЕсли;
	Возврат Ложь;
КонецФункции

