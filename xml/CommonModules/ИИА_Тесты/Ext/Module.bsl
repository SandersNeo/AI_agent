Функция ТестQuerySafetyGateВложенныеПоля() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		DSLВалидный =
			"{""dsl_version"":2,""steps"":[" +
			"{""action"":""GetObjectFields"",""object_type"":""Документ"",""object_name"":""РасходнаяНакладная""}," +
			"{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ПЕРВЫЕ 1 РасходнаяНакладная.Контрагент.Наименование КАК Контрагент ИЗ Документ.РасходнаяНакладная КАК РасходнаяНакладная""}" +
			"]}";
		РезультатВалидный = ИИА_DSL.ВыполнитьDSL(DSLВалидный);
		Если НЕ РезультатВалидный.Свойство("СистемныйОтвет") Тогда
			Результат.Сообщение = "Отсутствует системный ответ для проверки вложенного валидного пути";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(ВРег(РезультатВалидный.СистемныйОтвет), "QUERY_SAFETY_VIOLATION") > 0 Тогда
			Результат.Сообщение = "Валидный nested-path Контрагент.Наименование не должен блокироваться safety gate";
			Результат.Детали.Добавить(Лев(РезультатВалидный.СистемныйОтвет, 800));
			Возврат Результат;
		КонецЕсли;
		
		DSLНевалидный =
			"{""dsl_version"":2,""steps"":[" +
			"{""action"":""GetObjectFields"",""object_type"":""Документ"",""object_name"":""РасходнаяНакладная""}," +
			"{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ПЕРВЫЕ 1 РасходнаяНакладная.Контрагент.НесуществующееПоле КАК Х ИЗ Документ.РасходнаяНакладная КАК РасходнаяНакладная""}" +
			"]}";
		РезультатНевалидный = ИИА_DSL.ВыполнитьDSL(DSLНевалидный);
		Если НЕ РезультатНевалидный.Свойство("СистемныйОтвет") Тогда
			Результат.Сообщение = "Отсутствует системный ответ для проверки вложенного невалидного пути";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(ВРег(РезультатНевалидный.СистемныйОтвет), "QUERY_SAFETY_VIOLATION") = 0 Тогда
			Результат.Сообщение = "Невалидный nested-path должен блокироваться Query Safety Gate";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: nested-path в Query Safety Gate валидируется по whitelist_paths";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

