Функция ТестПромптТребуетOperationId() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		ПромптШага = ИИА_Промты.ПолучитьПромптГенерацииСледующегоШага("{""plan_version"":1,""goal"":""Тест"",""steps"":[{""id"":""step_1"",""kind"":""create_reference"",""title"":""Создать контрагента"",""depends_on"":[],""input"":{""object_name"":""Контрагенты"",""name"":""Тест""}},{""id"":""step_2"",""kind"":""write_object"",""title"":""Записать объект"",""depends_on"":[""step_1""],""input"":{}}]}", "{""id"":""step_2"",""kind"":""write_object"",""title"":""Записать объект"",""depends_on"":[""step_1""],""input"":{}}", "Факты", "", "");
		ПромптПроверки = ИИА_Промты.ПолучитьПромптExecutorПроверкиDSL("{""dsl_version"":2,""steps"":[{""action"":""Write""}]}", "");
		ПромптИсправления = ИИА_Промты.ПолучитьПромптИсправленияDSL("write_failed", "{""dsl_version"":2,""steps"":[{""action"":""SaveToStorage"",""key"":""x"",""data"":""y""}]}", "");
		
		Если СтрНайти(ПромптШага, "operation_id") = 0 Тогда
			Результат.Сообщение = "Промпт генерации шага должен требовать operation_id";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(ПромптШага, "CreateReference") = 0
			ИЛИ СтрНайти(ПромптШага, "Write") = 0
			ИЛИ СтрНайти(ПромптШага, "SaveToStorage") = 0
			ИЛИ СтрНайти(ПромптШага, "ForEach") = 0 Тогда
			Результат.Сообщение = "Промпт генерации шага должен перечислять write-side действия, требующие operation_id";
			Возврат Результат;
		КонецЕсли;
		
		Если СтрНайти(ПромптПроверки, "operation_id") = 0 Тогда
			Результат.Сообщение = "Промпт проверки DSL должен требовать operation_id для неидемпотентных действий";
			Возврат Результат;
		КонецЕсли;
		
		Если СтрНайти(ПромптИсправления, "operation_id") = 0 Тогда
			Результат.Сообщение = "Промпт исправления DSL должен сохранять или добавлять operation_id";
			Возврат Результат;
		КонецЕсли;
		
		Если СтрНайти(ПромптИсправления, "не меняй его operation_id") = 0 Тогда
			Результат.Сообщение = "Промпт исправления DSL должен запрещать менять operation_id при повторе";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Детали.Добавить("Промпт генерации шага требует operation_id");
		Результат.Детали.Добавить("Промпт проверки DSL требует operation_id");
		Результат.Детали.Добавить("Промпт исправления DSL сохраняет operation_id");
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: промпты требуют и сохраняют operation_id";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

