			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: валидация DSL работает";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

// Тест SaveToStorage и LoadFromStorage через DSL.
//
Функция ТестSaveToStorageLoadFromStorage() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		Результат.Детали.Добавить("Создан диалог");
		Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
			Результат.Сообщение = "Не удалось создать диалог";
			Возврат Результат;
		КонецЕсли;
		
		КлючТест = "ТестКлюч_" + Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss");
		ЗначениеТест = "Значение_" + КлючТест;
		
		ЗначениеЭкранир = СтрЗаменить(ЗначениеТест, "\", "\\");
		ЗначениеЭкранир = СтрЗаменить(ЗначениеЭкранир, """", "\""");
		DSLЗапись = "{""steps"":[{""action"":""SaveToStorage"",""key"":""" + КлючТест + """,""data"":""" + ЗначениеЭкранир + """}]}";
		РезЗапись = ИИА_Сервер.ВыполнитьDSLСценарийБезСообщений(DSLЗапись, СсылкаДиалога);
		Результат.Детали.Добавить("SaveToStorage: Успех=" + РезЗапись.Успех);
		Если НЕ РезЗапись.Успех Тогда
			Результат.Сообщение = "SaveToStorage не выполнен: " + РезЗапись.Сообщение;
			Возврат Результат;
		КонецЕсли;
		
		DSLЧтение = "{""steps"":[{""action"":""LoadFromStorage"",""key"":""" + КлючТест + """}]}";
		РезЧтение = ИИА_Сервер.ВыполнитьDSLСценарийБезСообщений(DSLЧтение, СсылкаДиалога);
		Результат.Детали.Добавить("LoadFromStorage: Успех=" + РезЧтение.Успех);
		Если НЕ РезЧтение.Успех Тогда
			Результат.Сообщение = "LoadFromStorage не выполнен: " + РезЧтение.Сообщение;
			Возврат Результат;
		КонецЕсли;
		Если РезЧтение.Результаты.Количество() > 0 Тогда
			РезШага = РезЧтение.Результаты[0];
			Если РезШага.Свойство("Данные") И Строка(РезШага.Данные) = ЗначениеТест Тогда
				Результат.Детали.Добавить("Прочитанное значение совпадает");
			КонецЕсли;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: SaveToStorage/LoadFromStorage";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

// Тестирует safe retry для SaveToStorage по operation_id.
//
Функция ТестIdempotencySaveToStorageOperationId() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		Если НЕ ЗначениеЗаполнено(СсылкаДиалога) Тогда
			Результат.Сообщение = "Не удалось создать диалог для проверки idempotency";
			Возврат Результат;
		КонецЕсли;
		
		КлючТеста = "IdempotencyKey_" + Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss");
		ЗначениеТеста = "Value_" + КлючТеста;
		OperationId = "op_save_" + Формат(ТекущаяДата(), "ДФ=yyyyMMddHHmmss");
		
		ЗначениеЭкранир = СтрЗаменить(ЗначениеТеста, "\", "\\");
		ЗначениеЭкранир = СтрЗаменить(ЗначениеЭкранир, """", "\""");
		DSL = "{""dsl_version"":2,""steps"":[{""action"":""SaveToStorage"",""key"":""" + КлючТеста + """,""data"":""" + ЗначениеЭкранир + """,""operation_id"":""" + OperationId + """}]}";
		
		Рез1 = ИИА_Сервер.ВыполнитьDSLСценарийБезСообщений(DSL, СсылкаДиалога);
		Если НЕ Рез1.Успех Тогда
			Результат.Сообщение = "Первый SaveToStorage завершился с ошибкой: " + Рез1.Сообщение;
			Возврат Результат;
		КонецЕсли;
		
		Рез2 = ИИА_Сервер.ВыполнитьDSLСценарийБезСообщений(DSL, СсылкаДиалога);
		Если НЕ Рез2.Успех Тогда
			Результат.Сообщение = "Повторный SaveToStorage завершился с ошибкой: " + Рез2.Сообщение;
			Возврат Результат;
		КонецЕсли;
		
		Если НЕ Рез2.Свойство("Результаты") ИЛИ Рез2.Результаты.Количество() = 0 Тогда
			Результат.Сообщение = "Во втором выполнении отсутствуют результаты шагов";
			Возврат Результат;
		КонецЕсли;
		
		РезультатШага = Рез2.Результаты[0];
		Если НЕ РезультатШага.Свойство("deduplicated_retry") ИЛИ НЕ РезультатШага.deduplicated_retry Тогда
			Результат.Сообщение = "Повторный вызов SaveToStorage с тем же operation_id должен возвращать deduplicated_retry=Истина";
			Возврат Результат;
		КонецЕсли;
		
		DSLЧтение = "{""dsl_version"":2,""steps"":[{""action"":""LoadFromStorage"",""key"":""" + КлючТеста + """}]}";
		РезЧтение = ИИА_Сервер.ВыполнитьDSLСценарийБезСообщений(DSLЧтение, СсылкаДиалога);
		Если НЕ РезЧтение.Успех Тогда
			Результат.Сообщение = "LoadFromStorage после повторов не выполнен: " + РезЧтение.Сообщение;
			Возврат Результат;
		КонецЕсли;
		
		Если РезЧтение.Результаты.Количество() = 0 Тогда
			Результат.Сообщение = "LoadFromStorage не вернул результата шага";
			Возврат Результат;
		КонецЕсли;
		
		РезШагаЧтения = РезЧтение.Результаты[0];
		Если НЕ РезШагаЧтения.Свойство("Данные") ИЛИ Строка(РезШагаЧтения.Данные) <> ЗначениеТеста Тогда
			Результат.Сообщение = "После deduplicated retry в хранилище должно остаться исходное значение";
			Возврат Результат;
		КонецЕсли;
		
		ДанныеДиалога = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
		Если ДанныеДиалога = Неопределено Тогда
			Результат.Сообщение = "Не удалось получить данные диалога из регистра";
			Возврат Результат;
		КонецЕсли;
		Если НЕ ДанныеДиалога.Свойство("DSL_OperationJournal") Тогда
			Результат.Сообщение = "В данных диалога отсутствует DSL_OperationJournal";
			Возврат Результат;
		КонецЕсли;
		Если ДанныеДиалога.DSL_OperationJournal.Получить(OperationId) = Неопределено Тогда
			Результат.Сообщение = "DSL_OperationJournal не содержит запись по operation_id";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Детали.Добавить("operation_id=" + OperationId);
		Результат.Детали.Добавить("Повторный вызов помечен как deduplicated_retry");
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: SaveToStorage безопасно дедуплицируется по operation_id";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

// Тест режима «только чтение» (Запрос1С): SetField должен быть запрещён.
//
Функция ТестРежимЗапрос1С() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Запрос1С);
