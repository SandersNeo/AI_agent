Функция ТестКонтрактAntiGiveup() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		Реестр = ИИА_RecoveryPolicy.ПолучитьРеестрПолитикВосстановления();
		ПолитикаПараметров = Реестр.Получить("parameter_missing");
		ПолитикаSafety = Реестр.Получить("query_safety_violation");
		ПолитикаExecution = Реестр.Получить("query_execution_error");
		Если ПолитикаПараметров = Неопределено Тогда
			Результат.Сообщение = "Отсутствует anti-giveup policy для parameter_missing";
			Возврат Результат;
		КонецЕсли;
		Если ПолитикаSafety = Неопределено Тогда
			Результат.Сообщение = "Отсутствует anti-giveup policy для query_safety_violation";
			Возврат Результат;
		КонецЕсли;
		Если ПолитикаExecution = Неопределено Тогда
			Результат.Сообщение = "Отсутствует anti-giveup policy для query_execution_error";
			Возврат Результат;
		КонецЕсли;
		
		Промпт = ИИА_Промты.ПолучитьПромптPlannerСледующегоШага("{""plan_version"":1,""goal"":""Тест"",""steps"":[{""id"":""step_1"",""kind"":""run_query"",""title"":""Тестовый запрос"",""depends_on"":[],""input"":{""query"":""ВЫБРАТЬ ...""}}]}", "{""id"":""step_1"",""kind"":""run_query"",""title"":""Тестовый запрос"",""depends_on"":[],""input"":{""query"":""ВЫБРАТЬ ...""}}", "Ошибка: field_not_found", "Период, Сумма", "");
		Если СтрНайти(ВРег(Промпт), "ANTI-GIVEUP") = 0 Тогда
			Результат.Сообщение = "Промпт Planner должен содержать anti-giveup правило";
			Возврат Результат;
		КонецЕсли;
		ПромптРемонта = ИИА_Промты.ПолучитьПромптИсправленияDSL("query_execution_error", "{""dsl_version"":2,""steps"":[{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ...""}]}", "");
		Если СтрНайти(ВРег(ПромптРемонта), "ПРЕДЫДУЩИЙ") = 0 Тогда
			Результат.Сообщение = "Промпт исправления должен запрещать ПРЕДЫДУЩИЙ и нестабильные конструкции";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: anti-giveup контракт настроен";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестAntiGiveupБлокРаннегоShowInfo() Экспорт
