Функция ТестКонтрактRuntimeTrace() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		ИИА_Сервер.УстановитьThreadId(СсылкаДиалога, "thread_test");
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Plan", "test_transition", Ложь);
		ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "PlanningSubgraph", "next_step_generation", Новый Структура("active_step_id", "step_1"));
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "execution_policy", "safe-path", "PlanningSubgraph", Новый Структура("source,step_id,policy,reason", "planning", "step_1", "planner_policy", "next_step_generation"));
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "typed_plan_saved", "Plan", Новый Структура("step_id", "step_1"), "test_transition");
		
		Trace = ИИА_Сервер.ПолучитьRuntimeTrace(СсылкаДиалога, 50);
		Если ТипЗнч(Trace) <> Тип("Массив") Или Trace.Количество() = 0 Тогда
			Результат.Сообщение = "Runtime trace должен возвращать массив событий";
			Возврат Результат;
		КонецЕсли;
		
		НайденDecision = Ложь;
		НайденCheckpoint = Ложь;
		Для Каждого Событие Из Trace Цикл
			Если ТипЗнч(Событие) <> Тип("Структура") Тогда
				Результат.Сообщение = "Runtime trace должен содержать структуры";
				Возврат Результат;
			КонецЕсли;
			Если НЕ Событие.Свойство("timestamp")
				ИЛИ НЕ Событие.Свойство("trace_type")
				ИЛИ НЕ Событие.Свойство("source")
				ИЛИ НЕ Событие.Свойство("trace_id")
				ИЛИ НЕ Событие.Свойство("thread_id") Тогда
				Результат.Сообщение = "Runtime trace event должен содержать базовые contract fields";
				Возврат Результат;
			КонецЕсли;
			Если Событие.trace_type = "decision_log" И Событие.kind = "execution_policy" Тогда
				НайденDecision = Истина;
				Если Событие.step_id <> "step_1" Или Событие.policy <> "planner_policy" Тогда
					Результат.Сообщение = "Decision event должен сохранять stable fields step_id/policy";
					Возврат Результат;
				КонецЕсли;
			КонецЕсли;
			Если Событие.trace_type = "checkpoint" И Событие.kind = "typed_plan_saved" Тогда
				НайденCheckpoint = Истина;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ НайденDecision Тогда
			Результат.Сообщение = "Runtime trace должен включать decision_log events";
			Возврат Результат;
		КонецЕсли;
		Если НЕ НайденCheckpoint Тогда
			Результат.Сообщение = "Runtime trace должен включать checkpoint events";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: runtime trace возвращает нормализованные события";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестКонтрактCheckpointHistory() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		ИИА_Сервер.УстановитьThreadId(СсылкаДиалога, "thread_checkpoint_test");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "typed_plan_saved", "Plan", Новый Структура("step_id,reason", "step_1", "checkpoint_one"), "Plan->Execute");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "execute_subgraph_entered", "Execute", Новый Структура("step_id,policy_id,reason", "step_2", "safe-path", "checkpoint_two"), "Execute->Validate");
		
		История = ИИА_Сервер.ПолучитьИсториюЧекпоинтовОркестратора(СсылкаДиалога, 10);
		Если ТипЗнч(История) <> Тип("Массив") Или История.Количество() <> 2 Тогда
			Результат.Сообщение = "Checkpoint history должен возвращать нормализованный массив";
			Возврат Результат;
		КонецЕсли;
		
		Последний = История[История.Количество() - 1];
		Если НЕ Последний.Свойство("checkpoint_index")
			Или НЕ Последний.Свойство("is_latest")
			Или НЕ Последний.Свойство("thread_id")
			Или НЕ Последний.Свойство("step_id")
			Или НЕ Последний.Свойство("reason") Тогда
			Результат.Сообщение = "Checkpoint history должен содержать contract fields";
			Возврат Результат;
		КонецЕсли;
		Если НЕ Последний.is_latest Или Последний.step_id <> "step_2" Или Последний.thread_id <> "thread_checkpoint_test" Тогда
			Результат.Сообщение = "Checkpoint history должен корректно нормализовать latest/thread/step";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: checkpoint history возвращает нормализованные записи";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестКонтрактCheckpointDiff() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "typed_plan_saved", "Plan", Новый Структура("step_id,reason", "step_1", "checkpoint_one"), "Plan->Execute");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "execute_subgraph_entered", "Execute", Новый Структура("step_id,reason", "step_2", "checkpoint_two"), "Execute->Validate");
		
		Diff = ИИА_Сервер.ПолучитьDiffЧекпоинтовОркестратора(СсылкаДиалога, 0, 1);
		Если Diff = Неопределено
			Или НЕ Diff.Свойство("before")
			Или НЕ Diff.Свойство("after")
			Или НЕ Diff.Свойство("changed_fields") Тогда
			Результат.Сообщение = "Checkpoint diff должен возвращать before/after/changed_fields";
			Возврат Результат;
		КонецЕсли;
		Если ТипЗнч(Diff.changed_fields) <> Тип("Массив") Или Diff.changed_fields.Количество() = 0 Тогда
			Результат.Сообщение = "Checkpoint diff должен находить измененные поля";
			Возврат Результат;
		КонецЕсли;
		
		НайденStage = Ложь;
		Для Каждого Изменение Из Diff.changed_fields Цикл
			Если Изменение.Свойство("field") И Изменение.field = "stage" Тогда
				НайденStage = Истина;
			КонецЕсли;
		КонецЦикла;
		Если НЕ НайденStage Тогда
			Результат.Сообщение = "Checkpoint diff должен фиксировать изменение stage";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: checkpoint diff возвращает измененные поля";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестResumeFromCheckpoint() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "typed_plan_saved", "Plan", Новый Структура("step_id,execution_policy,subgraph", "step_restore", "safe-path", "PlanningSubgraph"), "Plan->Execute");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "recovery_decision_abort", "Summarize", Новый Структура("step_id", "step_other"), "Validate->Summarize");
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Summarize", "test_changed", Ложь);
		ИИА_Сервер.УстановитьActiveStepId(СсылкаДиалога, "step_changed");
		
		Если НЕ ИИА_Оркестратор.ВозобновитьСЧекпоинта(СсылкаДиалога, 0, Ложь) Тогда
			Результат.Сообщение = "Resume from checkpoint должен отрабатывать без автозапуска";
			Возврат Результат;
		КонецЕсли;
		
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если Состояние = Неопределено
			Или Состояние.ТекущаяСтадия <> "Plan"
			Или Состояние.ПоследнийПереход <> "checkpoint_resume" Тогда
			Результат.Сообщение = "Resume from checkpoint должен восстанавливать stage и переход";
			Возврат Результат;
		КонецЕсли;
		Если Состояние.active_step_id <> "step_restore" Или Состояние.execution_policy <> "safe-path" Тогда
			Результат.Сообщение = "Resume from checkpoint должен восстанавливать active_step_id и execution_policy";
			Возврат Результат;
		КонецЕсли;
		
		Если ТипЗнч(Состояние.decision_log) <> Тип("Массив") Или Состояние.decision_log.Количество() = 0 Тогда
			Результат.Сообщение = "Resume from checkpoint должен писать decision_log";
			Возврат Результат;
		КонецЕсли;
		ПоследнееРешение = Состояние.decision_log[Состояние.decision_log.Количество() - 1];
		Если НЕ ПоследнееРешение.Свойство("kind")
			Или ПоследнееРешение.kind <> "checkpoint_resume"
			Или НЕ ПоследнееРешение.Свойство("decision")
			Или ПоследнееРешение.decision <> "requested" Тогда
			Результат.Сообщение = "Resume from checkpoint должен фиксировать checkpoint_resume решение";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: resume from checkpoint восстанавливает runtime state";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестКонтрактМетрикОркестратора() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "approval", "requested", "ReadQuerySubgraph", Новый Структура("source,step_id,reason", "approval", "step_1", "approval_required"));
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "approval", "approved", "ReadQuerySubgraph", Новый Структура("source,step_id,reason", "approval", "step_1", "approval_approved"));
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", "resume_same_operation_id", "RecoverySubgraph", Новый Структура("source,policy_id,reason", "recovery", "write_retry_same_operation_policy", "resume_same_operation_id"));
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", "abort_unsafe_write_retry", "RecoverySubgraph", Новый Структура("source,policy_id,reason", "recovery", "write_retry_missing_operation_id_policy", "abort_unsafe_write_retry"));
		ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "PlanningSubgraph", "enter");
		ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "ReadQuerySubgraph", "selected");
		ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "ReadQuerySubgraph", "completed");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "typed_plan_saved", "Plan");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "execute_subgraph_entered", "Execute");
		
		Метрики = ИИА_Сервер.ПолучитьМетрикиОркестратора(СсылкаДиалога);
		Если Метрики = Неопределено Тогда
			Результат.Сообщение = "Метрики оркестратора должны возвращаться";
			Возврат Результат;
		КонецЕсли;
		Если НЕ Метрики.Свойство("approval_rate")
			Или НЕ Метрики.Свойство("recovery_success_rate")
			Или НЕ Метрики.Свойство("top_failure_reasons")
			Или НЕ Метрики.Свойство("execution_path_frequency") Тогда
			Результат.Сообщение = "Метрики оркестратора должны содержать contract fields";
			Возврат Результат;
		КонецЕсли;
		Если Метрики.approval_requested <> 1 Или Метрики.approval_approved <> 1 Тогда
			Результат.Сообщение = "Approval metrics должны корректно считать requested/approved";
			Возврат Результат;
		КонецЕсли;
		Если Метрики.recovery_resume_count <> 1 Или Метрики.recovery_abort_count <> 1 Тогда
			Результат.Сообщение = "Recovery metrics должны корректно считать resume/abort";
			Возврат Результат;
		КонецЕсли;
		Если Метрики.checkpoint_count < 2 Или Метрики.decision_count < 4 Тогда
			Результат.Сообщение = "Метрики должны возвращать агрегаты по checkpoint/decision";
			Возврат Результат;
		КонецЕсли;
		Если ТипЗнч(Метрики.execution_path_frequency) <> Тип("Массив") Или Метрики.execution_path_frequency.Количество() = 0 Тогда
			Результат.Сообщение = "Метрики должны возвращать execution_path_frequency";
			Возврат Результат;
		КонецЕсли;
		Если ТипЗнч(Метрики.top_failure_reasons) <> Тип("Массив") Или Метрики.top_failure_reasons.Количество() = 0 Тогда
			Результат.Сообщение = "Метрики должны возвращать top_failure_reasons";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: метрики оркестратора агрегируются из runtime state";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестКонтрактМетрикОркестратораV2() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", "resume_same_operation_id", "RecoverySubgraph", Новый Структура("source,policy_id,reason", "recovery", "write_retry_same_operation_policy", "resume_same_operation_id"));
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "recovery_policy", "abort_unsafe_write_retry", "RecoverySubgraph", Новый Структура("source,policy_id,reason", "recovery", "write_retry_missing_operation_id_policy", "abort_unsafe_write_retry"));
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Plan", "plan_ready", Ложь);
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Execute", "execute_done", Ложь);
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "execute_failed", Истина);
		Метрики = ИИА_Сервер.ПолучитьМетрикиОркестратора(СсылкаДиалога);
		Если НЕ Метрики.Свойство("transition_frequency")
			Или НЕ Метрики.Свойство("retry_count_per_policy")
			Или НЕ Метрики.Свойство("stage_outcome_metrics") Тогда
			Результат.Сообщение = "V2-метрики должны содержать transition/policy/stage агрегаты";
			Возврат Результат;
		КонецЕсли;
		Если ТипЗнч(Метрики.transition_frequency) <> Тип("Массив")
			Или ТипЗнч(Метрики.retry_count_per_policy) <> Тип("Массив")
			Или ТипЗнч(Метрики.stage_outcome_metrics) <> Тип("Массив") Тогда
			Результат.Сообщение = "V2-метрики должны возвращать массивы";
			Возврат Результат;
		КонецЕсли;
		Если Метрики.transition_frequency.Количество() = 0
			Или Метрики.retry_count_per_policy.Количество() = 0
			Или Метрики.stage_outcome_metrics.Количество() = 0 Тогда
			Результат.Сообщение = "V2-метрики должны агрегировать реальные runtime данные";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
