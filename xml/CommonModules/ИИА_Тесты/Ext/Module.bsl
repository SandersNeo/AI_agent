		ТекстСлужебный = "До" + Символ(0) + "После";
		ИИА_Сервер.ДобавитьСообщениеВДиалог(
			СсылкаДиалога,
			Перечисления.ИИА_АвторСообщения.Пользователь,
			Перечисления.ИИА_ТипСообщения.Текст,
			ТекстСлужебный
		);
		Сообщения = ИИА_Сервер.ПолучитьСообщенияДиалога(СсылкаДиалога, 10);
