Функция НайтиЗначениеВМассиве(МассивЗначений, ОжидаемоеЗначение)
	Если ТипЗнч(МассивЗначений) <> Тип("Массив") Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Каждого ЗначениеМассива Из МассивЗначений Цикл
		Если СокрЛП(Строка(ЗначениеМассива)) = СокрЛП(Строка(ОжидаемоеЗначение)) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

