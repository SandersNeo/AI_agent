Функция ТестКонтрактПромптовСекции() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		ПустаяИстория = Новый ТаблицаЗначений;
		ПустаяИстория.Колонки.Добавить("Автор");
		ПустаяИстория.Колонки.Добавить("ТипСообщения");
		ПустаяИстория.Колонки.Добавить("Текст");
		ПустаяИстория.Колонки.Добавить("ТекстКода");
		ПакетПромпта = ИИА_Промты.СформироватьПромпт(Перечисления.ИИА_ТипДиалога.Агент, "Чат", "тест", ПустаяИстория, "", Неопределено, Ложь);
		СистемныйПромпт = ПакетПромпта.Сообщения[0].content;
		Если СтрНайти(ВРег(СистемныйПромпт), "PROMPT-VERSION:") = 0 Тогда
			Результат.Сообщение = "В системном промпте отсутствует секция Prompt-Version";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(ВРег(СистемныйПромпт), "КОНТРАКТ_ОТВЕТА") = 0 Тогда
			Результат.Сообщение = "В системном промпте отсутствует секция контракта ответа";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(ВРег(СистемныйПромпт), "НИКАКОГО ТЕКСТА ВНЕ JSON") = 0 Тогда
			Результат.Сообщение = "В системном промпте отсутствует явный запрет текста вне JSON";
			Возврат Результат;
		КонецЕсли;
