Функция ТестКонтрактTransitionRegistry() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		Реестр = ИИА_RuntimeКонтракты.ПолучитьРеестрTransitionContract();
		Если Реестр = Неопределено Тогда
			Результат.Сообщение = "Transition registry не создан";
			Возврат Результат;
		КонецЕсли;
		Если НЕ Реестр.Свойство("Decisions") Или НЕ Реестр.Свойство("Reasons") Или НЕ Реестр.Свойство("Policies") Тогда
			Результат.Сообщение = "Transition registry должен содержать Decisions/Reasons/Policies";
			Возврат Результат;
		КонецЕсли;
		Если НЕ НайтиЗначениеВМассиве(Реестр.Decisions, "continue")
			ИЛИ НЕ НайтиЗначениеВМассиве(Реестр.Decisions, "await_approval")
			ИЛИ НЕ НайтиЗначениеВМассиве(Реестр.Decisions, "replan") Тогда
			Результат.Сообщение = "Transition registry должен содержать базовые decisions";
			Возврат Результат;
		КонецЕсли;
		Если НЕ НайтиЗначениеВМассиве(Реестр.Reasons, "plan_ready")
			ИЛИ НЕ НайтиЗначениеВМассиве(Реестр.Reasons, "approval_required")
			ИЛИ НЕ НайтиЗначениеВМассиве(Реестр.Reasons, "resume_same_operation_id") Тогда
			Результат.Сообщение = "Transition registry должен содержать базовые reasons";
			Возврат Результат;
		КонецЕсли;
		Если НЕ НайтиЗначениеВМассиве(Реестр.Policies, "safe-path")
			ИЛИ НЕ НайтиЗначениеВМассиве(Реестр.Policies, "fast-path")
			ИЛИ НЕ НайтиЗначениеВМассиве(Реестр.Policies, "write_retry_same_operation_policy") Тогда
			Результат.Сообщение = "Transition registry должен содержать базовые policies";
			Возврат Результат;
		КонецЕсли;
		
		СубграфРезультат = ИИА_RuntimeКонтракты.СоздатьРезультатПодграфа("TestSubgraph", Истина, "Test->Next", Неопределено, Ложь, "unexpected_decision", Неопределено, "Execute", "unexpected_reason", "unexpected_policy", "step_1");
		Если СубграфРезультат.Decision <> "" Или СубграфРезультат.Reason <> "" Или СубграфРезультат.Policy <> "" Тогда
			Результат.Сообщение = "SubgraphResult должен отбрасывать значения вне transition registry";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: transition registry и нормализация контракта валидны";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

