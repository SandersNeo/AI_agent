Функция ТестСтратегияОтветаПровайдера() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		ПараметрыИИ = Новый Структура;
		ПараметрыИИ.Вставить("ResponseFormat", Новый Структура("type", "json_object"));
		
		СтратегияDSL = ИИА_Провайдеры.ПостроитьСтратегиюОтвета(ПараметрыИИ, "dsl");
		Если НЕ СтратегияDSL.UseBuiltInToolCall Тогда
			Результат.Сообщение = "Для dsl должен использоваться встроенный tool-calling";
			Возврат Результат;
		КонецЕсли;
		Если СтратегияDSL.UseJsonMode Тогда
			Результат.Сообщение = "Для dsl нельзя одновременно включать json-mode";
			Возврат Результат;
		КонецЕсли;
		Если СтратегияDSL.AllowAttachmentTools Тогда
			Результат.Сообщение = "Для dsl не должны подмешиваться tools вложений";
			Возврат Результат;
		КонецЕсли;
		
		СтратегияText = ИИА_Провайдеры.ПостроитьСтратегиюОтвета(Новый Структура, "text");
		Если СтратегияText.UseBuiltInToolCall Тогда
			Результат.Сообщение = "Для text не должен включаться встроенный tool-calling";
			Возврат Результат;
		КонецЕсли;
		Если НЕ СтратегияText.AllowAttachmentTools Тогда
			Результат.Сообщение = "Для text должны быть разрешены tools вложений";
			Возврат Результат;
		КонецЕсли;
		
		СтратегияJson = ИИА_Провайдеры.ПостроитьСтратегиюОтвета(ПараметрыИИ, "json_object");
		Если НЕ СтратегияJson.UseJsonMode Тогда
			Результат.Сообщение = "Для json_object должен включаться json-mode";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: стратегия ответа провайдера разделяет tool/json/text режимы";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

