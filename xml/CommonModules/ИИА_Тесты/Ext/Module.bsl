			Если Инструмент.Свойство("function") И Инструмент.function.Свойство("name") Тогда
				Если Инструмент.function.name = "get_attachment_text" Тогда
					НашлиЧтение = Истина;
				ИначеЕсли Инструмент.function.name = "search_attachments" Тогда
					НашлиПоиск = Истина;
				КонецЕсли;
