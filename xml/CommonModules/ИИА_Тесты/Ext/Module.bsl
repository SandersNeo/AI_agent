Функция ТестКонтрактRuntimeJournalValidator() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Plan", "bad_transition_value", Ложь);
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если Состояние.ПоследнийПереход <> "" Тогда
			Результат.Сообщение = "Runtime journal validator должен отбрасывать invalid state transition";
			Возврат Результат;
		КонецЕсли;
		Trace = ИИА_Сервер.ПолучитьRuntimeTrace(СсылкаДиалога, 10);
		Если ТипЗнч(Trace) <> Тип("Массив") Или Trace.Количество() = 0 Тогда
			Результат.Сообщение = "Runtime trace должен сохранять event_history после state transition";
			Возврат Результат;
		КонецЕсли;
		ПоследнееСобытие = Trace[Trace.Количество() - 1];
		Если ПоследнееСобытие.trace_type <> "checkpoint" Тогда
			ПоследнееСобытие = Trace[0];
		КонецЕсли;
		Если ПоследнееСобытие.Свойство("transition") И ПоследнееСобытие.transition <> "" Тогда
			Результат.Сообщение = "Runtime trace не должен пропускать invalid transition в journal";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: validator очищает invalid runtime transition";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

