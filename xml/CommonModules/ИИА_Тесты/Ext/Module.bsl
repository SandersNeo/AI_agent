		КонецЕсли;
		
		ИсторияЧекпоинтов = ИИА_Сервер.ПолучитьИсториюЧекпоинтовОркестратора(СсылкаДиалога, 10);
		Если ТипЗнч(ИсторияЧекпоинтов) <> Тип("Массив") Тогда
			Результат.Сообщение = "Checkpoint history должен оставаться массивом";
			Возврат Результат;
		КонецЕсли;
		Если ИсторияЧекпоинтов.Количество() <> 0 Тогда
			Результат.Сообщение = "Trace policy registry не должен сохранять invalid checkpoint type";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: trace policy registry валидирует subgraph/checkpoint события";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестDecisionTimeline() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "execution_policy", "safe-path", "PlanningSubgraph", Новый Структура("source,step_id,policy,reason", "planning", "step_1", "planner_policy", "next_step_generation"));
		Таймлайн = ИИА_Сервер.ПолучитьDecisionTimeline(СсылкаДиалога, 10);
		Если ПустаяСтрока(Таймлайн) Тогда
			Результат.Сообщение = "Decision timeline не должен быть пустым";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(Таймлайн, "execution_policy -> safe-path") = 0 Тогда
			Результат.Сообщение = "Decision timeline должен содержать kind и decision";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(Таймлайн, "source=planning") = 0 Тогда
			Результат.Сообщение = "Decision timeline должен содержать source";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(Таймлайн, "step=step_1") = 0 Тогда
			Результат.Сообщение = "Decision timeline должен содержать step_id";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
