Функция ТестКонтрактDecisionLogRecord() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "execution_policy", "safe-path", "PlanningSubgraph", Новый Структура("source,step_id,policy,reason", "planning", "step_1", "planner_policy", "next_step_generation"));
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если ТипЗнч(Состояние.decision_log) <> Тип("Массив") Или Состояние.decision_log.Количество() = 0 Тогда
			Результат.Сообщение = "Decision log должен содержать запись";
			Возврат Результат;
		КонецЕсли;
		ЗаписьРешения = Состояние.decision_log[Состояние.decision_log.Количество() - 1];
		Если НЕ ЗаписьРешения.Свойство("kind") Или НЕ ЗаписьРешения.Свойство("decision") Тогда
			Результат.Сообщение = "Decision record должен содержать kind и decision";
			Возврат Результат;
		КонецЕсли;
		Если НЕ ЗаписьРешения.Свойство("source") Или ЗаписьРешения.source <> "planning" Тогда
			Результат.Сообщение = "Decision record должен содержать stable field source";
			Возврат Результат;
		КонецЕсли;
		Если НЕ ЗаписьРешения.Свойство("step_id") Или ЗаписьРешения.step_id <> "step_1" Тогда
			Результат.Сообщение = "Decision record должен содержать stable field step_id";
			Возврат Результат;
		КонецЕсли;
		Если НЕ ЗаписьРешения.Свойство("policy") Или ЗаписьРешения.policy <> "planner_policy" Тогда
			Результат.Сообщение = "Decision record должен содержать stable field policy";
			Возврат Результат;
		КонецЕсли;
		Если НЕ ЗаписьРешения.Свойство("reason") Или ЗаписьРешения.reason <> "next_step_generation" Тогда
			Результат.Сообщение = "Decision record должен содержать stable field reason";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: decision log record имеет стабильный контракт";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестКонтрактDecisionLogPolicyRegistry() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "unknown_kind", "anything", "PlanningSubgraph");
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "approval", "unexpected_status", "ReadQuerySubgraph");
		ИИА_Сервер.ДобавитьРешениеВDecisionLog(СсылкаДиалога, "next_step_selected", "step_42", "PlanningSubgraph", Новый Структура("source,step_id,reason", "planning", "step_42", "planner_generated"));
		
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если ТипЗнч(Состояние.decision_log) <> Тип("Массив") Тогда
			Результат.Сообщение = "Decision log должен оставаться массивом";
			Возврат Результат;
		КонецЕсли;
		Если Состояние.decision_log.Количество() <> 1 Тогда
			Результат.Сообщение = "Policy registry должен отбрасывать invalid kind и invalid fixed decision";
			Возврат Результат;
		КонецЕсли;
		ЗаписьРешения = Состояние.decision_log[0];
		Если ЗаписьРешения.kind <> "next_step_selected" Или ЗаписьРешения.decision <> "step_42" Тогда
			Результат.Сообщение = "Policy registry должен пропускать допустимый freeform decision";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: decision log policy registry валидирует записи на входе";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестКонтрактTracePolicyRegistry() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ЗафиксироватьАктивныйПодграф(СсылкаДиалога, "PlanningSubgraph", "unknown_subgraph_decision");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалога, "unknown_checkpoint_type", "Plan");
		
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если ТипЗнч(Состояние.subgraph_history) <> Тип("Массив") Или Состояние.subgraph_history.Количество() <> 1 Тогда
			Результат.Сообщение = "Subgraph history должен сохранять запись";
			Возврат Результат;
		КонецЕсли;
		ЗаписьПодграфа = Состояние.subgraph_history[0];
		Если ЗаписьПодграфа.Свойство("decision") И НЕ ПустаяСтрока(Строка(ЗаписьПодграфа.decision)) Тогда
