			Результат.Сообщение = "Ожидалось одно сообщение в диалоге";
			Возврат Результат;
		КонецЕсли;
		Если НайтиНедопустимыйСимволXDTO(Строка(Сообщения[0].Текст)) > 0 Тогда
			Результат.Сообщение = "ПолучитьСообщенияДиалога должна возвращать XDTO-безопасный текст";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(Строка(Сообщения[0].Текст), "ДоПосле") = 0 Тогда
			Результат.Сообщение = "После очистки сообщение должно сохранять полезный текст";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: сообщения диалога очищаются для XDTO";
