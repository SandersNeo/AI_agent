Функция ТестКонтрактExecuteSubgraphRouting() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		WriteDSL = "{""dsl_version"":2,""steps"":[{""action"":""CreateReference"",""object_name"":""Контрагенты"",""operation_id"":""op_1""},{""action"":""Write"",""operation_id"":""op_2""}]}";
		ReadDSL = "{""dsl_version"":2,""steps"":[{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ПЕРВЫЕ 1 Наименование ИЗ Справочник.Контрагенты""}]}";
		GenericDSL = "{""dsl_version"":2,""steps"":[{""action"":""ShowInfo"",""message"":""ok""}]}";
		
		РоутингWrite = ИИА_Оркестратор.ОпределитьИсполнительныйПодграф(WriteDSL);
		РоутингRead = ИИА_Оркестратор.ОпределитьИсполнительныйПодграф(ReadDSL);
		РоутингGeneric = ИИА_Оркестратор.ОпределитьИсполнительныйПодграф(GenericDSL);
		
		Если РоутингWrite = Неопределено Или РоутингWrite.SubgraphName <> "WriteActionSubgraph" Тогда
			Результат.Сообщение = "Write DSL должен маршрутизироваться в WriteActionSubgraph";
			Возврат Результат;
		КонецЕсли;
		Если НЕ РоутингWrite.Свойство("HasWriteActions") Или НЕ РоутингWrite.HasWriteActions Тогда
			Результат.Сообщение = "Write routing должен маркировать HasWriteActions";
			Возврат Результат;
		КонецЕсли;
		
		Если РоутингRead = Неопределено Или РоутингRead.SubgraphName <> "ReadQuerySubgraph" Тогда
			Результат.Сообщение = "RunQuery DSL должен маршрутизироваться в ReadQuerySubgraph";
			Возврат Результат;
		КонецЕсли;
		Если НЕ РоутингRead.Свойство("HasRunQuery") Или НЕ РоутингRead.HasRunQuery Тогда
			Результат.Сообщение = "Read routing должен маркировать HasRunQuery";
			Возврат Результат;
		КонецЕсли;
		
		Если РоутингGeneric = Неопределено Или РоутингGeneric.SubgraphName <> "GenericExecuteSubgraph" Тогда
			Результат.Сообщение = "ShowInfo DSL должен оставаться в GenericExecuteSubgraph";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: Execute subgraph routing работает";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестDiscoverySubgraph() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Запрос1С);
		РезультатDiscovery = ИИА_Оркестратор.ВыполнитьDiscoverySubgraph(СсылкаДиалога, "Сколько контрагентов в базе?", Перечисления.ИИА_ТипДиалога.Запрос1С);
		Если РезультатDiscovery = Неопределено Тогда
			Результат.Сообщение = "DiscoverySubgraph не вернул результат";
			Возврат Результат;
		КонецЕсли;
		Если НЕ РезультатDiscovery.Свойство("SubgraphName") Или РезультатDiscovery.SubgraphName <> "DiscoverySubgraph" Тогда
			Результат.Сообщение = "DiscoverySubgraph должен возвращать свой идентификатор";
			Возврат Результат;
		КонецЕсли;
		Если НЕ РезультатDiscovery.Свойство("Details") Или НЕ РезультатDiscovery.Details.Свойство("ИспользоватьRAG") Тогда
			Результат.Сообщение = "DiscoverySubgraph должен возвращать decision details по RAG";
			Возврат Результат;
		КонецЕсли;
		Если НЕ РезультатDiscovery.Успех Тогда
			Результат.Сообщение = "DiscoverySubgraph должен завершаться успешно для обычной задачи";
			Возврат Результат;
		КонецЕсли;
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если ТипЗнч(Состояние.decision_log) <> Тип("Массив") Или Состояние.decision_log.Количество() < 2 Тогда
			Результат.Сообщение = "DiscoverySubgraph должен писать semantic decisions в decision_log";
			Возврат Результат;
		КонецЕсли;
		НайденDecisionRAG = Ложь;
		НайденDecisionPolicy = Ложь;
		Для Каждого ЗаписьРешения Из Состояние.decision_log Цикл
			Если ЗаписьРешения.Свойство("kind") И ЗаписьРешения.kind = "discovery_rag" Тогда
				НайденDecisionRAG = Истина;
			КонецЕсли;
			Если ЗаписьРешения.Свойство("kind") И ЗаписьРешения.kind = "execution_policy" И ЗаписьРешения.Свойство("subgraph") И ЗаписьРешения.subgraph = "DiscoverySubgraph" Тогда
				НайденDecisionPolicy = Истина;
			КонецЕсли;
		КонецЦикла;
		Если НЕ НайденDecisionRAG Тогда
			Результат.Сообщение = "DiscoverySubgraph должен логировать discovery_rag решение";
			Возврат Результат;
		КонецЕсли;
		Если НЕ НайденDecisionPolicy Тогда
			Результат.Сообщение = "DiscoverySubgraph должен логировать execution_policy решение";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: DiscoverySubgraph возвращает discovery decision";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестPlanningSubgraph() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Запрос1С);
		ИИА_Сервер.ОтправитьСообщениеСервера(СсылкаДиалога, Перечисления.ИИА_ТипДиалога.Запрос1С, "Сколько контрагентов в базе?");
		МассивMock = Новый Массив;
		МассивMock.Добавить(Новый Структура("Текст", "{""plan_version"":1,""goal"":""Сколько контрагентов в базе?"",""steps"":[{""id"":""step_1"",""kind"":""run_query"",""title"":""Подсчитать контрагентов"",""depends_on"":[],""input"":{""query"":""Сколько контрагентов в базе?""},""status"":""pending""}]}"));
		МассивMock.Добавить(Новый Структура("Текст,DSL,PlanStepId", "{""dsl_version"":2,""steps"":[{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ПЕРВЫЕ 1 Наименование ИЗ Справочник.Контрагенты""}]}", "{""dsl_version"":2,""steps"":[{""action"":""RunQuery"",""query"":""ВЫБРАТЬ ПЕРВЫЕ 1 Наименование ИЗ Справочник.Контрагенты""}]}", "step_1"));
		ИИА_Сервер.УстановитьОчередьMockОтветов(СсылкаДиалога, МассивMock);
		РезультатПланирования = ИИА_Оркестратор.ВыполнитьPlanningSubgraph(СсылкаДиалога);
		ИИА_Сервер.ОчиститьОчередьMockОтветов(СсылкаДиалога);
		Если РезультатПланирования = Неопределено
			ИЛИ НЕ РезультатПланирования.Свойство("Успех")
			ИЛИ НЕ РезультатПланирования.Успех Тогда
			Результат.Сообщение = "PlanningSubgraph должен успешно построить следующий шаг";
			Возврат Результат;
		КонецЕсли;
		Если НЕ РезультатПланирования.Свойство("NextStage") Или РезультатПланирования.NextStage <> "Execute" Тогда
			Результат.Сообщение = "PlanningSubgraph должен возвращать transition contract с NextStage=Execute";
			Возврат Результат;
		КонецЕсли;
		Если НЕ РезультатПланирования.Свойство("StepId") Или РезультатПланирования.StepId <> "step_1" Тогда
			Результат.Сообщение = "PlanningSubgraph должен возвращать StepId в transition contract";
			Возврат Результат;
		КонецЕсли;
		Если НЕ РезультатПланирования.Свойство("Policy") Или ПустаяСтрока(РезультатПланирования.Policy) Тогда
			Результат.Сообщение = "PlanningSubgraph должен возвращать Policy в transition contract";
			Возврат Результат;
		КонецЕсли;
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если Состояние = Неопределено Или Состояние.active_subgraph <> "PlanningSubgraph" Тогда
			Результат.Сообщение = "PlanningSubgraph должен фиксироваться как active_subgraph";
			Возврат Результат;
		КонецЕсли;
		Если ПустаяСтрока(Состояние.execution_policy) Тогда
			Результат.Сообщение = "PlanningSubgraph должен фиксировать execution_policy";
			Возврат Результат;
		КонецЕсли;
		Если ПустаяСтрока(Состояние.thread_id) Тогда
			Результат.Сообщение = "PlanningSubgraph должен фиксировать thread_id";
			Возврат Результат;
		КонецЕсли;
		Если ПустаяСтрока(Состояние.active_step_id) Тогда
			Результат.Сообщение = "PlanningSubgraph должен фиксировать active_step_id";
			Возврат Результат;
		КонецЕсли;
		Если ТипЗнч(Состояние.subgraph_history) <> Тип("Массив") Или Состояние.subgraph_history.Количество() = 0 Тогда
			Результат.Сообщение = "PlanningSubgraph должен писать subgraph_history";
			Возврат Результат;
		КонецЕсли;
		Если ТипЗнч(Состояние.decision_log) <> Тип("Массив") Или Состояние.decision_log.Количество() = 0 Тогда
			Результат.Сообщение = "PlanningSubgraph должен писать decision_log";
			Возврат Результат;
		КонецЕсли;
		НайденPolicyDecision = Ложь;
		НайденNextStepDecision = Ложь;
		Для Каждого ЗаписьРешения Из Состояние.decision_log Цикл
			Если ЗаписьРешения.Свойство("kind") И ЗаписьРешения.kind = "execution_policy" И ЗаписьРешения.Свойство("subgraph") И ЗаписьРешения.subgraph = "PlanningSubgraph" Тогда
				НайденPolicyDecision = Истина;
			КонецЕсли;
			Если ЗаписьРешения.Свойство("kind") И ЗаписьРешения.kind = "next_step_selected" И ЗаписьРешения.Свойство("decision") И ЗаписьРешения.decision = "step_1" Тогда
				НайденNextStepDecision = Истина;
			КонецЕсли;
		КонецЦикла;
		Если НЕ НайденPolicyDecision Тогда
			Результат.Сообщение = "PlanningSubgraph должен логировать execution_policy решение";
			Возврат Результат;
		КонецЕсли;
		Если НЕ НайденNextStepDecision Тогда
			Результат.Сообщение = "PlanningSubgraph должен логировать next_step_selected";
			Возврат Результат;
		КонецЕсли;
		Артефакт = ИИА_Сервер.ПолучитьАртефактПланировщика(СсылкаДиалога);
		Если Артефакт = Неопределено Или ПустаяСтрока(Артефакт.PlannedDSL) Тогда
			Результат.Сообщение = "PlanningSubgraph должен сохранить planner artifact";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: PlanningSubgraph обновляет runtime state и planner artifact";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестПолныйПутьApprovalApproveValidate() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Запрос1С);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		
		План = Новый Структура;
		План.Вставить("plan_version", 1);
		План.Вставить("goal", "Получить контрагентов");
		План.Вставить("steps", Новый Массив);
		Шаг = Новый Структура;
		Шаг.Вставить("id", "step_1");
		Шаг.Вставить("seq_no", 1);
		Шаг.Вставить("kind", "run_query");
		Шаг.Вставить("title", "Выполнить запрос");
		Шаг.Вставить("depends_on", Новый Массив);
		Шаг.Вставить("input", Новый Структура("query", "Контрагенты"));
		Шаг.Вставить("status", "pending");
		Шаг.Вставить("result_summary", "");
		Шаг.Вставить("result_data", Неопределено);
		План.steps.Добавить(Шаг);
		ИИА_TypedPlan.СохранитьTypedPlan(СсылкаДиалога, План);
		
		DSL = "{""dsl_version"":2,""steps"":[{""action"":""RunQuery"",""query"":""ВЫБРАТЬ Наименование ИЗ Справочник.Контрагенты""}]}";
		ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалога, DSL, "test_approval_path", "step_1");
		ИИА_Сервер.УстановитьActiveStepId(СсылкаДиалога, "step_1");
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Execute", "test_approval_path", Ложь);
		
		Если НЕ ИИА_Оркестратор.ВыполнитьСтадиюExecute(СсылкаДиалога) Тогда
			Результат.Сообщение = "Execute должен успешно перейти в AwaitApproval";
			Возврат Результат;
		КонецЕсли;
		
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если Состояние = Неопределено Или Состояние.ТекущаяСтадия <> "AwaitApproval" Тогда
			Результат.Сообщение = "После первого Execute оркестратор должен перейти в AwaitApproval";
			Возврат Результат;
		КонецЕсли;
		
		СостояниеПодтверждения = ИИА_Сервер.ПолучитьСостояниеПодтверждения(СсылкаДиалога);
		Если СостояниеПодтверждения = Неопределено
			Или НЕ СостояниеПодтверждения.Свойство("status")
			Или ВРег(Строка(СостояниеПодтверждения.status)) <> "PENDING" Тогда
			Результат.Сообщение = "Должно появиться pending-состояние подтверждения";
			Возврат Результат;
		КонецЕсли;
		Если НЕ СостояниеПодтверждения.Свойство("subgraph_name") Или СостояниеПодтверждения.subgraph_name <> "ReadQuerySubgraph" Тогда
			Результат.Сообщение = "Approval state должен сохранять subgraph_name";
			Возврат Результат;
		КонецЕсли;
		
		Если НЕ ИИА_ApprovalPolicy.ПодтвердитьОжидающееДействие(СсылкаДиалога, Ложь) Тогда
			Результат.Сообщение = "Подтверждение ожидающего действия должно отработать";
			Возврат Результат;
		КонецЕсли;
		
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если Состояние = Неопределено Или Состояние.ТекущаяСтадия <> "Execute" Тогда
			Результат.Сообщение = "После approve оркестратор должен вернуться в Execute";
			Возврат Результат;
		КонецЕсли;
		
		Если НЕ ИИА_Оркестратор.ВыполнитьСтадиюExecute(СсылкаДиалога) Тогда
			Результат.Сообщение = "Execute после approve должен исполнить DSL";
			Возврат Результат;
		КонецЕсли;
		
		РезультатValidate = ИИА_Оркестратор.ВыполнитьСтадиюValidate(СсылкаДиалога);
		Если РезультатValidate = Неопределено
			Или НЕ РезультатValidate.Свойство("NextStage")
			Или РезультатValidate.NextStage <> "Summarize" Тогда
			Результат.Сообщение = "Validate после approve должен завершать одноступенчатый план";
			Возврат Результат;
		КонецЕсли;
		
		ПланПосле = ИИА_TypedPlan.ПолучитьTypedPlan(СсылкаДиалога);
		Если ПланПосле = Неопределено Или ТипЗнч(ПланПосле.steps) <> Тип("Массив") Или ПланПосле.steps.Количество() = 0 Тогда
			Результат.Сообщение = "Typed plan должен сохраняться после validate";
			Возврат Результат;
		КонецЕсли;
		ШагПосле = ПланПосле.steps[0];
		Если НЕ ШагПосле.Свойство("status") Или ВРег(Строка(ШагПосле.status)) <> "DONE" Тогда
			Результат.Сообщение = "Validate должен помечать шаг как done";
			Возврат Результат;
		КонецЕсли;
		
		НайденApprovalRequested = Ложь;
		НайденApprovalApproved = Ложь;
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Для Каждого ЗаписьРешения Из Состояние.decision_log Цикл
			Если ЗаписьРешения.Свойство("kind")
				И ЗаписьРешения.kind = "approval"
				И ЗаписьРешения.Свойство("decision")
				И ЗаписьРешения.decision = "requested"
				И ЗаписьРешения.Свойство("subgraph")
				И ЗаписьРешения.subgraph = "ReadQuerySubgraph" Тогда
				НайденApprovalRequested = Истина;
			КонецЕсли;
			Если ЗаписьРешения.Свойство("kind")
				И ЗаписьРешения.kind = "approval"
				И ЗаписьРешения.Свойство("decision")
				И ЗаписьРешения.decision = "approved"
				И ЗаписьРешения.Свойство("subgraph")
				И ЗаписьРешения.subgraph = "ReadQuerySubgraph" Тогда
				НайденApprovalApproved = Истина;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ НайденApprovalRequested Или НЕ НайденApprovalApproved Тогда
			Результат.Сообщение = "Approval path должен писать requested и approved для ReadQuerySubgraph";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: путь Execute -> AwaitApproval -> Approve -> Validate работает";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестОчисткиСущностейRAG() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		ГрязныйТекст = "Ошибка API (500): HTTP 402 detail=requested up to 65536 tokens";
		ОчищенныйГрязный = ИИА_Промты.ОчиститьСущностиДляRAG(ГрязныйТекст);
		Результат.Детали.Добавить("Очищенный грязный текст: '" + ОчищенныйГрязный + "'");
		Если НЕ ПустаяСтрока(ОчищенныйГрязный) Тогда
			Результат.Сообщение = "Служебный текст не должен попадать в RAG-сущности";
			Возврат Результат;
		КонецЕсли;
		
		ПолезныйТекст = "Контрагент Мир Мебели счет 123 приходная накладная";
		ОчищенныйПолезный = ИИА_Промты.ОчиститьСущностиДляRAG(ПолезныйТекст);
		Результат.Детали.Добавить("Очищенный полезный текст: '" + ОчищенныйПолезный + "'");
		Если ПустаяСтрока(ОчищенныйПолезный) Тогда
			Результат.Сообщение = "Полезные сущности не должны очищаться в пустоту";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(ВРег(ОчищенныйПолезный), "КОНТРАГЕНТ") = 0 И СтрНайти(ВРег(ОчищенныйПолезный), "МЕБЕЛ") = 0 Тогда
			Результат.Сообщение = "Очистка сущностей потеряла смысловые токены: '" + ОчищенныйПолезный + "'";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: очистка сущностей RAG";
	Исключение
		Результат.Сообщение = "Исключение: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестКомпактногоФорматаRAG() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СтрокаRAG = ИИА_Промты.СформироватьСтрокуОбъектаRAG("Catalog", "Контрагенты", "Контрагенты", "Наименование, Код, ИНН, КПП, Договор");
		Результат.Детали.Добавить("Строка RAG: " + СтрокаRAG);
		Если СтрНайти(СтрокаRAG, "Catalog.Контрагенты") = 0 И СтрНайти(СтрокаRAG, "Справочник.Контрагенты") = 0 Тогда
			Результат.Сообщение = "Компактный формат должен содержать имя объекта";
