	ПутьMXL = "";
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ПутьMXL = СоздатьВременныйMXLДляТеста();
		ИИА_Вложения.ДобавитьВложениеИзФайла(СсылкаДиалога, ПутьMXL);
		
		ИсторияМассив = ИИА_Сервер.ПолучитьСообщенияДиалога(СсылкаДиалога, 10);
		История = ИИА_Сервер.ПреобразоватьМассивСообщенийВТаблицу(ИсторияМассив);
		Промпт = ИИА_Промты.СформироватьПромпт(Перечисления.ИИА_ТипДиалога.Агент, "Чат", "Что в приложенной таблице?", История, "", СсылкаДиалога, Ложь);
		Если Промпт = Неопределено ИЛИ НЕ Промпт.Свойство("Сообщения") Тогда
			Результат.Сообщение = "Промпт должен содержать сообщения";
			Возврат Результат;
		КонецЕсли;
		ПоследнееСообщение = Промпт.Сообщения[Промпт.Сообщения.Количество() - 1];
		Контент = ?(ПоследнееСообщение.Свойство("content"), Строка(ПоследнееСообщение.content), "");
		Если СтрНайти(Контент, "КОНТЕКСТ ВЛОЖЕНИЙ:") = 0 Тогда
			Результат.Сообщение = "Контекст вложений должен попадать в prompt";
			Возврат Результат;
		КонецЕсли;
		Если СтрНайти(Контент, ".mxl") = 0 Тогда
			Результат.Сообщение = "Имя MXL-файла должно попадать в prompt";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: prompt содержит контекст вложений";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

#КонецОбласти




