		// Неизвестное действие
		НеизвестныйDSL = "{""steps"":[{""action"":""UnknownAction""}]}";
		РезНеизв = ИИА_Сервер.ПроверитьDSLСценарий(НеизвестныйDSL);
		Результат.Детали.Добавить("Неизвестное действие: Успех=" + РезНеизв.Успех + " (ожидается Ложь)");
		Если РезНеизв.Успех Тогда
			Результат.Сообщение = "Неизвестное действие прошло валидацию";
			Возврат Результат;
		КонецЕсли;
		
		// GetObjectFields для регистра накопления (поддержка регистров)
		DSLРегистр = "{""steps"":[{""action"":""GetObjectFields"",""object_type"":""РегистрНакопления"",""object_name"":""ЗапасыНаСкладах""}]}";
		РезРегистр = ИИА_Сервер.ПроверитьDSLСценарий(DSLРегистр);
		Результат.Детали.Добавить("GetObjectFields РегистрНакопления: Успех=" + РезРегистр.Успех + " (ожидается Истина)");
		Если НЕ РезРегистр.Успех Тогда
