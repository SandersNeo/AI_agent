Функция ТестНативнаяПодготовкаImagePdf() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ПутьИзображения = СоздатьВременныйФайлИзображенияДляТеста();
		ПутьPDF = СоздатьВременныйPDFДляТеста();
		ИИА_Вложения.ДобавитьВложениеИзФайла(СсылкаДиалога, ПутьИзображения, "native.png");
		ИИА_Вложения.ДобавитьВложениеИзФайла(СсылкаДиалога, ПутьPDF, "native.pdf");
		Сообщения = Новый Массив;
		СообщениеСистема = Новый Структура("role,content", "system", "system");
		СообщениеПользователь = Новый Структура("role,content", "user", "Опиши приложенные файлы");
		Сообщения.Добавить(СообщениеСистема);
		Сообщения.Добавить(СообщениеПользователь);
		ПараметрыИИ = Новый Структура;
		ПараметрыИИ.Вставить("СсылкаДиалога", СсылкаДиалога);
		ПараметрыИИ.Вставить("Provider_BaseUrl", "https://api.openai.com/v1");
		Подготовленные = ИИА_Провайдеры.ПодготовитьСообщенияСНативнымиВложениями(Сообщения, ПараметрыИИ);
		Последнее = Подготовленные[Подготовленные.Количество() - 1];
		Если НЕ Последнее.Свойство("content") ИЛИ ТипЗнч(Последнее.content) <> Тип("Массив") Тогда
			Результат.Сообщение = "Для image/pdf content последнего сообщения должен превращаться в multimodal-массив";
			Возврат Результат;
		КонецЕсли;
		НашлиИзображение = Ложь;
		НашлиФайл = Ложь;
		Для Каждого Часть Из Последнее.content Цикл
			Если Часть.Свойство("type") И Часть.type = "image_url" Тогда
				НашлиИзображение = Истина;
			ИначеЕсли Часть.Свойство("type") И Часть.type = "file" Тогда
				НашлиФайл = Истина;
			КонецЕсли;
		КонецЦикла;
		Если НЕ НашлиИзображение ИЛИ НЕ НашлиФайл Тогда
			Результат.Сообщение = "Multimodal content должен содержать native image и native file для PDF";
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: image/pdf готовятся для нативной передачи";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

