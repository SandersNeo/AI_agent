Функция ТестAntiGiveupRecoveryExhausted() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Запрос1С);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "attempt_1", Истина);
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "attempt_2", Истина);
		ИИА_Сервер.УстановитьСостояниеОркестратора(СсылкаДиалога, "Recover", "attempt_3", Истина);
		
		ОшибкаExecutor = Новый Структура("Успех,Сообщение,error_code", Ложь, "field_not_found", "field_not_found");
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, ОшибкаExecutor);
		
		РезультатValidate = ИИА_Оркестратор.ВыполнитьСтадиюValidate(СсылкаДиалога);
		Если РезультатValidate = Неопределено Или НЕ РезультатValidate.Свойство("NextStage") Тогда
			Результат.Сообщение = "Validate должен вернуть следующую стадию";
			Возврат Результат;
		КонецЕсли;
		Если РезультатValidate.NextStage <> "Summarize" Тогда
			Результат.Сообщение = "При исчерпании recovery должен быть переход в Summarize";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: recovery_exhausted корректно ведет в summary";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

