			Результат.Сообщение = "После recovery должен оставаться planner artifact с тем же operation_id";
			Возврат Результат;
		КонецЕсли;
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если ТипЗнч(Состояние.decision_log) <> Тип("Массив") Или Состояние.decision_log.Количество() = 0 Тогда
			Результат.Сообщение = "Recovery должен писать decision_log для resume_same_operation_id";
			Возврат Результат;
		КонецЕсли;
		ПоследнееРешение = Состояние.decision_log[Состояние.decision_log.Количество() - 1];
		Если НЕ ПоследнееРешение.Свойство("decision") Или ПоследнееРешение.decision <> "resume_same_operation_id" Тогда
			Результат.Сообщение = "decision_log должен фиксировать resume_same_operation_id";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: write recovery возобновляет Execute с тем же operation_id";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
