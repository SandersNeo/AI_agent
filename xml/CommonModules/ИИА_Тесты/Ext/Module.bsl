Функция ТестКонтрактReplaySafetyPolicy() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалогаRead = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалогаRead, "{""dsl_version"":2,""steps"":[{""action"":""RunQuery"",""query"":""ВЫБРАТЬ Наименование ИЗ Справочник.Контрагенты""}]}", "test_read", "step_read");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалогаRead, "execute_subgraph_entered", "Execute");
		ReplayRead = ИИА_ReplayPolicy.КлассифицироватьReplaySafety(СсылкаДиалогаRead, 0);
		Если ReplayRead.classification <> "safe_replay" Тогда
			Результат.Сообщение = "Read-only DSL должен классифицироваться как safe_replay";
			Возврат Результат;
		КонецЕсли;
		
		СсылкаДиалогаWrite = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалогаWrite, "{""dsl_version"":2,""steps"":[{""action"":""Write"",""operation_id"":""op_resume""}]}", "test_write", "step_write");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалогаWrite, "execute_subgraph_entered", "Execute");
		ReplayWrite = ИИА_ReplayPolicy.КлассифицироватьReplaySafety(СсылкаДиалогаWrite, 0);
		Если ReplayWrite.classification <> "resume_only" Тогда
			Результат.Сообщение = "Write с operation_id должен классифицироваться как resume_only";
			Возврат Результат;
		КонецЕсли;
		
		СсылкаДиалогаUnsafe = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.СохранитьАртефактПланировщика(СсылкаДиалогаUnsafe, "{""dsl_version"":2,""steps"":[{""action"":""Write""}]}", "test_unsafe", "step_unsafe");
		ИИА_Сервер.СохранитьЧекпоинтОркестратора(СсылкаДиалогаUnsafe, "execute_subgraph_entered", "Execute");
		ReplayUnsafe = ИИА_ReplayPolicy.КлассифицироватьReplaySafety(СсылкаДиалогаUnsafe, 0);
		Если ReplayUnsafe.classification <> "no_replay" Тогда
			Результат.Сообщение = "Write без operation_id должен классифицироваться как no_replay";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: replay safety policy классифицирует safe/resume_only/no_replay";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

