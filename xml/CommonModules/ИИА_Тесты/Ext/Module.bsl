Функция ТестСписокМоделейOpenAI() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		Модели = ИИА_GitsellСервер.Gitsell_СписокМоделей();
		Если Модели = Неопределено ИЛИ Модели.Количество() = 0 Тогда
			Результат.Сообщение = "Список моделей пуст";
			Возврат Результат;
		КонецЕсли;
		ОжидаемыеМодели = Новый Массив;
		ОжидаемыеМодели.Добавить("gpt-4.1");
		ОжидаемыеМодели.Добавить("gpt-4.1-mini");
		ОжидаемыеМодели.Добавить("gpt-4.1-nano");
		ОжидаемыеМодели.Добавить("gpt-4o");
		ОжидаемыеМодели.Добавить("gpt-4o-mini");
		ОжидаемыеМодели.Добавить("gpt-5.4");
		ОжидаемыеМодели.Добавить("gpt-5.4-mini");
		ОжидаемыеМодели.Добавить("gpt-5.4-nano");
		ОжидаемыеМодели.Добавить("gpt-5.4-thinking");
		
		Для Каждого ИмяМодели Из ОжидаемыеМодели Цикл
			Найдена = Ложь;
			Для Каждого Модель Из Модели Цикл
				Если Модель.Свойство("id") И Строка(Модель.id) = ИмяМодели Тогда
					Найдена = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если НЕ Найдена Тогда
				Результат.Сообщение = "В списке моделей отсутствует " + ИмяМодели;
				Возврат Результат;
			КонецЕсли;
		КонецЦикла;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: список OpenAI моделей обновлен";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

