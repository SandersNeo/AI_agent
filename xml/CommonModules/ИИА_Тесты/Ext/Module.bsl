Функция ТестDSLПостроительSetFieldFieldName() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Запрос1С);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		
		План = Новый Структура;
		План.Вставить("plan_version", 1);
		План.Вставить("goal", "Создать контрагента Петров");
		План.Вставить("steps", Новый Массив);
		
		Шаг1 = Новый Структура;
		Шаг1.Вставить("id", "step_1");
		Шаг1.Вставить("seq_no", 1);
		Шаг1.Вставить("kind", "create_reference");
		Шаг1.Вставить("title", "Создать новый элемент справочника Контрагенты");
		Шаг1.Вставить("depends_on", Новый Массив);
		Шаг1.Вставить("input", Новый Структура("object_name", "Справочник.Контрагенты"));
		Шаг1.Вставить("status", "pending");
		План.steps.Добавить(Шаг1);
		
		Шаг2 = Новый Структура;
		Шаг2.Вставить("id", "step_2");
		Шаг2.Вставить("seq_no", 2);
		Шаг2.Вставить("kind", "set_field");
		Шаг2.Вставить("title", "Установить наименование контрагента");
		Шаг2.Вставить("depends_on", Новый Массив);
		Шаг2.depends_on.Добавить("step_1");
		Шаг2.Вставить("input", Новый Структура("field_name,value", "Наименование", "Петров"));
		Шаг2.Вставить("status", "pending");
		План.steps.Добавить(Шаг2);
		
		Шаг3 = Новый Структура;
		Шаг3.Вставить("id", "step_3");
		Шаг3.Вставить("seq_no", 3);
		Шаг3.Вставить("kind", "write_object");
		Шаг3.Вставить("title", "Сохранить контрагента");
		Шаг3.Вставить("depends_on", Новый Массив);
		Шаг3.depends_on.Добавить("step_2");
		Шаг3.Вставить("input", Новый Структура);
		Шаг3.Вставить("status", "pending");
		План.steps.Добавить(Шаг3);
		
		Шаг4 = Новый Структура;
		Шаг4.Вставить("id", "step_4");
		Шаг4.Вставить("seq_no", 4);
		Шаг4.Вставить("kind", "show_info");
		Шаг4.Вставить("title", "Показать информацию о созданном контрагенте");
		Шаг4.Вставить("depends_on", Новый Массив);
		Шаг4.depends_on.Добавить("step_3");
		Шаг4.Вставить("input", Новый Структура);
		Шаг4.Вставить("status", "pending");
		План.steps.Добавить(Шаг4);
		
		ИИА_TypedPlan.СохранитьTypedPlan(СсылкаДиалога, План);
		DSL = ИИА_DSLПостроитель.ПостроитьDSLИзЦепочкиШаговПлана(СсылкаДиалога, Шаг1);
		Если ПустаяСтрока(DSL) Тогда
			Результат.Сообщение = "DSL builder должен собрать write-цепочку из typed plan";
			Возврат Результат;
		КонецЕсли;
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(DSL);
		DSLСтруктура = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		Если ТипЗнч(DSLСтруктура) <> Тип("Структура")
			Или НЕ DSLСтруктура.Свойство("steps")
			Или ТипЗнч(DSLСтруктура.steps) <> Тип("Массив")
			Или DSLСтруктура.steps.Количество() < 2 Тогда
			Результат.Сообщение = "DSL builder должен возвращать steps-массив минимум из двух шагов";
			Результат.Детали.Добавить(DSL);
			Возврат Результат;
		КонецЕсли;
		ШагSetField = DSLСтруктура.steps[1];
		Если ТипЗнч(ШагSetField) <> Тип("Структура")
			Или НЕ ШагSetField.Свойство("action")
			Или ВРег(Строка(ШагSetField.action)) <> "SETFIELD"
			Или НЕ ШагSetField.Свойство("field")
			Или Строка(ШагSetField.field) <> "Наименование" Тогда
			Результат.Сообщение = "SetField должен сериализовать field_name в поле field";
			Результат.Детали.Добавить(DSL);
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: DSL builder переносит field_name в field для write-chain";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестКонтрактQuerySafetyGate() Экспорт
