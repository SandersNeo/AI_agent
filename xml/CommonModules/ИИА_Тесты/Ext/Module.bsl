Функция ТестRecoveryResumeAfterCommittedWrite() Экспорт
	Результат = СформироватьРезультатТеста(Ложь, "", Новый Массив);
	Попытка
		СсылкаДиалога = ИИА_Сервер.СоздатьНовыйДиалог("Администратор", Перечисления.ИИА_ТипДиалога.Агент);
		ИИА_Сервер.ИнициализироватьКонтекстАрхитектуры(СсылкаДиалога);
		
		OperationId = "op_test_committed_write";
		ОшибкаExecutor = Новый Структура("Успех,Сообщение,error_code,operation_id", Ложь, "Ошибка записи объекта: таймаут", "write_failed", OperationId);
		ИИА_Сервер.СохранитьРезультатExecutor(СсылкаДиалога, ОшибкаExecutor);
		ИИА_Сервер.ДобавитьЗаписьВСайдЭффектЛог(СсылкаДиалога, Новый Структура("effect_type,action,operation_id", "object_written", "Write", OperationId));
		
		Политика = ИИА_Оркестратор.ПрименитьПолитикуВосстановления(СсылкаДиалога, "write_failed", "Ошибка записи объекта: таймаут");
		Если Политика = Неопределено ИЛИ НЕ Политика.Обработано Тогда
			Результат.Сообщение = "Write recovery должен обработать committed side effect";
			Возврат Результат;
		КонецЕсли;
		Если НЕ Политика.Свойство("СледующаяСтадия") ИЛИ Политика.СледующаяСтадия <> "Validate" Тогда
			Результат.Сообщение = "Committed write должен вести recovery в Validate";
			Возврат Результат;
		КонецЕсли;
		Если НЕ Политика.Свойство("Решение") ИЛИ Политика.Решение <> "resume" Тогда
			Результат.Сообщение = "Committed write должен давать решение resume";
			Возврат Результат;
		КонецЕсли;
		
		СинтетическийРезультат = ИИА_Сервер.ПолучитьРезультатExecutor(СсылкаДиалога);
		Если СинтетическийРезультат = Неопределено ИЛИ НЕ СинтетическийРезультат.Свойство("Успех") ИЛИ НЕ СинтетическийРезультат.Успех Тогда
			Результат.Сообщение = "Recovery должен сохранить синтетически успешный executor result";
			Возврат Результат;
		КонецЕсли;
		Состояние = ИИА_Сервер.ПолучитьСостояниеОркестратора(СсылкаДиалога);
		Если ТипЗнч(Состояние.decision_log) <> Тип("Массив") Или Состояние.decision_log.Количество() = 0 Тогда
			Результат.Сообщение = "Recovery должен писать decision_log для committed write";
			Возврат Результат;
		КонецЕсли;
		ПоследнееРешение = Состояние.decision_log[Состояние.decision_log.Количество() - 1];
		Если НЕ ПоследнееРешение.Свойство("kind") Или ПоследнееРешение.kind <> "recovery_policy" Тогда
			Результат.Сообщение = "Последняя запись decision_log должна быть recovery_policy";
			Возврат Результат;
		КонецЕсли;
		Если НЕ ПоследнееРешение.Свойство("decision") Или ПоследнееРешение.decision <> "resume_after_committed_write" Тогда
			Результат.Сообщение = "decision_log должен фиксировать resume_after_committed_write";
			Возврат Результат;
		КонецЕсли;
		
		Результат.Успех = Истина;
		Результат.Сообщение = "Тест пройден: committed write переводит recovery в Validate";
	Исключение
		Результат.Сообщение = "Ошибка: " + ОписаниеОшибки();
		Результат.Детали.Добавить(Результат.Сообщение);
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ТестRecoveryResumeSameOperationId() Экспорт
