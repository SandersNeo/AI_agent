КонецФункции

Функция СериализоватьJSONВСтроку(ЗначениеJSON) Экспорт
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ЗначениеJSON);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

Функция ПолучитьПараметрШагаПлана(ШагПлана, ИмяПараметра, ЗначениеПоУмолчанию = "")
	Если ШагПлана = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Вход = Неопределено;
	Если ТипЗнч(ШагПлана) = Тип("Структура") И ШагПлана.Свойство("input", Вход) И ТипЗнч(Вход) = Тип("Структура") Тогда
		Если Вход.Свойство(ИмяПараметра) Тогда
			Возврат Вход[ИмяПараметра];
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(ШагПлана) = Тип("Структура") И ШагПлана.Свойство(ИмяПараметра) Тогда
		Возврат ШагПлана[ИмяПараметра];
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ПолучитьСвойствоИзСтруктуры(Объект, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
	Если Объект = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Попытка
		Если (ТипЗнч(Объект) = Тип("Структура") Или ТипЗнч(Объект) = Тип("ФиксированнаяСтруктура")) И Объект.Свойство(ИмяСвойства) Тогда
			Возврат Объект[ИмяСвойства];
		КонецЕсли;
	Исключение
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ЭтоМассивоподобноеЗначение(Значение)
	ТипЗначения = ТипЗнч(Значение);
	Возврат ТипЗначения = Тип("Массив") Или ТипЗначения = Тип("ФиксированныйМассив");
КонецФункции

Функция ПолучитьЭлементМассиваУниверсально(Коллекция, Индекс)
	Если Коллекция = Неопределено Или НЕ ЭтоМассивоподобноеЗначение(Коллекция) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Индекс < 0 Или Индекс >= Коллекция.Количество() Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат Коллекция[Индекс];
КонецФункции

Функция ЭкранироватьСтрокуДляЗапроса(Значение)
	Возврат СтрЗаменить(Строка(Значение), """", """""");
КонецФункции

Функция ФорматироватьЦелоеДляЗапроса(Значение)
	Возврат Формат(Число(Значение), "ЧГ=0; ЧН=0");
КонецФункции

Функция СоздатьМассивСтрок(Значения) Экспорт
	Результат = Новый Массив;
	Если Значения = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	Для Каждого Значение Из Значения Цикл
		Результат.Добавить(Строка(Значение));
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ПостроитьЛитералДаты1С(ДатаЗначение)
	Возврат "ДАТАВРЕМЯ(" 
		+ ФорматироватьЦелоеДляЗапроса(Год(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(Месяц(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(День(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(Час(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(Минута(ДатаЗначение)) + ","
		+ ФорматироватьЦелоеДляЗапроса(Секунда(ДатаЗначение)) + ")";
КонецФункции

Функция ПолучитьНачалоКалендарнойНедели(МоментВремени)
	НомерДняНедели = ДеньНедели(МоментВремени);
	Если НомерДняНедели <= 0 Тогда
		НомерДняНедели = 7;
	КонецЕсли;
	Возврат НачалоДня(МоментВремени - (НомерДняНедели - 1) * 24 * 60 * 60);
КонецФункции

Функция ПолучитьНачалоМесяцаЛокально(МоментВремени)
	Возврат Дата(Год(МоментВремени), Месяц(МоментВремени), 1);
КонецФункции

Функция ПолучитьКонецМесяцаЛокально(МоментВремени)
	ГодЗнач = Год(МоментВремени);
	МесяцЗнач = Месяц(МоментВремени);
	Если МесяцЗнач = 12 Тогда
		СледующийМесяц = Дата(ГодЗнач + 1, 1, 1);
	Иначе
		СледующийМесяц = Дата(ГодЗнач, МесяцЗнач + 1, 1);
	КонецЕсли;
	Возврат КонецДня(СледующийМесяц - 24 * 60 * 60);
КонецФункции

Функция ОпределитьЕдиницуПериодаИзТекста(ПериодВРег)
	Если СтрНайти(ПериодВРег, "ДЕН") > 0 Тогда
		Возврат "DAY";
	КонецЕсли;
	Если СтрНайти(ПериодВРег, "НЕДЕЛ") > 0 Тогда
		Возврат "WEEK";
	КонецЕсли;
	Если СтрНайти(ПериодВРег, "МЕСЯЦ") > 0 Тогда
		Возврат "MONTH";
	КонецЕсли;
	Возврат "";
КонецФункции

Функция СодержитЛюбойМаркерПериода(ПериодВРег, Маркеры)
	Для Каждого Маркер Из Маркеры Цикл
		Если СтрНайти(ПериодВРег, ВРег(Строка(Маркер))) > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция ПопробоватьПолучитьГраницыСтандартногоПериода(ПериодВРег, Сейчас)
	Результат = Новый Структура("Начало,Конец", Неопределено, Неопределено);
	Единица = ОпределитьЕдиницуПериодаИзТекста(ПериодВРег);
	Если ПустаяСтрока(Единица) Тогда
		Возврат Результат;
	КонецЕсли;
	
	МаркерыПрошлого = Новый Массив;
	МаркерыПрошлого.Добавить("ПРОШЛ");
	МаркерыПрошлого.Добавить("ПРЕДЫДУЩ");
	МаркерыТекущего = Новый Массив;
	МаркерыТекущего.Добавить("ТЕКУЩ");
	МаркерыСкользящего = Новый Массив;
	МаркерыСкользящего.Добавить("ЗА ");
	МаркерыСкользящего.Добавить("ПОСЛЕДН");
	ЭтоПрошлыйЗавершенный = СодержитЛюбойМаркерПериода(ПериодВРег, МаркерыПрошлого);
	ЭтоТекущий = СодержитЛюбойМаркерПериода(ПериодВРег, МаркерыТекущего);
	ЭтоСкользящий = СодержитЛюбойМаркерПериода(ПериодВРег, МаркерыСкользящего);
	
	Если ЭтоПрошлыйЗавершенный Тогда
		Если Единица = "WEEK" Тогда
			НачалоТекущейНедели = ПолучитьНачалоКалендарнойНедели(Сейчас);
			Результат.Начало = НачалоТекущейНедели - 7 * 24 * 60 * 60;
			Результат.Конец = КонецДня(НачалоТекущейНедели - 24 * 60 * 60);
			Возврат Результат;
		ИначеЕсли Единица = "MONTH" Тогда
			НачалоТекущегоМесяца = ПолучитьНачалоМесяцаЛокально(Сейчас);
			ПоследнийДеньПрошлогоМесяца = НачалоТекущегоМесяца - 24 * 60 * 60;
			Результат.Начало = ПолучитьНачалоМесяцаЛокально(ПоследнийДеньПрошлогоМесяца);
			Результат.Конец = КонецДня(ПоследнийДеньПрошлогоМесяца);
			Возврат Результат;
		ИначеЕсли Единица = "DAY" Тогда
			Вчера = Сейчас - 24 * 60 * 60;
			Результат.Начало = НачалоДня(Вчера);
			Результат.Конец = КонецДня(Вчера);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоТекущий Тогда
		Если Единица = "WEEK" Тогда
			Результат.Начало = ПолучитьНачалоКалендарнойНедели(Сейчас);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		ИначеЕсли Единица = "MONTH" Тогда
			Результат.Начало = ПолучитьНачалоМесяцаЛокально(Сейчас);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		ИначеЕсли Единица = "DAY" Тогда
			Результат.Начало = НачалоДня(Сейчас);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтоСкользящий Тогда
		Если Единица = "WEEK" Тогда
			Результат.Начало = НачалоДня(Сейчас - 7 * 24 * 60 * 60);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		ИначеЕсли Единица = "MONTH" Тогда
			Результат.Начало = НачалоДня(Сейчас - 30 * 24 * 60 * 60);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		ИначеЕсли Единица = "DAY" Тогда
			Результат.Начало = НачалоДня(Сейчас);
			Результат.Конец = КонецДня(Сейчас);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьГраницыПериодаИзТекста(ТекстПериода)
	Результат = Новый Структура("Начало,Конец", Неопределено, Неопределено);
	ПериодВРег = ВРег(СокрЛП(Строка(ТекстПериода)));
	Сейчас = ТекущаяДата();
	
	Если ПериодВРег = "СЕГОДНЯ" Тогда
		Результат.Начало = НачалоДня(Сейчас);
		Результат.Конец = КонецДня(Сейчас);
		Возврат Результат;
	КонецЕсли;
	
	Если ПериодВРег = "ВЧЕРА" Тогда
		Вчера = Сейчас - 24 * 60 * 60;
		Результат.Начало = НачалоДня(Вчера);
		Результат.Конец = КонецДня(Вчера);
		Возврат Результат;
	КонецЕсли;
	
	Результат = ПопробоватьПолучитьГраницыСтандартногоПериода(ПериодВРег, Сейчас);
	Если Результат.Начало <> Неопределено ИЛИ Результат.Конец <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ЭтоРазделительТокенаПериода(Символ)
	Если ПустаяСтрока(Символ) Тогда
		Возврат Истина;
	КонецЕсли;
	Разделители = " ,.;:()[]{}=<>+-*/\""'%" + Символы.ПС + Символы.Таб;
	Возврат СтрНайти(Разделители, Символ) > 0;
КонецФункции

Функция НормализоватьТокенПериода(Токен)
	ИсходныйТокен = Строка(Токен);
	ТокенВРег = ВРег(СокрЛП(ИсходныйТокен));
	Если ПустаяСтрока(ТокенВРег) Тогда
		Возврат ИсходныйТокен;
	КонецЕсли;
	
	ТипГраницы = "";
	ИмяПериода = "";
	Если СтрНайти(ТокенВРег, "НАЧАЛО_") = 1 Тогда
		ТипГраницы = "НАЧАЛО";
		ИмяПериода = Сред(ТокенВРег, СтрДлина("НАЧАЛО_") + 1);
	ИначеЕсли СтрНайти(ТокенВРег, "КОНЕЦ_") = 1 Тогда
		ТипГраницы = "КОНЕЦ";
		ИмяПериода = Сред(ТокенВРег, СтрДлина("КОНЕЦ_") + 1);
	Иначе
		Возврат ИсходныйТокен;
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяПериода) Тогда
		Возврат ИсходныйТокен;
	КонецЕсли;
	
	ИмяПериода = СтрЗаменить(ИмяПериода, "_", " ");
	Границы = ПолучитьГраницыПериодаИзТекста(ИмяПериода);
	Если ТипГраницы = "НАЧАЛО" И Границы.Начало <> Неопределено Тогда
		Возврат ПостроитьЛитералДаты1С(Границы.Начало);
	КонецЕсли;
	Если ТипГраницы = "КОНЕЦ" И Границы.Конец <> Неопределено Тогда
		Возврат ПостроитьЛитералДаты1С(Границы.Конец);
	КонецЕсли;
	
	Возврат ИсходныйТокен;
КонецФункции

Функция НормализоватьПлейсхолдерыПериодаВТекстеЗапроса(ТекстЗапроса)
	Текст = Строка(ТекстЗапроса);
	Если ПустаяСтрока(СокрЛП(Текст)) Тогда
		Возврат Текст;
	КонецЕсли;
	
	Результат = "";
	ТекущийТокен = "";
	Для Позиция = 1 По СтрДлина(Текст) Цикл
		Символ = Сред(Текст, Позиция, 1);
		Если ЭтоРазделительТокенаПериода(Символ) Тогда
			Если НЕ ПустаяСтрока(ТекущийТокен) Тогда
				Результат = Результат + НормализоватьТокенПериода(ТекущийТокен);
				ТекущийТокен = "";
			КонецЕсли;
			Результат = Результат + Символ;
		Иначе
			ТекущийТокен = ТекущийТокен + Символ;
		КонецЕсли;
	КонецЦикла;
	Если НЕ ПустаяСтрока(ТекущийТокен) Тогда
		Результат = Результат + НормализоватьТокенПериода(ТекущийТокен);
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция НормализоватьСокращенныйЯвныйRunQuery(ТекстЗапроса)
	Текст = СокрЛП(Строка(ТекстЗапроса));
	Если ПустаяСтрока(Текст) Тогда
		Возврат Текст;
	КонецЕсли;
	ТекстВРег = ВРег(Текст);
	Если Лев(ТекстВРег, 8) <> "ВЫБРАТЬ " Тогда
		Возврат Текст;
	КонецЕсли;
	Если СтрНайти(ТекстВРег, " ИЗ ") > 0 Или СтрНайти(ТекстВРег, Символы.ПС + "ИЗ") > 0 Тогда
		Возврат Текст;
	КонецЕсли;
	ПозКак = СтрНайти(ТекстВРег, " КАК ");
	ПозГде = СтрНайти(ТекстВРег, " ГДЕ ");
	Если ПозКак = 0 Или ПозГде = 0 Или ПозКак <= 8 Или ПозГде <= ПозКак Тогда
		Возврат Текст;
	КонецЕсли;
	ПолноеИмяОбъекта = СокрЛП(Сред(Текст, 9, ПозКак - 8));
	Псевдоним = СокрЛП(Сред(Текст, ПозКак + 5, ПозГде - ПозКак - 5));
	Условие = СокрЛП(Сред(Текст, ПозГде + 5));
	Если ПустаяСтрока(ПолноеИмяОбъекта) Или ПустаяСтрока(Псевдоним) Или ПустаяСтрока(Условие) Тогда
		Возврат Текст;
	КонецЕсли;
	ПолноеИмяОбъектаВРег = ВРег(ПолноеИмяОбъекта);
	Если СтрНайти(ПолноеИмяОбъектаВРег, "СПРАВОЧНИК.") <> 1
		И СтрНайти(ПолноеИмяОбъектаВРег, "ДОКУМЕНТ.") <> 1
		И СтрНайти(ПолноеИмяОбъектаВРег, "РЕГИСТРНАКОПЛЕНИЯ.") <> 1
		И СтрНайти(ПолноеИмяОбъектаВРег, "РЕГИСТРСВЕДЕНИЙ.") <> 1 Тогда
		Возврат Текст;
	КонецЕсли;
	Если НЕ ЭтоКорректныйИдентификаторДляЗапроса(Псевдоним) Тогда
		Возврат Текст;
	КонецЕсли;
	Возврат "ВЫБРАТЬ " + Псевдоним + ".Ссылка КАК Ссылка"
		+ Символы.ПС + "ИЗ " + ПолноеИмяОбъекта + " КАК " + Псевдоним
		+ Символы.ПС + "ГДЕ " + Условие;
КонецФункции

Функция ЭтоКорректныйИдентификаторДляЗапроса(ТекстИдентификатора)
	Идентификатор = СокрЛП(Строка(ТекстИдентификатора));
	Если ПустаяСтрока(Идентификатор) Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Позиция = 1 По СтрДлина(Идентификатор) Цикл
		Символ = Сред(Идентификатор, Позиция, 1);
		КодСимвола = КодСимвола(Символ);
		Если НЕ ((КодСимвола >= 48 И КодСимвола <= 57)
			ИЛИ (КодСимвола >= 65 И КодСимвола <= 90)
			ИЛИ (КодСимвола >= 97 И КодСимвола <= 122)
			ИЛИ (КодСимвола >= 1040 И КодСимвола <= 1103)
			ИЛИ КодСимвола = 1025
			ИЛИ КодСимвола = 1105
			ИЛИ Символ = "_") Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Функция ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаПровайдера(ТекстЗапроса)
	Текст = НормализоватьСокращенныйЯвныйRunQuery(ТекстЗапроса);
	Текст = СокрЛП(Строка(Текст));
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	ТекстВРег = ВРег(Текст);
	ПозИз = СтрНайти(ТекстВРег, Символы.ПС + "ИЗ");
	Если ПозИз = 0 Тогда
		ПозИз = СтрНайти(ТекстВРег, " ИЗ ");
	КонецЕсли;
	Если ПозИз = 0 Тогда
		Возврат "";
	КонецЕсли;
	Остаток = СокрЛП(Сред(Текст, ПозИз + 3));
	Если Лев(Остаток, 1) = Символы.ПС Тогда
		Остаток = СокрЛП(Сред(Остаток, 2));
	КонецЕсли;
	Если ПустаяСтрока(Остаток) Тогда
		Возврат "";
	КонецЕсли;
	Разделители = Новый Массив;
	Разделители.Добавить(" ");
	Разделители.Добавить(Символы.ПС);
	Разделители.Добавить(Символы.Таб);
	ПозКонца = 0;
	Для Каждого Разделитель Из Разделители Цикл
		ПозРазделителя = СтрНайти(Остаток, Разделитель);
		Если ПозРазделителя > 0 И (ПозКонца = 0 ИЛИ ПозРазделителя < ПозКонца) Тогда
			ПозКонца = ПозРазделителя;
		КонецЕсли;
	КонецЦикла;
	Если ПозКонца = 0 Тогда
		Возврат СокрЛП(Остаток);
	КонецЕсли;
	Возврат СокрЛП(Лев(Остаток, ПозКонца - 1));
КонецФункции

Функция ИзвлечьПсевдонимИсточникаИзТекстаЗапросаПровайдера(ТекстЗапроса)
	Текст = СокрЛП(Строка(ТекстЗапроса));
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	ТекстВРег = ВРег(Текст);
	ПозКак = СтрНайти(ТекстВРег, " КАК ");
	Если ПозКак = 0 Тогда
		Возврат "";
	КонецЕсли;
	Остаток = Сред(Текст, ПозКак + 5);
	Разделители = Новый Массив;
	Разделители.Добавить(" ");
	Разделители.Добавить(Символы.ПС);
	Разделители.Добавить(Символы.Таб);
	ПозицияКонца = 0;
	Для Каждого Разделитель Из Разделители Цикл
		ПозРазделителя = СтрНайти(Остаток, Разделитель);
		Если ПозРазделителя > 0 И (ПозицияКонца = 0 ИЛИ ПозРазделителя < ПозицияКонца) Тогда
			ПозицияКонца = ПозРазделителя;
		КонецЕсли;
	КонецЦикла;
	Если ПозицияКонца = 0 Тогда
		Возврат СокрЛП(Остаток);
	КонецЕсли;
	Возврат СокрЛП(Лев(Остаток, ПозицияКонца - 1));
КонецФункции

Функция НормализоватьЯвныйRunQueryПоМетаданным(ТекстЗапроса, ПолноеИмяОбъекта)
	Текст = НормализоватьПлейсхолдерыПериодаВТекстеЗапроса(Строка(ТекстЗапроса));
	Если ПустаяСтрока(СокрЛП(Текст)) Тогда
		Возврат Текст;
	КонецЕсли;
	Если ПустаяСтрока(ПолноеИмяОбъекта) Тогда
		ПолноеИмяОбъекта = ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаПровайдера(Текст);
	КонецЕсли;
	Whitelist = ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта);
	Если Whitelist.Количество() = 0 Тогда
		Возврат Текст;
	КонецЕсли;
	WhitelistПути = ПолучитьWhitelistПутейОбъектаЛокально(ПолноеИмяОбъекта);
	Псевдоним = ИзвлечьПсевдонимИсточникаИзТекстаЗапросаПровайдера(Текст);
	ТекстВРег = ВРег(Текст);
	Префикс = "ВЫБРАТЬ ";
	Если Лев(ТекстВРег, СтрДлина(Префикс)) <> Префикс Тогда
		Возврат Текст;
	КонецЕсли;
	ПозИз = СтрНайти(ТекстВРег, Символы.ПС + "ИЗ");
	Если ПозИз = 0 Тогда
		ПозИз = СтрНайти(ТекстВРег, " ИЗ ");
	КонецЕсли;
	Если ПозИз = 0 Тогда
		Возврат Текст;
	КонецЕсли;
	СекцияВыбрать = СокрЛП(Сред(Текст, СтрДлина(Префикс) + 1, ПозИз - СтрДлина(Префикс) - 1));
	Если ПустаяСтрока(СекцияВыбрать) Тогда
		Возврат Текст;
	КонецЕсли;
	ПсевдонимВРег = ВРег(Псевдоним);
	Если НЕ ПустаяСтрока(Псевдоним) И ВРег(СекцияВыбрать) = ПсевдонимВРег И ПолеЕстьВWhitelistЛокально(Whitelist, "Ссылка") Тогда
		Возврат Лев(Текст, СтрДлина(Префикс)) + Псевдоним + ".Ссылка КАК Ссылка" + Сред(Текст, ПозИз);
	КонецЕсли;
	НоваяСекцияВыбрать = НормализоватьСекциюВыбратьПоWhitelistЛокально(СекцияВыбрать, Псевдоним, Whitelist, РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта).ObjectName);
	Если НЕ ПустаяСтрока(НоваяСекцияВыбрать) И НоваяСекцияВыбрать <> СекцияВыбрать Тогда
		Текст = Лев(Текст, СтрДлина(Префикс)) + НоваяСекцияВыбрать + Сред(Текст, ПозИз);
	КонецЕсли;
	Текст = НормализоватьСтроковыйФильтрПоWhitelistПутямЛокально(Текст, WhitelistПути);
	Возврат Текст;
КонецФункции

Функция РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта)
	Результат = Новый Структура("ObjectType,ObjectName", "", "");
	Имя = СокрЛП(Строка(ПолноеИмяОбъекта));
	ПозТочки = СтрНайти(Имя, ".");
	Если ПозТочки > 0 Тогда
		Результат.ObjectType = Лев(Имя, ПозТочки - 1);
		Результат.ObjectName = Сред(Имя, ПозТочки + 1);
	Иначе
		Результат.ObjectName = Имя;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта)
	Whitelist = Новый Массив;
	Разбор = РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта);
	Если ПустаяСтрока(Разбор.ObjectType) ИЛИ ПустаяСтрока(Разбор.ObjectName) Тогда
		Возврат Whitelist;
	КонецЕсли;
	ИнформацияОбОбъекте = Неопределено;
	Если Разбор.ObjectType = "Справочник" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыСправочника(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "Документ" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыДокумента(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "РегистрНакопления" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыРегистраНакопления(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "РегистрСведений" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыРегистраСведений(Разбор.ObjectName);
	КонецЕсли;
	Если ИнформацияОбОбъекте = Неопределено
		ИЛИ ТипЗнч(ИнформацияОбОбъекте) <> Тип("Структура")
		ИЛИ НЕ ИнформацияОбОбъекте.Свойство("Найден")
		ИЛИ НЕ ИнформацияОбОбъекте.Найден Тогда
		Возврат Whitelist;
	КонецЕсли;
	Если ИнформацияОбОбъекте.Свойство("Реквизиты") И ТипЗнч(ИнформацияОбОбъекте.Реквизиты) = Тип("Массив") Тогда
		Для Каждого Реквизит Из ИнформацияОбОбъекте.Реквизиты Цикл
			Если ТипЗнч(Реквизит) = Тип("Структура") И Реквизит.Свойство("Имя") Тогда
				ИмяРеквизита = СокрЛП(Строка(Реквизит.Имя));
				Если НЕ ПустаяСтрока(ИмяРеквизита) И Лев(ВРег(ИмяРеквизита), 6) <> "УДАЛИТ" И Whitelist.Найти(ИмяРеквизита) = Неопределено Тогда
					Whitelist.Добавить(ИмяРеквизита);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если Whitelist.Найти("Ссылка") = Неопределено Тогда
		Whitelist.Добавить("Ссылка");
	КонецЕсли;
	Возврат Whitelist;
КонецФункции

Функция ПолучитьWhitelistПутейОбъектаЛокально(ПолноеИмяОбъекта)
	WhitelistПути = Новый Массив;
	Разбор = РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта);
	Если ПустаяСтрока(Разбор.ObjectType) ИЛИ ПустаяСтрока(Разбор.ObjectName) Тогда
		Возврат WhitelistПути;
	КонецЕсли;
	ИнформацияОбОбъекте = Неопределено;
	Если Разбор.ObjectType = "Справочник" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыСправочника(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "Документ" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыДокумента(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "РегистрНакопления" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыРегистраНакопления(Разбор.ObjectName);
	ИначеЕсли Разбор.ObjectType = "РегистрСведений" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыРегистраСведений(Разбор.ObjectName);
	КонецЕсли;
	Если ИнформацияОбОбъекте = Неопределено
		ИЛИ ТипЗнч(ИнформацияОбОбъекте) <> Тип("Структура")
		ИЛИ НЕ ИнформацияОбОбъекте.Свойство("Найден")
		ИЛИ НЕ ИнформацияОбОбъекте.Найден Тогда
		Возврат WhitelistПути;
	КонецЕсли;
	Если ИнформацияОбОбъекте.Свойство("Реквизиты") И ТипЗнч(ИнформацияОбОбъекте.Реквизиты) = Тип("Массив") Тогда
		Для Каждого Реквизит Из ИнформацияОбОбъекте.Реквизиты Цикл
			Если ТипЗнч(Реквизит) = Тип("Структура") И Реквизит.Свойство("Имя") Тогда
				ИмяРеквизита = СокрЛП(Строка(Реквизит.Имя));
				Если ПустаяСтрока(ИмяРеквизита) ИЛИ Лев(ВРег(ИмяРеквизита), 6) = "УДАЛИТ" Тогда
					Продолжить;
				КонецЕсли;
				Если Реквизит.Свойство("Тип") И ЭтоСсылочныйТипРеквизитаЛокально(Строка(Реквизит.Тип)) Тогда
					Если WhitelistПути.Найти(ИмяРеквизита + ".Наименование") = Неопределено Тогда
						WhitelistПути.Добавить(ИмяРеквизита + ".Наименование");
					КонецЕсли;
					Если WhitelistПути.Найти(ИмяРеквизита + ".Ссылка") = Неопределено Тогда
						WhitelistПути.Добавить(ИмяРеквизита + ".Ссылка");
					КонецЕсли;
					Если WhitelistПути.Найти(ИмяРеквизита + ".Код") = Неопределено Тогда
						WhitelistПути.Добавить(ИмяРеквизита + ".Код");
					КонецЕсли;
					Если WhitelistПути.Найти(ИмяРеквизита + ".Номер") = Неопределено Тогда
						WhitelistПути.Добавить(ИмяРеквизита + ".Номер");
					КонецЕсли;
					Если WhitelistПути.Найти(ИмяРеквизита + ".Дата") = Неопределено Тогда
						WhitelistПути.Добавить(ИмяРеквизита + ".Дата");
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если WhitelistПути.Найти("Ссылка") = Неопределено Тогда
		WhitelistПути.Добавить("Ссылка");
	КонецЕсли;
	Возврат WhitelistПути;
КонецФункции

Функция ЭтоСсылочныйТипРеквизитаЛокально(СтрокаТипа)
	ТекстТипа = ВРег(СокрЛП(Строка(СтрокаТипа)));
	Возврат СтрНайти(ТекстТипа, "СПРАВОЧНИКССЫЛКА.") > 0
		ИЛИ СтрНайти(ТекстТипа, "ДОКУМЕНТССЫЛКА.") > 0
		ИЛИ СтрНайти(ТекстТипа, "ПЛАНВИДОВХАРАКТЕРИСТИКССЫЛКА.") > 0;
КонецФункции

Функция НайтиПутьДляСтроковогоСравненияЛокально(ИмяПоля, WhitelistПути)
	Если WhitelistПути = Неопределено ИЛИ WhitelistПути.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	Префикс = ВРег(ПолучитьБазовоеИмяПоляЛокально(ИмяПоля)) + ".";
	ЛучшийПуть = "";
	Для Каждого Путь Из WhitelistПути Цикл
		ПутьСтрокой = СокрЛП(Строка(Путь));
		ПутьВРег = ВРег(ПутьСтрокой);
		Если Лев(ПутьВРег, СтрДлина(Префикс)) <> Префикс Тогда
			Продолжить;
		КонецЕсли;
		Если Прав(ПутьВРег, СтрДлина(".НАИМЕНОВАНИЕ")) = ".НАИМЕНОВАНИЕ" Тогда
			Возврат ПутьСтрокой;
		КонецЕсли;
		Если ПустаяСтрока(ЛучшийПуть) Тогда
			ЛучшийПуть = ПутьСтрокой;
		КонецЕсли;
	КонецЦикла;
	Возврат ЛучшийПуть;
КонецФункции

Функция НормализоватьСтроковыйФильтрПоWhitelistПутямЛокально(ТекстЗапроса, WhitelistПути)
	Результат = Строка(ТекстЗапроса);
	Если WhitelistПути = Неопределено ИЛИ WhitelistПути.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	Для Каждого Путь Из WhitelistПути Цикл
		ПутьСтрокой = СокрЛП(Строка(Путь));
		ПозТочки = СтрНайти(ПутьСтрокой, ".");
		Если ПозТочки = 0 Тогда
			Продолжить;
		КонецЕсли;
		ИмяПоля = Лев(ПутьСтрокой, ПозТочки - 1);
		ПутьДляСтроки = НайтиПутьДляСтроковогоСравненияЛокально(ИмяПоля, WhitelistПути);
		Если ПустаяСтрока(ПутьДляСтроки) Тогда
			Продолжить;
		КонецЕсли;
		Результат = СтрЗаменить(Результат, ИмяПоля + " = """, ПутьДляСтроки + " = """);
		Результат = СтрЗаменить(Результат, ИмяПоля + " = '", ПутьДляСтроки + " = '");
		Результат = СтрЗаменить(Результат, ИмяПоля + "='", ПутьДляСтроки + "='");
		Результат = СтрЗаменить(Результат, "(" + ИмяПоля + " = """, "(" + ПутьДляСтроки + " = """);
		Результат = СтрЗаменить(Результат, "(" + ИмяПоля + " = '", "(" + ПутьДляСтроки + " = '");
		Для Каждого Идентификатор Из ИзвлечьИдентификаторыИзСтрокиФильтраЛокально(Результат) Цикл
			Если ВРег(ПолучитьБазовоеИмяПоляЛокально(Идентификатор)) <> ВРег(ИмяПоля) Тогда
				Продолжить;
			КонецЕсли;
			ПолныйПуть = ПолучитьПрефиксКвалификатораПоляЛокально(Идентификатор) + ПутьДляСтроки;
			Результат = СтрЗаменить(Результат, Идентификатор + " = """, ПолныйПуть + " = """);
			Результат = СтрЗаменить(Результат, Идентификатор + " = '", ПолныйПуть + " = '");
			Результат = СтрЗаменить(Результат, Идентификатор + "='", ПолныйПуть + "='");
			Результат = СтрЗаменить(Результат, "(" + Идентификатор + " = """, "(" + ПолныйПуть + " = """);
			Результат = СтрЗаменить(Результат, "(" + Идентификатор + " = '", "(" + ПолныйПуть + " = '");
		КонецЦикла;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ПолучитьБазовоеИмяПоляЛокально(ИмяПоля)
	Имя = СокрЛП(Строка(ИмяПоля));
	ПозицияТочки = 0;
	Для Индекс = 1 По СтрДлина(Имя) Цикл
		Если Сред(Имя, Индекс, 1) = "." Тогда
			ПозицияТочки = Индекс;
		КонецЕсли;
	КонецЦикла;
	Если ПозицияТочки = 0 Тогда
		Возврат Имя;
	КонецЕсли;
	Возврат Сред(Имя, ПозицияТочки + 1);
КонецФункции

Функция ПолучитьПрефиксКвалификатораПоляЛокально(ИмяПоля)
	Имя = СокрЛП(Строка(ИмяПоля));
	ПозицияТочки = 0;
	Для Индекс = 1 По СтрДлина(Имя) Цикл
		Если Сред(Имя, Индекс, 1) = "." Тогда
			ПозицияТочки = Индекс;
		КонецЕсли;
	КонецЦикла;
	Если ПозицияТочки = 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат Лев(Имя, ПозицияТочки);
КонецФункции

Функция ИзвлечьИдентификаторыИзСтрокиФильтраЛокально(ТекстФильтра)
	Результат = Новый Массив;
	Текст = СтрЗаменить(Строка(ТекстФильтра), Символы.ПС, " ");
	Разделители = Новый Массив;
	Разделители.Добавить("(");
	Разделители.Добавить(")");
	Разделители.Добавить("=");
	Разделители.Добавить("<");
	Разделители.Добавить(">");
	Разделители.Добавить(",");
	Для Каждого Разделитель Из Разделители Цикл
		Текст = СтрЗаменить(Текст, Строка(Разделитель), " ");
	КонецЦикла;
	Для Каждого Часть Из СтрРазделить(Текст, " ") Цикл
		Идентификатор = СокрЛП(Строка(Часть));
		Если ПустаяСтрока(Идентификатор) Тогда
			Продолжить;
		КонецЕсли;
		Если Идентификатор = "И" ИЛИ Идентификатор = "ИЛИ" ИЛИ Идентификатор = "НЕ" Тогда
			Продолжить;
		КонецЕсли;
		Если Лев(Идентификатор, 1) = """" ИЛИ Лев(Идентификатор, 1) = "'" Тогда
			Продолжить;
		КонецЕсли;
		Если ЭтоПохожеНаЧислоЛокально(Идентификатор) Тогда
			Продолжить;
		КонецЕсли;
		Если Результат.Найти(Идентификатор) = Неопределено Тогда
			Результат.Добавить(Идентификатор);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ЭтоПохожеНаЧислоЛокально(Текст)
	Значение = СокрЛП(Строка(Текст));
	Если ПустаяСтрока(Значение) Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Индекс = 1 По СтрДлина(Значение) Цикл
		Символ = Сред(Значение, Индекс, 1);
		Если (Символ < "0" ИЛИ Символ > "9") И Символ <> "." И Символ <> "," И Символ <> "-" Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Функция НормализоватьСекциюВыбратьПоWhitelistЛокально(СекцияВыбрать, Псевдоним, Whitelist, ИмяОбъекта)
	НовыеВыражения = Новый Массив;
	Для Каждого ЧастьВыбора Из СтрРазделить(СекцияВыбрать, ",") Цикл
		Выражение = СокрЛП(Строка(ЧастьВыбора));
		Если ПустаяСтрока(Выражение) Тогда
			Продолжить;
		КонецЕсли;
		ПозКак = СтрНайти(ВРег(Выражение), " КАК ");
		ИсходноеВыражение = Выражение;
		ПсевдонимПоля = "";
		Если ПозКак > 0 Тогда
			ИсходноеВыражение = СокрЛП(Лев(Выражение, ПозКак - 1));
			ПсевдонимПоля = СокрЛП(Сред(Выражение, ПозКак + 5));
		КонецЕсли;
		БазовоеИмяПоля = ПолучитьБазовоеИмяПоляЛокально(ИсходноеВыражение);
		ПрефиксКвалификатора = ПолучитьПрефиксКвалификатораПоляЛокально(ИсходноеВыражение);
		ЗаменаПоля = "";
		Если ПолеЕстьВWhitelistЛокально(Whitelist, БазовоеИмяПоля) Тогда
			ЗаменаПоля = БазовоеИмяПоля;
		ИначеЕсли НЕ ПустаяСтрока(ИмяОбъекта) И ВРег(БазовоеИмяПоля) = ВРег(ИмяОбъекта) И ПолеЕстьВWhitelistЛокально(Whitelist, "Ссылка") Тогда
			ЗаменаПоля = "Ссылка";
		ИначеЕсли БазовоеИмяПоля = Псевдоним И ПолеЕстьВWhitelistЛокально(Whitelist, "Ссылка") Тогда
			ЗаменаПоля = "Ссылка";
		КонецЕсли;
		Если ПустаяСтрока(ЗаменаПоля) Тогда
			Продолжить;
		КонецЕсли;
		Если ПустаяСтрока(ПсевдонимПоля) Тогда
			ПсевдонимПоля = ЗаменаПоля;
		КонецЕсли;
		НовыеВыражения.Добавить(ПрефиксКвалификатора + ЗаменаПоля + " КАК " + ПсевдонимПоля);
	КонецЦикла;
	Если НовыеВыражения.Количество() = 0 И ПолеЕстьВWhitelistЛокально(Whitelist, "Ссылка") Тогда
		Если ПустаяСтрока(Псевдоним) Тогда
			Возврат "Ссылка КАК Ссылка";
		КонецЕсли;
		Возврат Псевдоним + ".Ссылка КАК Ссылка";
	КонецЕсли;
	Если НовыеВыражения.Количество() = 0 Тогда
		Возврат СекцияВыбрать;
	КонецЕсли;
	Возврат СтрСоединить(НовыеВыражения, ", ");
КонецФункции

Функция ОценитьПохожестьПоля(ИсходноеПоле, Кандидат)
	ИсходноеСырое = СокрЛП(Строка(ИсходноеПоле));
	КандидатСырой = СокрЛП(Строка(Кандидат));
	Исходное = ВРег(ИсходноеСырое);
	КандидатВРег = ВРег(КандидатСырой);
	Если ПустаяСтрока(Исходное) ИЛИ ПустаяСтрока(КандидатВРег) Тогда
		Возврат -1;
	КонецЕсли;
	Если Исходное = КандидатВРег Тогда
		Возврат 1000;
	КонецЕсли;
	Если СовпадаютТокеныCamelCaseПоля(ИсходноеСырое, КандидатСырой) Тогда
		Возврат 900;
	КонецЕсли;
	Оценка = 0;
	Для Индекс = 1 По Мин(СтрДлина(Исходное), СтрДлина(КандидатВРег)) Цикл
		Если Сред(Исходное, Индекс, 1) <> Сред(КандидатВРег, Индекс, 1) Тогда
			Прервать;
		КонецЕсли;
		Оценка = Оценка + 5;
	КонецЦикла;
	Если СтрНайти(КандидатВРег, Исходное) > 0 Тогда
		Оценка = Оценка + 40;
	КонецЕсли;
	Если СтрНайти(Исходное, КандидатВРег) > 0 Тогда
		Оценка = Оценка + 20;
	КонецЕсли;
	Если СтрНайти(Исходное, "СУММА") > 0 И СтрНайти(КандидатВРег, "СУММА") > 0 Тогда
		Оценка = Оценка + 30;
	КонецЕсли;
	Возврат Оценка;
КонецФункции

Функция ЭтоГраницаCamelCase(ПредыдущийСимвол, ТекущийСимвол)
	Если ПустаяСтрока(Строка(ПредыдущийСимвол)) Или ПустаяСтрока(Строка(ТекущийСимвол)) Тогда
		Возврат Ложь;
	КонецЕсли;
	КодПред = КодСимвола(ПредыдущийСимвол);
	КодТек = КодСимвола(ТекущийСимвол);
	ЭтоПредБуква = ((КодПред >= 65 И КодПред <= 90) Или (КодПред >= 97 И КодПред <= 122)
		Или (КодПред >= 1040 И КодПред <= 1103) Или КодПред = 1025 Или КодПред = 1105);
	ЭтоТекБуква = ((КодТек >= 65 И КодТек <= 90) Или (КодТек >= 97 И КодТек <= 122)
		Или (КодТек >= 1040 И КодТек <= 1103) Или КодТек = 1025 Или КодТек = 1105);
	Если НЕ ЭтоПредБуква Или НЕ ЭтоТекБуква Тогда
		Возврат Ложь;
	КонецЕсли;
	ЭтоПредСтрочная = ((КодПред >= 97 И КодПред <= 122) Или (КодПред >= 1072 И КодПред <= 1103) Или КодПред = 1105);
	ЭтоТекЗаглавная = ((КодТек >= 65 И КодТек <= 90) Или (КодТек >= 1040 И КодТек <= 1071) Или КодТек = 1025);
	Возврат ЭтоПредСтрочная И ЭтоТекЗаглавная;
КонецФункции

Функция РазбитьCamelCaseПолеНаТокены(ИмяПоля)
	Результат = Новый Массив;
	Текст = СокрЛП(Строка(ИмяПоля));
	Если ПустаяСтрока(Текст) Тогда
		Возврат Результат;
	КонецЕсли;
	ТекущийТокен = "";
	ПредыдущийСимвол = "";
	Для Индекс = 1 По СтрДлина(Текст) Цикл
		Символ = Сред(Текст, Индекс, 1);
		Если НЕ ПустаяСтрока(ТекущийТокен) И ЭтоГраницаCamelCase(ПредыдущийСимвол, Символ) Тогда
			Результат.Добавить(ВРег(ТекущийТокен));
			ТекущийТокен = Символ;
		Иначе
			ТекущийТокен = ТекущийТокен + Символ;
		КонецЕсли;
		ПредыдущийСимвол = Символ;
	КонецЦикла;
	Если НЕ ПустаяСтрока(ТекущийТокен) Тогда
		Результат.Добавить(ВРег(ТекущийТокен));
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция СовпадаютТокеныCamelCaseПоля(ИсходноеПоле, Кандидат)
	ТокеныИсходного = РазбитьCamelCaseПолеНаТокены(ИсходноеПоле);
	ТокеныКандидата = РазбитьCamelCaseПолеНаТокены(Кандидат);
	Если ТокеныИсходного.Количество() < 2 Или ТокеныИсходного.Количество() <> ТокеныКандидата.Количество() Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Каждого Токен Из ТокеныИсходного Цикл
		Если ТокеныКандидата.Найти(Токен) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Функция ПолеЕстьВWhitelistЛокально(Whitelist, ИмяПоля)
	Для Каждого Кандидат Из Whitelist Цикл
		Если ВРег(Строка(Кандидат)) = ВРег(Строка(ИмяПоля)) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

Функция ВыбратьЛучшееПолеПоWhitelistЛокально(ИсходноеПоле, Whitelist)
	ЛучшееПоле = "";
	ЛучшаяОценка = -1;
	Для Каждого Кандидат Из Whitelist Цикл
		Оценка = ОценитьПохожестьПоля(ИсходноеПоле, Кандидат);
		Если Оценка > ЛучшаяОценка Тогда
			ЛучшаяОценка = Оценка;
			ЛучшееПоле = Строка(Кандидат);
		КонецЕсли;
	КонецЦикла;
	Возврат ЛучшееПоле;
КонецФункции

Функция НормализоватьПоляШагаПоМетаданным(ПолноеИмяОбъекта, Поля)
	Если НЕ ЭтоМассивоподобноеЗначение(Поля) Тогда
		Возврат Поля;
	КонецЕсли;
	Whitelist = ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта);
	Если Whitelist.Количество() = 0 Тогда
		Возврат Поля;
	КонецЕсли;
	НовыеПоля = Новый Массив;
	Для Каждого Поле Из Поля Цикл
		ИмяПоля = СокрЛП(Строка(Поле));
		Если ПустаяСтрока(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		ЛучшееПоле = ИмяПоля;
		ЛучшаяОценка = -1;
		Для Каждого Кандидат Из Whitelist Цикл
			Оценка = ОценитьПохожестьПоля(ИмяПоля, Кандидат);
			Если Оценка > ЛучшаяОценка Тогда
				ЛучшаяОценка = Оценка;
				ЛучшееПоле = Строка(Кандидат);
			КонецЕсли;
		КонецЦикла;
		Если НЕ ПустаяСтрока(ЛучшееПоле) И НовыеПоля.Найти(ЛучшееПоле) = Неопределено Тогда
			НовыеПоля.Добавить(ЛучшееПоле);
		ИначеЕсли НовыеПоля.Найти(ИмяПоля) = Неопределено Тогда
			НовыеПоля.Добавить(ИмяПоля);
		КонецЕсли;
	КонецЦикла;
	Возврат НовыеПоля;
КонецФункции

Функция НормализоватьСтруктуруФильтраПоМетаданным(ПолноеИмяОбъекта, Фильтр)
	Если Фильтр = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Whitelist = ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта);
	Если Whitelist.Количество() = 0 Тогда
		Возврат Фильтр;
	КонецЕсли;
	Если ТипЗнч(Фильтр) = Тип("Структура") ИЛИ ТипЗнч(Фильтр) = Тип("ФиксированнаяСтруктура") Тогда
		НовыйФильтр = Новый Структура;
		Для Каждого Пара Из Фильтр Цикл
			ИмяПоля = Строка(Пара.Ключ);
			Если ПолеЕстьВWhitelistЛокально(Whitelist, ИмяПоля) Тогда
				НовыйФильтр.Вставить(ИмяПоля, Пара.Значение);
			Иначе
				ЗаменаПоля = ВыбратьЛучшееПолеПоWhitelistЛокально(ИмяПоля, Whitelist);
				Если ПустаяСтрока(ЗаменаПоля) Тогда
					НовыйФильтр.Вставить(ИмяПоля, Пара.Значение);
				Иначе
					НовыйФильтр.Вставить(ЗаменаПоля, Пара.Значение);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Возврат НовыйФильтр;
	КонецЕсли;
	Если ТипЗнч(Фильтр) = Тип("Строка") Тогда
		Результат = Строка(Фильтр);
		Для Каждого Поле Из Whitelist Цикл
		КонецЦикла;
		Для Каждого Поле Из СтрРазделить(Результат, " ") Цикл
			ИмяПоля = СокрЛП(Строка(Поле));
			Если ПустаяСтрока(ИмяПоля) Тогда
				Продолжить;
			КонецЕсли;
			Если ПолеЕстьВWhitelistЛокально(Whitelist, ИмяПоля) Тогда
				Продолжить;
			КонецЕсли;
			ЗаменаПоля = ВыбратьЛучшееПолеПоWhitelistЛокально(ИмяПоля, Whitelist);
			Если ПустаяСтрока(ЗаменаПоля) ИЛИ ВРег(ЗаменаПоля) = ВРег(ИмяПоля) Тогда
				Продолжить;
			КонецЕсли;
			Результат = СтрЗаменить(Результат, ИмяПоля + " = ", ЗаменаПоля + " = ");
			Результат = СтрЗаменить(Результат, ИмяПоля + " < ", ЗаменаПоля + " < ");
			Результат = СтрЗаменить(Результат, ИмяПоля + " > ", ЗаменаПоля + " > ");
		КонецЦикла;
		Возврат Результат;
	КонецЕсли;
	Возврат Фильтр;
КонецФункции

Функция ПостроитьСписокПолейДляЗапроса(ПолноеИмяОбъекта, Поля)
	Если НЕ ЭтоМассивоподобноеЗначение(Поля) Или Поля.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Части = Новый Массив;
	Для Каждого Поле Из Поля Цикл
		ИмяПоля = СокрЛП(Строка(Поле));
		Если ПустаяСтрока(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		Части.Добавить(ИмяПоля + " КАК " + ИмяПоля);
	КонецЦикла;
	
	Если Части.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат СтрСоединить(Части, ", ");
КонецФункции

Функция НормализоватьСтроковыйФильтрДляЗапроса(Знач ИсходныйФильтр)
	Фильтр = СокрЛП(Строка(ИсходныйФильтр));
	Если ПустаяСтрока(Фильтр) Тогда
		Возврат "";
	КонецЕсли;
	
	Фильтр = СтрЗаменить(Фильтр, "Объект.", "");
	Фильтр = СтрЗаменить(Фильтр, "объект.", "");
	Фильтр = СтрЗаменить(Фильтр, "'", """");
	Фильтр = СтрЗаменить(Фильтр, "по дате ", "");
	Фильтр = СтрЗаменить(Фильтр, "По дате ", "");
	Фильтр = СтрЗаменить(Фильтр, "ПО ДАТЕ ", "");
	Фильтр = НормализоватьПлейсхолдерыПериодаВТекстеЗапроса(Фильтр);
	ФильтрВРег = ВРег(СтрЗаменить(СтрЗаменить(Фильтр, Символы.ПС, " "), Символы.Таб, " "));
	Если СтрНайти(ФильтрВРег, "=") > 0 Тогда
		ЧастиРавенства = СтрРазделить(Фильтр, "=");
		Если ЧастиРавенства.Количество() = 2 Тогда
			ЛеваяЧасть = СокрЛП(Строка(ЧастиРавенства[0]));
			ПраваяЧасть = СокрЛП(Строка(ЧастиРавенства[1]));
			Если (ВРег(ЛеваяЧасть) = "ПЕРИОД" ИЛИ ВРег(ЛеваяЧасть) = "ДАТА") И НЕ ПустаяСтрока(ПраваяЧасть) Тогда
				ГраницыЯвногоПериода = ПолучитьГраницыПериодаИзТекста(ПраваяЧасть);
				Если ГраницыЯвногоПериода.Начало <> Неопределено И ГраницыЯвногоПериода.Конец <> Неопределено Тогда
					Возврат "Дата МЕЖДУ " + ПостроитьЛитералДаты1С(ГраницыЯвногоПериода.Начало) + " И " + ПостроитьЛитералДаты1С(ГраницыЯвногоПериода.Конец);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если СтрНайти(Фильтр, "=") = 0
		И СтрНайти(Фильтр, ">") = 0
		И СтрНайти(Фильтр, "<") = 0
		И СтрНайти(ВРег(Фильтр), " МЕЖДУ ") = 0
		И СтрНайти(ВРег(Фильтр), " ПОДОБНО ") = 0 Тогда
		Границы = ПолучитьГраницыПериодаИзТекста(Фильтр);
		Если Границы.Начало <> Неопределено И Границы.Конец <> Неопределено Тогда
			Возврат "Дата МЕЖДУ " + ПостроитьЛитералДаты1С(Границы.Начало) + " И " + ПостроитьЛитералДаты1С(Границы.Конец);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Фильтр;
КонецФункции

Функция ВыбратьПолеПериодаПоWhitelist(ПолноеИмяОбъекта)
	Whitelist = ПолучитьWhitelistПолейОбъектаЛокально(ПолноеИмяОбъекта);
	Если Whitelist.Количество() = 0 Тогда
		Возврат "Дата";
	КонецЕсли;
	ЛучшееПоле = "";
	ЛучшаяОценка = -1;
	Для Каждого Поле Из Whitelist Цикл
		ИмяПоля = Строка(Поле);
		ИмяПоляВРег = ВРег(ИмяПоля);
		Оценка = 0;
		Если ИмяПоляВРег = "ДАТА" Тогда
			Оценка = Оценка + 100;
		КонецЕсли;
		Если ИмяПоляВРег = "ПЕРИОД" Тогда
			Оценка = Оценка + 95;
		КонецЕсли;
		Если СтрНайти(ИмяПоляВРег, "ДАТ") > 0 Тогда
			Оценка = Оценка + 40;
		КонецЕсли;
		Если СтрНайти(ИмяПоляВРег, "ПЕРИОД") > 0 Тогда
			Оценка = Оценка + 35;
		КонецЕсли;
		Если СтрНайти(ИмяПоляВРег, "МОМЕНТ") > 0 Тогда
			Оценка = Оценка + 20;
		КонецЕсли;
		Если СтрНайти(ИмяПоляВРег, "TIME") > 0 ИЛИ СтрНайти(ИмяПоляВРег, "DATE") > 0 Тогда
			Оценка = Оценка + 10;
		КонецЕсли;
		Если Оценка > ЛучшаяОценка Тогда
			ЛучшаяОценка = Оценка;
			ЛучшееПоле = ИмяПоля;
		КонецЕсли;
	КонецЦикла;
	Если ПустаяСтрока(ЛучшееПоле) Тогда
		Возврат "Дата";
	КонецЕсли;
	Возврат ЛучшееПоле;
КонецФункции

Функция НормализоватьПолноеИмяОбъектаПоМетаданным(ПолноеИмяОбъекта)
	ИмяПолное = СокрЛП(Строка(ПолноеИмяОбъекта));
	Если ПустаяСтрока(ИмяПолное) ИЛИ СтрНайти(ИмяПолное, ".") = 0 Тогда
		Возврат ИмяПолное;
	КонецЕсли;
	Разбор = РазобратьПолноеИмяОбъекта(ИмяПолное);
	ТипОбъекта = Разбор.ObjectType;
	ИмяОбъекта = Разбор.ObjectName;
	Если ПустаяСтрока(ТипОбъекта) ИЛИ ПустаяСтрока(ИмяОбъекта) Тогда
		Возврат ИмяПолное;
	КонецЕсли;
	Если ТипОбъекта = "Документ" И ИИА_Метаданные.СуществуетДокумент(ИмяОбъекта) Тогда
		Возврат ТипОбъекта + "." + ИмяОбъекта;
	КонецЕсли;
	Если ТипОбъекта = "Справочник" И ИИА_Метаданные.СуществуетСправочник(ИмяОбъекта) Тогда
		Возврат ТипОбъекта + "." + ИмяОбъекта;
	КонецЕсли;
	Похожие = ИИА_Метаданные.НайтиПохожиеОбъекты(ИмяОбъекта, ТипОбъекта);
	Для Каждого Похожий Из Похожие Цикл
		Если ТипОбъекта = "Документ" И ИИА_Метаданные.СуществуетДокумент(Похожий) Тогда
			Возврат ТипОбъекта + "." + Похожий;
		КонецЕсли;
		Если ТипОбъекта = "Справочник" И ИИА_Метаданные.СуществуетСправочник(Похожий) Тогда
			Возврат ТипОбъекта + "." + Похожий;
		КонецЕсли;
	КонецЦикла;
	Возврат ИмяПолное;
КонецФункции

Функция ПостроитьУсловияЗапросаИзФильтра(ПолноеИмяОбъекта, Фильтр)
	Если Фильтр = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	ПолеПериода = ВыбратьПолеПериодаПоWhitelist(ПолноеИмяОбъекта);
	
	Если ТипЗнч(Фильтр) = Тип("Строка") Тогда
		ТекстУсловия = НормализоватьСтроковыйФильтрДляЗапроса(Фильтр);
		Если НЕ ПустаяСтрока(ПолеПериода) И ВРег(ПолеПериода) <> "ДАТА" Тогда
			ТекстУсловия = СтрЗаменить(ТекстУсловия, "Дата МЕЖДУ ", ПолеПериода + " МЕЖДУ ");
		КонецЕсли;
		Возврат ТекстУсловия;
	КонецЕсли;
	
	Если ТипЗнч(Фильтр) <> Тип("Структура") И ТипЗнч(Фильтр) <> Тип("ФиксированнаяСтруктура") Тогда
		Возврат "";
	КонецЕсли;
	
	Условия = Новый Массив;
	Для Каждого Пара Из Фильтр Цикл
		ИмяПоля = Строка(Пара.Ключ);
		ЗначениеФильтра = Пара.Значение;
		ИмяПоляВРег = ВРег(ИмяПоля);
		
		Если ИмяПоляВРег = "ПЕРИОД" Тогда
			Границы = ПолучитьГраницыПериодаИзТекста(ЗначениеФильтра);
			Если Границы.Начало <> Неопределено И Границы.Конец <> Неопределено Тогда
				Условия.Добавить(ПолеПериода + " МЕЖДУ " + ПостроитьЛитералДаты1С(Границы.Начало) + " И " + ПостроитьЛитералДаты1С(Границы.Конец));
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если (ИмяПоляВРег = "ДАТА" ИЛИ ИмяПоляВРег = "ПЕРИОД")
			И (ТипЗнч(ЗначениеФильтра) = Тип("Структура") ИЛИ ТипЗнч(ЗначениеФильтра) = Тип("ФиксированнаяСтруктура")) Тогда
			ДатаС = ПолучитьСвойствоИзСтруктуры(ЗначениеФильтра, "from", Неопределено);
			ДатаПо = ПолучитьСвойствоИзСтруктуры(ЗначениеФильтра, "to", Неопределено);
			НачДата = ПопыткаПрочитатьДатуИзСтроки(ДатаС);
			КонДата = ПопыткаПрочитатьДатуИзСтроки(ДатаПо);
			Если НачДата <> Неопределено И КонДата <> Неопределено Тогда
				Условия.Добавить(ИмяПоля + " МЕЖДУ " + ПостроитьЛитералДаты1С(НачалоДня(НачДата)) + " И " + ПостроитьЛитералДаты1С(КонецДня(КонДата)));
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ЗначениеФильтра) = Тип("Строка") Тогда
			Условия.Добавить(ИмяПоля + " = """ + ЭкранироватьСтрокуДляЗапроса(ЗначениеФильтра) + """");
		ИначеЕсли ТипЗнч(ЗначениеФильтра) = Тип("Число") Тогда
			Условия.Добавить(ИмяПоля + " = " + Строка(ЗначениеФильтра));
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрСоединить(Условия, Символы.ПС + " И ");
КонецФункции

Функция НормализоватьАгрегациюДляЗапроса(Знач Агрегация, Знач Поля)
	ТекстАгрегации = СокрЛП(Строка(Агрегация));
	Если ПустаяСтрока(ТекстАгрегации) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстАгрегации = СтрЗаменить(ТекстАгрегации, "Объект.", "");
	ТекстАгрегации = СтрЗаменить(ТекстАгрегации, "объект.", "");
	ТекстАгрегации = СтрЗаменить(ТекстАгрегации, " AS ", " КАК ");
	ТекстАгрегации = СтрЗаменить(ТекстАгрегации, " as ", " КАК ");
	Если СтрНайти(ВРег(ТекстАгрегации), "СУММА(") = 0 И СтрНайти(ВРег(ТекстАгрегации), "SUM(") > 0 Тогда
		ТекстАгрегации = СтрЗаменить(ТекстАгрегации, "SUM(", "СУММА(");
	КонецЕсли;
	Возврат ТекстАгрегации;
КонецФункции

Функция ПопыткаПрочитатьДатуИзСтроки(Знач СтрокаДаты)
	СтрокаЗначения = СокрЛП(Строка(СтрокаДаты));
	Если ПустаяСтрока(СтрокаЗначения) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Если СтрДлина(СтрокаЗначения) >= 10 И Сред(СтрокаЗначения, 5, 1) = "-" И Сред(СтрокаЗначения, 8, 1) = "-" Тогда
			ГодЗнач = Число(Лев(СтрокаЗначения, 4));
			МесяцЗнач = Число(Сред(СтрокаЗначения, 6, 2));
			ДеньЗнач = Число(Сред(СтрокаЗначения, 9, 2));
			Возврат Дата(ГодЗнач, МесяцЗнач, ДеньЗнач);
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
КонецФункции

Функция ЭтоПохожеНаВалидныйTypedPlanJSON(ТекстJSON)
	Текст = ВРег(СокрЛП(Строка(ТекстJSON)));
	Если ПустаяСтрока(Текст) Тогда
		Возврат Ложь;
	КонецЕсли;
	Возврат СтрНайти(Текст, """PLAN_VERSION""") > 0
		И СтрНайти(Текст, """STEPS""") > 0
		И СтрНайти(Текст, "[{") > 0;
КонецФункции

Функция ПостроитьRunQueryИзШагаПлана(ШагПлана)
	ПолноеИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object", ""));
	Если ПустаяСтрока(ПолноеИмяОбъекта) Тогда
		ПолноеИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_name", ""));
	КонецЕсли;
	ПолноеИмяОбъекта = НормализоватьПолноеИмяОбъектаПоМетаданным(ПолноеИмяОбъекта);
	
	QueryТекст = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "query", ""));
	Если НЕ ПустаяСтрока(QueryТекст) Тогда
		QueryТекст = НормализоватьСтроковыйФильтрДляЗапроса(QueryТекст);
		QueryТекст = НормализоватьСокращенныйЯвныйRunQuery(QueryТекст);
		Если ПустаяСтрока(ПолноеИмяОбъекта) Тогда
			ПолноеИмяОбъекта = НормализоватьПолноеИмяОбъектаПоМетаданным(ИзвлечьПолноеИмяОбъектаИзТекстаЗапросаПровайдера(QueryТекст));
		КонецЕсли;
		Если НЕ ПустаяСтрока(ПолноеИмяОбъекта) Тогда
			QueryТекст = НормализоватьЯвныйRunQueryПоМетаданным(QueryТекст, ПолноеИмяОбъекта);
		КонецЕсли;
		Если Лев(ВРег(СокрЛП(QueryТекст)), 7) <> "ВЫБРАТЬ" Тогда
			Возврат "ВЫБРАТЬ 1 КАК Значение";
		КонецЕсли;
		Возврат QueryТекст;
	КонецЕсли;
	
	Если ПустаяСтрока(ПолноеИмяОбъекта) Тогда
		Возврат "ВЫБРАТЬ 1 КАК Н";
	КонецЕсли;
	
	Фильтр = ПолучитьПараметрШагаПлана(ШагПлана, "filter", Неопределено);
	Поля = ПолучитьПараметрШагаПлана(ШагПлана, "fields", Неопределено);
	Если Поля = Неопределено Тогда
		Поля = ПолучитьПараметрШагаПлана(ШагПлана, "select", Неопределено);
	КонецЕсли;
	Поля = НормализоватьПоляШагаПоМетаданным(ПолноеИмяОбъекта, Поля);
	Фильтр = НормализоватьСтруктуруФильтраПоМетаданным(ПолноеИмяОбъекта, Фильтр);
	Агрегация = НормализоватьАгрегациюДляЗапроса(ПолучитьПараметрШагаПлана(ШагПлана, "aggregation", ""), Поля);
	СписокПолей = ПостроитьСписокПолейДляЗапроса(ПолноеИмяОбъекта, Поля);
	Если ПустаяСтрока(СписокПолей) И НЕ ПустаяСтрока(Агрегация) Тогда
		СписокПолей = Агрегация;
	ИначеЕсли НЕ ПустаяСтрока(СписокПолей) И НЕ ПустаяСтрока(Агрегация) Тогда
		СписокПолей = СписокПолей + ", " + Агрегация;
	ИначеЕсли ПустаяСтрока(СписокПолей) Тогда
		Возврат "ВЫБРАТЬ 1 КАК Значение";
	КонецЕсли;
	Условия = ПостроитьУсловияЗапросаИзФильтра(ПолноеИмяОбъекта, Фильтр);
	
	Текст = "ВЫБРАТЬ ";
	Текст = Текст + СписокПолей + Символы.ПС
		+ "ИЗ" + Символы.ПС
		+ ПолноеИмяОбъекта;
	Если НЕ ПустаяСтрока(Условия) Тогда
		Текст = Текст + Символы.ПС + "ГДЕ" + Символы.ПС + Условия;
	КонецЕсли;
	Возврат Текст;
КонецФункции

Функция ИзвлечьДанныеИзРезультатаШагаПлана(РезультатШага)
	Если РезультатШага = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "Данные", Неопределено);
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "data", Неопределено);
	КонецЕсли;
	Если Данные <> Неопределено Тогда
		Возврат Данные;
	КонецЕсли;
	
	Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "ДанныеЗапроса", Неопределено);
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "ДанныеЗапросаДляТаблицы", Неопределено);
	КонецЕсли;
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "rows", Неопределено);
	КонецЕсли;
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "СсылкиОбъектов", Неопределено);
	КонецЕсли;
	Если Данные = Неопределено Тогда
		Данные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "changed_objects", Неопределено);
	КонецЕсли;
	Если Данные <> Неопределено Тогда
		Возврат Данные;
	КонецЕсли;
	
	RunQueryДанные = ПолучитьСвойствоИзСтруктуры(РезультатШага, "run_query", Неопределено);
	Если ЭтоМассивоподобноеЗначение(RunQueryДанные) И RunQueryДанные.Количество() > 0 Тогда
		ПервыйRunQuery = ПолучитьЭлементМассиваУниверсально(RunQueryДанные, 0);
		Если ПервыйRunQuery <> Неопределено Тогда
			Данные = ПолучитьСвойствоИзСтруктуры(ПервыйRunQuery, "rows", Неопределено);
			Если Данные <> Неопределено Тогда
				Возврат Данные;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Результаты = ПолучитьСвойствоИзСтруктуры(РезультатШага, "Результаты", Неопределено);
	Если ЭтоМассивоподобноеЗначение(Результаты) Тогда
		Для Индекс = 0 По Результаты.Количество() - 1 Цикл
			ЭлементРезультата = ПолучитьЭлементМассиваУниверсально(Результаты, Индекс);
			Если ЭлементРезультата = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ДанныеЭлемента = ПолучитьСвойствоИзСтруктуры(ЭлементРезультата, "Данные", Неопределено);
			Если ДанныеЭлемента = Неопределено Тогда
				ДанныеЭлемента = ПолучитьСвойствоИзСтруктуры(ЭлементРезультата, "data", Неопределено);
			КонецЕсли;
			Если ДанныеЭлемента = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ДанныеЗапроса = ПолучитьСвойствоИзСтруктуры(ДанныеЭлемента, "ДанныеЗапроса", Неопределено);
			Если ДанныеЗапроса = Неопределено Тогда
				ДанныеЗапроса = ПолучитьСвойствоИзСтруктуры(ДанныеЭлемента, "ДанныеЗапросаДляТаблицы", Неопределено);
			КонецЕсли;
			Если ДанныеЗапроса = Неопределено Тогда
				ДанныеЗапроса = ПолучитьСвойствоИзСтруктуры(ДанныеЭлемента, "rows", Неопределено);
			КонецЕсли;
			Если ДанныеЗапроса <> Неопределено Тогда
				Возврат ДанныеЗапроса;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

Функция РазрешитьЗначениеИзРезультатовПлана(СсылкаДиалога, ИсходноеЗначение)
	Если ТипЗнч(ИсходноеЗначение) <> Тип("Строка") Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	Выражение = СокрЛП(ИсходноеЗначение);
	Если СтрНайти(ВРег(Выражение), "STEP_") > 0 И Лев(ВРег(Выражение), 5) <> "STEP_" Тогда
		ИзвлеченныйStepId = ИзвлечьStepIdИзТекста(Выражение);
		Если НЕ ПустаяСтрока(ИзвлеченныйStepId) Тогда
			Выражение = ИзвлеченныйStepId;
		КонецЕсли;
	КонецЕсли;
	Если Лев(ВРег(Выражение), 9) = "РЕЗУЛЬТАТ " Тогда
		Выражение = СокрЛП(Сред(Выражение, 10));
	ИначеЕсли Лев(ВРег(Выражение), 12) = "РЕЗУЛЬТАТ ИЗ " Тогда
		Выражение = СокрЛП(Сред(Выражение, 13));
	КонецЕсли;
	ВыражениеВРег = ВРег(Выражение);
	Если Лев(ВыражениеВРег, 3) = "ИЗ " Тогда
		Выражение = СокрЛП(Сред(Выражение, 4));
		ВыражениеВРег = ВРег(Выражение);
	КонецЕсли;
	Если Лев(ВыражениеВРег, 5) <> "STEP_" Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	
	ПозТочки = СтрНайти(Выражение, ".");
	Если ПозТочки = 0 Тогда
		StepId = Выражение;
		Хвост = "";
	Иначе
		StepId = Лев(Выражение, ПозТочки - 1);
		Хвост = Сред(Выражение, ПозТочки + 1);
	КонецЕсли;
	
	ИмяПоля = "";
	Если Лев(ВРег(Хвост), 9) = "RESULT[0]" Тогда
		ПозПоля = СтрНайти(Хвост, "].");
		Если ПозПоля > 0 Тогда
			ИмяПоля = Сред(Хвост, ПозПоля + 2);
		КонецЕсли;
	Иначе
		ИмяПоля = Хвост;
	КонецЕсли;
	
	ШагПлана = ИИА_TypedPlan.ПолучитьШагПланаПоИдентификатору(СсылкаДиалога, StepId);
	Если ШагПлана = Неопределено Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	РезультатШага = ПолучитьСвойствоИзСтруктуры(ШагПлана, "result_data", Неопределено);
	Если РезультатШага = Неопределено Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	Данные = ИзвлечьДанныеИзРезультатаШагаПлана(РезультатШага);
	ПерваяСтрока = ПолучитьЭлементМассиваУниверсально(Данные, 0);
	Если ПерваяСтрока = Неопределено Тогда
		Возврат ИсходноеЗначение;
	КонецЕсли;
	Если ПустаяСтрока(ИмяПоля) Тогда
		Если ТипЗнч(ПерваяСтрока) = Тип("Структура") ИЛИ ТипЗнч(ПерваяСтрока) = Тип("ФиксированнаяСтруктура") Тогда
			СсылкаЗначение = ПолучитьСвойствоИзСтруктуры(ПерваяСтрока, "Ссылка", Неопределено);
			Если СсылкаЗначение <> Неопределено Тогда
				Возврат СсылкаЗначение;
			КонецЕсли;
		КонецЕсли;
		Возврат ПерваяСтрока;
	КонецЕсли;
	Возврат ПолучитьСвойствоИзСтруктуры(ПерваяСтрока, ИмяПоля, ИсходноеЗначение);
КонецФункции

Функция ИзвлечьStepIdИзТекста(Текст)
	ТекстВРег = ВРег(Строка(Текст));
	ПозStep = СтрНайти(ТекстВРег, "STEP_");
	Если ПозStep = 0 Тогда
		Возврат "";
	КонецЕсли;
	Остаток = Сред(ТекстВРег, ПозStep);
	Результат = "";
	Для Позиция = 1 По СтрДлина(Остаток) Цикл
		Символ = Сред(Остаток, Позиция, 1);
		Если (Символ >= "A" И Символ <= "Z") ИЛИ (Символ >= "0" И Символ <= "9") ИЛИ Символ = "_" Тогда
			Результат = Результат + Символ;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Возврат НРег(Результат);
КонецФункции

Процедура ДобавитьШагВСценарийDSL(Шаги, Действие, Параметры = Неопределено)
	Если Шаги = Неопределено ИЛИ ТипЗнч(Шаги) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	Шаг = Новый Структура;
	Шаг.Вставить("action", Действие);
	Если Параметры <> Неопределено Тогда
		Если ТипЗнч(Параметры) = Тип("Структура") Тогда
			Для Каждого КлючИЗначение Из Параметры Цикл
				Шаг.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
			КонецЦикла;
		ИначеЕсли ТипЗнч(Параметры) = Тип("Соответствие") Тогда
			Для Каждого КлючИЗначение Из Параметры Цикл
				Шаг.Вставить(Строка(КлючИЗначение.Ключ), КлючИЗначение.Значение);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Шаги.Добавить(Шаг);
КонецПроцедуры

Функция ПолучитьСледующийШагПланаДляВосстановления(СсылкаДиалога)
	Если СсылкаДиалога = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат ИИА_TypedPlan.ПолучитьСледующийШагПлана(СсылкаДиалога);
КонецФункции

Функция ПостроитьDSLИзШагаПлана(ШагПлана, НомерПункта = 1, СсылкаДиалога = Неопределено) Экспорт
	Если ШагПлана = Неопределено ИЛИ ТипЗнч(ШагПлана) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	Kind = ?(ШагПлана.Свойство("kind"), Строка(ШагПлана.kind), "");
	Если ПустаяСтрока(Kind) Тогда
		QueryКандидат = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "query", ""));
		Если НЕ ПустаяСтрока(QueryКандидат) Тогда
			Kind = "RUN_QUERY";
		Иначе
			Возврат "";
		КонецЕсли;
	КонецЕсли;
	KindКлюч = ВРег(Kind);

	Шаг = Новый Структура;
	ОперацияИД = "recovered_plan_step_" + Строка(НомерПункта) + "_" + Kind;

	Если KindКлюч = "RUN_QUERY" Тогда
		ПолноеИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object", ""));
		Если ПустаяСтрока(ПолноеИмяОбъекта) Тогда
			ПолноеИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_name", ""));
		КонецЕсли;
		ПараметрыЗапроса = ПолучитьПараметрШагаПлана(ШагПлана, "parameters", Неопределено);
		ЯвныйQuery = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "query", ""));
		QueryТекст = ПостроитьRunQueryИзШагаПлана(ШагПлана);
		Если ПустаяСтрока(QueryТекст) Тогда
			Возврат "";
		КонецЕсли;
		Если НЕ ПустаяСтрока(ПолноеИмяОбъекта) И (ПустаяСтрока(ЯвныйQuery) Или Лев(ВРег(СокрЛП(ЯвныйQuery)), 7) <> "ВЫБРАТЬ") Тогда
			РазборОбъекта = РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта);
			DSLСтруктура = Новый Структура;
			DSLСтруктура.Вставить("dsl_version", 2);
			Шаги = Новый Массив;
			ШагУточнения = Новый Структура;
			ШагУточнения.Вставить("action", "GetObjectFields");
			ШагУточнения.Вставить("object_type", РазборОбъекта.ObjectType);
			ШагУточнения.Вставить("object_name", РазборОбъекта.ObjectName);
			Шаги.Добавить(ШагУточнения);
			ШагЗапроса = Новый Структура;
			ШагЗапроса.Вставить("action", "RunQuery");
			ШагЗапроса.Вставить("query", QueryТекст);
			Шаги.Добавить(ШагЗапроса);
			DSLСтруктура.Вставить("steps", Шаги);
			Возврат СериализоватьJSONВСтроку(DSLСтруктура);
		КонецЕсли;
		Шаг.Вставить("action", "RunQuery");
		Шаг.Вставить("query", QueryТекст);
		Если ПараметрыЗапроса <> Неопределено Тогда
			Шаг.Вставить("parameters", ПараметрыЗапроса);
		КонецЕсли;
	ИначеЕсли KindКлюч = "CREATE_REFERENCE" Тогда
		Шаг.Вставить("action", "CreateReference");
		ИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_name", ""));
		Если ПустаяСтрока(ИмяОбъекта) Тогда
			ИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object", ""));
		КонецЕсли;
		ИмяОбъекта = НормализоватьПолноеИмяОбъектаПоМетаданным(ИмяОбъекта);
		Если СтрНайти(ИмяОбъекта, ".") > 0 Тогда
			ИмяОбъекта = Сред(ИмяОбъекта, СтрНайти(ИмяОбъекта, ".") + 1);
		КонецЕсли;
		Шаг.Вставить("object_name", ИмяОбъекта);
		Имя = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "name", ""));
		Если НЕ ПустаяСтрока(Имя) Тогда
			Шаг.Вставить("name", Имя);
		КонецЕсли;
		Шаг.Вставить("operation_id", ОперацияИД);
	ИначеЕсли KindКлюч = "CREATE_DOCUMENT" Тогда
		Шаг.Вставить("action", "CreateDocument");
		ИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_name", ""));
		Если ПустаяСтрока(ИмяОбъекта) Тогда
			ИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object", ""));
		КонецЕсли;
		Если ПустаяСтрока(ИмяОбъекта) Тогда
			ИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "document_type", ""));
		КонецЕсли;
		Если ПустаяСтрока(ИмяОбъекта) Тогда
			ИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "document", ""));
		КонецЕсли;
		ИмяОбъекта = НормализоватьПолноеИмяОбъектаПоМетаданным(ИмяОбъекта);
		Если СтрНайти(ИмяОбъекта, ".") > 0 Тогда
			ИмяОбъекта = Сред(ИмяОбъекта, СтрНайти(ИмяОбъекта, ".") + 1);
		КонецЕсли;
		Шаг.Вставить("object_name", ИмяОбъекта);
		Шаг.Вставить("operation_id", ОперацияИД);
	ИначеЕсли KindКлюч = "SET_FIELD" Тогда
		ИмяПоля = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "field", ""));
		Если ПустаяСтрока(ИмяПоля) Тогда
			ИмяПоля = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "field_name", ""));
		КонецЕсли;
		ЗначениеПоля = ПолучитьПараметрШагаПлана(ШагПлана, "value", "");
		КартаПолей = ПолучитьПараметрШагаПлана(ШагПлана, "fields", Неопределено);
		Если КартаПолей = Неопределено Тогда
			КартаПолей = ПолучитьПараметрШагаПлана(ШагПлана, "fields_to_set", Неопределено);
		КонецЕсли;
		Если КартаПолей <> Неопределено И (ТипЗнч(КартаПолей) = Тип("Структура") ИЛИ ТипЗнч(КартаПолей) = Тип("Соответствие")) Тогда
			DSLСтруктура = Новый Структура;
			DSLСтруктура.Вставить("dsl_version", 2);
			ШагиDSL = Новый Массив;
			СчетчикПоля = 0;
			Для Каждого Поле Из КартаПолей Цикл
				СчетчикПоля = СчетчикПоля + 1;
				ИмяПоляКарты = ?(ТипЗнч(КартаПолей) = Тип("Структура"), Поле.Ключ, Строка(Поле.Ключ));
				ЗначениеПоляКарты = Поле.Значение;
				Если СсылкаДиалога <> Неопределено Тогда
					ЗначениеПоляКарты = РазрешитьЗначениеИзРезультатовПлана(СсылкаДиалога, ЗначениеПоляКарты);
				КонецЕсли;
				ДобавитьШагВСценарийDSL(ШагиDSL, "SetField", Новый Структура("field,value,operation_id", ИмяПоляКарты, ЗначениеПоляКарты, ОперацияИД + "_" + Строка(СчетчикПоля)));
			КонецЦикла;
			Если ШагиDSL.Количество() = 0 Тогда
				Возврат "";
			КонецЕсли;
			DSLСтруктура.Вставить("steps", ШагиDSL);
			Возврат СериализоватьJSONВСтроку(DSLСтруктура);
		КонецЕсли;
		Если СсылкаДиалога <> Неопределено Тогда
			ЗначениеПоля = РазрешитьЗначениеИзРезультатовПлана(СсылкаДиалога, ЗначениеПоля);
		КонецЕсли;
		Шаг.Вставить("action", "SetField");
		Шаг.Вставить("field", ИмяПоля);
		Шаг.Вставить("value", ЗначениеПоля);
		Шаг.Вставить("operation_id", ОперацияИД);
	ИначеЕсли KindКлюч = "WRITE_OBJECT" Тогда
		Шаг.Вставить("action", "Write");
		Шаг.Вставить("operation_id", ОперацияИД);
	ИначеЕсли KindКлюч = "SHOW_INFO" Тогда
		Шаг.Вставить("action", "ShowInfo");
		Сообщение = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "message", ""));
		Если ПустаяСтрока(Сообщение) Тогда
			Сообщение = ?(ШагПлана.Свойство("title"), Строка(ШагПлана.title), "Шаг плана выполнен.");
		КонецЕсли;
		Шаг.Вставить("message", Сообщение);
	ИначеЕсли KindКлюч = "GET_METADATA" Тогда
		Шаг.Вставить("action", "GetMetadata");
		Фильтр = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "filter", ""));
		Если НЕ ПустаяСтрока(Фильтр) Тогда
			Шаг.Вставить("filter", Фильтр);
		КонецЕсли;
	ИначеЕсли KindКлюч = "GET_OBJECT_FIELDS" Тогда
		Шаг.Вставить("action", "GetObjectFields");
		ПолноеИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_type", "")) + "." + Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_name", ""));
		ПолноеИмяОбъекта = НормализоватьПолноеИмяОбъектаПоМетаданным(ПолноеИмяОбъекта);
		РазборОбъекта = РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта);
		Шаг.Вставить("object_type", РазборОбъекта.ObjectType);
		Шаг.Вставить("object_name", РазборОбъекта.ObjectName);
	ИначеЕсли KindКлюч = "CHECK_OBJECT_EXISTS" Тогда
		Шаг.Вставить("action", "CheckObjectExists");
		ПолноеИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_type", "")) + "." + Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_name", ""));
		ПолноеИмяОбъекта = НормализоватьПолноеИмяОбъектаПоМетаданным(ПолноеИмяОбъекта);
		РазборОбъекта = РазобратьПолноеИмяОбъекта(ПолноеИмяОбъекта);
		Шаг.Вставить("object_type", РазборОбъекта.ObjectType);
		Шаг.Вставить("object_name", РазборОбъекта.ObjectName);
	ИначеЕсли KindКлюч = "FIND_REFERENCE_BY_NAME" Тогда
		Шаг.Вставить("action", "FindReferenceByName");
		ИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object_name", ""));
		Если ПустаяСтрока(ИмяОбъекта) Тогда
			ИмяОбъекта = Строка(ПолучитьПараметрШагаПлана(ШагПлана, "object", ""));
		КонецЕсли;
		ИмяОбъекта = НормализоватьПолноеИмяОбъектаПоМетаданным(ИмяОбъекта);
		Если СтрНайти(ИмяОбъекта, ".") > 0 Тогда
			ИмяОбъекта = Сред(ИмяОбъекта, СтрНайти(ИмяОбъекта, ".") + 1);
		КонецЕсли;
		Шаг.Вставить("object_name", ИмяОбъекта);
		Шаг.Вставить("name", Строка(ПолучитьПараметрШагаПлана(ШагПлана, "name", "")));
	Иначе
		Возврат "";
	КонецЕсли;

	DSLСтруктура = Новый Структура;
	DSLСтруктура.Вставить("dsl_version", 2);
	Шаги = Новый Массив;
	Шаги.Добавить(Шаг);
	DSLСтруктура.Вставить("steps", Шаги);
	Возврат СериализоватьJSONВСтроку(DSLСтруктура);
КонецФункции

Функция ИзвлечьШагиИзDSLJSON(DSL_JSON)
	Если ПустаяСтрока(DSL_JSON) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ИИА_DSL.НормализоватьJSONТекст(DSL_JSON));
		DSLСтруктура = ПрочитатьJSON(ЧтениеJSON);
		ЧтениеJSON.Закрыть();
		Если ТипЗнч(DSLСтруктура) = Тип("Структура")
			И DSLСтруктура.Свойство("steps")
			И ТипЗнч(DSLСтруктура.steps) = Тип("Массив") Тогда
			Возврат DSLСтруктура.steps;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

Функция ПолучитьСвойствоШагаПланаЛокально(Значение, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Структура") И Значение.Свойство(ИмяСвойства) Тогда
		Возврат Значение[ИмяСвойства];
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("ФиксированнаяСтруктура") И Значение.Свойство(ИмяСвойства) Тогда
		Возврат Значение[ИмяСвойства];
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ЭтоСтартЦепочкиЗаписывающегоКонтекста(Kind)
	KindВРег = ВРег(СокрЛП(Строка(Kind)));
	Возврат KindВРег = "CREATE_DOCUMENT"
		ИЛИ KindВРег = "CREATE_REFERENCE"
		ИЛИ KindВРег = "FIND_REFERENCE_BY_NAME";
КонецФункции

Функция ЭтоПродолжениеЦепочкиЗаписывающегоКонтекста(Kind)
	KindВРег = ВРег(СокрЛП(Строка(Kind)));
	Возврат KindВРег = "SET_FIELD"
		ИЛИ KindВРег = "WRITE_OBJECT"
		ИЛИ KindВРег = "SHOW_INFO";
КонецФункции

Функция МожноВключитьШагВЦепочкуDSL(ШагПлана, УжеВключенныеШаги, СсылкаДиалога)
	Если ШагПлана = Неопределено ИЛИ ТипЗнч(ШагПлана) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	Если ШагПлана.Свойство("status") И ВРег(Строка(ШагПлана.status)) = "DONE" Тогда
		Возврат Ложь;
	КонецЕсли;
	Зависимости = ПолучитьСвойствоШагаПланаЛокально(ШагПлана, "depends_on", Неопределено);
	Если ТипЗнч(Зависимости) = Тип("Массив") Тогда
		Для Индекс = 0 По Зависимости.Количество() - 1 Цикл
			Зависимость = Строка(ПолучитьЭлементМассиваУниверсально(Зависимости, Индекс));
			Если ПустаяСтрока(Зависимость) Тогда
				Продолжить;
			КонецЕсли;
			Если УжеВключенныеШаги.Найти(ВРег(Зависимость)) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ШагЗависимости = ИИА_TypedPlan.ПолучитьШагПланаПоИдентификатору(СсылкаДиалога, Зависимость);
			Если ШагЗависимости = Неопределено
				ИЛИ НЕ ШагЗависимости.Свойство("status")
				ИЛИ ВРег(Строка(ШагЗависимости.status)) <> "DONE" Тогда
				Возврат Ложь;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Если ВРег(Строка(ПолучитьСвойствоШагаПланаЛокально(ШагПлана, "kind", ""))) = "SET_FIELD" Тогда
		КартаПолей = ПолучитьПараметрШагаПлана(ШагПлана, "fields", Неопределено);
		Если КартаПолей <> Неопределено И (ТипЗнч(КартаПолей) = Тип("Структура") ИЛИ ТипЗнч(КартаПолей) = Тип("Соответствие")) Тогда
			Для Каждого Поле Из КартаПолей Цикл
				ЗначениеПоляКарты = Поле.Значение;
				Если СсылкаДиалога <> Неопределено Тогда
					ЗначениеПоляКарты = РазрешитьЗначениеИзРезультатовПлана(СсылкаДиалога, ЗначениеПоляКарты);
				КонецЕсли;
				Если ТипЗнч(ЗначениеПоляКарты) = Тип("Строка") И Лев(ВРег(СокрЛП(ЗначениеПоляКарты)), 5) = "STEP_" Тогда
					Возврат Истина;
				КонецЕсли;
			КонецЦикла;
		Иначе
			ЗначениеПоля = ПолучитьПараметрШагаПлана(ШагПлана, "value", "");
			Если СсылкаДиалога <> Неопределено Тогда
				ЗначениеПоля = РазрешитьЗначениеИзРезультатовПлана(СсылкаДиалога, ЗначениеПоля);
			КонецЕсли;
			Если ТипЗнч(ЗначениеПоля) = Тип("Строка") И Лев(ВРег(СокрЛП(ЗначениеПоля)), 5) = "STEP_" Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Возврат Истина;
КонецФункции

Функция ПостроитьDSLИзЦепочкиШаговПлана(СсылкаДиалога, СтартовыйШаг) Экспорт
	Если СсылкаДиалога = Неопределено
		ИЛИ СтартовыйШаг = Неопределено
		ИЛИ ТипЗнч(СтартовыйШаг) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	Если НЕ ЭтоСтартЦепочкиЗаписывающегоКонтекста(ПолучитьСвойствоШагаПланаЛокально(СтартовыйШаг, "kind", "")) Тогда
		Возврат "";
	КонецЕсли;
	План = ИИА_TypedPlan.ПолучитьTypedPlan(СсылкаДиалога);
	Если План = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Если НЕ План.Свойство("steps") ИЛИ ТипЗнч(План.steps) <> Тип("Массив") Тогда
		Возврат "";
	КонецЕсли;
	СтартStepId = Строка(ПолучитьСвойствоШагаПланаЛокально(СтартовыйШаг, "id", ""));
	Если ПустаяСтрока(СтартStepId) Тогда
		Возврат "";
	КонецЕсли;
	ШагиDSL = Новый Массив;
	УжеВключенныеШаги = Новый Массив;
	Начали = Ложь;
	НомерПункта = 0;
	Для Каждого ШагПлана Из План.steps Цикл
		НомерПункта = НомерПункта + 1;
		ТекущийStepId = Строка(ПолучитьСвойствоШагаПланаЛокально(ШагПлана, "id", ""));
		Если НЕ Начали Тогда
			Если ВРег(ТекущийStepId) <> ВРег(СтартStepId) Тогда
				Продолжить;
			КонецЕсли;
			Начали = Истина;
		КонецЕсли;
		KindШага = Строка(ПолучитьСвойствоШагаПланаЛокально(ШагПлана, "kind", ""));
		Если ВРег(ТекущийStepId) <> ВРег(СтартStepId) И НЕ ЭтоПродолжениеЦепочкиЗаписывающегоКонтекста(KindШага) Тогда
			Прервать;
		КонецЕсли;
		Если НЕ МожноВключитьШагВЦепочкуDSL(ШагПлана, УжеВключенныеШаги, СсылкаДиалога) Тогда
			Прервать;
		КонецЕсли;
		DSLШага = ИИА_DSLПостроитель.ПостроитьDSLИзШагаПлана(ШагПлана, НомерПункта, СсылкаДиалога);
		ШагиDSLШага = ИзвлечьШагиИзDSLJSON(DSLШага);
		Если ШагиDSLШага = Неопределено Тогда
			Прервать;
		КонецЕсли;
		Если ТипЗнч(ШагиDSLШага) <> Тип("Массив") ИЛИ ШагиDSLШага.Количество() = 0 Тогда
			Прервать;
		КонецЕсли;
		Для Каждого DSLШаг Из ШагиDSLШага Цикл
			ШагиDSL.Добавить(DSLШаг);
		КонецЦикла;
		УжеВключенныеШаги.Добавить(ВРег(ТекущийStepId));
	КонецЦикла;
	Если ШагиDSL.Количество() <= 1 Тогда
		Возврат "";
	КонецЕсли;
	DSLСтруктура = Новый Структура;
	DSLСтруктура.Вставить("dsl_version", 2);
	DSLСтруктура.Вставить("steps", ШагиDSL);
	Возврат СериализоватьJSONВСтроку(DSLСтруктура);
КонецФункции

Функция ПопыткаВосстановитьDSLИзТекущегоПлана(ПараметрыИИ) Экспорт
	Если ПараметрыИИ = Неопределено ИЛИ ТипЗнч(ПараметрыИИ) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	Если НЕ ПараметрыИИ.Свойство("СсылкаДиалога") ИЛИ ПараметрыИИ.СсылкаДиалога = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ШагПлана = ПолучитьСледующийШагПланаДляВосстановления(ПараметрыИИ.СсылкаДиалога);
	Если ШагПлана = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	НомерПункта = ?(ШагПлана.Свойство("seq_no"), Число(ШагПлана.seq_no), 1);
	DSL_JSON = ИИА_DSLПостроитель.ПостроитьDSLИзШагаПлана(ШагПлана, НомерПункта, ПараметрыИИ.СсылкаДиалога);
	Если ПустаяСтрока(DSL_JSON) Тогда
		Возврат "";
	КонецЕсли;
	
	РезультатПроверки = ИИА_DSL.ПроверитьDSL(DSL_JSON);
	Если НЕ РезультатПроверки.Успех Тогда
		Возврат "";
	КонецЕсли;
	
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(ПараметрыИИ.СсылкаДиалога, "[CONTRACT_RECOVERED] submit_dsl восстановлен из текущего шага typed plan");
	Возврат DSL_JSON;
КонецФункции

Функция ПопыткаВосстановитьNextStepDSLИзТекущегоПлана(ПараметрыИИ, StepId = "") Экспорт
	Если ПараметрыИИ = Неопределено ИЛИ ТипЗнч(ПараметрыИИ) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если НЕ ПараметрыИИ.Свойство("СсылкаДиалога") ИЛИ ПараметрыИИ.СсылкаДиалога = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ШагПлана = Неопределено;
	Если НЕ ПустаяСтрока(Строка(StepId)) Тогда
		ШагПлана = ИИА_TypedPlan.ПолучитьШагПланаПоИдентификатору(ПараметрыИИ.СсылкаДиалога, StepId);
	КонецЕсли;
	Если ШагПлана = Неопределено Тогда
		ШагПлана = ПолучитьСледующийШагПланаДляВосстановления(ПараметрыИИ.СсылкаДиалога);
	КонецЕсли;
	Если ШагПлана = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НомерПункта = ?(ШагПлана.Свойство("seq_no"), Число(ШагПлана.seq_no), 1);
	DSL_JSON = ИИА_DSLПостроитель.ПостроитьDSLИзЦепочкиШаговПлана(ПараметрыИИ.СсылкаДиалога, ШагПлана);
	Если ПустаяСтрока(DSL_JSON) Тогда
		DSL_JSON = ИИА_DSLПостроитель.ПостроитьDSLИзШагаПлана(ШагПлана, НомерПункта, ПараметрыИИ.СсылкаДиалога);
	КонецЕсли;
	Если ПустаяСтрока(DSL_JSON) Тогда
		Возврат Неопределено;
	КонецЕсли;
	ПроверкаDSL = ИИА_DSL.ПроверитьDSL(DSL_JSON);
	Если НЕ ПроверкаDSL.Успех Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = СоздатьБазовыйРезультатИИ();
	Результат.ТипОтвета = "DSL";
	Результат.DSL = DSL_JSON;
	Результат.ВыполнитьDSL = Истина;
	Результат.PlanStepId = ?(ШагПлана.Свойство("id"), Строка(ШагПлана.id), Строка(StepId));
	Результат.Текст = DSL_JSON;
	Результат.RawModelText = DSL_JSON;
	ИИА_Сервер.ДобавитьЗаписьВЛогДиалога(ПараметрыИИ.СсылкаДиалога, "[CONTRACT_RECOVERED] submit_next_step восстановлен локально из typed step " + Результат.PlanStepId);
	Возврат Результат;
КонецФункции

Функция ПопыткаЛокальноСгенерироватьNextStepDSL(СсылкаДиалога, StepId = "") Экспорт
	ПараметрыИИ = Новый Структура("СсылкаДиалога", СсылкаДиалога);
	Возврат ИИА_DSLПостроитель.ПопыткаВосстановитьNextStepDSLИзТекущегоПлана(ПараметрыИИ, StepId);
КонецФункции

#КонецОбласти





