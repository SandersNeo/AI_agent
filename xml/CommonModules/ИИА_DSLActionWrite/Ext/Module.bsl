#Область ПрограммныйИнтерфейс

Функция ВыполнитьCreateReference(Шаг, КонтекстВыполнения) Экспорт
	Результат = СоздатьБазовыйРезультатШага("CreateReference", ИИА_DSLКонтракт.ПолучитьКонтрактДействия("CreateReference"));
	OperationId = ИИА_DSLReplay.ПолучитьOperationIdШага(Шаг);
	Результат.operation_id = OperationId;
	ИмяСправочника = ИИА_DSLQuerySafety.РазрешитьИмяСправочника(Шаг.object_name, КонтекстВыполнения);
	Если ПустаяСтрока(ИмяСправочника) Тогда
		Результат.Сообщение = "Справочник '" + Шаг.object_name + "' не найден";
		УстановитьТипизированнуюОшибку(Результат, "object_not_found", "metadata", Истина, "run_getmetadata", Новый Структура("object_type,object_name", "Справочник", Шаг.object_name));
		Возврат Результат;
	КонецЕсли;
	МенеджерСправочника = Справочники[ИмяСправочника];
	Если МенеджерСправочника = Неопределено Тогда
		Результат.Сообщение = "Не удалось получить менеджер справочника '" + ИмяСправочника + "'";
		УстановитьТипизированнуюОшибку(Результат, "metadata_access_error", "metadata", Истина, "retry_getmetadata", Новый Структура("object_type,object_name", "Справочник", ИмяСправочника));
		Возврат Результат;
	КонецЕсли;
	НаименованиеДляПоиска = "";
	Если Шаг.Свойство("name") Тогда
		НаименованиеДляПоиска = СокрЛП(Строка(Шаг.name));
	КонецЕсли;
	Если ПустаяСтрока(НаименованиеДляПоиска) И Шаг.Свойство("data") И ТипЗнч(Шаг.data) = Тип("Структура") И Шаг.data.Свойство("Наименование") Тогда
		НаименованиеДляПоиска = СокрЛП(Строка(Шаг.data.Наименование));
	КонецЕсли;
	Если НЕ ПустаяСтрока(НаименованиеДляПоиска) Тогда
		СуществующаяСсылка = МенеджерСправочника.НайтиПоНаименованию(НаименованиеДляПоиска);
		Если ЗначениеЗаполнено(СуществующаяСсылка) Тогда
			СуществующийОбъект = СуществующаяСсылка.ПолучитьОбъект();
			КонтекстВыполнения.Вставить("ТекущийОбъект", СуществующийОбъект);
			КонтекстВыполнения.Вставить("ТипОбъекта", "Справочник");
			КонтекстВыполнения.Вставить("ИмяОбъекта", ИмяСправочника);
			УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, "Справочник", ИмяСправочника, СуществующийОбъект);
			Результат.Успех = Истина;
			Результат.Сообщение = "Элемент справочника '" + ИмяСправочника + "' уже существует, дубль не создавался";
			Результат.Данные = СуществующаяСсылка;
			КонтекстВыполнения.Вставить("СсылкаОбъекта", СуществующаяСсылка);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	НовыйЭлемент = МенеджерСправочника.СоздатьЭлемент();
	КонтекстВыполнения.Вставить("ТекущийОбъект", НовыйЭлемент);
	КонтекстВыполнения.Вставить("ТипОбъекта", "Справочник");
	КонтекстВыполнения.Вставить("ИмяОбъекта", ИмяСправочника);
	УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, "Справочник", ИмяСправочника, НовыйЭлемент);
	Если Шаг.Свойство("data") И ТипЗнч(Шаг.data) = Тип("Структура") Тогда
		Для Каждого ПараКлючЗначение Из Шаг.data Цикл
			Попытка
				ЗначениеДляУстановки = ПодготовитьЗначениеДляУстановкиРеквизита(КонтекстВыполнения, ПараКлючЗначение.Ключ, ПараКлючЗначение.Значение);
				УстановитьЗначениеРеквизита(НовыйЭлемент, ПараКлючЗначение.Ключ, ЗначениеДляУстановки);
				ПроверитьЧтоСсылочныйРеквизитЗаполнен(НовыйЭлемент, КонтекстВыполнения, ПараКлючЗначение.Ключ, ЗначениеДляУстановки);
				ДобавитьИзмененноеПоле(КонтекстВыполнения, ПараКлючЗначение.Ключ, ЗначениеДляУстановки);
			Исключение
				Результат.Сообщение = "Ошибка установки поля '" + ПараКлючЗначение.Ключ + "': " + ОписаниеОшибки();
				УстановитьТипизированнуюОшибку(Результат, "field_write_error", "validation", Истина, "run_getobjectfields", Новый Структура("object_name,field", ИмяСправочника, ПараКлючЗначение.Ключ));
				Возврат Результат;
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	Результат.Успех = Истина;
	Результат.Сообщение = "Создан элемент справочника '" + ИмяСправочника + "'";
	Результат.Данные = НовыйЭлемент.Ссылка;
	КонтекстВыполнения.Вставить("СсылкаОбъекта", НовыйЭлемент.Ссылка);
	ИИА_DSLReplay.ДобавитьЗаписьВСайдЭффектЛогИзDSL(КонтекстВыполнения, "draft_created", "CreateReference", OperationId);
	Возврат Результат;
КонецФункции

Функция ВыполнитьCreateDocument(Шаг, КонтекстВыполнения) Экспорт
	Результат = СоздатьБазовыйРезультатШага("CreateDocument", ИИА_DSLКонтракт.ПолучитьКонтрактДействия("CreateDocument"));
	OperationId = ИИА_DSLReplay.ПолучитьOperationIdШага(Шаг);
	Результат.operation_id = OperationId;
	ИмяДокумента = ИИА_DSLQuerySafety.НормализоватьИмяОбъектаМетаданных(Шаг.object_name, "Документ");
	МенеджерДокумента = Документы[ИмяДокумента];
	Если МенеджерДокумента = Неопределено Тогда
		Результат.Сообщение = "Не удалось получить менеджер документа '" + ИмяДокумента + "'";
		УстановитьТипизированнуюОшибку(Результат, "metadata_access_error", "metadata", Истина, "retry_getmetadata", Новый Структура("object_type,object_name", "Документ", ИмяДокумента));
		Возврат Результат;
	КонецЕсли;
	НовыйДокумент = МенеджерДокумента.СоздатьДокумент();
	КонтекстВыполнения.Вставить("ТекущийОбъект", НовыйДокумент);
	КонтекстВыполнения.Вставить("ТипОбъекта", "Документ");
	КонтекстВыполнения.Вставить("ИмяОбъекта", ИмяДокумента);
	УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, "Документ", ИмяДокумента, НовыйДокумент);
	ДанныеДляУстановки = Новый Структура;
	Если Шаг.Свойство("data") И ТипЗнч(Шаг.data) = Тип("Структура") Тогда
		Для Каждого ПараКлючЗначение Из Шаг.data Цикл
			ДанныеДляУстановки.Вставить(ПараКлючЗначение.Ключ, ПараКлючЗначение.Значение);
		КонецЦикла;
	КонецЕсли;
	Если НЕ ДанныеДляУстановки.Свойство("Дата") Тогда
		ИнформацияОДокументе = ИИА_Метаданные.ПолучитьРеквизитыДокумента(ИмяДокумента);
		Если ИнформацияОДокументе.Найден Тогда
			ЕстьДата = Ложь;
			Для Каждого Реквизит Из ИнформацияОДокументе.Реквизиты Цикл
				Если ТипЗнч(Реквизит) = Тип("Структура") И Реквизит.Свойство("Имя") И ВРег(Реквизит.Имя) = "ДАТА" Тогда
					ЕстьДата = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если ЕстьДата Тогда
				ДанныеДляУстановки.Вставить("Дата", ТекущаяДата());
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ДанныеДляУстановки.Количество() > 0 Тогда
		Для Каждого ПараКлючЗначение Из ДанныеДляУстановки Цикл
			Попытка
				ЗначениеДляУстановки = ПодготовитьЗначениеДляУстановкиРеквизита(КонтекстВыполнения, ПараКлючЗначение.Ключ, ПараКлючЗначение.Значение);
				УстановитьЗначениеРеквизита(НовыйДокумент, ПараКлючЗначение.Ключ, ЗначениеДляУстановки);
				ПроверитьЧтоСсылочныйРеквизитЗаполнен(НовыйДокумент, КонтекстВыполнения, ПараКлючЗначение.Ключ, ЗначениеДляУстановки);
				ДобавитьИзмененноеПоле(КонтекстВыполнения, ПараКлючЗначение.Ключ, ЗначениеДляУстановки);
			Исключение
				Результат.Сообщение = "Ошибка установки поля '" + ПараКлючЗначение.Ключ + "': " + ОписаниеОшибки();
				УстановитьТипизированнуюОшибку(Результат, "field_write_error", "validation", Истина, "run_getobjectfields", Новый Структура("object_name,field", ИмяДокумента, ПараКлючЗначение.Ключ));
				Возврат Результат;
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	Результат.Успех = Истина;
	Результат.Сообщение = "Создан документ '" + ИмяДокумента + "'";
	Результат.Данные = НовыйДокумент.Ссылка;
	КонтекстВыполнения.Вставить("СсылкаОбъекта", НовыйДокумент.Ссылка);
	ИИА_DSLReplay.ДобавитьЗаписьВСайдЭффектЛогИзDSL(КонтекстВыполнения, "draft_created", "CreateDocument", OperationId);
	Возврат Результат;
КонецФункции

Функция ВыполнитьSetField(Шаг, КонтекстВыполнения) Экспорт
	Результат = СоздатьБазовыйРезультатШага("SetField", ИИА_DSLКонтракт.ПолучитьКонтрактДействия("SetField"));
	OperationId = ИИА_DSLReplay.ПолучитьOperationIdШага(Шаг);
	Результат.operation_id = OperationId;
	Если НЕ КонтекстВыполнения.Свойство("ТекущийОбъект") Тогда
		Результат.Сообщение = "Нет текущего объекта для установки поля. Используйте CreateReference, CreateDocument или FindReferenceByName перед SetField";
		УстановитьТипизированнуюОшибку(Результат, "missing_object_context", "validation", Ложь, "select_or_create_object_first", Новый Структура("action", "SetField"));
		Возврат Результат;
	КонецЕсли;
	ТекущийОбъект = КонтекстВыполнения.ТекущийОбъект;
	ТипОбъекта = КонтекстВыполнения.ТипОбъекта;
	ИмяОбъекта = КонтекстВыполнения.ИмяОбъекта;
	Если Шаг.Свойство("field") Тогда
		ИмяПоля = Шаг.field;
	ИначеЕсли Шаг.Свойство("field_name") Тогда
		ИмяПоля = Шаг.field_name;
	Иначе
		Результат.Сообщение = "Поле field или field_name не указано";
		Результат.missing_parameters.Добавить("field");
		УстановитьТипизированнуюОшибку(Результат, "parameter_missing", "validation", Ложь, "provide_field_name", Новый Структура("action", "SetField"));
		Возврат Результат;
	КонецЕсли;
	Если ИмяПоля = "ПометкаНаУдаление" Тогда
		ИмяПоля = "ПометкаУдаления";
	ИначеЕсли ИмяПоля = "Description" Тогда
		ИмяПоля = "Наименование";
	КонецЕсли;
	Если ТипОбъекта = "Справочник" И НЕ ИИА_Метаданные.СуществуетРеквизитСправочника(ИмяОбъекта, ИмяПоля) Тогда
		Результат.Сообщение = "Реквизит '" + ИмяПоля + "' не найден в справочнике '" + ИмяОбъекта + "'";
		Возврат Результат;
	ИначеЕсли ТипОбъекта = "Документ" И НЕ ИИА_Метаданные.СуществуетРеквизитДокумента(ИмяОбъекта, ИмяПоля) Тогда
		Результат.Сообщение = "Реквизит '" + ИмяПоля + "' не найден в документе '" + ИмяОбъекта + "'";
		Возврат Результат;
	КонецЕсли;
	Попытка
		ЗначениеДляУстановки = ПодготовитьЗначениеДляУстановкиРеквизита(КонтекстВыполнения, ИмяПоля, Шаг.value);
		УстановитьЗначениеРеквизита(ТекущийОбъект, ИмяПоля, ЗначениеДляУстановки);
		ПроверитьЧтоСсылочныйРеквизитЗаполнен(ТекущийОбъект, КонтекстВыполнения, ИмяПоля, ЗначениеДляУстановки);
		ДобавитьИзмененноеПоле(КонтекстВыполнения, ИмяПоля, ЗначениеДляУстановки);
	Исключение
		Результат.Сообщение = "Ошибка установки значения поля '" + ИмяПоля + "': " + ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;
	Результат.Успех = Истина;
	Результат.Сообщение = "Установлено значение поля '" + ИмяПоля + "'";
	ИИА_DSLReplay.ДобавитьЗаписьВСайдЭффектЛогИзDSL(КонтекстВыполнения, "field_set", "SetField", OperationId);
	Возврат Результат;
КонецФункции

Функция ВыполнитьWrite(Шаг, КонтекстВыполнения) Экспорт
	Результат = СоздатьБазовыйРезультатШага("Write", ИИА_DSLКонтракт.ПолучитьКонтрактДействия("Write"));
	OperationId = ИИА_DSLReplay.ПолучитьOperationIdШага(Шаг);
	Результат.operation_id = OperationId;
	Если НЕ КонтекстВыполнения.Свойство("ТекущийОбъект") Тогда
		Если НЕ ПустаяСтрока(OperationId)
			И КонтекстВыполнения.Свойство("СсылкаДиалога")
			И ЗначениеЗаполнено(КонтекстВыполнения.СсылкаДиалога) Тогда
			ПоследнийЭффект = ИИА_ReplayPolicy.НайтиПоследнийSideEffectПоOperationId(КонтекстВыполнения.СсылкаДиалога, OperationId);
			Если ИИА_ReplayPolicy.ЭтоКоммитящийSideEffect(ПоследнийЭффект) Тогда
				Результат.Успех = Истина;
				Результат.Сообщение = "Повтор Write пропущен: объект уже был записан ранее для operation_id " + OperationId;
				Результат.Вставить("deduplicated_retry", Истина);
				Результат.next_step_guidance = "Write уже зафиксирован ранее; повторная запись не требуется.";
				Возврат Результат;
			КонецЕсли;
		КонецЕсли;
		Результат.Сообщение = "Нет текущего объекта для записи. Используйте CreateReference, CreateDocument или FindReferenceByName перед Write";
		УстановитьТипизированнуюОшибку(Результат, "missing_object_context", "validation", Ложь, "select_or_create_object_first", Новый Структура("action", "Write"));
		Возврат Результат;
	КонецЕсли;
	Попытка
		КонтекстВыполнения.ТекущийОбъект.Записать();
	Исключение
		Результат.Сообщение = "Ошибка записи объекта: " + ОписаниеОшибки();
		УстановитьТипизированнуюОшибку(Результат, "write_failed", "runtime", Истина, "retry_write_with_same_operation_id", Новый Структура("action", "Write"));
		Возврат Результат;
	КонецПопытки;
	Результат.Успех = Истина;
	Результат.Сообщение = "Объект успешно записан";
	Результат.Данные = КонтекстВыполнения.ТекущийОбъект.Ссылка;
	КонтекстВыполнения.Вставить("СсылкаОбъекта", КонтекстВыполнения.ТекущийОбъект.Ссылка);
	ИИА_DSLReplay.ДобавитьЗаписьВСайдЭффектЛогИзDSL(КонтекстВыполнения, "object_written", "Write", OperationId);
	Возврат Результат;
КонецФункции

#Область СлужебныеПроцедурыИФункции

Процедура УстановитьТипизированнуюОшибку(Результат, КодОшибки, Категория, Retryable, SuggestedAction, Контекст = Неопределено)
	Результат.Вставить("error_code", КодОшибки);
	Результат.Вставить("error_category", Категория);
	Результат.Вставить("retryable", Retryable);
	Результат.Вставить("suggested_action", SuggestedAction);
	Результат.Вставить("recommendation", SuggestedAction);
	Результат.Вставить("error_context", Контекст);
КонецПроцедуры

Функция СоздатьБазовыйРезультатШага(Действие = "", Контракт = Неопределено)
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	Результат.Вставить("error_code", "");
	Результат.Вставить("error_category", "");
	Результат.Вставить("retryable", Ложь);
	Результат.Вставить("suggested_action", "");
	Результат.Вставить("recommendation", "");
	Результат.Вставить("error_context", Неопределено);
	Результат.Вставить("missing_parameters", Новый Массив);
	Результат.Вставить("partial_failure", Ложь);
	Результат.Вставить("next_step_guidance", "");
	Результат.Вставить("operation_id", "");
	Результат.Вставить("idempotent", Ложь);
	Результат.Вставить("supports_safe_retries", Истина);
	Результат.Вставить("retry_strategy", "retry_same_call");
	Результат.Вставить("requires_write", Ложь);
	Результат.Вставить("action", Действие);
	Если Контракт <> Неопределено Тогда
		Если Контракт.Свойство("idempotent") Тогда
			Результат.idempotent = Контракт.idempotent;
		КонецЕсли;
		Если Контракт.Свойство("requires_write") Тогда
			Результат.requires_write = Контракт.requires_write;
		КонецЕсли;
		Если Контракт.Свойство("supports_safe_retries") Тогда
			Результат.supports_safe_retries = Контракт.supports_safe_retries;
		КонецЕсли;
		Если Контракт.Свойство("retry_strategy") Тогда
			Результат.retry_strategy = Контракт.retry_strategy;
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Процедура УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, ТипОбъекта, ИмяОбъекта, ТекущийОбъект, ЭтоНовый = Неопределено)
	КонтекстВыполнения.Вставить("DSL_ТипОбъекта", ТипОбъекта);
	КонтекстВыполнения.Вставить("DSL_ИмяОбъекта", ИмяОбъекта);
	КонтекстВыполнения.Вставить("DSL_ТекущийОбъект", ТекущийОбъект);
	КонтекстВыполнения.Вставить("DSL_ИзмененныеПоля", Новый Структура);
	Если ЭтоНовый = Неопределено Тогда
		Попытка
			ЭтоНовый = НЕ ЗначениеЗаполнено(ТекущийОбъект.Ссылка);
		Исключение
			ЭтоНовый = Истина;
		КонецПопытки;
	КонецЕсли;
	КонтекстВыполнения.Вставить("DSL_НовыйОбъект", ЭтоНовый);
КонецПроцедуры

Процедура ДобавитьИзмененноеПоле(КонтекстВыполнения, ИмяПоля, Значение)
	Если НЕ КонтекстВыполнения.Свойство("DSL_ИзмененныеПоля") Тогда
		КонтекстВыполнения.Вставить("DSL_ИзмененныеПоля", Новый Структура);
	КонецЕсли;
	КонтекстВыполнения.DSL_ИзмененныеПоля.Вставить(ИмяПоля, Значение);
КонецПроцедуры

Функция ПодготовитьЗначениеДляУстановкиРеквизита(КонтекстВыполнения, ИмяРеквизита, Значение)
	Если ТипЗнч(Значение) = Тип("Структура") Тогда
		СсылкаИзСтруктуры = ИзвлечьСсылкуИзЗначенияРезультата(Значение);
		Если СсылкаИзСтруктуры <> Неопределено Тогда
			Возврат СсылкаИзСтруктуры;
		КонецЕсли;
		Возврат Значение;
	КонецЕсли;
	Если ТипЗнч(Значение) <> Тип("Строка") Тогда
		Возврат Значение;
	КонецЕсли;
	ТекстЗначения = СокрЛП(Значение);
	Если ПустаяСтрока(ТекстЗначения) Тогда
		Возврат Значение;
	КонецЕсли;
	Если Лев(ВРег(ТекстЗначения), 5) = "STEP_" Тогда
		РазрешенноеЗначение = РазрешитьЗначениеИзРезультатаШагаПланаДляWrite(КонтекстВыполнения, ТекстЗначения);
		Если РазрешенноеЗначение <> Неопределено Тогда
			СсылкаИзРезультатаШага = ИзвлечьСсылкуИзЗначенияРезультата(РазрешенноеЗначение);
			Если СсылкаИзРезультатаШага <> Неопределено Тогда
				Возврат СсылкаИзРезультатаШага;
			КонецЕсли;
			Если ТипЗнч(РазрешенноеЗначение) <> Тип("Строка") Тогда
				Возврат РазрешенноеЗначение;
			КонецЕсли;
			ТекстЗначения = СокрЛП(Строка(РазрешенноеЗначение));
		КонецЕсли;
	КонецЕсли;
	Если Лев(ВРег(ТекстЗначения), 5) = "STEP_" Тогда
		ВызватьИсключение "Не удалось разрешить ссылку на результат шага плана: " + ТекстЗначения;
	КонецЕсли;
	Если НЕ КонтекстВыполнения.Свойство("ТипОбъекта") ИЛИ НЕ КонтекстВыполнения.Свойство("ИмяОбъекта") Тогда
		Возврат Значение;
	КонецЕсли;
	ТипРеквизита = ПолучитьТипРеквизитаОбъекта(КонтекстВыполнения.ТипОбъекта, КонтекстВыполнения.ИмяОбъекта, ИмяРеквизита);
	Если ПустаяСтрока(ТипРеквизита) Тогда
		Возврат Значение;
	КонецЕсли;
	Если Лев(ВРег(ТипРеквизита), 17) = "СПРАВОЧНИКССЫЛКА." Тогда
		ИмяСправочника = Сред(ТипРеквизита, 18);
		НайденнаяСсылка = НайтиСсылкуСправочникаПоСтроке(ИмяСправочника, ТекстЗначения);
		Если НайденнаяСсылка = Неопределено Тогда
			ВызватьИсключение "Не найден элемент справочника '" + ИмяСправочника + "' по значению '" + ТекстЗначения + "'";
		КонецЕсли;
		Возврат НайденнаяСсылка;
	ИначеЕсли Лев(ВРег(ТипРеквизита), 14) = "ДОКУМЕНТССЫЛКА." Тогда
		ИмяДокумента = Сред(ТипРеквизита, 15);
		НайденнаяСсылка = НайтиСсылкуДокументаПоНомеру(ИмяДокумента, ТекстЗначения);
		Если НайденнаяСсылка = Неопределено Тогда
			ВызватьИсключение "Не найден документ '" + ИмяДокумента + "' по номеру '" + ТекстЗначения + "'";
		КонецЕсли;
		Возврат НайденнаяСсылка;
	КонецЕсли;
	ИмяСправочника = РазрешитьИмяОбъектаСсылочногоТипа(ТипРеквизита, "Справочник");
	Если НЕ ПустаяСтрока(ИмяСправочника) И Метаданные.Справочники.Найти(ИмяСправочника) <> Неопределено Тогда
		НайденнаяСсылка = НайтиСсылкуСправочникаПоСтроке(ИмяСправочника, ТекстЗначения);
		Если НайденнаяСсылка = Неопределено Тогда
			ВызватьИсключение "Не найден элемент справочника '" + ИмяСправочника + "' по значению '" + ТекстЗначения + "'";
		КонецЕсли;
		Возврат НайденнаяСсылка;
	КонецЕсли;
	ИмяДокумента = РазрешитьИмяОбъектаСсылочногоТипа(ТипРеквизита, "Документ");
	Если НЕ ПустаяСтрока(ИмяДокумента) И Метаданные.Документы.Найти(ИмяДокумента) <> Неопределено Тогда
		НайденнаяСсылка = НайтиСсылкуДокументаПоНомеру(ИмяДокумента, ТекстЗначения);
		Если НайденнаяСсылка = Неопределено Тогда
			ВызватьИсключение "Не найден документ '" + ИмяДокумента + "' по номеру '" + ТекстЗначения + "'";
		КонецЕсли;
		Возврат НайденнаяСсылка;
	КонецЕсли;
	Возврат Значение;
КонецФункции

Функция РазрешитьЗначениеИзРезультатаШагаПланаДляWrite(КонтекстВыполнения, ИсходноеЗначение)
	Если ТипЗнч(ИсходноеЗначение) <> Тип("Строка") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если НЕ КонтекстВыполнения.Свойство("СсылкаДиалога") ИЛИ НЕ ЗначениеЗаполнено(КонтекстВыполнения.СсылкаДиалога) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Выражение = СокрЛП(ИсходноеЗначение);
	Если ПустаяСтрока(Выражение) Тогда
		Возврат Неопределено;
	КонецЕсли;
	ВыражениеВРег = ВРег(Выражение);
	Если Лев(ВыражениеВРег, 5) <> "STEP_" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПозТочки = СтрНайти(Выражение, ".");
	Если ПозТочки = 0 Тогда
		StepId = Выражение;
		Хвост = "";
	Иначе
		StepId = Лев(Выражение, ПозТочки - 1);
		Хвост = Сред(Выражение, ПозТочки + 1);
	КонецЕсли;
	
	ИмяПоля = "";
	ХвостВРег = ВРег(Хвост);
	Если ПустаяСтрока(Хвост) Или ХвостВРег = "RESULT" Тогда
		ИмяПоля = "";
	ИначеЕсли Лев(ХвостВРег, 9) = "RESULT[0]" Тогда
		ПозПоля = СтрНайти(Хвост, "].");
		Если ПозПоля > 0 Тогда
			ИмяПоля = Сред(Хвост, ПозПоля + 2);
		КонецЕсли;
	ИначеЕсли Лев(ХвостВРег, 7) = "RESULT." Тогда
		ИмяПоля = Сред(Хвост, 8);
	Иначе
		ИмяПоля = Хвост;
	КонецЕсли;
	
	ШагПлана = ИИА_TypedPlan.ПолучитьШагПланаПоИдентификатору(КонтекстВыполнения.СсылкаДиалога, StepId);
	Если ШагПлана = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	РезультатШага = ПолучитьСвойствоПланаЛокально(ШагПлана, "result_data", Неопределено);
	Если РезультатШага = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Данные = ИзвлечьДанныеИзРезультатаШагаПланаДляWrite(РезультатШага);
	ПерваяСтрока = ПолучитьПервыйЭлементМассиваЛокально(Данные);
	Если ПерваяСтрока = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если ПустаяСтрока(ИмяПоля) Тогда
		СсылкаЗначение = ИзвлечьСсылкуИзЗначенияРезультата(ПерваяСтрока);
		Если СсылкаЗначение <> Неопределено Тогда
			Возврат СсылкаЗначение;
		КонецЕсли;
		Возврат ПерваяСтрока;
	КонецЕсли;
	Возврат ПолучитьСвойствоПланаЛокально(ПерваяСтрока, ИмяПоля, Неопределено);
КонецФункции

Функция ИзвлечьСсылкуИзЗначенияРезультата(Значение)
	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Структура") Тогда
		Если Значение.Свойство("Ссылка") Тогда
			Возврат Значение.Ссылка;
		КонецЕсли;
		Если Значение.Свойство("guid") И ЗначениеЗаполнено(Значение.guid) Тогда
			СсылкаПоУИД = НайтиСсылкуПоУИДЛокально(Строка(Значение.guid));
			Если СсылкаПоУИД <> Неопределено Тогда
				Возврат СсылкаПоУИД;
			КонецЕсли;
		КонецЕсли;
		Для Каждого Пара Из Значение Цикл
			Кандидат = ИзвлечьСсылкуИзЗначенияРезультата(Пара.Значение);
			Если Кандидат <> Неопределено Тогда
				Возврат Кандидат;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ТипЗначения = Тип("Массив") Тогда
		Для Каждого Элемент Из Значение Цикл
			Кандидат = ИзвлечьСсылкуИзЗначенияРезультата(Элемент);
			Если Кандидат <> Неопределено Тогда
				Возврат Кандидат;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ТипЗначения <> Тип("Строка")
		И ТипЗначения <> Тип("Число")
		И ТипЗначения <> Тип("Булево")
		И ТипЗначения <> Тип("Дата") Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция ИзвлечьДанныеИзРезультатаШагаПланаДляWrite(РезультатШага)
	RunQueryДанные = ПолучитьСвойствоПланаЛокально(РезультатШага, "run_query", Неопределено);
	Если ТипЗнч(RunQueryДанные) = Тип("Массив") И RunQueryДанные.Количество() > 0 Тогда
		ПервыйRunQuery = RunQueryДанные[0];
		Если ПервыйRunQuery <> Неопределено Тогда
			Данные = ПолучитьСвойствоПланаЛокально(ПервыйRunQuery, "rows", Неопределено);
			Если Данные <> Неопределено Тогда
				Возврат Данные;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Результаты = ПолучитьСвойствоПланаЛокально(РезультатШага, "Результаты", Неопределено);
	Если ТипЗнч(Результаты) = Тип("Массив") Тогда
		Для Каждого ЭлементРезультата Из Результаты Цикл
			Если ЭлементРезультата = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ДанныеЭлемента = ПолучитьСвойствоПланаЛокально(ЭлементРезультата, "Данные", Неопределено);
			Если ДанныеЭлемента = Неопределено Тогда
				ДанныеЭлемента = ПолучитьСвойствоПланаЛокально(ЭлементРезультата, "data", Неопределено);
			КонецЕсли;
			Если ДанныеЭлемента = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ДанныеЗапроса = ПолучитьСвойствоПланаЛокально(ДанныеЭлемента, "ДанныеЗапроса", Неопределено);
			Если ДанныеЗапроса = Неопределено Тогда
				ДанныеЗапроса = ПолучитьСвойствоПланаЛокально(ДанныеЭлемента, "ДанныеЗапросаДляТаблицы", Неопределено);
			КонецЕсли;
			Если ДанныеЗапроса = Неопределено Тогда
				ДанныеЗапроса = ПолучитьСвойствоПланаЛокально(ДанныеЭлемента, "rows", Неопределено);
			КонецЕсли;
			Если ДанныеЗапроса <> Неопределено Тогда
				Возврат ДанныеЗапроса;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция ПолучитьПервыйЭлементМассиваЛокально(Данные)
	Если Данные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если ТипЗнч(Данные) = Тип("Массив") Тогда
		Если Данные.Количество() = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;
		Возврат Данные[0];
	КонецЕсли;
	Возврат Данные;
КонецФункции

Функция ПолучитьСвойствоПланаЛокально(Значение, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
	Если ТипЗнч(Значение) = Тип("Структура") Или ТипЗнч(Значение) = Тип("ФиксированнаяСтруктура") Тогда
		Если Значение.Свойство(ИмяСвойства) Тогда
			Возврат Значение[ИмяСвойства];
		КонецЕсли;
	ИначеЕсли ТипЗнч(Значение) = Тип("Соответствие") Или ТипЗнч(Значение) = Тип("ФиксированноеСоответствие") Тогда
		ЛокЗначение = Значение.Получить(ИмяСвойства);
		Если ЛокЗначение <> Неопределено Тогда
			Возврат ЛокЗначение;
		КонецЕсли;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция НайтиСсылкуПоУИДЛокально(знач УИД)
	Если ПустаяСтрока(СокрЛП(Строка(УИД))) Тогда
		Возврат Неопределено;
	КонецЕсли;
	МассивМетаданных = Новый Массив;
	МассивМетаданных.Добавить(Справочники);
	МассивМетаданных.Добавить(Документы);
	МассивМетаданных.Добавить(ПланыВидовХарактеристик);
	МассивТипов = Новый Массив;
	Для Каждого СтрМетаданные Из МассивМетаданных Цикл
		Для Каждого Стр Из СтрМетаданные.ТипВсеСсылки().Типы() Цикл
			МассивТипов.Добавить(Стр);
		КонецЦикла;
	КонецЦикла;
	ТаблицаСсылок = Новый ТаблицаЗначений;
	ТаблицаСсылок.Колонки.Добавить("УИД", Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(36)));
	ТаблицаСсылок.Колонки.Добавить("Ссылка", Новый ОписаниеТипов(МассивТипов));
	Для Каждого СтрМетаданные Из МассивМетаданных Цикл
		Для Каждого Менеджер Из СтрМетаданные Цикл
			Попытка
				НовСтр = ТаблицаСсылок.Добавить();
				НовСтр.Ссылка = Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка(УИД)));
				НовСтр.УИД = Строка(УИД);
			Исключение
			КонецПопытки;
		КонецЦикла;
	КонецЦикла;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|   ТаблицаСсылок.Ссылка КАК Ссылка,
		|   ТаблицаСсылок.УИД КАК УИД
		|ИЗ
		|   &ТаблицаСсылок КАК ТаблицаСсылок
		|ГДЕ
		|   НЕ ТаблицаСсылок.Ссылка.ПометкаУдаления ЕСТЬ NULL";
	Запрос.УстановитьПараметр("ТаблицаСсылок", ТаблицаСсылок);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Ссылка;
КонецФункции

Функция ПолучитьТипРеквизитаОбъекта(ТипОбъекта, ИмяОбъекта, ИмяРеквизита)
	Если ТипОбъекта = "Справочник" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыСправочника(ИмяОбъекта);
	ИначеЕсли ТипОбъекта = "Документ" Тогда
		ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыДокумента(ИмяОбъекта);
	Иначе
		Возврат "";
	КонецЕсли;
	Если ИнформацияОбОбъекте = Неопределено ИЛИ НЕ ИнформацияОбОбъекте.Найден Тогда
		Возврат "";
	КонецЕсли;
	Для Каждого Реквизит Из ИнформацияОбОбъекте.Реквизиты Цикл
		Если ТипЗнч(Реквизит) = Тип("Структура")
			И Реквизит.Свойство("Имя")
			И ВРег(Строка(Реквизит.Имя)) = ВРег(ИмяРеквизита) Тогда
			Возврат Строка(?(Реквизит.Свойство("Тип"), Реквизит.Тип, ""));
		КонецЕсли;
	КонецЦикла;
	Возврат "";
КонецФункции

Функция РазрешитьИмяОбъектаСсылочногоТипа(ПодсказкаТипа, ОжидаемыйТип)
	Если ПустаяСтрока(ПодсказкаТипа) Тогда
		Возврат "";
	КонецЕсли;
	ИмяОбъекта = ИИА_DSLQuerySafety.НормализоватьИмяОбъектаМетаданных(ПодсказкаТипа, ОжидаемыйТип);
	Если ОжидаемыйТип = "Справочник" И НЕ ПустаяСтрока(ИмяОбъекта) И Метаданные.Справочники.Найти(ИмяОбъекта) <> Неопределено Тогда
		Возврат ИмяОбъекта;
	ИначеЕсли ОжидаемыйТип = "Документ" И НЕ ПустаяСтрока(ИмяОбъекта) И Метаданные.Документы.Найти(ИмяОбъекта) <> Неопределено Тогда
		Возврат ИмяОбъекта;
	КонецЕсли;
	Возврат НайтиИмяОбъектаМетаданныхПоПодсказке(ПодсказкаТипа, ОжидаемыйТип);
КонецФункции

Функция НайтиИмяОбъектаМетаданныхПоПодсказке(ПодсказкаТипа, ОжидаемыйТип)
	НормПодсказка = НормализоватьСтрокуСопоставления(ПодсказкаТипа);
	Если ПустаяСтрока(НормПодсказка) Тогда
		Возврат "";
	КонецЕсли;
	ОсноваПодсказки = НормализоватьОсновуСтрокиСопоставления(НормПодсказка);
	ЛучшееИмя = "";
	Если ОжидаемыйТип = "Справочник" Тогда
		КоллекцияМетаданных = Метаданные.Справочники;
	ИначеЕсли ОжидаемыйТип = "Документ" Тогда
		КоллекцияМетаданных = Метаданные.Документы;
	Иначе
		Возврат "";
	КонецЕсли;
	Для Каждого ЭлементМетаданных Из КоллекцияМетаданных Цикл
		НормИмя = НормализоватьСтрокуСопоставления(ЭлементМетаданных.Имя);
		НормСиноним = НормализоватьСтрокуСопоставления(ЭлементМетаданных.Синоним);
		ОсноваИмени = НормализоватьОсновуСтрокиСопоставления(НормИмя);
		ОсноваСинонима = НормализоватьОсновуСтрокиСопоставления(НормСиноним);
		Если НормПодсказка = НормИмя ИЛИ НормПодсказка = НормСиноним Тогда
			Возврат ЭлементМетаданных.Имя;
		КонецЕсли;
		Если НЕ ПустаяСтрока(ОсноваПодсказки) И (ОсноваПодсказки = ОсноваИмени ИЛИ ОсноваПодсказки = ОсноваСинонима) Тогда
			Возврат ЭлементМетаданных.Имя;
		КонецЕсли;
		Если ПустаяСтрока(ЛучшееИмя) Тогда
			Если НЕ ПустаяСтрока(НормСиноним) И (СтрНайти(НормСиноним, НормПодсказка) > 0 ИЛИ СтрНайти(НормПодсказка, НормСиноним) > 0) Тогда
				ЛучшееИмя = ЭлементМетаданных.Имя;
			ИначеЕсли НЕ ПустаяСтрока(НормИмя) И (СтрНайти(НормИмя, НормПодсказка) > 0 ИЛИ СтрНайти(НормПодсказка, НормИмя) > 0) Тогда
				ЛучшееИмя = ЭлементМетаданных.Имя;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат ЛучшееИмя;
КонецФункции

Функция НормализоватьСтрокуСопоставления(Значение)
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Результат = ВРег(СокрЛП(Строка(Значение)));
	СимволыДляУдаления = Новый Массив;
	СимволыДляУдаления.Добавить(" ");
	СимволыДляУдаления.Добавить(".");
	СимволыДляУдаления.Добавить(",");
	СимволыДляУдаления.Добавить(";");
	СимволыДляУдаления.Добавить(":");
	СимволыДляУдаления.Добавить("-");
	СимволыДляУдаления.Добавить("_");
	СимволыДляУдаления.Добавить("'");
	СимволыДляУдаления.Добавить("""");
	СимволыДляУдаления.Добавить("(");
	СимволыДляУдаления.Добавить(")");
	СимволыДляУдаления.Добавить("[");
	СимволыДляУдаления.Добавить("]");
	СимволыДляУдаления.Добавить("{");
	СимволыДляУдаления.Добавить("}");
	СимволыДляУдаления.Добавить("/");
	СимволыДляУдаления.Добавить("\");
	СимволыДляУдаления.Добавить("«");
	СимволыДляУдаления.Добавить("»");
	Для Каждого Символ Из СимволыДляУдаления Цикл
		Результат = СтрЗаменить(Результат, Символ, "");
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция НормализоватьОсновуСтрокиСопоставления(Значение)
	Результат = НормализоватьСтрокуСопоставления(Значение);
	Если СтрДлина(Результат) > 4 Тогда
		Окончания = Новый Массив;
		Окончания.Добавить("ами");
		Окончания.Добавить("ями");
		Окончания.Добавить("ов");
		Окончания.Добавить("ев");
		Окончания.Добавить("ом");
		Окончания.Добавить("ем");
		Окончания.Добавить("ой");
		Окончания.Добавить("ий");
		Окончания.Добавить("ый");
		Окончания.Добавить("ая");
		Окончания.Добавить("яя");
		Окончания.Добавить("ы");
		Окончания.Добавить("и");
		Окончания.Добавить("а");
		Окончания.Добавить("я");
		Окончания.Добавить("ь");
		Для Каждого Окончание Из Окончания Цикл
			Если Прав(Результат, СтрДлина(Окончание)) = Окончание Тогда
				Результат = Лев(Результат, СтрДлина(Результат) - СтрДлина(Окончание));
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ЭтоСсылочныйТипРеквизита(ТипРеквизита)
	Если ПустаяСтрока(ТипРеквизита) Тогда
		Возврат Ложь;
	КонецЕсли;
	ТипВРег = ВРег(ТипРеквизита);
	Если Лев(ТипВРег, 17) = "СПРАВОЧНИКССЫЛКА." ИЛИ Лев(ТипВРег, 14) = "ДОКУМЕНТССЫЛКА." Тогда
		Возврат Истина;
	КонецЕсли;
	Возврат НЕ ПустаяСтрока(РазрешитьИмяОбъектаСсылочногоТипа(ТипРеквизита, "Справочник"))
		ИЛИ НЕ ПустаяСтрока(РазрешитьИмяОбъектаСсылочногоТипа(ТипРеквизита, "Документ"));
КонецФункции

Процедура ПроверитьЧтоСсылочныйРеквизитЗаполнен(Объект, КонтекстВыполнения, ИмяРеквизита, ЗначениеДляУстановки)
	Если НЕ КонтекстВыполнения.Свойство("ТипОбъекта") ИЛИ НЕ КонтекстВыполнения.Свойство("ИмяОбъекта") Тогда
		Возврат;
	КонецЕсли;
	ТипРеквизита = ПолучитьТипРеквизитаОбъекта(КонтекстВыполнения.ТипОбъекта, КонтекстВыполнения.ИмяОбъекта, ИмяРеквизита);
	Если НЕ ЭтоСсылочныйТипРеквизита(ТипРеквизита) Тогда
		Возврат;
	КонецЕсли;
	УстановленноеЗначение = Объект[ИмяРеквизита];
	Если НЕ ЗначениеЗаполнено(УстановленноеЗначение) Тогда
		ВызватьИсключение "Ссылочный реквизит '" + ИмяРеквизита + "' не был заполнен значением '" + Строка(ЗначениеДляУстановки) + "'";
	КонецЕсли;
КонецПроцедуры

Функция НайтиСсылкуСправочникаПоСтроке(ИмяСправочника, ЗначениеПоиска)
	Если ПустаяСтрока(ИмяСправочника) Или ПустаяСтрока(ЗначениеПоиска) Тогда
		Возврат Неопределено;
	КонецЕсли;
	ПоляПоиска = ПолучитьПоляПоискаСправочникаПоСтроке(ИмяСправочника);
	Если ПоляПоиска.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	Условия = Новый Массив;
	Для Каждого ИмяПоля Из ПоляПоиска Цикл
		Если НЕ ЭтоКорректныйИдентификатор1С(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		Условия.Добавить(ИмяПоля + " = &Значение");
	КонецЦикла;
	Если Условия.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ссылка
	|ИЗ
	|	Справочник." + ИмяСправочника + "
	|ГДЕ
	|	" + СтрСоединить(Условия, Символы.ПС + "	ИЛИ ");
	Запрос.УстановитьПараметр("Значение", ЗначениеПоиска);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Ссылка;
КонецФункции

Функция ПолучитьПоляПоискаСправочникаПоСтроке(ИмяСправочника)
	Результат = Новый Массив;
	Информация = ИИА_Метаданные.ПолучитьРеквизитыСправочника(ИмяСправочника);
	Если Информация = Неопределено ИЛИ ТипЗнч(Информация) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	Реквизиты = Неопределено;
	Если Информация.Свойство("Реквизиты") Тогда
		Реквизиты = Информация.Реквизиты;
	КонецЕсли;
	Если ТипЗнч(Реквизиты) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	Для Каждого Реквизит Из Реквизиты Цикл
		Если ТипЗнч(Реквизит) <> Тип("Структура") И ТипЗнч(Реквизит) <> Тип("ФиксированнаяСтруктура") Тогда
			Продолжить;
		КонецЕсли;
		ИмяПоля = "";
		Если Реквизит.Свойство("Имя") Тогда
			ИмяПоля = СокрЛП(Строка(Реквизит.Имя));
		КонецЕсли;
		Если ПустаяСтрока(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ ЭтоКорректныйИдентификатор1С(ИмяПоля) Тогда
			Продолжить;
		КонецЕсли;
		ИмяПоляВРег = ВРег(ИмяПоля);
		Если ИмяПоляВРег = "НАИМЕНОВАНИЕПОЛНОЕ" ИЛИ ИмяПоляВРег = "ПОЛНОЕНАИМЕНОВАНИЕ" Тогда
			Продолжить;
		КонецЕсли;
		Если ИмяПоляВРег = "КОД"
			ИЛИ ИмяПоляВРег = "НАИМЕНОВАНИЕ"
			ИЛИ ИмяПоляВРег = "DESCRIPTION"
			ИЛИ СтрНайти(ИмяПоляВРег, "НАИМЕНОВАН") > 0 Тогда
			Если Результат.Найти(ИмяПоля) = Неопределено Тогда
				Результат.Добавить(ИмяПоля);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Если Результат.Найти("Код") = Неопределено Тогда
		Результат.Добавить("Код");
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ЭтоКорректныйИдентификатор1С(ИмяПоля)
	ИмяПоля = СокрЛП(Строка(ИмяПоля));
	Если ПустаяСтрока(ИмяПоля) Тогда
		Возврат Ложь;
	КонецЕсли;
	Для Позиция = 1 По СтрДлина(ИмяПоля) Цикл
		Символ = Сред(ИмяПоля, Позиция, 1);
		КодСимвола = КодСимвола(Символ);
		ЭтоЛатиница = (КодСимвола >= 65 И КодСимвола <= 90) ИЛИ (КодСимвола >= 97 И КодСимвола <= 122);
		ЭтоКириллица = (КодСимвола >= 1040 И КодСимвола <= 1103) ИЛИ КодСимвола = 1025 ИЛИ КодСимвола = 1105;
		ЭтоЦифра = КодСимвола >= 48 И КодСимвола <= 57;
		Если НЕ (ЭтоЛатиница ИЛИ ЭтоКириллица ИЛИ ЭтоЦифра ИЛИ Символ = "_") Тогда
			Возврат Ложь;
		КонецЕсли;
		Если Позиция = 1 И ЭтоЦифра Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат Истина;
КонецФункции

Функция НайтиСсылкуДокументаПоНомеру(ИмяДокумента, НомерДокумента)
	Если ПустаяСтрока(ИмяДокумента) Или ПустаяСтрока(НомерДокумента) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Документы.Ссылка
	|ИЗ
	|	Документ." + ИмяДокумента + " КАК Документы
	|ГДЕ
	|	Документы.Номер = &Номер";
	Запрос.УстановитьПараметр("Номер", НомерДокумента);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Ссылка;
КонецФункции

Процедура УстановитьЗначениеРеквизита(Объект, ИмяРеквизита, Значение)
	ТипОбъекта = ТипЗнч(Объект);
	СтрокаТипа = Строка(ТипОбъекта);
	Если СтрНайти(СтрокаТипа, "Справочник объект") > 0 ИЛИ СтрНайти(СтрокаТипа, "Документ объект") > 0 Тогда
		Объект[ИмяРеквизита] = Значение;
	Иначе
		ВызватьИсключение "Неподдерживаемый тип объекта для установки реквизита: " + СтрокаТипа;
	КонецЕсли;
КонецПроцедуры

