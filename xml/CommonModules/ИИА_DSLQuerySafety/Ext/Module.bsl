#Область ПрограммныйИнтерфейс

Функция ИзвлечьПоляИзТекстаЗапроса(ТекстЗапроса) Экспорт
	Результат = Новый Массив;
	Если ПустаяСтрока(ТекстЗапроса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПутиПолей = ИзвлечьПутиПолейИзТекстаЗапроса(ТекстЗапроса);
	Для Каждого ПутьПоля Из ПутиПолей Цикл
		ПоследнееПоле = Строка(ПутьПоля);
		ПозицияТочки = СтрНайти(ПоследнееПоле, ".");
		Пока ПозицияТочки > 0 Цикл
			ПоследнееПоле = Сред(ПоследнееПоле, ПозицияТочки + 1);
			ПозицияТочки = СтрНайти(ПоследнееПоле, ".");
		КонецЦикла;
		ПоследнееПоле = СокрЛП(ПоследнееПоле);
		Если НЕ ПустаяСтрока(ПоследнееПоле) И Результат.Найти(ПоследнееПоле) = Неопределено Тогда
			Результат.Добавить(ПоследнееПоле);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ИзвлечьПутиПолейИзТекстаЗапроса(ТекстЗапроса) Экспорт
	Результат = Новый Массив;
	Если ПустаяСтрока(ТекстЗапроса) Тогда
		Возврат Результат;
	КонецЕсли;
	
	НормТекст = ТекстЗапроса;
	НормТекст = СтрЗаменить(НормТекст, Символы.ПС, " ");
	НормТекст = СтрЗаменить(НормТекст, Символы.ВК, " ");
	НормТекст = СтрЗаменить(НормТекст, ",", " ");
	НормТекст = СтрЗаменить(НормТекст, ";", " ");
	НормТекст = СтрЗаменить(НормТекст, "(", " ");
	НормТекст = СтрЗаменить(НормТекст, ")", " ");
	НормТекст = СтрЗаменить(НормТекст, """", " ");
	НормТекст = СтрЗаменить(НормТекст, "'", " ");
	Части = СтрРазделить(НормТекст, " ", Ложь);
	
	Для Каждого Часть Из Части Цикл
		Токен = СокрЛП(Часть);
		Если ПустаяСтрока(Токен) Тогда
			Продолжить;
		КонецЕсли;
		Если СтрНайти(Токен, ".") = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Сегменты = СтрРазделить(Токен, ".", Ложь);
		Если Сегменты.Количество() = 2 Тогда
			Префикс = ВРег(СокрЛП(Сегменты[0]));
			Если Префикс = "ДОКУМЕНТ" ИЛИ Префикс = "СПРАВОЧНИК" ИЛИ Префикс = "РЕГИСТРНАКОПЛЕНИЯ" ИЛИ Префикс = "РЕГИСТРСВЕДЕНИЙ" Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		НормПуть = Токен;
		Если Сегменты.Количество() > 2 Тогда
			НормПуть = "";
			Для ИндексСегмента = 1 По Сегменты.Количество() - 1 Цикл
				Если ПустаяСтрока(НормПуть) Тогда
					НормПуть = Сегменты[ИндексСегмента];
				Иначе
					НормПуть = НормПуть + "." + Сегменты[ИндексСегмента];
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		НормПуть = СокрЛП(НормПуть);
		Если НЕ ПустаяСтрока(НормПуть) И Результат.Найти(НормПуть) = Неопределено Тогда
			Результат.Добавить(НормПуть);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ПроверитьQuerySafetyGate(ТекстЗапроса, КонтекстВыполнения) Экспорт
	Результат = Новый Структура("Успех,КодОшибки,Сообщение,Контекст", Истина, "", "", Неопределено);
	
	Если ПустаяСтрока(ТекстЗапроса) Тогда
		Результат.Успех = Ложь;
		Результат.КодОшибки = "query_safety_violation";
		Результат.Сообщение = "Пустой текст запроса";
		Результат.Контекст = Новый Структура("reason", "empty_query");
		Возврат Результат;
	КонецЕсли;
	
	Если СтрДлина(ТекстЗапроса) > 5000 Тогда
		Результат.Успех = Ложь;
		Результат.КодОшибки = "query_safety_violation";
		Результат.Сообщение = "Запрос слишком длинный, превышает лимит безопасности.";
		Результат.Контекст = Новый Структура("reason,limit", "query_too_long", 5000);
		Возврат Результат;
	КонецЕсли;
	
	Если КонтекстВыполнения.Свойство("DSL_РазрешенныеПоляОбъекта") И ТипЗнч(КонтекстВыполнения.DSL_РазрешенныеПоляОбъекта) = Тип("Массив") Тогда
		Разрешенные = КонтекстВыполнения.DSL_РазрешенныеПоляОбъекта;
		Если Разрешенные.Количество() > 0 Тогда
			ПоляЗапроса = ИзвлечьПоляИзТекстаЗапроса(ТекстЗапроса);
			ПутиЗапроса = ИзвлечьПутиПолейИзТекстаЗапроса(ТекстЗапроса);
			РазрешенныеПути = Новый Массив;
			Если КонтекстВыполнения.Свойство("DSL_РазрешенныеПутиПолейОбъекта")
				И ТипЗнч(КонтекстВыполнения.DSL_РазрешенныеПутиПолейОбъекта) = Тип("Массив") Тогда
				РазрешенныеПути = КонтекстВыполнения.DSL_РазрешенныеПутиПолейОбъекта;
			КонецЕсли;
			
			Неизвестные = Новый Массив;
			Для Каждого ПолеЗапроса Из ПоляЗапроса Цикл
				Найдено = Ложь;
				Для Каждого ПолеРазрешенное Из Разрешенные Цикл
					Если ВРег(Строка(ПолеРазрешенное)) = ВРег(Строка(ПолеЗапроса)) Тогда
						Найдено = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Если НЕ Найдено Тогда
					Для Каждого ПутьЗапросаИзПоля Из ПутиЗапроса Цикл
						ДлинаПоля = СтрДлина(Строка(ПолеЗапроса));
						ПутьВРег = ВРег(Строка(ПутьЗапросаИзПоля));
						ПолеВРег = ВРег(Строка(ПолеЗапроса));
						Если СтрДлина(ПутьВРег) <= ДлинаПоля + 1 Тогда
							Продолжить;
						КонецЕсли;
						Если Прав(ПутьВРег, ДлинаПоля + 1) <> "." + ПолеВРег Тогда
							Продолжить;
						КонецЕсли;
						Для Каждого ПутьРазрешенный Из РазрешенныеПути Цикл
							Если ВРег(Строка(ПутьРазрешенный)) = ПутьВРег Тогда
								Найдено = Истина;
								Прервать;
							КонецЕсли;
						КонецЦикла;
						Если Найдено Тогда
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				Если НЕ Найдено И ВРег(Строка(ПолеЗапроса)) = "НАИМЕНОВАНИЕ" Тогда
					Для Каждого ПутьЗапросаИзПоля Из ПутиЗапроса Цикл
						Если ПолучитьПоследнийСегментПути(ПутьЗапросаИзПоля) <> "Наименование" Тогда
							Продолжить;
						КонецЕсли;
						БазовоеПолеПути = ПолучитьПервыйСегментПути(ПутьЗапросаИзПоля);
						Для Каждого ПолеРазрешенное Из Разрешенные Цикл
							Если ВРег(Строка(ПолеРазрешенное)) = ВРег(БазовоеПолеПути) Тогда
								Найдено = Истина;
								Прервать;
							КонецЕсли;
						КонецЦикла;
						Если Найдено Тогда
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				Если НЕ Найдено Тогда
					Неизвестные.Добавить(ПолеЗапроса);
				КонецЕсли;
			КонецЦикла;
			
			Для Каждого ПутьЗапроса Из ПутиЗапроса Цикл
				Если СтрНайти(Строка(ПутьЗапроса), ".") = 0 Тогда
					Продолжить;
				КонецЕсли;
				НайденоПуть = Ложь;
				ПоследнееПолеПути = ПолучитьПоследнийСегментПути(ПутьЗапроса);
				Для Каждого ПолеРазрешенное Из Разрешенные Цикл
					Если ВРег(Строка(ПолеРазрешенное)) = ВРег(ПоследнееПолеПути) Тогда
						НайденоПуть = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Для Каждого ПутьРазрешенный Из РазрешенныеПути Цикл
					Если ВРег(Строка(ПутьРазрешенный)) = ВРег(Строка(ПутьЗапроса)) Тогда
						НайденоПуть = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Если НЕ НайденоПуть И ПолучитьПоследнийСегментПути(ПутьЗапроса) = "Наименование" Тогда
					БазовоеПолеПути = ПолучитьПервыйСегментПути(ПутьЗапроса);
					Для Каждого ПолеРазрешенное Из Разрешенные Цикл
						Если ВРег(Строка(ПолеРазрешенное)) = ВРег(БазовоеПолеПути) Тогда
							НайденоПуть = Истина;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				Если НЕ НайденоПуть Тогда
					Неизвестные.Добавить(ПутьЗапроса);
				КонецЕсли;
			КонецЦикла;
			
			Если Неизвестные.Количество() > 0 Тогда
				Результат.Успех = Ложь;
				Результат.КодОшибки = "query_safety_violation";
				Результат.Сообщение = "Query Safety Gate: обнаружены поля вне whitelist GetObjectFields: " + СтрСоединить(Неизвестные, ", ");
				Результат.Контекст = Новый Структура("reason,unknown_fields", "field_whitelist_violation", СтрСоединить(Неизвестные, ","));
				Возврат Результат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьПоследнийСегментПути(ПутьПоля)

	Результат = Строка(ПутьПоля);
	ПозицияТочки = СтрНайти(Результат, ".");
	Пока ПозицияТочки > 0 Цикл
		Результат = Сред(Результат, ПозицияТочки + 1);
		ПозицияТочки = СтрНайти(Результат, ".");
	КонецЦикла;
	Возврат СокрЛП(Результат);

КонецФункции

Функция ПолучитьПервыйСегментПути(ПутьПоля)

	Результат = СокрЛП(Строка(ПутьПоля));
	ПозицияТочки = СтрНайти(Результат, ".");
	Если ПозицияТочки > 0 Тогда
		Возврат Лев(Результат, ПозицияТочки - 1);
	КонецЕсли;
	Возврат Результат;

КонецФункции

Функция НормализоватьИмяОбъектаМетаданных(ИмяОбъекта, ТипОжидаемый = "") Экспорт
	Имя = СокрЛП(Строка(ИмяОбъекта));
	Если СтрНачинаетсяС(Имя, "Документ.") Тогда
		Возврат СокрЛП(Сред(Имя, 10));
	КонецЕсли;
	Если СтрНачинаетсяС(Имя, "Справочник.") Тогда
		Возврат СокрЛП(Сред(Имя, 12));
	КонецЕсли;
	Если СтрНачинаетсяС(Имя, "РегистрНакопления.") Тогда
		Возврат СокрЛП(Сред(Имя, 19));
	КонецЕсли;
	Если СтрНачинаетсяС(Имя, "РегистрСведений.") Тогда
		Возврат СокрЛП(Сред(Имя, 17));
	КонецЕсли;
	Возврат Имя;
КонецФункции

Функция РазрешитьИмяСправочника(ИсходноеИмяСправочника, КонтекстВыполнения = Неопределено) Экспорт
	ИмяСправочника = НормализоватьИмяОбъектаМетаданных(ИсходноеИмяСправочника, "Справочник");
	Если ИИА_Метаданные.СуществуетСправочник(ИмяСправочника) Тогда
		Возврат ИмяСправочника;
	КонецЕсли;
	
	Кандидаты = Новый Массив;
	Кандидаты.Добавить(ИмяСправочника + "ы");
	Кандидаты.Добавить(ИмяСправочника + "и");
	Кандидаты.Добавить(ИмяСправочника + "а");
	Для Каждого Кандидат Из Кандидаты Цикл
		Если ИИА_Метаданные.СуществуетСправочник(Кандидат) Тогда
			Возврат Кандидат;
		КонецЕсли;
	КонецЦикла;
	
	Похожие = ИИА_Метаданные.НайтиПохожиеОбъекты(ИмяСправочника, "Справочник");
	Для Каждого Похожий Из Похожие Цикл
		Если ИИА_Метаданные.СуществуетСправочник(Похожий) Тогда
			Возврат Похожий;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
КонецФункции

#КонецОбласти
