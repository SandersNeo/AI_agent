#Область ПрограммныйИнтерфейс

Функция ПолучитьOperationIdШага(Шаг) Экспорт
	Если Шаг = Неопределено Или ТипЗнч(Шаг) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	Если Шаг.Свойство("operation_id") Тогда
		Возврат СокрЛП(Строка(Шаг.operation_id));
	КонецЕсли;
	Если Шаг.Свойство("idempotency_key") Тогда
		Возврат СокрЛП(Строка(Шаг.idempotency_key));
	КонецЕсли;
	Возврат "";
КонецФункции

Функция ЭтоWriteДействиеDSL(Действие) Экспорт
	ДействиеВРег = ВРег(СокрЛП(Действие));
	Возврат ДействиеВРег = "CREATEDOCUMENT"
		ИЛИ ДействиеВРег = "CREATEREFERENCE"
		ИЛИ ДействиеВРег = "SETFIELD"
		ИЛИ ДействиеВРег = "WRITE";
КонецФункции

Функция СгенерироватьOperationIdДляDSL(Действие, КонтекстВыполнения) Экспорт
	Основа = "op_" + НРег(СокрЛП(Действие));
	Если КонтекстВыполнения <> Неопределено И ТипЗнч(КонтекстВыполнения) = Тип("Структура") Тогда
		Если КонтекстВыполнения.Свойство("trace_id") И НЕ ПустаяСтрока(Строка(КонтекстВыполнения.trace_id)) Тогда
			Основа = Основа + "_" + Строка(КонтекстВыполнения.trace_id);
		КонецЕсли;
		Если КонтекстВыполнения.Свойство("ИмяОбъекта") И НЕ ПустаяСтрока(Строка(КонтекстВыполнения.ИмяОбъекта)) Тогда
			Основа = Основа + "_" + НРег(Строка(КонтекстВыполнения.ИмяОбъекта));
		КонецЕсли;
	КонецЕсли;
	Основа = Основа + "_" + Формат(ТекущаяДатаСеанса(), "ДФ=yyyyMMddHHmmss");
	Основа = Основа + "_" + СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");
	Возврат Основа;
КонецФункции

Функция ПолучитьЖурналОперацийИзКонтекста(КонтекстВыполнения) Экспорт
	ПустойЖурнал = Новый Соответствие;
	Если КонтекстВыполнения = Неопределено Или ТипЗнч(КонтекстВыполнения) <> Тип("Структура") Тогда
		Возврат ПустойЖурнал;
	КонецЕсли;
	Если КонтекстВыполнения.Свойство("DSL_OperationJournal") И ТипЗнч(КонтекстВыполнения.DSL_OperationJournal) = Тип("Соответствие") Тогда
		Возврат КонтекстВыполнения.DSL_OperationJournal;
	КонецЕсли;
	Если КонтекстВыполнения.Свойство("СсылкаДиалога") И ЗначениеЗаполнено(КонтекстВыполнения.СсылкаДиалога) Тогда
		СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(КонтекстВыполнения.СсылкаДиалога);
		Если СтруктураДанных <> Неопределено
			И ТипЗнч(СтруктураДанных) = Тип("Структура")
			И СтруктураДанных.Свойство("DSL_OperationJournal")
			И ТипЗнч(СтруктураДанных.DSL_OperationJournal) = Тип("Соответствие") Тогда
			КонтекстВыполнения.Вставить("DSL_OperationJournal", СтруктураДанных.DSL_OperationJournal);
			Возврат СтруктураДанных.DSL_OperationJournal;
		КонецЕсли;
	КонецЕсли;
	КонтекстВыполнения.Вставить("DSL_OperationJournal", ПустойЖурнал);
	Возврат ПустойЖурнал;
КонецФункции

Процедура СохранитьЖурналОперацийВКонтекстИРегистр(КонтекстВыполнения, Журнал) Экспорт
	Если КонтекстВыполнения = Неопределено Или ТипЗнч(КонтекстВыполнения) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	КонтекстВыполнения.Вставить("DSL_OperationJournal", Журнал);
	Если НЕ КонтекстВыполнения.Свойство("СсылкаДиалога") Или НЕ ЗначениеЗаполнено(КонтекстВыполнения.СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	СсылкаДиалога = КонтекстВыполнения.СсылкаДиалога;
	СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
	Если СтруктураДанных = Неопределено Или ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		СтруктураДанных = Новый Структура;
	Иначе
		Копия = Новый Структура;
		Для Каждого КлючЗначение Из СтруктураДанных Цикл
			Копия.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
		КонецЦикла;
		СтруктураДанных = Копия;
	КонецЕсли;
	СтруктураДанных.Вставить("DSL_OperationJournal", Журнал);
	ИИА_DialogStorage.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
КонецПроцедуры

Функция ПолучитьРезультатОперации(КонтекстВыполнения, OperationId) Экспорт
	Если ПустаяСтрока(OperationId) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Журнал = ПолучитьЖурналОперацийИзКонтекста(КонтекстВыполнения);
	Если ТипЗнч(Журнал) <> Тип("Соответствие") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат Журнал.Получить(OperationId);
КонецФункции

Процедура ЗафиксироватьРезультатОперации(КонтекстВыполнения, OperationId, Действие, РезультатШага) Экспорт
	Если ПустаяСтрока(OperationId) Тогда
		Возврат;
	КонецЕсли;
	Журнал = ПолучитьЖурналОперацийИзКонтекста(КонтекстВыполнения);
	ЗаписьЖурнала = Новый Структура;
	ЗаписьЖурнала.Вставить("action", Действие);
	ЗаписьЖурнала.Вставить("result", РезультатШага);
	Журнал.Вставить(OperationId, ЗаписьЖурнала);
	СохранитьЖурналОперацийВКонтекстИРегистр(КонтекстВыполнения, Журнал);
КонецПроцедуры

Процедура ДобавитьЗаписьВСайдЭффектЛогИзDSL(КонтекстВыполнения, ВидЭффекта, Действие, OperationId = "", ДопДанные = Неопределено) Экспорт
	Если КонтекстВыполнения = Неопределено Или ТипЗнч(КонтекстВыполнения) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	Если НЕ КонтекстВыполнения.Свойство("СсылкаДиалога") Или НЕ ЗначениеЗаполнено(КонтекстВыполнения.СсылкаДиалога) Тогда
		Возврат;
	КонецЕсли;
	Запись = Новый Структура;
	Запись.Вставить("effect_type", ВидЭффекта);
	Запись.Вставить("action", Действие);
	Запись.Вставить("operation_id", OperationId);
	Запись.Вставить("replay_safety", ОпределитьReplaySafetyДляДействияDSL(Действие, OperationId));
	Если КонтекстВыполнения.Свойство("DSL_ТипОбъекта") Тогда
		Запись.Вставить("object_type", КонтекстВыполнения.DSL_ТипОбъекта);
	КонецЕсли;
	Если КонтекстВыполнения.Свойство("DSL_ИмяОбъекта") Тогда
		Запись.Вставить("object_name", КонтекстВыполнения.DSL_ИмяОбъекта);
	КонецЕсли;
	Если КонтекстВыполнения.Свойство("СсылкаОбъекта") И ЗначениеЗаполнено(КонтекстВыполнения.СсылкаОбъекта) Тогда
		Запись.Вставить("object_ref", СериализоватьДляJSON(КонтекстВыполнения.СсылкаОбъекта));
	КонецЕсли;
	Если ДопДанные <> Неопределено Тогда
		Запись.Вставить("details", СериализоватьДляJSON(ДопДанные));
	КонецЕсли;
	ИИА_Сервер.ДобавитьЗаписьВСайдЭффектЛог(КонтекстВыполнения.СсылкаДиалога, Запись);
КонецПроцедуры

Функция ОпределитьReplaySafetyДляДействияDSL(Действие, OperationId) Экспорт
	РеестрКонтрактов = ИИА_DSLКонтракт.ПолучитьРеестрКонтрактовDSL();
	Контракт = РеестрКонтрактов.Получить(СокрЛП(Строка(Действие)));
	Если Контракт = Неопределено Тогда
		Возврат "no_replay";
	КонецЕсли;
	Если Контракт.Свойство("supports_safe_retries") И Контракт.supports_safe_retries Тогда
		Возврат "safe_replay";
	КонецЕсли;
	Если НЕ ПустаяСтрока(СокрЛП(Строка(OperationId))) Тогда
		Возврат "resume_only";
	КонецЕсли;
	Возврат "no_replay";
КонецФункции

Процедура НормализоватьРезультатШага(Результат, Действие, OperationId, Контракт) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если НЕ Результат.Свойство("error_code") Тогда
		Результат.Вставить("error_code", "");
	КонецЕсли;
	Если НЕ Результат.Свойство("error_category") Тогда
		Результат.Вставить("error_category", "");
	КонецЕсли;
	Если НЕ Результат.Свойство("retryable") Тогда
		Результат.Вставить("retryable", Ложь);
	КонецЕсли;
	Если НЕ Результат.Свойство("suggested_action") Тогда
		Результат.Вставить("suggested_action", "");
	КонецЕсли;
	Если НЕ Результат.Свойство("recommendation") Тогда
		Результат.Вставить("recommendation", ?(Результат.Свойство("suggested_action"), Результат.suggested_action, ""));
	КонецЕсли;
	Если НЕ Результат.Свойство("error_context") Тогда
		Результат.Вставить("error_context", Неопределено);
	КонецЕсли;
	Если НЕ Результат.Свойство("missing_parameters") Тогда
		Результат.Вставить("missing_parameters", Новый Массив);
	КонецЕсли;
	Если НЕ Результат.Свойство("partial_failure") Тогда
		Результат.Вставить("partial_failure", Ложь);
	КонецЕсли;
	Если НЕ Результат.Свойство("next_step_guidance") Тогда
		Результат.Вставить("next_step_guidance", "");
	КонецЕсли;
	Если НЕ Результат.Свойство("operation_id") Тогда
		Результат.Вставить("operation_id", OperationId);
	ИначеЕсли ПустаяСтрока(Строка(Результат.operation_id)) Тогда
		Результат.operation_id = OperationId;
	КонецЕсли;
	Если НЕ Результат.Свойство("action") Тогда
		Результат.Вставить("action", Действие);
	КонецЕсли;
	Если Контракт <> Неопределено Тогда
		Если НЕ Результат.Свойство("idempotent") Тогда
			Результат.Вставить("idempotent", Контракт.idempotent);
		КонецЕсли;
		Если НЕ Результат.Свойство("requires_write") Тогда
			Результат.Вставить("requires_write", Контракт.requires_write);
		КонецЕсли;
		Если НЕ Результат.Свойство("supports_safe_retries") Тогда
			Результат.Вставить("supports_safe_retries", Контракт.supports_safe_retries);
		КонецЕсли;
		Если НЕ Результат.Свойство("retry_strategy") Тогда
			Результат.Вставить("retry_strategy", Контракт.retry_strategy);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#Область СлужебныеПроцедурыИФункции

Функция СериализоватьДляJSON(Значение)
	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Строка") Или ТипЗначения = Тип("Число") Или ТипЗначения = Тип("Булево") Тогда
		Возврат Значение;
	КонецЕсли;
	Если ТипЗначения = Тип("Дата") Тогда
		Возврат Формат(Значение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	КонецЕсли;
	Если ТипЗначения = Тип("Массив") Тогда
		НовыйМассив = Новый Массив;
		Для Каждого Элемент Из Значение Цикл
			НовыйМассив.Добавить(СериализоватьДляJSON(Элемент));
		КонецЦикла;
		Возврат НовыйМассив;
	КонецЕсли;
	Если ТипЗначения = Тип("Структура") Тогда
		НоваяСтруктура = Новый Структура;
		Для Каждого ПараКлючЗначение Из Значение Цикл
			НоваяСтруктура.Вставить(ПараКлючЗначение.Ключ, СериализоватьДляJSON(ПараКлючЗначение.Значение));
		КонецЦикла;
		Возврат НоваяСтруктура;
	КонецЕсли;
	Если (Справочники.ТипВсеСсылки().СодержитТип(ТипЗначения) 
		Или Документы.ТипВсеСсылки().СодержитТип(ТипЗначения)
		Или ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(ТипЗначения)) Тогда
		СтруктураСсылки = Новый Структура;
		СтруктураСсылки.Вставить("ref", Строка(Значение));
		Попытка
			СтруктураСсылки.Вставить("guid", Строка(Значение.УникальныйИдентификатор()));
		Исключение
			СтруктураСсылки.Вставить("guid", "");
		КонецПопытки;
		Попытка
			СтруктураСсылки.Вставить("meta_name", Значение.Метаданные().Имя);
		Исключение
			СтруктураСсылки.Вставить("meta_name", "");
		КонецПопытки;
		Возврат СтруктураСсылки;
	КонецЕсли;
	Возврат Строка(Значение);
КонецФункции

