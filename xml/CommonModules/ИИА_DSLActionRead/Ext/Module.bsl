#Область ПрограммныйИнтерфейс

Функция ВыполнитьFindReferenceByName(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	ИмяСправочника = ИИА_DSLQuerySafety.РазрешитьИмяСправочника(Шаг.object_name, КонтекстВыполнения);
	Если ПустаяСтрока(ИмяСправочника) Тогда
		Результат.Сообщение = "Справочник '" + Шаг.object_name + "' не найден";
		Возврат Результат;
	КонецЕсли;
	Если Шаг.Свойство("name") Тогда
		ИмяДляПоиска = Шаг.name;
	ИначеЕсли Шаг.Свойство("value") Тогда
		ИмяДляПоиска = Шаг.value;
	Иначе
		Результат.Сообщение = "Поле name или value не указано";
		Возврат Результат;
	КонецЕсли;
	МенеджерСправочника = Справочники[ИмяСправочника];
	Если МенеджерСправочника = Неопределено Тогда
		Результат.Сообщение = "Не удалось получить менеджер справочника '" + ИмяСправочника + "'";
		Возврат Результат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Элементы.Ссылка
	|ИЗ
	|	Справочник." + ИмяСправочника + " КАК Элементы
	|ГДЕ
	|	Элементы.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Наименование", ИмяДляПоиска);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Результат.Сообщение = "Элемент справочника '" + ИмяСправочника + "' с наименованием '" + ИмяДляПоиска + "' не найден";
		Возврат Результат;
	КонецЕсли;
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	НайденнаяСсылка = Выборка.Ссылка;
	КонтекстВыполнения.Вставить("ТекущийОбъект", НайденнаяСсылка.ПолучитьОбъект());
	КонтекстВыполнения.Вставить("ТипОбъекта", "Справочник");
	КонтекстВыполнения.Вставить("ИмяОбъекта", ИмяСправочника);
	УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, "Справочник", ИмяСправочника, КонтекстВыполнения.ТекущийОбъект, Ложь);
	Результат.Успех = Истина;
	Результат.Сообщение = "Найден элемент справочника '" + ИмяСправочника + "' с наименованием '" + ИмяДляПоиска + "'";
	Результат.Данные = НайденнаяСсылка;
	Возврат Результат;
КонецФункции

Функция ВыполнитьFindReferenceByGUID(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	УИДДляПоиска = Шаг.guid;
	НайденнаяСсылка = НайтиСсылкуПоУИД(УИДДляПоиска);
	Если НайденнаяСсылка = Неопределено Тогда
		Результат.Сообщение = "Объект с УИД '" + УИДДляПоиска + "' не найден";
		Возврат Результат;
	КонецЕсли;
	ТипОбъекта = "";
	ИмяОбъекта = "";
	Если Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(НайденнаяСсылка)) Тогда
		ТипОбъекта = "Справочник";
		ИмяОбъекта = НайденнаяСсылка.Метаданные().Имя;
	ИначеЕсли Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(НайденнаяСсылка)) Тогда
		ТипОбъекта = "Документ";
		ИмяОбъекта = НайденнаяСсылка.Метаданные().Имя;
	Иначе
		Результат.Сообщение = "Найден объект с УИД '" + УИДДляПоиска + "', но его тип не поддерживается";
		Возврат Результат;
	КонецЕсли;
	КонтекстВыполнения.Вставить("ТекущийОбъект", НайденнаяСсылка.ПолучитьОбъект());
	КонтекстВыполнения.Вставить("ТипОбъекта", ТипОбъекта);
	КонтекстВыполнения.Вставить("ИмяОбъекта", ИмяОбъекта);
	УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, ТипОбъекта, ИмяОбъекта, КонтекстВыполнения.ТекущийОбъект, Ложь);
	Результат.Успех = Истина;
	Результат.Сообщение = "Найден объект '" + ИмяОбъекта + "' (тип: " + ТипОбъекта + ") с УИД '" + УИДДляПоиска + "'";
	Результат.Данные = НайденнаяСсылка;
	Возврат Результат;
КонецФункции

Функция ВыполнитьFindReferenceByURL(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	URLДляПоиска = Шаг.url;
	Попытка
		ИмяОбъекта = "";
		ТипОбъекта = "";
		УИДОбъекта = "";
		Если СтрНайти(URLДляПоиска, "Справочник.") > 0 Тогда
			ТипОбъекта = "Справочник";
			НачалоИмени = СтрНайти(URLДляПоиска, "Справочник.") + 12;
			КонецИмени = СтрНайти(URLДляПоиска, "?", НаправлениеПоиска.СНачала, НачалоИмени);
			Если КонецИмени = 0 Тогда
				КонецИмени = СтрДлина(URLДляПоиска) + 1;
			КонецЕсли;
			ИмяОбъекта = Сред(URLДляПоиска, НачалоИмени, КонецИмени - НачалоИмени);
		ИначеЕсли СтрНайти(URLДляПоиска, "Документ.") > 0 Тогда
			ТипОбъекта = "Документ";
			НачалоИмени = СтрНайти(URLДляПоиска, "Документ.") + 9;
			КонецИмени = СтрНайти(URLДляПоиска, "?", НаправлениеПоиска.СНачала, НачалоИмени);
			Если КонецИмени = 0 Тогда
				КонецИмени = СтрДлина(URLДляПоиска) + 1;
			КонецЕсли;
			ИмяОбъекта = Сред(URLДляПоиска, НачалоИмени, КонецИмени - НачалоИмени);
		Иначе
			Результат.Сообщение = "Не удалось определить тип объекта из URL (ожидается Справочник. или Документ.)";
			Возврат Результат;
		КонецЕсли;
		ПозицияRef = СтрНайти(URLДляПоиска, "ref=");
		Если ПозицияRef > 0 Тогда
			УИДОбъекта = Сред(URLДляПоиска, ПозицияRef + 4);
			ПозицияАмперсанда = СтрНайти(УИДОбъекта, "&");
			Если ПозицияАмперсанда > 0 Тогда
				УИДОбъекта = Лев(УИДОбъекта, ПозицияАмперсанда - 1);
			КонецЕсли;
			УИДОбъекта = СтрЗаменить(УИДОбъекта, "%20", " ");
			УИДОбъекта = СтрЗаменить(УИДОбъекта, "%3D", "=");
		Иначе
			Результат.Сообщение = "Не найден параметр ref= в навигационной ссылке";
			Возврат Результат;
		КонецЕсли;
		НайденнаяСсылка = НайтиСсылкуПоУИД(УИДОбъекта);
		Если НайденнаяСсылка = Неопределено Тогда
			Результат.Сообщение = "Объект с УИД '" + УИДОбъекта + "' не найден";
			Возврат Результат;
		КонецЕсли;
		Если Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(НайденнаяСсылка)) Тогда
			ТипОбъекта = "Справочник";
			ИмяОбъекта = НайденнаяСсылка.Метаданные().Имя;
		ИначеЕсли Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(НайденнаяСсылка)) Тогда
			ТипОбъекта = "Документ";
			ИмяОбъекта = НайденнаяСсылка.Метаданные().Имя;
		Иначе
			Результат.Сообщение = "Найден объект с УИД '" + УИДОбъекта + "', но его тип не поддерживается";
			Возврат Результат;
		КонецЕсли;
		КонтекстВыполнения.Вставить("ТекущийОбъект", НайденнаяСсылка.ПолучитьОбъект());
		КонтекстВыполнения.Вставить("ТипОбъекта", ТипОбъекта);
		КонтекстВыполнения.Вставить("ИмяОбъекта", ИмяОбъекта);
		УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, ТипОбъекта, ИмяОбъекта, КонтекстВыполнения.ТекущийОбъект, Ложь);
		Результат.Успех = Истина;
		Результат.Сообщение = "Найден объект '" + ИмяОбъекта + "' по навигационной ссылке (УИД: " + УИДОбъекта + ")";
		Результат.Данные = НайденнаяСсылка;
	Исключение
		Результат.Сообщение = "Ошибка при поиске объекта по URL: " + ОписаниеОшибки();
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ВыполнитьRunQuery(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	ТекстЗапроса = Шаг.query;
	ТекстЗапросаИсходный = ТекстЗапроса;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "«", """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "»", """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "“", """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "”", """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, Символ(171), """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, Символ(187), """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "'", """");
	ТекстЗапроса = НормализоватьПробелыВТекстеЗапроса(ТекстЗапроса);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&""", """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "& """, """");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Объект.", "");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "объект.", "");
	ТекстЗапроса = ИсправитьПорядокДобавитьКДате(ТекстЗапроса);
	ТекстЗапросаВерхний = ВРег(ТекстЗапроса);
	ТекстБезПробелов = СтрЗаменить(ТекстЗапросаВерхний, " ", "");
	Если СтрНайти(ТекстБезПробелов, "СТРНАЙТИ(") > 0
		ИЛИ СтрНайти(ТекстБезПробелов, "STRFIND(") > 0
		ИЛИ СтрНайти(ТекстБезПробелов, "СТРНАЧИНАЕТСЯС(") > 0
		ИЛИ СтрНайти(ТекстБезПробелов, "STRSTARTSWITH(") > 0
		ИЛИ СтрНайти(ТекстБезПробелов, "ПОДОБИЕ(") > 0
		ИЛИ СтрНайти(ТекстБезПробелов, "SIMILARITY(") > 0
		ИЛИ СтрНайти(ТекстБезПробелов, "НАЙТИ(") > 0 Тогда
		Результат.Сообщение = "Ошибка: Использована недопустимая функция в запросе";
		УстановитьТипизированнуюОшибку(Результат, "query_safety_violation", "safety", Истина, "rewrite_query_with_like", Новый Структура("reason", "forbidden_functions"));
		Возврат Результат;
	КонецЕсли;
	Если СтрНайти(ТекстЗапросаВерхний, "ИЗМЕНИТЬ") > 0
		ИЛИ СтрНайти(ТекстЗапросаВерхний, "УДАЛИТЬ") > 0
		ИЛИ СтрНайти(ТекстЗапросаВерхний, "ВСТАВИТЬ") > 0
		ИЛИ СтрНайти(ТекстЗапросаВерхний, "ОБНОВИТЬ") > 0 Тогда
		Результат.Сообщение = "Запрос содержит операции модификации данных. Разрешены только SELECT запросы";
		УстановитьТипизированнуюОшибку(Результат, "query_safety_violation", "safety", Истина, "use_select_only", Новый Структура("reason", "mutating_operations"));
		Возврат Результат;
	КонецЕсли;
	ПроверкаGate = ИИА_DSLQuerySafety.ПроверитьQuerySafetyGate(ТекстЗапроса, КонтекстВыполнения);
	Если НЕ ПроверкаGate.Успех Тогда
		Результат.Сообщение = ПроверкаGate.Сообщение;
		УстановитьТипизированнуюОшибку(Результат, ПроверкаGate.КодОшибки, "safety", Истина, "run_getobjectfields_then_retry", ПроверкаGate.Контекст);
		Возврат Результат;
	КонецЕсли;
	Попытка
		Запрос = Новый Запрос(ТекстЗапроса);
		Если Шаг.Свойство("parameters") И Шаг.parameters <> Неопределено Тогда
			Если ТипЗнч(Шаг.parameters) = Тип("Массив") Тогда
				Для Каждого ПараметрСтруктура Из Шаг.parameters Цикл
					Если ТипЗнч(ПараметрСтруктура) = Тип("Структура") Тогда
						Для Каждого КлючЗначение Из ПараметрСтруктура Цикл
							Запрос.УстановитьПараметр(КлючЗначение.Ключ, ОбработатьЗначениеПараметра(КлючЗначение.Значение, КонтекстВыполнения));
						КонецЦикла;
					КонецЕсли;
				КонецЦикла;
			ИначеЕсли ТипЗнч(Шаг.parameters) = Тип("Структура") Тогда
				Для Каждого КлючЗначение Из Шаг.parameters Цикл
					Запрос.УстановитьПараметр(КлючЗначение.Ключ, ОбработатьЗначениеПараметра(КлючЗначение.Значение, КонтекстВыполнения));
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		ТаблицаРезультатов = Запрос.Выполнить().Выгрузить();
		МассивКолонок = Новый Массив;
		Для Каждого Колонка Из ТаблицаРезультатов.Колонки Цикл
			МассивКолонок.Добавить(Колонка.Имя);
		КонецЦикла;
		МассивРезультатов = Новый Массив;
		Для Каждого СтрокаТаблицы Из ТаблицаРезультатов Цикл
			СтруктураСтроки = Новый Структура;
			Для Каждого Колонка Из ТаблицаРезультатов.Колонки Цикл
				Попытка
					ЗначениеКолонки = СтрокаТаблицы[Колонка.Имя];
					Если ЗначениеКолонки = Неопределено Или ТипЗнч(ЗначениеКолонки) = Тип("Строка") Или ТипЗнч(ЗначениеКолонки) = Тип("Число") Или ТипЗнч(ЗначениеКолонки) = Тип("Булево") Или ТипЗнч(ЗначениеКолонки) = Тип("Дата") Тогда
						СтруктураСтроки.Вставить(Колонка.Имя, ЗначениеКолонки);
					Иначе
						СтруктураСтроки.Вставить(Колонка.Имя, ЗначениеКолонки);
					КонецЕсли;
				Исключение
					СтруктураСтроки.Вставить(Колонка.Имя, "");
				КонецПопытки;
			КонецЦикла;
			МассивРезультатов.Добавить(СтруктураСтроки);
		КонецЦикла;
		Результат.Успех = Истина;
		Результат.Сообщение = "Запрос выполнен успешно. Получено строк: " + Формат(ТаблицаРезультатов.Количество(), "ЧН=0");
		Результат.Данные = МассивРезультатов;
		Результат.Вставить("КолонкиЗапроса", МассивКолонок);
		Результат.Вставить("КоличествоСтрок", ТаблицаРезультатов.Количество());
		КонтекстВыполнения.Вставить("РезультатЗапроса", МассивРезультатов);
		КонтекстВыполнения.Вставить("QueryResult", МассивРезультатов);
		КонтекстВыполнения.Вставить("РезультатЗапросаДляТаблицы", МассивРезультатов);
		Результат.Вставить("ДанныеЗапросаДляТаблицы", МассивРезультатов);
		Результат.Вставить("ТипДействия", "RunQuery");
		Результат.Вставить("ЕстьРезультатЗапроса", Истина);
	Исключение
		ТекстОшибкиЗапроса = ОписаниеОшибки();
		Результат.Сообщение = "Ошибка выполнения запроса: " + ТекстОшибкиЗапроса;
		УстановитьТипизированнуюОшибку(Результат, "query_execution_error", "runtime", Истина, "repair_dsl", Новый Структура("source", "query_engine"));
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ВыполнитьShowInfo(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Истина);
	Сообщение = "";
	Если Шаг.Свойство("message") Тогда
		Сообщение = Строка(Шаг.message);
	ИначеЕсли Шаг.Свойство("title") И Шаг.Свойство("data") Тогда
		Сообщение = СокрЛП(Строка(Шаг.title)) + ": " + СокрЛП(Строка(Шаг.data));
	ИначеЕсли Шаг.Свойство("title") Тогда
		Сообщение = СокрЛП(Строка(Шаг.title));
	ИначеЕсли Шаг.Свойство("data") Тогда
		Сообщение = СокрЛП(Строка(Шаг.data));
	Иначе
		Результат.Успех = Ложь;
		Результат.Вставить("Сообщение", "ShowInfo: не передано ни message, ни совместимые поля title/data");
		Возврат Результат;
	КонецЕсли;
	ЕстьРезультатЗапроса = Ложь;
	Если КонтекстВыполнения.Свойство("РезультатЗапроса") И КонтекстВыполнения.РезультатЗапроса <> Неопределено Тогда
		РезультатЗапроса = КонтекстВыполнения.РезультатЗапроса;
		Если ТипЗнч(РезультатЗапроса) = Тип("Массив") И РезультатЗапроса.Количество() > 0 Тогда
			ЕстьРезультатЗапроса = Истина;
		КонецЕсли;
	КонецЕсли;
	Если КонтекстВыполнения.Свойство("РезультатЗапроса") И КонтекстВыполнения.РезультатЗапроса <> Неопределено Тогда
		РезультатЗапроса = КонтекстВыполнения.РезультатЗапроса;
		Если ТипЗнч(РезультатЗапроса) = Тип("Массив") И РезультатЗапроса.Количество() > 0 Тогда
			ПерваяСтрока = РезультатЗапроса[0];
			Если ТипЗнч(ПерваяСтрока) = Тип("Структура") Тогда
				Для Каждого ПараКлючЗначение Из ПерваяСтрока Цикл
					Плейсхолдер = "{" + ПараКлючЗначение.Ключ + "}";
					Если СтрНайти(Сообщение, Плейсхолдер) > 0 Тогда
						Сообщение = СтрЗаменить(Сообщение, Плейсхолдер, Строка(ПараКлючЗначение.Значение));
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Для Каждого ПараКлючЗначение Из КонтекстВыполнения Цикл
		ИмяПараметра = ПараКлючЗначение.Ключ;
		Если ИмяПараметра = "ТекущийОбъект" Или ИмяПараметра = "ТипОбъекта" Или ИмяПараметра = "ИмяОбъекта"
			Или ИмяПараметра = "СсылкаДиалога" Или ИмяПараметра = "РезультатЗапроса" Или ИмяПараметра = "РезультатЗапросаДляТаблицы" Тогда
			Продолжить;
		КонецЕсли;
		Плейсхолдер = "{" + ИмяПараметра + "}";
		Если СтрНайти(Сообщение, Плейсхолдер) > 0 Тогда
			Сообщение = СтрЗаменить(Сообщение, Плейсхолдер, Строка(ПараКлючЗначение.Значение));
		КонецЕсли;
	КонецЦикла;
	Результат.Вставить("Сообщение", Сообщение);
	Если СтрНайти(Сообщение, "{") > 0 И СтрНайти(Сообщение, "}") > 0 Тогда
		Результат.Успех = Ложь;
		Результат.Сообщение = "Ошибка: Сообщение содержит нераспознанные поля " + Сообщение + ". Это значит, что RunQuery не вернул данных или не был выполнен. Сначала получи данные!";
	КонецЕсли;
	Результат.Вставить("Данные", Сообщение);
	Результат.Вставить("ТипДействия", "ShowInfo");
	Результат.Вставить("ЕстьРезультатЗапроса", ЕстьРезультатЗапроса);
	Возврат Результат;
КонецФункции

Функция ВыполнитьGetChangedObjects(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	Попытка
		Если НЕ КонтекстВыполнения.Свойство("СсылкаДиалога") ИЛИ НЕ ЗначениеЗаполнено(КонтекстВыполнения.СсылкаДиалога) Тогда
			Результат.Сообщение = "Ссылка на диалог не передана в контекст выполнения";
			Возврат Результат;
		КонецЕсли;
		Диалог = КонтекстВыполнения.СсылкаДиалога.ПолучитьОбъект();
		МассивСсылок = Новый Массив;
		Для Каждого СтрокаИзмененныхОбъектов Из Диалог.ИзмененныеОбъекты Цикл
			Если ЗначениеЗаполнено(СтрокаИзмененныхОбъектов.СсылкаНаОбъект) Тогда
				МассивСсылок.Добавить(СтрокаИзмененныхОбъектов.СсылкаНаОбъект);
			КонецЕсли;
		КонецЦикла;
		Результат.Успех = Истина;
		Результат.Сообщение = "Получено объектов из табличной части: " + Формат(МассивСсылок.Количество(), "ЧН=0");
		Результат.Данные = МассивСсылок;
	Исключение
		Результат.Сообщение = "Ошибка получения объектов из табличной части: " + ОписаниеОшибки();
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ВыполнитьGetMetadata(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	Фильтр = "";
	Если Шаг.Свойство("filter") Тогда
		Фильтр = Шаг.filter;
	КонецЕсли;
	Попытка
		РезультатМетаданных = Новый Структура;
		РезультатМетаданных.Вставить("Справочники", ИИА_Метаданные.ПолучитьСписокСправочников(Фильтр));
		РезультатМетаданных.Вставить("Документы", ИИА_Метаданные.ПолучитьСписокДокументов(Фильтр));
		РезультатМетаданных.Вставить("РегистрыСведений", ИИА_Метаданные.ПолучитьСписокРегистровСведений(Фильтр));
		РезультатМетаданных.Вставить("РегистрыНакопления", ИИА_Метаданные.ПолучитьСписокРегистровНакопления(Фильтр));
		РезультатМетаданных.Вставить("РегистрыБухгалтерии", ИИА_Метаданные.ПолучитьСписокРегистровБухгалтерии(Фильтр));
		Результат.Успех = Истина;
		ТекстСообщения = "Получены метаданные конфигурации" + ?(ПустаяСтрока(Фильтр), "", " с фильтром '" + Фильтр + "'") + ":" + Символы.ПС;
		ВсегоОбъектов = 0;
		Для Каждого КлючЗначение Из РезультатМетаданных Цикл
			Коллекция = КлючЗначение.Значение;
			Если Коллекция.Количество() > 0 Тогда
				ТекстСообщения = ТекстСообщения + "- " + КлючЗначение.Ключ + ": ";
				МассивИмен = Новый Массив;
				Для Каждого Элемент Из Коллекция Цикл
					МассивИмен.Добавить(Элемент.ПолноеИмя + ?(ПустаяСтрока(Элемент.Синоним), "", " — " + Элемент.Синоним));
				КонецЦикла;
				ТекстСообщения = ТекстСообщения + СтрСоединить(МассивИмен, ", ") + Символы.ПС;
				ВсегоОбъектов = ВсегоОбъектов + Коллекция.Количество();
			КонецЕсли;
		КонецЦикла;
		Если ВсегоОбъектов = 0 Тогда
			ТекстСообщения = ТекстСообщения + "ОБЪЕКТЫ НЕ НАЙДЕНЫ. Попробуй другой фильтр или поищи похожие имена.";
		ИначеЕсли ВсегоОбъектов < 10 Тогда
			ТекстСообщения = ТекстСообщения + "ИНСТРУКЦИЯ: Выбери объект из списка выше. Для GetObjectFields используй полное имя (например Документ.НакладнаяНаРеализацию): object_type=часть до точки, object_name=часть после точки.";
		КонецЕсли;
		Результат.Сообщение = ТекстСообщения;
		Результат.Данные = РезультатМетаданных;
	Исключение
		Результат.Сообщение = "Ошибка при получении метаданных: " + ОписаниеОшибки();
		УстановитьТипизированнуюОшибку(Результат, "metadata_access_error", "metadata", Истина, "retry_getmetadata", Новый Структура("filter", Фильтр));
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ВыполнитьGetObjectFields(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	Результат.Вставить("error_code", "");
	Результат.Вставить("error_context", Неопределено);
	ИмяОбъекта = ИИА_DSLQuerySafety.НормализоватьИмяОбъектаМетаданных(Шаг.object_name, Шаг.object_type);
	ТипОбъекта = Шаг.object_type;
	Попытка
		Если ТипОбъекта = "Справочник" Тогда
			ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыСправочника(ИмяОбъекта);
		ИначеЕсли ТипОбъекта = "Документ" Тогда
			ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыДокумента(ИмяОбъекта);
		ИначеЕсли ТипОбъекта = "РегистрНакопления" Тогда
			ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыРегистраНакопления(ИмяОбъекта);
		ИначеЕсли ТипОбъекта = "РегистрСведений" Тогда
			ИнформацияОбОбъекте = ИИА_Метаданные.ПолучитьРеквизитыРегистраСведений(ИмяОбъекта);
		Иначе
			Результат.Сообщение = "Неподдерживаемый тип объекта: " + ТипОбъекта;
			УстановитьТипизированнуюОшибку(Результат, "unsupported_object_type", "validation", Ложь, "fix_object_type", Новый Структура("object_type", ТипОбъекта));
			Возврат Результат;
		КонецЕсли;
		Если НЕ ИнформацияОбОбъекте.Найден Тогда
			Результат.Сообщение = ТипОбъекта + " '" + ИмяОбъекта + "' не найден";
			УстановитьТипизированнуюОшибку(Результат, "object_not_found", "metadata", Истина, "run_getmetadata", Новый Структура("object_type,object_name", ТипОбъекта, ИмяОбъекта));
			Возврат Результат;
		КонецЕсли;
		Результат.Успех = Истина;
		Результат.Сообщение = "Получены реквизиты " + НРег(Строка(ТипОбъекта)) + "а '" + ИмяОбъекта + "'";
		Результат.Данные = ПодготовитьДанныеРеквизитовДляЛлм(ИнформацияОбОбъекте);
		WhitelistПоля = Новый Массив;
		WhitelistПути = Новый Массив;
		Для Каждого РеквизитОбъекта Из ИнформацияОбОбъекте.Реквизиты Цикл
			Если ТипЗнч(РеквизитОбъекта) = Тип("Структура") И РеквизитОбъекта.Свойство("Имя") Тогда
				ИмяРеквизита = Строка(РеквизитОбъекта.Имя);
				Если Лев(ВРег(ИмяРеквизита), 6) <> "УДАЛИТ" Тогда
					WhitelistПоля.Добавить(ИмяРеквизита);
					ДобавитьВWhitelistПути(WhitelistПути, ИмяРеквизита + ".Наименование");
					ДобавитьВWhitelistПути(WhitelistПути, ИмяРеквизита + ".Ссылка");
					Если РеквизитОбъекта.Свойство("Тип") И ЭтоСсылочныйТипРеквизита(Строка(РеквизитОбъекта.Тип)) Тогда
						ДобавитьВWhitelistПути(WhitelistПути, ИмяРеквизита + ".Код");
						ДобавитьВWhitelistПути(WhitelistПути, ИмяРеквизита + ".Номер");
						ДобавитьВWhitelistПути(WhitelistПути, ИмяРеквизита + ".Дата");
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		ДобавитьВWhitelistПути(WhitelistПути, "Ссылка");
		Если WhitelistПоля.Найти("Ссылка") = Неопределено Тогда
			WhitelistПоля.Добавить("Ссылка");
		КонецЕсли;
		КонтекстВыполнения.Вставить("DSL_РазрешенныеПоляОбъекта", WhitelistПоля);
		КонтекстВыполнения.Вставить("DSL_РазрешенныеПутиПолейОбъекта", WhitelistПути);
		Результат.Вставить("whitelist_fields", WhitelistПоля);
		Результат.Вставить("whitelist_paths", WhitelistПути);
		Результат.Вставить("ТипДействия", "GetObjectFields");
	Исключение
		Результат.Сообщение = "Ошибка при получении реквизитов: " + ОписаниеОшибки();
		УстановитьТипизированнуюОшибку(Результат, "metadata_access_error", "metadata", Истина, "retry_getobjectfields", Новый Структура("object_type,object_name", ТипОбъекта, ИмяОбъекта));
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ВыполнитьCheckObjectExists(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	Результат.Вставить("error_code", "");
	Результат.Вставить("error_context", Неопределено);
	ИсходноеИмяОбъекта = Шаг.object_name;
	ИмяОбъекта = ИИА_DSLQuerySafety.НормализоватьИмяОбъектаМетаданных(Шаг.object_name, Шаг.object_type);
	ТипОбъекта = Шаг.object_type;
	Попытка
		Существует = Ложь;
		НайденоЧерезFuzzy = Ложь;
		Если ТипОбъекта = "Справочник" Тогда
			Существует = ИИА_Метаданные.СуществуетСправочник(ИмяОбъекта);
		ИначеЕсли ТипОбъекта = "Документ" Тогда
			Существует = ИИА_Метаданные.СуществуетДокумент(ИмяОбъекта);
		ИначеЕсли ТипОбъекта = "РегистрНакопления" Тогда
			Существует = ИИА_Метаданные.СуществуетРегистрНакопления(ИмяОбъекта);
		ИначеЕсли ТипОбъекта = "РегистрСведений" Тогда
			Существует = ИИА_Метаданные.СуществуетРегистрСведений(ИмяОбъекта);
		Иначе
			Результат.Сообщение = "Неподдерживаемый тип объекта: " + ТипОбъекта;
			УстановитьТипизированнуюОшибку(Результат, "unsupported_object_type", "validation", Ложь, "fix_object_type", Новый Структура("object_type", ТипОбъекта));
			Возврат Результат;
		КонецЕсли;
		РезультатИнформации = Новый Структура;
		РезультатИнформации.Вставить("Существует", Существует);
		РезультатИнформации.Вставить("Имя", ИмяОбъекта);
		РезультатИнформации.Вставить("Тип", ТипОбъекта);
		РезультатИнформации.Вставить("ЗапрошенноеИмя", ИсходноеИмяОбъекта);
		Результат.Успех = Истина;
		Если Существует Тогда
			Результат.Сообщение = НРег(Строка(ТипОбъекта)) + " '" + ИмяОбъекта + "' существует";
		Иначе
			Результат.Сообщение = НРег(Строка(ТипОбъекта)) + " '" + ИмяОбъекта + "' НЕ существует. Используй GetMetadata с фильтром для поиска правильного имени. Не повторяй CheckObjectExists с тем же именем!";
		КонецЕсли;
		Результат.Данные = РезультатИнформации;
	Исключение
		Результат.Сообщение = "Ошибка при проверке существования объекта: " + ОписаниеОшибки();
		УстановитьТипизированнуюОшибку(Результат, "metadata_access_error", "metadata", Истина, "retry_check_object", Новый Структура("object_type,object_name", ТипОбъекта, ИмяОбъекта));
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ВыполнитьSelectObject(Шаг, КонтекстВыполнения) Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	Ссылка = Неопределено;
	Если Шаг.Свойство("reference") Тогда
		Ссылка = Шаг.reference;
	ИначеЕсли Шаг.Свойство("object") Тогда
		Ссылка = Шаг.object;
	ИначеЕсли Шаг.Свойство("object_type") И Шаг.Свойство("object_name") И (Шаг.Свойство("name") Или Шаг.Свойство("value")) Тогда
		ШагПоиска = Новый Структура;
		ШагПоиска.Вставить("object_name", Шаг.object_name);
		ШагПоиска.Вставить("name", ?(Шаг.Свойство("name"), Шаг.name, Шаг.value));
		РезПоиска = ВыполнитьFindReferenceByName(ШагПоиска, КонтекстВыполнения);
		Если НЕ РезПоиска.Успех Тогда
			Результат.Сообщение = РезПоиска.Сообщение;
			Возврат Результат;
		КонецЕсли;
		Ссылка = РезПоиска.Данные;
		Результат.Успех = Истина;
		Результат.Сообщение = "Выбран объект по наименованию: " + Строка(Ссылка);
		Результат.Данные = Ссылка;
		Возврат Результат;
	КонецЕсли;
	ТипЗнчСсылки = ТипЗнч(Ссылка);
	Попытка
		Если НЕ (Справочники.ТипВсеСсылки().СодержитТип(ТипЗнчСсылки) ИЛИ Документы.ТипВсеСсылки().СодержитТип(ТипЗнчСсылки) ИЛИ ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(ТипЗнчСсылки)) Тогда
			Результат.Сообщение = "Ошибка выбора объекта: Значение типа '" + Строка(ТипЗнчСсылки) + "' не является ссылкой на объект. Значение: " + Строка(Ссылка);
			Возврат Результат;
		КонецЕсли;
		Объект = Ссылка.ПолучитьОбъект();
		Если Объект = Неопределено Тогда
			Результат.Сообщение = "Не удалось получить объект по ссылке (объект не найден)";
			Возврат Результат;
		КонецЕсли;
		КонтекстВыполнения.Вставить("ТекущийОбъект", Объект);
		КонтекстВыполнения.Вставить("СсылкаОбъекта", Ссылка);
		Если Справочники.ТипВсеСсылки().СодержитТип(ТипЗнчСсылки) Тогда
			КонтекстВыполнения.Вставить("ТипОбъекта", "Справочник");
		ИначеЕсли Документы.ТипВсеСсылки().СодержитТип(ТипЗнчСсылки) Тогда
			КонтекстВыполнения.Вставить("ТипОбъекта", "Документ");
		Иначе
			КонтекстВыполнения.Вставить("ТипОбъекта", "Неизвестно");
		КонецЕсли;
		Попытка
			КонтекстВыполнения.Вставить("ИмяОбъекта", Ссылка.Метаданные().Имя);
		Исключение
			КонтекстВыполнения.Вставить("ИмяОбъекта", "Неизвестно");
		КонецПопытки;
		УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, КонтекстВыполнения.ТипОбъекта, КонтекстВыполнения.ИмяОбъекта, Объект, Ложь);
		Результат.Успех = Истина;
		Результат.Сообщение = "Выбран объект: " + Строка(Ссылка);
		Результат.Данные = Ссылка;
	Исключение
		Результат.Сообщение = "Ошибка выбора объекта (неверный тип ссылки?): " + ОписаниеОшибки();
	КонецПопытки;
	Возврат Результат;
КонецФункции

#Область СлужебныеПроцедурыИФункции

Процедура УстановитьТипизированнуюОшибку(Результат, КодОшибки, Категория, Retryable, SuggestedAction, Контекст = Неопределено)
	Результат.Вставить("error_code", КодОшибки);
	Результат.Вставить("error_category", Категория);
	Результат.Вставить("retryable", Retryable);
	Результат.Вставить("suggested_action", SuggestedAction);
	Результат.Вставить("recommendation", SuggestedAction);
	Результат.Вставить("error_context", Контекст);
КонецПроцедуры

Процедура УстановитьDSLКонтекстОбъекта(КонтекстВыполнения, ТипОбъекта, ИмяОбъекта, ТекущийОбъект, ЭтоНовый = Неопределено)
	КонтекстВыполнения.Вставить("DSL_ТипОбъекта", ТипОбъекта);
	КонтекстВыполнения.Вставить("DSL_ИмяОбъекта", ИмяОбъекта);
	КонтекстВыполнения.Вставить("DSL_ТекущийОбъект", ТекущийОбъект);
	КонтекстВыполнения.Вставить("DSL_ИзмененныеПоля", Новый Структура);
	Если ЭтоНовый = Неопределено Тогда
		Попытка
			ЭтоНовый = НЕ ЗначениеЗаполнено(ТекущийОбъект.Ссылка);
		Исключение
			ЭтоНовый = Истина;
		КонецПопытки;
	КонецЕсли;
	КонтекстВыполнения.Вставить("DSL_НовыйОбъект", ЭтоНовый);
КонецПроцедуры

Функция НайтиСсылкуПоУИД(знач УИД)
	ЭтоМассив = ТипЗнч(УИД) = Тип("Массив");
	МассивУидов = Новый Массив;
	Если ЭтоМассив Тогда
		МассивУидов = УИД;
	Иначе
		МассивУидов.Добавить(УИД);
	КонецЕсли;
	Результат = Неопределено;
	МассивМетаданных = Новый Массив;
	МассивМетаданных.Добавить(Справочники);
	МассивМетаданных.Добавить(Документы);
	МассивМетаданных.Добавить(ПланыВидовХарактеристик);
	МассивТипов = Новый Массив;
	Для Каждого СтрМетаданное Из МассивМетаданных Цикл
		Для Каждого Стр Из СтрМетаданное.ТипВсеСсылки().Типы() Цикл
			МассивТипов.Добавить(Стр);
		КонецЦикла;
	КонецЦикла;
	ТаблицаСсылок = Новый ТаблицаЗначений;
	ТаблицаСсылок.Колонки.Добавить("УИД", Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(36)));
	ТаблицаСсылок.Колонки.Добавить("Ссылка", Новый ОписаниеТипов(МассивТипов));
	Для Каждого СтрМетаданное Из МассивМетаданных Цикл
		Для Каждого Менеджер Из СтрМетаданное Цикл
			Для Каждого СтрУИД Из МассивУидов Цикл
				Попытка
					НовСтр = ТаблицаСсылок.Добавить();
					НовСтр.Ссылка = Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрУИД));
					НовСтр.УИД = СтрУИД;
				Исключение
				КонецПопытки;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|   ТаблицаСсылок.Ссылка КАК Ссылка,
		|   ТаблицаСсылок.УИД КАК УИД
		|ИЗ
		|   &ТаблицаСсылок КАК ТаблицаСсылок
		|ГДЕ
		|   НЕ ТаблицаСсылок.Ссылка.ПометкаУдаления ЕСТЬ NULL";
	Запрос.УстановитьПараметр("ТаблицаСсылок", ТаблицаСсылок);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Если ЭтоМассив Тогда
			Результат = РезультатЗапроса.Выгрузить();
		Иначе
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			ВыборкаДетальныеЗаписи.Следующий();
			Результат = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПодготовитьДанныеРеквизитовДляЛлм(ИнформацияОбОбъекте)
	ДанныеДляЛлм = Новый Структура;
	ДанныеДляЛлм.Вставить("Найден", ИнформацияОбОбъекте.Найден);
	ДанныеДляЛлм.Вставить("Имя", ИнформацияОбОбъекте.Имя);
	ДанныеДляЛлм.Вставить("Синоним", ИнформацияОбОбъекте.Синоним);
	Если ИнформацияОбОбъекте.Свойство("ТабличныеЧасти") Тогда
		ДанныеДляЛлм.Вставить("ТабличныеЧасти", ИнформацияОбОбъекте.ТабличныеЧасти);
	КонецЕсли;
	МассивИмен = Новый Массив;
	Для Каждого Реквизит Из ИнформацияОбОбъекте.Реквизиты Цикл
		Если ТипЗнч(Реквизит) = Тип("Структура") И Реквизит.Свойство("Имя")
			И Лев(ВРег(Реквизит.Имя), 6) <> "УДАЛИТ" Тогда
			МассивИмен.Добавить(Реквизит.Имя);
		КонецЕсли;
	КонецЦикла;
	РеквизитыКратко = Новый Массив;
	РеквизитыКратко.Добавить(Новый Структура("Имя, Синоним", СтрСоединить(МассивИмен, ", "), ""));
	ДанныеДляЛлм.Вставить("Реквизиты", РеквизитыКратко);
	Возврат ДанныеДляЛлм;
КонецФункции

Процедура ДобавитьВWhitelistПути(WhitelistПути, Путь)
	Если WhitelistПути.Найти(Путь) = Неопределено Тогда
		WhitelistПути.Добавить(Путь);
	КонецЕсли;
КонецПроцедуры

Функция ЭтоСсылочныйТипРеквизита(СтрокаТипа)
	ТекстТипа = ВРег(СокрЛП(СтрокаТипа));
	Возврат СтрНайти(ТекстТипа, "СПРАВОЧНИКССЫЛКА.") > 0 ИЛИ СтрНайти(ТекстТипа, "ДОКУМЕНТССЫЛКА.") > 0 ИЛИ СтрНайти(ТекстТипа, "ПЛАНВИДОВХАРАКТЕРИСТИКССЫЛКА.") > 0;
КонецФункции

Функция ОбработатьЗначениеПараметра(Значение, КонтекстВыполнения)
	Если ТипЗнч(Значение) <> Тип("Строка") Тогда
		Возврат Значение;
	КонецЕсли;
	Если СтрНайти(Значение, "#(") = 1 И Прав(Значение, 1) = ")" Тогда
		ПутьКЗначению = Сред(Значение, 3, СтрДлина(Значение) - 3);
		Если СтрНайти(ПутьКЗначению, ".") = 0 И КонтекстВыполнения.Свойство(ПутьКЗначению) Тогда
			Возврат КонтекстВыполнения[ПутьКЗначению];
		КонецЕсли;
	КонецЕсли;
	Возврат Значение;
КонецФункции

Функция НормализоватьПробелыВТекстеЗапроса(Знач ТекстЗапроса)
	Результат = Строка(ТекстЗапроса);
	Результат = СтрЗаменить(Результат, Символ(160), " ");
	Результат = СтрЗаменить(Результат, Символ(8239), " ");
	Результат = СтрЗаменить(Результат, Символ(8199), " ");
	Результат = СтрЗаменить(Результат, Символ(8201), " ");
	Возврат Результат;
КонецФункции

Функция ИсправитьПорядокДобавитьКДате(ТекстЗапроса)
	Возврат ТекстЗапроса;
КонецФункции

