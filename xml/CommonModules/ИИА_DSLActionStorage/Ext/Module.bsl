#Область ПрограммныйИнтерфейс

Функция ВыполнитьSaveToStorage(Шаг, КонтекстВыполнения) Экспорт
	Результат = СоздатьБазовыйРезультатШага("SaveToStorage", ИИА_DSLКонтракт.ПолучитьКонтрактДействия("SaveToStorage"));
	Ключ = Шаг.key;
	ДанныеДляСохранения = Шаг.data;
	Попытка
		Если НЕ КонтекстВыполнения.Свойство("СсылкаДиалога") Или НЕ ЗначениеЗаполнено(КонтекстВыполнения.СсылкаДиалога) Тогда
			Результат.Сообщение = "Для работы с хранилищем требуется ссылка на диалог";
			УстановитьТипизированнуюОшибку(Результат, "missing_dialog_context", "validation", Ложь, "provide_dialog_context", Новый Структура("action", "SaveToStorage"));
			Возврат Результат;
		КонецЕсли;
		СсылкаДиалога = КонтекстВыполнения.СсылкаДиалога;
		СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
		Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
			СтруктураДанных = Новый Структура;
		Иначе
			Копия = Новый Структура;
			Для Каждого КлючЗначение Из СтруктураДанных Цикл
				Копия.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
			КонецЦикла;
			СтруктураДанных = Копия;
		КонецЕсли;
		СтруктураДанных.Вставить(Ключ, ДанныеДляСохранения);
		ИИА_DialogStorage.ЗаписатьДанныеДиалогаВРегистр(СсылкаДиалога, СтруктураДанных);
		Результат.Успех = Истина;
		Результат.Сообщение = "Данные сохранены в хранилище с ключом '" + Ключ + "'";
		Результат.Данные = Истина;
		Результат.next_step_guidance = "Для безопасного повтора SaveToStorage используй тот же operation_id.";
	Исключение
		Результат.Сообщение = "Ошибка при сохранении в хранилище: " + ОписаниеОшибки();
		УстановитьТипизированнуюОшибку(Результат, "storage_write_error", "runtime", Истина, "retry_storage_write_with_same_operation_id", Новый Структура("key", Ключ));
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ВыполнитьLoadFromStorage(Шаг, КонтекстВыполнения) Экспорт
	Результат = СоздатьБазовыйРезультатШага("LoadFromStorage", ИИА_DSLКонтракт.ПолучитьКонтрактДействия("LoadFromStorage"));
	Ключ = Шаг.key;
	Попытка
		Если НЕ КонтекстВыполнения.Свойство("СсылкаДиалога") Или НЕ ЗначениеЗаполнено(КонтекстВыполнения.СсылкаДиалога) Тогда
			Результат.Сообщение = "Для работы с хранилищем требуется ссылка на диалог";
			УстановитьТипизированнуюОшибку(Результат, "missing_dialog_context", "validation", Ложь, "provide_dialog_context", Новый Структура("action", "LoadFromStorage"));
			Возврат Результат;
		КонецЕсли;
		СсылкаДиалога = КонтекстВыполнения.СсылкаДиалога;
		СтруктураДанных = ИИА_DialogStorage.ПолучитьДанныеДиалогаИзРегистра(СсылкаДиалога);
		Если СтруктураДанных = Неопределено ИЛИ ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
			Результат.Сообщение = "Хранилище пусто. Ключ '" + Ключ + "' не найден";
			УстановитьТипизированнуюОшибку(Результат, "storage_key_not_found", "validation", Ложь, "save_data_before_load", Новый Структура("key", Ключ));
			Возврат Результат;
		КонецЕсли;
		Если НЕ СтруктураДанных.Свойство(Ключ) Тогда
			Результат.Сообщение = "Ключ '" + Ключ + "' не найден в хранилище";
			УстановитьТипизированнуюОшибку(Результат, "storage_key_not_found", "validation", Ложь, "check_storage_key", Новый Структура("key", Ключ));
			Возврат Результат;
		КонецЕсли;
		ЗагруженныеДанные = СтруктураДанных[Ключ];
		КонтекстВыполнения.Вставить("Хранилище_" + Ключ, ЗагруженныеДанные);
		Результат.Успех = Истина;
		Результат.Сообщение = "Данные загружены из хранилища по ключу '" + Ключ + "'";
		Результат.Данные = ЗагруженныеДанные;
		Результат.next_step_guidance = "Используй значение из результата или переменную Хранилище_" + Ключ + " в следующих шагах.";
	Исключение
		Результат.Сообщение = "Ошибка при загрузке из хранилища: " + ОписаниеОшибки();
		УстановитьТипизированнуюОшибку(Результат, "storage_read_error", "runtime", Истина, "retry_storage_read", Новый Структура("key", Ключ));
	КонецПопытки;
	Возврат Результат;
КонецФункции

Функция ВыполнитьForEach(Шаг, КонтекстВыполнения) Экспорт
	Результат = СоздатьБазовыйРезультатШага("ForEach", ИИА_DSLКонтракт.ПолучитьКонтрактДействия("ForEach"));
	Результат.Данные = Новый Массив;
	Коллекция = Неопределено;
	Если ТипЗнч(Шаг.collection) = Тип("Строка") Тогда
		Если КонтекстВыполнения.Свойство(Шаг.collection) Тогда
			Коллекция = КонтекстВыполнения[Шаг.collection];
		ИначеЕсли КонтекстВыполнения.Свойство("Хранилище_" + Шаг.collection) Тогда
			Коллекция = КонтекстВыполнения["Хранилище_" + Шаг.collection];
		Иначе
			Результат.Сообщение = "Коллекция '" + Шаг.collection + "' не найдена в контексте выполнения";
			УстановитьТипизированнуюОшибку(Результат, "collection_not_found", "validation", Ложь, "load_or_prepare_collection", Новый Структура("collection", Шаг.collection));
			Возврат Результат;
		КонецЕсли;
	Иначе
		Коллекция = Шаг.collection;
	КонецЕсли;
	Если ТипЗнч(Коллекция) <> Тип("Массив") Тогда
		Результат.Сообщение = "Значение параметра collection должно быть массивом. Получено: " + Строка(ТипЗнч(Коллекция));
		УстановитьТипизированнуюОшибку(Результат, "invalid_collection_type", "validation", Ложь, "provide_array_collection", Новый Структура("actual_type", Строка(ТипЗнч(Коллекция))));
		Возврат Результат;
	КонецЕсли;
	ШагиЦикла = Шаг.steps;
	КоличествоОбработанных = 0;
	Для Каждого Элемент Из Коллекция Цикл
		КонтекстВыполнения.Вставить("CurrentItem", Элемент);
		Для Каждого ВнутреннийШаг Из ШагиЦикла Цикл
			РезультатВнутреннего = ИИА_DSL.ВыполнитьШаг(ВнутреннийШаг, КонтекстВыполнения);
			Если РезультатВнутреннего.Свойство("Данные") И ЗначениеЗаполнено(РезультатВнутреннего.Данные) Тогда
				Результат.Данные.Добавить(РезультатВнутреннего.Данные);
			КонецЕсли;
			Если НЕ РезультатВнутреннего.Успех Тогда
				Результат.Сообщение = "Ошибка в цикле ForEach на элементе " + Формат(КоличествоОбработанных + 1, "ЧН=0") + ", шаг '" + ВнутреннийШаг.action + "': " + РезультатВнутреннего.Сообщение;
				Результат.partial_failure = Истина;
				Результат.error_context = Новый Структура("item_index,action,processed_count", КоличествоОбработанных + 1, ВнутреннийШаг.action, КоличествоОбработанных);
				Результат.retryable = РезультатВнутреннего.retryable;
				Результат.suggested_action = ?(РезультатВнутреннего.Свойство("suggested_action"), РезультатВнутреннего.suggested_action, "resume_foreach_with_same_operation_id");
				Результат.recommendation = Результат.suggested_action;
				Если РезультатВнутреннего.Свойство("error_code") И НЕ ПустаяСтрока(Строка(РезультатВнутреннего.error_code)) Тогда
					Результат.error_code = Строка(РезультатВнутреннего.error_code);
				Иначе
					Результат.error_code = "foreach_partial_failure";
				КонецЕсли;
				Результат.error_category = ?(РезультатВнутреннего.Свойство("error_category"), РезультатВнутреннего.error_category, "runtime");
				Результат.next_step_guidance = "Исправь причину сбоя и повтори ForEach с тем же operation_id, чтобы не дублировать уже завершённые шаги.";
				Возврат Результат;
			КонецЕсли;
		КонецЦикла;
		КоличествоОбработанных = КоличествоОбработанных + 1;
	КонецЦикла;
	КонтекстВыполнения.Удалить("CurrentItem");
	Результат.Успех = Истина;
	Результат.Сообщение = "Цикл ForEach выполнен успешно. Обработано элементов: " + Формат(КоличествоОбработанных, "ЧН=0");
	Результат.next_step_guidance = "Повторяй ForEach только с тем же operation_id, если нужен безопасный retry.";
	Возврат Результат;
КонецФункции

#Область СлужебныеПроцедурыИФункции

Процедура УстановитьТипизированнуюОшибку(Результат, КодОшибки, Категория, Retryable, SuggestedAction, Контекст = Неопределено)
	Результат.Вставить("error_code", КодОшибки);
	Результат.Вставить("error_category", Категория);
	Результат.Вставить("retryable", Retryable);
	Результат.Вставить("suggested_action", SuggestedAction);
	Результат.Вставить("recommendation", SuggestedAction);
	Результат.Вставить("error_context", Контекст);
КонецПроцедуры

Функция СоздатьБазовыйРезультатШага(Действие = "", Контракт = Неопределено)
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("Данные", Неопределено);
	Результат.Вставить("error_code", "");
	Результат.Вставить("error_category", "");
	Результат.Вставить("retryable", Ложь);
	Результат.Вставить("suggested_action", "");
	Результат.Вставить("recommendation", "");
	Результат.Вставить("error_context", Неопределено);
	Результат.Вставить("missing_parameters", Новый Массив);
	Результат.Вставить("partial_failure", Ложь);
	Результат.Вставить("next_step_guidance", "");
	Результат.Вставить("operation_id", "");
	Результат.Вставить("idempotent", Ложь);
	Результат.Вставить("supports_safe_retries", Истина);
	Результат.Вставить("retry_strategy", "retry_same_call");
	Результат.Вставить("requires_write", Ложь);
	Результат.Вставить("action", Действие);
	Если Контракт <> Неопределено Тогда
		Если Контракт.Свойство("idempotent") Тогда
			Результат.idempotent = Контракт.idempotent;
		КонецЕсли;
		Если Контракт.Свойство("requires_write") Тогда
			Результат.requires_write = Контракт.requires_write;
		КонецЕсли;
		Если Контракт.Свойство("supports_safe_retries") Тогда
			Результат.supports_safe_retries = Контракт.supports_safe_retries;
		КонецЕсли;
		Если Контракт.Свойство("retry_strategy") Тогда
			Результат.retry_strategy = Контракт.retry_strategy;
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;
КонецФункции

